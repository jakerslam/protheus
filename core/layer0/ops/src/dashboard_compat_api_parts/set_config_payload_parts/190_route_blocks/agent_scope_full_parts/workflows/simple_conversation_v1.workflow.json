{
  "name": "simple_conversation_v1",
  "workflow_type": "hard_agent_workflow",
  "default": true,
  "description": "Tool menu interface. If the LLM submits Respond directly at Gate 1, no tool menu is consumed and the final response is LLM-authored.",
  "stages": [
    "gate_1_work_category_menu",
    "gate_2_tool_family_menu",
    "gate_3_tool_menu",
    "gate_4_request_payload_input",
    "gate_4b_tool_confirmation_menu",
    "gate_5_post_tool_menu",
    "gate_5b_synthesis_handoff",
    "gate_6_llm_final_output"
  ],
  "final_response_policy": "llm_authored_only_no_system_injection",
  "gate_contract": "tool_menu_interface_v1",
  "tool_menu_interface_contract": {
    "version": "tool_menu_interface_v1",
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "system_injected_chat_text_allowed": false,
    "llm_gate_instruction": "INTERNAL GATE — output is never shown to the user. Gate 1: {gate_question}. You MUST output ONLY a JSON object and nothing else. Format: {\"gate\": \"<value>\"} where <value> is exactly one of: {category_options}. No-tool values — {no_tool_categories} — skip tools and go straight to synthesis. Tool values — {tool_bearing_categories} — open the tool menu. IMPORTANT: when you choose a no-tool gate value (respond_directly or equivalent), you MUST also include a \"final_answer\" field with the actual natural-language reply the user should see. Example for a direct conversational reply: {\"gate\": \"respond_directly\", \"final_answer\": \"Hey! What can I help you with?\"}. Example for a synthesis reply: {\"gate\": \"respond_directly\", \"final_answer\": \"Based on the results: ...\"}. Example for a web lookup (no final_answer needed): {\"gate\": \"web_research\"}. Do NOT write any other text outside the JSON object.",
    "gate_shapes_allowed": [
      "multiple_choice",
      "text_input",
      "internal_handoff"
    ],
    "gate_order": [
      "gate_1_work_category_menu",
      "gate_2_tool_family_menu",
      "gate_3_tool_menu",
      "gate_4_request_payload_input",
      "gate_4b_tool_confirmation_menu",
      "gate_5_post_tool_menu",
      "gate_5b_synthesis_handoff",
      "gate_6_llm_final_output"
    ],
    "gates": {
      "gate_2_tool_family_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_3_tool_menu"
      },
      "gate_3_tool_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_4_request_payload_input"
      },
      "gate_4_request_payload_input": {
        "input_kind": "text_input",
        "transition": "gate_4b_tool_confirmation_menu"
      },
      "gate_4b_tool_confirmation_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "confirm",
            "label": "Confirm",
            "private_token": true,
            "visible_chat": false,
            "transition": "execute_tool"
          },
          {
            "key": "cancel",
            "label": "Cancel",
            "private_token": true,
            "visible_chat": false,
            "terminal_state": "cancelled"
          }
        ]
      },
      "gate_5_post_tool_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "finish",
            "label": "Finish and synthesize",
            "transition": "gate_5b_synthesis_handoff"
          },
          {
            "key": "another_tool",
            "label": "Another tool",
            "transition": "gate_2_tool_family_menu"
          }
        ]
      },
      "gate_5b_synthesis_handoff": {
        "input_kind": "internal_handoff",
        "purpose": "Bridge between an internal routing decision (gate_1 'respond directly' / 'planning from current context', or gate_5 'finish and synthesize') and the user-visible reply. This stage exists to guarantee that the model turn which emits the user-facing answer is NOT the same model turn that emitted any private routing token. Without this stage, the model tends to suffix the gate-1 menu option (e.g. '1 = Respond directly') onto the start of the answer it then writes.",
        "submission_contract": {
          "visibility": "private_token_only",
          "structured_token_fields": [
            "handoff_acknowledged",
            "ready_for_synthesis"
          ],
          "accepted_outputs": [
            "ready",
            "ack",
            "ok"
          ],
          "forbidden_output_classes": [
            "choice_narration",
            "tool_recommendation_without_submission",
            "visible_chat_text",
            "gate_choice_echo",
            "menu_option_label_echo"
          ],
          "chat_injection_allowed": false
        },
        "handoff_prompt": "INTERNAL HANDOFF \u2014 NOT VISIBLE TO USER. The routing decision has been recorded by the runtime; the user has NOT seen and will NEVER see any menu option, gate label, gate number, or routing token. Do not repeat, restate, paraphrase, or acknowledge the routing choice in any form. Reply with only the literal token 'ready' on this turn. The next turn (gate_6_llm_final_output) is where you will write the user-facing answer to the original user message; this turn is purely a structural separator that exists so the choice-emitting turn and the answer-emitting turn are never the same turn.",
        "transition": "gate_6_llm_final_output"
      },
      "gate_6_llm_final_output": {
        "input_kind": "text_input",
        "final_authority": "llm_only",
        "final_output_contract": {
          "visible_chat_source": "llm_final_answer_only",
          "internal_streams": [
            "workflow_state",
            "agent_internal_notes",
            "tool_trace",
            "eval_trace"
          ],
          "chat_excludes": [
            "workflow_state",
            "agent_internal_notes",
            "tool_trace",
            "eval_trace",
            "prompt_analysis",
            "tool_call_payload",
            "function_call_json",
            "tool_request_envelope",
            "tool_observation_raw",
            "stage_token",
            "gate_token"
          ],
          "chat_requirement": "This is the user-visible reply turn. The previous internal handoff turn has already separated routing/tool reasoning from synthesis, so write ONLY the answer to the original user message in natural prose, as if you were starting a fresh assistant turn with no prior internal scaffolding. Do not echo any menu option, gate label, gate number, routing token, tool name, function-call JSON, or raw tool observation \u2014 the user has not seen any of them and treating them as visible context will leak. If you used tools, present findings as knowledge you have, not as a process narrative ('I will search', 'I called X', 'please hold' are all forbidden). One coherent response, addressed to the user."
        }
      },
      "gate_1_work_category_menu": {
        "input_kind": "multiple_choice",
        "question": "What kind of work is this?",
        "submission_contract": {
          "visibility": "private_token_only",
          "accepted_outputs": [
            "1",
            "Respond directly",
            "2",
            "Planning from current context",
            "3",
            "Web research",
            "4",
            "Workspace/files",
            "5",
            "Code execution / terminal",
            "6",
            "Agent management",
            "7",
            "Memory/notes",
            "8",
            "External apps/integrations"
          ],
          "structured_token_fields": [
            "token",
            "choice",
            "selection",
            "selected_option",
            "response_gate",
            "workflow_gate",
            "gate",
            "category",
            "work_category",
            "option"
          ],
          "forbidden_output_classes": [
            "choice_narration",
            "tool_recommendation_without_submission",
            "visible_chat_text"
          ],
          "chat_injection_allowed": false
        },
        "options": [
          {
            "key": "respond_directly",
            "label": "Respond directly",
            "aliases": [
              "1"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": false,
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "planning_current_context",
            "label": "Planning from current context",
            "aliases": [
              "2"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": false,
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "web_research",
            "label": "Web research",
            "aliases": [
              "3"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "workspace_files",
            "label": "Workspace/files",
            "aliases": [
              "4"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "code_execution_terminal",
            "label": "Code execution / terminal",
            "aliases": [
              "5"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "agent_management",
            "label": "Agent management",
            "aliases": [
              "6"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "memory_notes",
            "label": "Memory/notes",
            "aliases": [
              "7"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "external_apps_integrations",
            "label": "External apps/integrations",
            "aliases": [
              "8"
            ],
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          }
        ]
      }
    },
    "private_tokens": [
      "confirm",
      "cancel",
      "respond_directly",
      "planning_current_context"
    ],
    "terminal_states": [
      "completed",
      "cancelled",
      "blocked",
      "failed"
    ],
    "gate_stability_contract": {
      "version": "gate_stability_v1",
      "event_stream": "local/state/ops/workflow_gate_stability/events.jsonl",
      "latest_summary": "local/state/ops/workflow_gate_stability/latest.json",
      "versions_ring": "local/state/ops/workflow_gate_stability/versions_ring.json",
      "workflow_snapshots_dir": "local/state/ops/workflow_gate_stability/workflow_versions",
      "versions_ring_size": 3,
      "tracked_gates": [
        "gate_1_work_category_menu",
        "gate_2_tool_family_menu",
        "gate_5_post_tool_menu",
        "gate_6_llm_final_output"
      ],
      "required_artifacts": {
        "gate_1_work_category_menu": [
          "workflow_category_or_direct_final_answer"
        ],
        "gate_2_tool_family_menu": [
          "tool_request"
        ],
        "gate_5_post_tool_menu": [
          "tool_result"
        ],
        "gate_6_llm_final_output": [
          "final_response"
        ]
      },
      "failure_classes": [
        "empty_response",
        "invalid_artifact",
        "leaked_internal_payload",
        "missing_transition",
        "retry_exhausted",
        "not_applicable"
      ]
    },
    "declared_loopbacks": [
      {
        "from": "gate_5_post_tool_menu",
        "on": "another_tool",
        "to": "gate_2_tool_family_menu"
      }
    ],
