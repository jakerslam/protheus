    "tool_menu_by_family": {
      "web_research": [
        {
          "option": 1,
          "key": "web_search",
          "label": "Search web",
          "request_format": {
            "source": "web",
            "query": "<search criteria>",
            "aperture": "medium"
          },
          "request_example": {
            "source": "web",
            "query": "latest rust 2026 release notes",
            "aperture": "medium"
          }
        },
        {
          "option": 2,
          "key": "web_fetch",
          "label": "Fetch URL",
          "request_format": {
            "url": "<https url>"
          },
          "request_example": {
            "url": "https://www.rust-lang.org/"
          }
        }
      ],
      "workspace_files": [
        {
          "option": 1,
          "key": "parse_workspace",
          "label": "Parse workspace",
          "request_format": {
            "path": "<path>",
            "operation": "inspect|read|mutate"
          },
          "request_example": {
            "path": "core/layer0/ops/src",
            "operation": "inspect"
          }
        },
        {
          "option": 2,
          "key": "file_read",
          "aliases": [
            "read_file"
          ],
          "label": "Read file",
          "request_format": {
            "path": "<path>"
          },
          "request_example": {
            "path": "core/layer0/ops/src/main.rs"
          }
        },
        {
          "option": 3,
          "key": "apply_patch",
          "label": "Apply patch",
          "request_format": {
            "path": "<path>",
            "patch": "<unified diff>"
          },
          "request_example": {
            "path": "core/layer0/ops/src/main.rs",
            "patch": "*** Begin Patch\\n*** Update File: core/layer0/ops/src/main.rs\\n@@\\n- old\\n+ new\\n*** End Patch"
          }
        }
      ],
      "code_execution_terminal": [
        {
          "option": 1,
          "key": "terminal_exec",
          "label": "Run terminal command",
          "request_format": {
            "cmd": "<command>",
            "cwd": "<workspace path optional>"
          },
          "request_example": {
            "cmd": "cargo test --manifest-path core/layer0/ops/Cargo.toml --lib",
            "cwd": "/Users/jay/.openclaw/workspace"
          }
        }
      ],
      "agent_management": [
        {
          "option": 1,
          "key": "spawn_agent",
          "label": "Spawn agent",
          "request_format": {
            "objective": "<bounded task>",
            "agent_type": "default|worker|explorer"
          },
          "request_example": {
            "objective": "inspect workflow traces for one failing turn",
            "agent_type": "explorer"
          }
        }
      ],
      "memory_notes": [
        {
          "option": 1,
          "key": "read_memory",
          "label": "Read memory",
          "request_format": {
            "scope": "session|workspace",
            "query": "<criteria>"
          },
          "request_example": {
            "scope": "workspace",
            "query": "recent orchestration commits"
          }
        },
        {
          "option": 2,
          "key": "workspace_search",
          "label": "Search workspace",
          "request_format": {
            "path": "<path>",
            "pattern": "<criteria>"
          },
          "request_example": {
            "path": "core/layer0/ops/src",
            "pattern": "need_tool_access"
          }
        }
      ],
      "external_apps_integrations": [
        {
          "option": 1,
          "key": "external_app_request",
          "label": "Use external app/integration",
          "request_format": {
            "app": "<app name>",
            "action": "<requested action>",
            "payload": {}
          },
          "request_example": {
            "app": "github",
            "action": "inspect pull request",
            "payload": {
              "query": "<PR or issue>"
            }
          }
        }
      ],
      "none": []
    },
    "llm_gate_instruction": "Private workflow gate submission only. Gate 1: `{gate_question}`. Reply with one token only from this menu: {category_options}. Use a no-tool token ({no_tool_categories}) to go straight to final answer. Use a tool token ({tool_bearing_categories}) to open the private tool menu. Do not narrate, explain, or say what you would choose. Visible chat is only Gate 6 final answer.",
    "llm_tool_request_instruction": "Private workflow gate submission only. Selected category: `{selected_category_label}`. Pick one catalog tool from this JSON menu and provide its request payload. Reply exactly as: `Category: {selected_category_label}. Tool family: {selected_category_label}. Tool: <catalog tool key>. Request payload: <JSON>.` Do not narrate or say what you would choose. Visible chat is only Gate 6 final answer.\n\nTool menu JSON:\n{selected_tool_menu_json}",
    "tool_request_submission_contract": {
      "version": "tool_request_submission_contract_v1",
      "field_order": [
        "category",
        "tool_family",
        "tool",
        "request_payload"
      ],
      "field_labels": {
        "category": "Category:",
        "tool_family": "Tool family:",
        "tool": "Tool:",
        "request_payload": "Request payload:"
      },
      "field_aliases": {
        "request_payload": [
          "Payload:"
        ]
      },
      "chat_injection_allowed": false,
      "system_may_infer_missing_fields": false
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "confirmation_states",
      "diagnostic_markers",
      "final_output_contract",
      "gate_options",
      "gate_transitions",
      "interaction_gates",
      "loopbacks",
      "tool_family_menus",
      "tool_input_schemas",
      "trace_status_messages"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  }
}
