    "trace_status_messages": {
      "pending_final_llm": {
        "ui": "Workflow at final answer gate; waiting for LLM-authored output.",
        "agent_process": "Final answer gate active. Submit the user-facing answer only."
      },
      "synthesized": {
        "ui": "Workflow complete; final answer came from the LLM final gate.",
        "agent_process": "Final answer gate complete."
      },
      "no_post_synthesis_required": {
        "ui": "Workflow complete; no-tool category selected and direct LLM answer is available.",
        "agent_process": "No-tool category selected. Respond directly without tool menus."
      },
      "skipped_missing_model": {
        "ui": "Workflow paused; no model was available for the final answer gate.",
        "agent_process": "Final answer gate blocked because the model provider is unavailable."
      },
      "diagnostic_failure_pass_through": {
        "ui": "Workflow recorded a diagnostic failure; no system-authored chat text was injected.",
        "agent_process": "Diagnostic recorded. Visible chat remains LLM-authored only."
      },
      "guard_violation_pass_through": {
        "ui": "Workflow recorded a guard diagnostic; visible chat remains the LLM output.",
        "agent_process": "Guard diagnostic recorded. Do not replace the final answer with system prose."
      },
