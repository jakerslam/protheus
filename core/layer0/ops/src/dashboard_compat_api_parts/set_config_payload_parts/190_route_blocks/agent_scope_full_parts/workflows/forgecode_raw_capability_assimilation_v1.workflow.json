{
  "name": "forgecode_raw_capability_assimilation_v1",
  "workflow_type": "hard_agent_workflow",
  "default": false,
  "description": "Raw-capability ForgeCode assimilation menu interface. The workflow only presents selectable tools and payload fields; capability mapping remains LLM-authored.",
  "stages": [
    "gate_1_need_tool_access_menu",
    "gate_2_tool_family_menu",
    "gate_3_tool_menu",
    "gate_4_request_payload_input",
    "gate_4b_tool_confirmation_menu",
    "gate_5_post_tool_menu",
    "gate_6_llm_final_output"
  ],
  "final_response_policy": "llm_authored_only_no_system_injection",
  "gate_contract": "tool_menu_interface_v1",
  "tool_menu_interface_contract": {
    "version": "tool_menu_interface_v1",
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "system_injected_chat_text_allowed": false,
    "gate_shapes_allowed": [
      "multiple_choice",
      "text_input"
    ],
    "gate_order": [
      "gate_1_need_tool_access_menu",
      "gate_2_tool_family_menu",
      "gate_3_tool_menu",
      "gate_4_request_payload_input",
      "gate_4b_tool_confirmation_menu",
      "gate_5_post_tool_menu",
      "gate_6_llm_final_output"
    ],
    "gates": {
      "gate_1_need_tool_access_menu": {
        "input_kind": "multiple_choice",
        "question": "Need tools? Yes/No",
        "options": [
          {
            "key": "no",
            "label": "No",
            "private_token": true,
            "visible_chat": false,
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "yes",
            "label": "Yes",
            "private_token": true,
            "visible_chat": false,
            "transition": "gate_2_tool_family_menu"
          }
        ]
      },
      "gate_2_tool_family_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_3_tool_menu"
      },
      "gate_3_tool_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_4_request_payload_input"
      },
      "gate_4_request_payload_input": {
        "input_kind": "text_input",
        "transition": "gate_4b_tool_confirmation_menu"
      },
      "gate_4b_tool_confirmation_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "confirm",
            "label": "Confirm",
            "private_token": true,
            "visible_chat": false,
            "transition": "execute_tool"
          },
          {
            "key": "cancel",
            "label": "Cancel",
            "private_token": true,
            "visible_chat": false,
            "terminal_state": "cancelled"
          }
        ]
      },
      "gate_5_post_tool_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "finish",
            "label": "Finish and synthesize",
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "another_tool",
            "label": "Another tool",
            "transition": "gate_2_tool_family_menu"
          }
        ]
      },
      "gate_6_llm_final_output": {
        "input_kind": "text_input",
        "final_authority": "llm_only"
      }
    },
    "private_tokens": [
      "no",
      "yes",
      "confirm",
      "cancel"
    ],
    "terminal_states": [
      "completed",
      "cancelled",
      "blocked",
      "failed"
    ],
    "declared_loopbacks": [
      {
        "from": "gate_5_post_tool_menu",
        "on": "another_tool",
        "to": "gate_2_tool_family_menu"
      }
    ]
  }
}
