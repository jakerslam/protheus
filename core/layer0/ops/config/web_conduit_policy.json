{
  "canonical_owner": "core/layer0/ops",
  "mode": "production",
  "version": "v1",
  "web_conduit": {
    "allow_domains": [],
    "deny_domains": [
      "127.0.0.1",
      "localhost",
      "metadata.google.internal",
      "169.254.169.254"
    ],
    "enabled": true,
    "max_response_bytes": 350000,
    "rate_limit_per_minute": 30,
    "require_human_for_sensitive": true,
    "search_default_count": 16,
    "search_max_count": 40,
    "search_cache_ttl_minutes": 8,
    "search_provider_order": [
      "serperdev",
      "duckduckgo",
      "duckduckgo_lite",
      "bing_rss",
      "gdelt_doc"
    ],
    "fetch_provider_order": [
      "direct_http"
    ],
    "native_codex_web_search": {
      "enabled": false,
      "mode": "cached",
      "allowed_domains": []
    },
    "provider_circuit_breaker": {
      "enabled": true,
      "failure_threshold": 3,
      "open_for_secs": 300,
      "soft_failure_errors": [
        "low_signal_search_payload",
        "no_usable_summary",
        "query_result_mismatch"
      ]
    },
    "sensitive_domains": [
      "accounts.google.com",
      "api.stripe.com",
      "paypal.com",
      "chase.com",
      "bankofamerica.com"
    ],
    "timeout_ms": 12000
  }
}
