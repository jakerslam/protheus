{
  "version": "1.0",
  "canonical_owner": "core/layer0/ops",
  "enabled": true,
  "hot_runtime": [
    { "id": "memory_index", "authority": "core/layer0/memory", "paths": ["core/layer0/memory"], "read_contract": "native_store" },
    { "id": "state_kernel", "authority": "core/layer0/ops/src/state_kernel.rs", "paths": ["local/state/ops/state_kernel"], "read_contract": "typed_store" },
    { "id": "workflow_state", "authority": "core/layer0/ops/src/workflow_graph_bridge.rs", "paths": ["local/state/workflow"], "read_contract": "typed_store" }
  ],
  "audit_mirror": [
    { "id": "event_stream", "paths": ["local/state/events/event_stream.jsonl"], "contract": "append_only_jsonl" },
    { "id": "ops_receipts", "paths": ["local/state/ops"], "contract": "append_only_receipts" },
    { "id": "memory_receipts", "paths": ["local/state/memory"], "contract": "append_only_receipts" }
  ],
  "paths": {
    "latest_path": "local/state/ops/state_tiering_contract/latest.json",
    "receipts_path": "local/state/ops/state_tiering_contract/receipts.jsonl"
  }
}
