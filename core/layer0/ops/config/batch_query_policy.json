          "path_contains": [
            "/forum",
            "/community",
            "/discussion"
          ]
        }
      ],
      "synthesis_boundary": "The LLM receives ranked evidence objects with source class, confidence, coverage, claim hints, and freshness signals; these are signals for reasoning, not a required final answer format.",
      "result_envelope": {
