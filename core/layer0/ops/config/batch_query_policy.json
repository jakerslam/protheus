{
  "canonical_owner": "core/layer0/ops",
  "version": "v1",
  "batch_query": {
    "enabled_sources": [
      "web"
    ],
    "allow_large": false,
    "max_parallel_subqueries": 4,
    "query_timeout_ms": 30000,
    "cache": {
      "mode": "enabled",
      "ttl_success_seconds": 1800,
      "ttl_no_results_seconds": 120,
      "max_entries": 240,
      "lifecycle": {
        "cleanup_bound": "state_cleanup_policy:local/state/batch_query",
        "validation_metadata": [
          "etag",
          "last_modified",
          "head_fingerprint",
          "source_timestamp"
        ],
        "freshness_check": "conditional_headers_or_head_fingerprint_when_available"
      }
    },
    "retrieval_telemetry": {
      "enabled": true,
      "include_per_query": true,
      "record_attempted_queries": true,
      "record_provider_raw_rows": true,
      "record_filtered_rows": true,
      "record_failure_reasons": true,
      "chat_visible": false
    },
    "result_retention": {
      "enabled": true,
      "retain_low_confidence_raw_results": true,
      "max_low_confidence_items": 6,
      "confidence_label": "low_confidence_raw",
      "record_rejection_reasons": true,
      "chat_visible_as_source_backing": false
    },
    "coverage_aware_evidence": {
      "enabled": true,
      "purpose": "promote retrieved evidence across the research facets implied by the user request and submitted query pack instead of keeping only the globally highest-ranked rows",
      "max_facets": 8,
      "min_facet_terms": 2,
      "record_coverage": true,
      "authority": "generic_research_facet_coverage_no_domain_specific_lanes",
      "non_goals": [
        "do_not_hardcode_research_domains",
        "do_not_force_user_visible_output_format",
        "do_not_treat_weak_raw_rows_as_strong_source_backing"
      ]
    },
    "source_diversification": {
      "enabled": true,
      "purpose": "track source-class and source-domain breadth as synthesis calibration, without requiring every research question to use every source class",
      "min_source_classes": 2,
      "preferred_source_classes": [
        "official_or_primary",
        "scholarly_or_research",
        "news_or_current",
        "independent_analysis",
        "general_web"
      ],
      "non_goals": [
        "do_not_hardcode_domains_or_topics",
        "do_not_treat_source_class_diversity_as_more_important_than_relevance",
        "do_not_force_visible_answer_format"
      ]
    },
    "site_corpus_pack": {
      "enabled": true,
      "source_pattern": "firecrawl_llmstxt_map_scrape_corpus_pack_without_output_shape_hardcoding",
      "trigger": "user_goal_targets_a_site_docs_set_url_collection_or_known_corpus",
      "pipeline": [
        "map_candidate_urls",
        "dedupe_and_limit_urls_before_fetch_budget",
        "fetch_or_read_selected_pages_in_batches",
        "derive_compact_page_summary_rows",
        "keep_full_text_as_internal_detail_refs",
        "rank_compact_index_for_synthesis"
      ],
      "budget": {
        "default_max_urls": 50,
        "hard_max_urls": 500,
        "default_batch_size": 10
      },
      "cache": {
        "reuse_larger_cached_corpus_for_smaller_requested_limits": true,
        "stale_after_days": 7,
        "respect_zero_retention_and_no_store_policy": true
      },
      "non_goals": [
        "do_not_force_llms_txt_as_final_output",
        "do_not_hardcode_description_word_counts",
        "do_not_hide_full_text_payloads_in_chat",
        "do_not_hardcode_model_selection"
      ]
    },
    "async_site_slice": {
      "enabled": true,
      "source_pattern": "firecrawl_async_map_crawl_status_projection",
      "purpose": "Use map/discovery and bounded page reads as separate stages for site-scale evidence instead of treating a crawl handle or search result count as evidence.",
      "trigger": "site_docs_corpus_or_same_domain_coverage_gap_after_search",
      "pipeline": [
        "map_candidate_urls_from_index_sitemap_and_search",
        "filter_by_domain_path_depth_robots_file_type_and_budget",
        "dedupe_canonical_urls_before_fetch_budget",
        "read_selected_pages_with_ttl_and_concurrency_bounds",
        "project_status_counts_expiry_cursor_warnings_and_completed_page_refs",
        "package_completed_pages_as_evidence_pack_items"
      ],
      "budget": {
        "default_max_urls": 50,
        "hard_max_urls": 500,
        "default_window_items": 100,
        "max_window_bytes": 10485760
      },
      "option_precedence": "explicit_user_or_workflow_fields_override_agent_planned_fields",
      "projection_fields": [
        "task_id",
        "status",
        "completed",
        "total",
        "expires_at",
        "next_cursor",
        "warning",
        "page_evidence_refs"
      ],
      "non_goals": [
        "do_not_make_handle_creation_count_as_evidence",
        "do_not_return_raw_queue_state_to_chat",
        "do_not_require_prompt_to_generate_crawl_options",
        "do_not_cache_private_or_zero_retention_corpora",
        "do_not_force_visible_answer_format"
      ]
    },
    "high_volume_candidate_filtering": {
      "enabled": true,
      "source_pattern": "firecrawl_high_volume_candidate_map_rerank_filter",
      "purpose": "Cast a wider candidate net for site or corpus research, then use ranking, traces, and evidence thresholds to decide what to read.",
      "trigger": "mapped_or_search_candidates_are_too_few_too_many_or_low_coverage",
      "candidate_pool": {
        "max_initial_candidates": 1000,
        "broaden_when_unique_candidates_lte": 1,
        "rerank_again_when_candidates_gt": 100,
        "record_unique_candidate_count": true,
        "record_used_in_synthesis": true
      },
      "signals": [
        "query_or_goal_relevance",
        "candidate_title_and_description",
        "source_path_and_domain_fit",
        "source_class",
        "coverage_bucket_match",
        "dedupe_group",
        "access_or_block_reason"
      ],
      "trace_fields": [
        "candidate_locator",
        "discovery_pass",
        "selected_for_fetch",
        "rejection_reason",
        "used_in_synthesis",
        "warning"
      ],
      "non_goals": [
        "do_not_use_candidate_volume_as_evidence_sufficiency",
        "do_not_hardcode_research_domains_or_prompt_examples",
        "do_not_require_provider_specific_rerank_syntax",
        "do_not_make_candidate_trace_chat_visible"
      ]
    },
    "retrieval_execution_lifecycle": {
      "enabled": true,
      "source_patterns": [
        "firecrawl_queue_backlog_lock_reconcile_lifecycle",
        "firecrawl_incremental_crawl_discovery_enqueue",
        "firecrawl_extract_dlq_terminal_projection"
      ],
      "purpose": "Keep high-volume retrieval dependable by separating work admission, backlog, active locks, completion, cleanup, and reconciliation from evidence packaging.",
      "work_state_values": [
        "queued",
        "backlogged",
        "active",
        "completed",
        "failed",
        "dead_lettered",
        "expired",
        "cancelled"
      ],
      "admission_rules": [
        "group_work_by_owner_and_optional_retrieval_run",
        "apply_team_or_run_concurrency_before_enqueueing_more_fetch_work",
        "bound_backlog_timeout_to_the_parent_retrieval_lifecycle",
        "prefer_idempotent_or_no_op_add_when_retrying_existing_work"
      ],
      "worker_rules": [
        "claim_work_with_lock_or_owner_token",
        "renew_active_locks_for_long_running_reads",
        "only_the_lock_holder_may_mark_work_completed_or_failed",
        "release_active_concurrency_markers_on_completion_or_failure",
        "record_transport_or_access_failures_as_error_summaries_not_source_evidence"
      ],
      "terminal_failure_rules": [
        "convert_crashed_or_dead_lettered_work_into_bounded_failed_status_artifacts",
        "ack_or_release_handled_failures_after_status_is_persisted",
        "retry_only_when_a_changed_request_or_recovery_lane_exists",
        "preserve_error_summary_and_missing_evidence_reason_for_synthesis_gap_handling"
      ],
      "reconciliation_rules": [
        "scan_durable_backlog_and_runtime_queue_indexes_for_drift",
        "requeue_missing_backlog_items_when_capacity_is_unavailable",
        "promote_eligible_items_when_capacity_is_available",
        "bound_stale_entry_skips_per_reconciliation_run",
        "report_recovered_counts_as_diagnostics_only"
      ],
      "incremental_discovery_rules": [
        "discover_links_from_completed_pages_only_when_allowed_by_crawl_policy",
        "dedupe_and_lock_discovered_urls_before_enqueue",
        "record_denial_reasons_for_filtered_discovered_urls",
        "increment_discovery_depth_as_internal_metadata",
        "do_not_enqueue_after_parent_retrieval_is_cancelled"
      ],
      "projection_boundary": "synthesis sees evidence refs, result windows, access summaries, and explicit coverage gaps; queue, lock, priority, and worker internals stay telemetry-only",
      "non_goals": [
        "do_not_bind_retrieval_to_a_specific_queue_backend",
        "do_not_use_job_counts_as_evidence_quality",
        "do_not_make_retrieval_lifecycle_status_final_answer_text",
        "do_not_hardcode_provider_or_domain_specific_capacity_rules"
      ]
    },
    "evidence_pack_quality": {
      "enabled": true,
      "min_usable_items": 2,
      "min_source_domains": 2,
      "purpose": "report whether the hidden evidence pack is absent, thin, low-confidence-only, or usable before final synthesis",
      "non_goals": [
        "do_not_use_quality_metadata_as_citable_evidence",
        "do_not_treat_candidate_count_as_sufficiency",
        "do_not_prescribe_answer_shape"
      ]
    },
    "managed_search_index": {
      "enabled": true,
      "source_patterns": [
        "firecrawl_managed_search_index_modes",
        "firecrawl_precrawl_budgeted_index_backfill"
      ],
      "purpose": "Use an admitted search-index lane as candidate discovery and ranking support when available, while treating live page reads and evidence extraction as the authority for claims.",
      "modes": [
        "hybrid",
        "keyword",
        "semantic",
        "bm25"
      ],
      "filters": [
        "domain",
        "country",
        "language",
        "freshness",
        "render_profile"
      ],
      "result_fields": [
        "title",
        "locator",
        "snippet",
        "score",
        "bm25_rank",
        "vector_rank",
        "freshness_score",
        "quality_score",
        "last_crawled_at"
      ],
      "failure_behavior": "return_empty_candidate_lane_with_internal_status_on_timeout_unavailable_or_invalid_index_response",
      "background_corpus_warming": {
        "enabled_when_policy_allows_public_cache": true,
        "budget_axes": [
          "source_priority",
          "observed_request_frequency",
          "domain_budget",
          "per_page_event_weight",
          "resource_pressure"
        ],
        "admission_rules": [
          "only_index_public_or_storage_permitted_content",
          "batch_source_selection_to_avoid_resource_spikes",
          "do_not_block_live_retrieval_on_optional_index_write_failure",
          "publish_completed_page_refs_not_queue_handles"
        ]
      },
      "non_goals": [
        "do_not_treat_index_hit_count_as_evidence_sufficiency",
        "do_not_replace_fetch_when_body_context_is_required",
        "do_not_expose_index_scores_as_final_answer_text",
        "do_not_bind_to_a_specific_index_service"
      ]
    },
    "second_pass_recovery": {
      "enabled": true,
      "trigger": "no_usable_synthesis_candidates_or_no_raw_provider_artifacts_after_first_pass",
      "max_queries": 4,
      "record_recovery_queries": true,
      "templates": [
        "{query} source-backed evidence",
        "{query} primary or official source",
        "{query} independent evaluation or source-backed analysis",
        "{query} examples evidence primary reports"
      ],
      "non_goals": [
        "do_not_hide_query_expansion_from_trace",
        "do_not_hardcode_domains_or_topic_candidates",
        "do_not_force_user_visible_output_format"
      ]
    },
    "coverage_gap_recovery": {
      "enabled": true,
      "trigger": "candidate_volume_exists_but_usable_evidence_or_facet_coverage_is_low",
      "max_queries": 4,
      "min_usable_evidence": 3,
      "min_covered_facets": 3,
      "min_covered_facet_ratio": 0.75,
      "record_recovery_queries": true,
      "templates": [
        "{facet} source-backed evidence",
        "{facet} primary or official source",
        "{facet} independent analysis evidence",
        "{facet} examples reports data"
      ],
      "non_goals": [
        "do_not_hide_query_expansion_from_trace",
        "do_not_hardcode_domains_or_topic_candidates",
        "do_not_force_user_visible_output_format",
        "do_not_treat_high_candidate_count_as_evidence_sufficiency"
      ]
    },
    "coverage_aware_query_planning": {
      "enabled": true,
      "authority": "agent_submitted_query_pack_with_policy_scoring",
      "source_patterns": [
        "firecrawl_search_result_scrape_merge",
        "firecrawl_deep_research_gap_loop_without_final_format_hardcoding"
      ],
      "trigger": "multi_entity_or_multi_aspect_or_open_ended_research",
      "budget": {
        "min_lanes_for_multi_entity": 4,
        "default_max_lanes": 8,
        "reserve_recovery_lanes": 2,
        "parallel_lane_limit": 4
      },
      "two_phase_retrieval": {
        "enabled": true,
        "initial_discovery_pass": {
          "allowed": true,
          "purpose": "learn vocabulary, candidate entities, source classes, and likely coverage gaps from a cheap broad pass",
          "completion_status": "non_terminal_for_research_shaped_requests_unless_sufficiency_signals_are_met"
        },
        "targeted_followup_pass": {
          "required_when": [
            "broad_or_open_ended_research",
            "comparative_or_evaluative_research",
            "multi_entity_or_multi_aspect_research",
            "initial_results_are_low_signal_or_off_topic",
            "named_entities_or_user_stated_aspects_are_missing_from_results"
          ],
          "query_source": "combine_user_request_with_discovery_terms_and_gap_signals",
          "minimum_followup_lanes": 3,
          "maximum_followup_lanes": 8,
          "lane_allocation": "cover_major_entities_user_stated_aspects_source_classes_time_windows_and_cross_comparison_before_repeating_broad_topic_queries"
        },
        "finish_rule": "synthesis may proceed only after coverage is sufficient or after bounded followup records explicit gap reasons for missing lanes"
      },
      "lane_types": [
        "overall_objective",
        "entity_or_candidate",
        "user_stated_aspect_or_criterion",
        "cross_comparison_or_source_diversity",
        "coverage_gap_recovery"
      ],
      "planning_rules": [
        "preserve the user's original research objective as the top-level query",
        "when the workflow payload includes keywords, required coverage, aliases, or negative terms, treat them as agent-submitted retrieval metadata and compile them into visible query-plan lanes instead of hidden expansion",
        "quote exact entity and alias phrases when compiling metadata lanes, but do not quote generic facets or keywords by default",
        "a single broad query may start discovery, but it is not enough to finish broad, comparative, current, evaluative, multi-entity, or multi-aspect research unless evidence sufficiency is already met",
        "after a weak discovery pass, use the observed snippets, off-topic terms, and missing buckets to submit targeted follow-up queries instead of asking the user to narrow",
        "when the prompt names multiple entities or candidates, allocate at least one retrieval lane to each major entity before synthesis",
        "when the prompt names aspects, criteria, risks, time windows, or source constraints, allocate retrieval lanes to those dimensions instead of using only generic topic searches",
        "when the prompt is open-ended, use discovery lanes for category, source class, and decision criteria before relying on prior-memory candidates",
        "do not drop a major entity, criterion, or requested scope without recording a coverage gap"
      ],
      "iterative_gap_loop": {
        "enabled": true,
        "state_fields": [
          "original_user_goal",
          "seen_locators",
          "evidence_refs",
          "coverage_gaps",
          "followup_query_lanes",
          "depth",
          "failed_attempts",
          "stop_reason"
        ],
        "step_contract": [
          "start_with_concise_discovery_lanes",
          "read_or_fetch_promising_candidate_urls",
          "dedupe_seen_locators_before_fetch_budget",
          "derive_gap_lanes_from_current_evidence",
          "issue_specific_followups_when_coverage_is_weak",
          "reserve_budget_for_final_synthesis",
          "finish_with_sufficient_evidence_or_explicit_gap_reasons"
        ],
        "stop_controls": {
          "default_depth": 2,
          "max_depth": 4,
          "default_parallel_followup_lanes": 3,
          "max_parallel_followup_lanes": 4,
          "max_failed_planning_attempts": 3
        },
        "non_goals": [
          "do_not_hardcode_domains_topics_or_output_sections",
          "do_not_use_provider_activity_as_source_evidence",
          "do_not_override_the_user_selected_model"
        ]
      },
      "coverage_buckets": {
        "enabled": true,
        "bucket_kinds": [
          "entity",
          "aspect",
          "source_class",
          "time_window",
          "cross_comparison"
        ],
        "status_values": [
          "covered",
          "weak",
          "missing",
          "not_applicable"
        ],
        "record_fields": [
          "bucket_id",
          "bucket_kind",
          "requested_text",
          "query_refs",
          "evidence_count",
          "source_domain_count",
          "quality_flags",
          "gap_reason"
        ]
      },
      "non_goals": [
        "do_not_hardcode_domain_candidates",
        "do_not_force_user_visible_answer_format",
        "do_not_expand_queries_hidden_from_submitted_payload"
      ]
    },
    "semantic_query_planning": {
      "enabled": true,
      "source_pattern": "exa_semantic_search_guidance",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "authority": "agent_submitted_query_pack_visible_to_trace",
      "query_style": "describe_target_sources_pages_or_evidence_not_keywords_only",
      "diversity_axes": [
        "entity_or_candidate",
        "user_stated_aspect_or_criterion",
        "source_class",
        "time_window",
        "stance_or_failure_mode",
        "implementation_or_methodology",
        "cross_comparison"
      ],
      "anti_patterns": [
        "synonym_only_rewrites",
        "single_word_or_two_word_broad_queries",
        "boolean_operator_assumptions",
        "quoted_phrase_assumptions",
        "provider_specific_category_syntax_as_required_behavior"
      ],
      "sizing_policy": {
        "precise_named_entity": {
          "suggested_result_window": [
            5,
            8
          ]
        },
        "narrow_constrained_research": {
          "suggested_result_window": [
            8,
            12
          ]
        },
        "broad_discovery": {
          "suggested_result_window": [
            12,
            16
          ],
          "prefer_more_distinct_queries_over_one_large_query": true
        }
      },
      "record_fields": [
        "query_intent",
        "target_source_description",
        "diversity_axis",
        "expected_evidence_type",
        "coverage_bucket_ref",
        "provider_filter_hints"
      ],
      "non_goals": [
        "do_not_make_provider_specific_query_syntax_required",
        "do_not_force_subagent_or_parallel_agent_usage",
        "do_not_force_user_visible_output_format"
      ]
    },
    "page_extraction": {
      "enabled": true,
      "extract_mode": "markdown",
      "max_links_per_stage": 3,
      "max_total_fetches": 8,
      "min_link_score": 0.0,
      "min_usable_items_before_skip": 2,
      "min_snippet_words_before_skip": 22,
      "min_query_overlap_terms_before_skip": 2,
      "trigger": "low_thin_or_coverage_weak_candidates",
      "url_hygiene": {
        "enabled": true,
        "drop_fragment_for_dedupe": true,
        "canonical_dedupe_prefer_https_and_non_www": true,
        "require_http_protocol": true,
        "excluded_file_extensions": [
          ".png",
          ".jpg",
          ".jpeg",
          ".gif",
          ".webp",
          ".svg",
          ".ico",
          ".css",
          ".js",
          ".woff",
          ".woff2",
          ".ttf",
          ".mp3",
          ".mp4",
          ".avi",
          ".mov",
          ".zip",
          ".gz",
          ".tar",
          ".dmg",
          ".exe"
        ]
      },
      "prefetch": {
        "enabled": true,
        "goal": "discover_and_rank_links_before_full_fetch",
        "mode": "fast_link_and_head_discovery_before_selected_full_fetch",
        "skip_heavy_processing_during_discovery": true,
        "max_prefetch_links": 24,
        "include_link_text": true,
        "include_parent_context": true,
        "artifact_contract": "html_links_metadata_only_until_selected_for_full_processing",
        "skip_outputs": [
          "cleaned_html",
          "markdown",
          "extracted_content",
          "screenshots",
          "pdf"
        ],
        "can_reprocess_raw_html_with_base_url": true,
        "link_normalization": {
          "resolve_relative_urls": true,
          "dedupe_canonical_urls": true,
          "ignore_schemes": [
            "javascript",
            "mailto",
            "tel",
            "file",
            "data"
          ],
          "ignore_anchor_only_links": true,
          "trim_href_whitespace": true,
          "preserve_query_strings": true,
          "preserve_fragments_unless_anchor_only": true,
          "preserve_https_for_internal_links_after_redirect": true,
          "reject_invalid_base_urls": true,
          "truncate_link_text_chars": 200,
          "record_internal_external_classification": true,
          "handle_protocol_relative_urls": true,
          "treat_subdomains_as_configurable_same_site": true,
          "return_empty_links_on_malformed_html": true
        }
      },
      "source_access": {
        "robots_policy": "respect_and_record",
        "robots_cache_ttl_seconds": 86400,
        "robots_failure_lane": "unknown_or_error_not_success",
        "record_access_fields": [
          "robots_status",
          "robots_allowed",
          "robots_error",
          "redirect_chain",
          "content_type",
          "document_type"
        ]
      },
      "document_extraction": {
        "enabled": true,
        "handled_types": [
          "html",
          "pdf",
          "text"
        ],
        "source_patterns": [
          "firecrawl_parse_upload_as_no_browse_document_lane",
          "firecrawl_native_document_normalized_model"
        ],
        "artifact_model": "normalize_document_like_content_before_synthesis",
        "artifact_fields": [
          "document_type",
          "page_count",
          "page_numbers",
          "text_chars",
          "metadata_title",
          "metadata_author",
          "extraction_quality"
        ],
        "pdf": {
          "route_unsupported_fetch_content_type_to_pdf_extract": true,
          "extract_text": true,
          "extract_metadata": true,
          "extract_links": true,
          "extract_images_default": false,
          "page_batching": true,
          "scanned_pdf_without_ocr_quality_flag": "image_only_pdf"
        },
        "parse_upload_lane": {
          "authority": "tooling_capability_lane_not_web_browse",
          "supported_when_declared_by_tool_cd": true,
          "reject_browsing_options": [
            "actions",
            "screenshot",
            "waitFor",
            "location",
            "mobile_rendering"
          ],
          "cache_policy": "do_not_store_uploaded_or_parse_only_artifacts_without_explicit_cache_permission",
          "output_contract": "normalized_document_artifact"
        }
      },
      "head_preview": {
        "enabled": true,
        "max_candidates": 16,
        "timeout_ms": 5000,
        "fields": [
          "title",
          "description",
          "canonical",
          "lang",
          "jsonld",
          "open_graph",
          "jsonld_schema_types",
          "head_fingerprint",
          "status"
        ]
      },
      "candidate_selection": {
        "strategy": "score_then_fetch_best_available",
        "score_axes": [
          "query_relevance",
          "link_text_signal",
          "head_metadata_signal",
          "source_diversity",
          "freshness_when_relevant",
          "content_density",
          "low_junk_signal"
        ],
        "record_rejection_reasons": true,
        "score_report": {
          "record_threshold": true,
          "record_min_max_avg": true,
          "record_top_matched_terms": true,
          "normalize_scores": true,
          "deterministic_for_same_cached_inputs": true,
          "empty_query_returns_unscored_discovery": true
        }
      },
      "search_result_followup": {
        "enabled": true,
        "source_pattern": "exa_search_then_fetch",
        "provider_binding": "none_source_pattern_is_attribution_only",
        "fetch_when": [
          "highlights_are_thin_but_source_is_promising",
          "snippet_mentions_requested_value_without_value",
          "soft_filter_requires_body_context",
          "requested_fields_are_missing_from_snippet",
          "source_quality_or_claim_validation_is_needed"
        ],
        "do_not_fetch_when": [
          "snippet_is_sufficient_for_narrow_lookup",
          "result_is_off_topic",
          "source_is_duplicate",
          "source_access_policy_blocks_fetch"
        ],
        "batching": {
          "preferred_url_batch_min": 3,
          "preferred_url_batch_max": 8,
          "respect_max_total_fetches": true
        },
        "record_fields": [
          "followup_reason",
          "source_url",
          "snippet_signal",
          "missing_field",
          "fetch_status",
          "per_url_error"
        ]
      },
      "retrieval_profile_selection": {
        "enabled": true,
        "authority": "content_and_evidence_state_not_domain_routes",
        "match_axes": [
          "content_type",
          "document_type",
          "quality_flags",
          "evidence_gap",
          "explicit_user_constraints"
        ],
        "fallback_profile": "default_markdown_fetch",
        "first_match_wins": true,
        "record_selected_profile": true,
        "disallow_match_axes": [
          "hardcoded_domain_name",
          "golden_case_id",
          "example_prompt_phrase"
        ]
      },
      "dynamic_escalation": {
        "enabled": true,
        "default": "off",
        "source_patterns": [
          "firecrawl_browser_session_ttl_concurrency_claim_cleanup",
          "firecrawl_scrape_replay_before_interact",
          "firecrawl_browser_agent_snapshot_action_loop",
          "firecrawl_trace_zdr_sanitization"
        ],
        "allowed_when_quality_flags_include": [
          "needs_js",
          "needs_dynamic",
          "needs_interaction",
          "blocked_but_retryable"
        ],
        "requires_capability": "web_fetch.dynamic_page_allowed"
      },
      "session_reuse": {
        "default": "stateless",
        "allowed_when": [
          "sequential_dynamic_steps_required",
          "explicit_session_handle_supplied",
          "capability_policy_admits_session_state"
        ],
        "parallel_session_reuse_allowed": false,
        "close_or_expire_on_completion": true,
        "record_session_state": "handle_only"
      },
      "dynamic_browser_interaction": {
        "enabled": true,
        "purpose": "Bounded browser interaction can enrich evidence when a normal fetch/read lane cannot surface the needed content.",
        "activation": [
          "static_or_rendered_page_evidence_is_missing_required_interactive_content",
          "prior_page_context_is_replayable_or_user_explicitly_supplies_an_interaction_goal",
          "tool_cd_declares_browser_interaction_capability"
        ],
        "session_lifecycle": [
          "enforce_owner_concurrency_and_ttl_before_session_creation",
          "retry_session_creation_with_short_backoff",
          "persist_session_handle_before_exposing_it_to_followup_execution",
          "delete_remote_session_if_persistence_fails",
          "claim_destroyed_state_before_cleanup_or_billing_side_effects",
          "invalidate_active_session_counts_after_create_destroy_or_webhook"
        ],
        "replay_policy": [
          "build_replay_from_prior_fetch_or_scrape_context_when_available",
          "sanitize_actions_and_clamp_waits_before_execution",
          "skip_output_only_actions_during_replay",
          "synchronize_to_one_foreground_content_page_after_replay"
        ],
        "action_loop_policy": [
          "use_current_url_and_interactive_snapshot_as_initial_state",
          "treat_element_refs_as_invalid_after_page_changes",
          "resnapshot_after_state_changing_actions",
          "bound_step_count_and_per_step_timeout",
          "block_new_tabs_and_out_of_scope_navigation_by_default",
          "package_extracted_text_or_action_result_as_evidence_refs_not_raw_browser_trace"
        ],
        "privacy_policy": [
          "external_trace_opt_in_only",
          "disable_external_trace_when_zero_retention_or_private_context_applies",
          "strip_query_string_and_fragment_from_trace_urls",
          "keep_debug_logs_internal"
        ],
        "non_goals": [
          "do_not_make_dynamic_interaction_default_for_all_queries",
          "do_not_prescribe_final_answer_format",
          "do_not_bind_to_specific_browser_agent_model",
          "do_not_expose_raw_cdp_urls_accessibility_trees_or_tool_refs_to_chat"
        ]
      },
      "artifact_transformation_stack": {
        "enabled": true,
        "source_patterns": [
          "firecrawl_transformer_stack_format_gated_derivation",
          "firecrawl_page_local_query_direct_quote",
          "firecrawl_projection_field_coercion",
          "firecrawl_change_tracking_diff_lane",
          "firecrawl_specialty_postprocessor_lane"
        ],
        "purpose": "Convert fetched page artifacts into evidence-ready variants while deriving only requested or internally useful fields.",
        "derivation_order": [
          "html_cleanup",
          "markdown_derivation_when_needed",
          "clean_content_when_requested",
          "link_image_attribute_derivation",
          "metadata_backfill",
          "optional_index_write",
          "structured_extract_or_summary",
          "page_local_query_or_highlights",
          "change_tracking",
          "projection_field_coercion"
        ],
        "format_gating_rules": [
          "derive_markdown_for_downstream_json_summary_query_highlight_or_change_tracking_even_when_markdown_is_not_final_requested_output",
          "skip_expensive_derivations_when_neither_requested_nor_needed_for_internal_retrieval_quality",
          "warn_when_requested_artifact_is_absent_after_transformers",
          "drop_unrequested_heavy_fields_before_projection",
          "keep transient index_ids and transformer diagnostics internal"
        ],
        "page_local_query": {
          "enabled": true,
          "strategies": [
            "direct_quote_line_selection",
            "freeform_page_answer",
            "highlight_selection"
          ],
          "rules": [
            "answer_only_from_current_page_artifact",
            "treat_page_content_as_untrusted_data_not_instructions",
            "preserve selected table_headers_code_blocks_and_original_order",
            "return_absent_or_warning_when_page_lacks_requested_information"
          ]
        },
        "change_tracking": {
          "enabled_when_requested": true,
          "modes": [
            "status",
            "text_diff",
            "structured_json_diff"
          ],
          "requires_retained_prior_artifact": true,
          "disabled_when_zero_retention": true
        },
        "postprocessors": {
          "enabled": true,
          "capability_matched": true,
          "purpose": "Allow content-type or provider-specific processors to convert otherwise low-value pages into normalized evidence artifacts behind a capability gate.",
          "non_goals": [
            "do_not_make_provider_specific_postprocessor_output_a_final_answer_template",
            "do_not_run_when_lockdown_or_policy_disallows_external_processing"
          ]
        },
        "non_goals": [
          "do_not_prescribe_final_answer_format",
          "do_not_hardcode_domain_topics_or_golden_cases",
          "do_not_project_raw_transformer_diagnostics_to_chat"
        ]
      }
    },
    "structured_results": {
      "enabled": true,
      "max_rows_per_stage": 16,
      "deterministic_extraction_first": true,
      "strategy_ladder": [
        "schema_selector_when_repeating_structure_detected",
        "regex_entity_extraction_for_known_low-risk_patterns",
        "semantic_extraction_when_structure_is_inconsistent"
      ],
      "record_fields": [
        "strategy",
        "base_selector",
        "element_count",
        "schema_confidence",
        "field_count",
        "extracted_row_count",
        "fallback_reason"
      ],
      "schema_safety": {
        "sample_before_full_extract": true,
        "validate_parent_selector_not_singleton_when_list_expected": true,
        "retain_base_attributes": true,
        "support_nested_and_list_fields": true,
        "raw_schema_chat_visible": false
      }
    },
    "provider_result_envelope": {
      "enabled": true,
      "source_pattern": "exa_safe_provider_fields",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "raw_payload_chat_visible": false,
      "sensitive_keys_removed": [
        "requestTags",
        "authorization",
        "cookie",
        "set-cookie"
      ],
      "search_metadata_fields": [
        "request_id",
        "resolved_search_type",
        "auto_prompt",
        "auto_date",
        "search_time_ms",
        "cost_summary",
        "provider_statuses"
      ],
      "result_metadata_fields": [
