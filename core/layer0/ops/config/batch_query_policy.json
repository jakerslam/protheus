        "error_tag",
        "http_status_code"
      ],
      "grounding_fields": [
        "field",
        "confidence",
        "citation_url",
        "citation_title"
      ],
      "consumed_by": [
        "research_plane_policy.evidence_extraction.provider_result_envelope",
        "web_retrieval_v0.tool_cd.diagnostic_projection_contract.progressive_retrieval_contract.provider_result_envelope"
      ],
      "retention_policy": "metadata_and_evidence_excerpts_only_until_synthesized"
    },
    "advanced_search_controls": {
      "enabled": true,
      "source_pattern": "exa_advanced_search_surface",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "authority": "adapter_owned_optional_request_fields",
      "controls": [
        "source_class_or_category_hint",
        "include_domains",
        "exclude_domains",
        "start_published_date",
        "end_published_date",
        "start_crawl_date",
        "end_crawl_date",
        "include_text",
        "exclude_text",
        "user_location",
        "moderation",
        "additional_queries",
        "text_max_characters",
        "context_max_characters",
        "summary_query",
        "highlights_query",
        "highlights_max_characters",
        "freshness_max_age",
        "live_fetch_preference",
        "live_fetch_timeout_ms",
        "subpage_limit",
        "subpage_target_terms"
      ],
      "use_when": [
        "user_explicitly_requests_source_scope",
        "time_window_or_freshness_is_part_of_task",
        "evidence_state_requires_more_body_context",
        "known_promising_result_needs_subpage_expansion",
        "retrieval_quality_needs_source_class_balance"
      ],
      "non_goals": [
        "do_not_make_provider_specific_category_syntax_required",
        "do_not_add_domain_specific_defaults",
        "do_not_hide_filters_from_query_contract"
      ]
    },
    "provider_request_lifecycle": {
      "enabled": true,
      "source_pattern": "exa_mcp_auth_rate_error_lifecycle",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "purpose": "classify provider and transport states before synthesis so retrieval failures do not look like empty successful evidence",
      "status_values": [
        "usable",
        "low_signal",
        "irrelevant",
        "empty_success",
        "partial_success",
        "bad_request_shape",
        "auth_required",
        "rate_limited",
        "transient_provider_failure",
        "permanent_provider_failure"
      ],
      "retry_policy": {
        "retry_transient_statuses": [
          500,
          502,
          503,
          504
        ],
        "do_not_retry_without_request_change": [
          "bad_request_shape",
          "auth_required",
          "permanent_provider_failure"
        ],
        "rate_limit_handling": "record_retry_after_and_budget_status_without_turning_it_into_final_chat"
      },
      "record_fields": [
        "request_status",
        "auth_state",
        "rate_limit_state",
        "retry_after",
        "provider_error_code",
        "provider_error_message_ref",
        "bad_request_shape_hint",
        "request_sanitized",
        "partial_success_count",
        "partial_error_count"
      ],
      "feeds": [
        "tool_result_quality.status",
        "research_plane_policy.evidence_extraction.retrieval_status_classification",
        "web_retrieval_v0.tool_cd.diagnostic_projection_contract.progressive_retrieval_contract.provider_error_contract"
      ],
      "research_status_normalization": {
        "usable": "usable_evidence",
        "low_signal": "low_signal_evidence",
        "irrelevant": "irrelevant_evidence",
        "empty_success": "empty_success",
        "partial_success": "partial_success",
        "bad_request_shape": "bad_request_shape",
        "auth_required": "auth_or_permission_blocked",
        "rate_limited": "rate_limited",
        "transient_provider_failure": "transient_provider_failure",
        "permanent_provider_failure": "permanent_provider_failure"
      },
      "non_goals": [
        "do_not_expose_credentials_or_raw_provider_errors_to_chat",
        "do_not_treat_protocol_success_as_evidence_usefulness",
        "do_not_require_provider_specific_routes"
      ]
    },
    "adaptive_sufficiency": {
      "enabled": true,
      "authority": "policy_owned_retrieval_primitive",
      "min_evidence_items": 4,
      "min_source_domains": 3,
      "candidate_gain_threshold": 0.08,
      "stop_when": [
        "evidence_threshold_met",
        "source_diversity_threshold_met",
        "candidate_gain_below_threshold",
        "query_budget_exhausted",
        "tool_budget_exhausted"
