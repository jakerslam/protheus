{
  "version": "tool_cd_web_retrieval_v0",
  "source": "scrapling_pattern_assimilation_v0",
  "diagnostic_projection_contract": {
    "version": "web_retrieval_quality_diagnostics_v1",
    "chat_visibility": "hidden_until_synthesized",
    "required_result_fields": [
      "tool_result_quality.status",
      "tool_result_quality.flags",
      "tool_result_quality.candidate_count",
      "tool_result_quality.evidence_count",
      "tool_result_quality.retry.recommended",
      "tool_result_quality.retry.reason",
      "tool_result_quality.retry.next_action",
      "tool_result_quality.retry.query_strategy_hints",
      "query_plan",
      "query_plan_source",
      "provider_result_count",
      "partial_failure_details"
    ],
    "optional_result_artifact_fields": [
      "result_envelope.source_url",
      "result_envelope.final_url",
      "result_envelope.canonical_url",
      "result_envelope.status_code",
      "result_envelope.redirected_status_code",
      "result_envelope.fetch_mode",
      "result_envelope.cache_status",
      "result_envelope.cache_freshness_status",
      "result_envelope.head_fingerprint",
      "result_envelope.score_distribution",
      "result_envelope.score_threshold",
      "result_envelope.sources_used",
      "result_envelope.checkpoint_ref",
      "result_envelope.resume_state_ref",
      "result_envelope.cancelled",
      "result_envelope.robots_status",
      "result_envelope.robots_allowed",
      "result_envelope.content_type",
      "result_envelope.document_type",
      "result_envelope.quality_flags",
      "result_envelope.error_message",
      "evidence_artifacts.raw_markdown",
      "evidence_artifacts.markdown_with_citations",
      "evidence_artifacts.references_markdown",
      "evidence_artifacts.fit_markdown",
      "evidence_artifacts.table_summary",
      "evidence_artifacts.link_summary",
      "evidence_artifacts.media_summary",
      "evidence_artifacts.page_metadata_summary",
      "evidence_artifacts.document_metadata_summary",
      "evidence_artifacts.pdf_text_excerpt",
      "evidence_artifacts.pdf_page_summary",
      "evidence_chunks"
    ],
    "recovery_semantics": {
      "authority": "agent_submitted_query_pack",
      "hidden_query_expansion_allowed": false,
      "retry_recommended_next_action": "agent_refine_query_pack_and_retry_if_budget_remains",
      "retry_query_strategy": [
        "preserve the original research objective",
        "split broad requests into entity, aspect, time-window, or source-type searches",
        "target primary, official, source-backed, or directly citable pages when relevant",
        "use low-relevance and off-topic diagnostics to remove weak terms",
        "synthesize from best recorded evidence only after internal recovery is exhausted"
      ]
    },
    "progressive_retrieval_contract": {
      "authority": "tool_cd_declares_strategy_rust_executes_without_domain_routes",
      "source_pattern": "crawl4ai_progressive_sufficiency",
      "objective": "gather enough useful evidence before synthesis instead of forcing a final answer from structurally successful but weak search output",
      "sufficiency_signals": [
        "candidate_count",
        "evidence_count",
        "source_domain_count",
        "score_distribution",
        "confidence_delta",
        "candidate_quality_flags",
        "source_diversity_flags",
        "freshness_flags",
        "partial_failure_details"
      ],
      "candidate_scoring_axes": [
        "query_relevance",
        "source_diversity",
        "source_authority",
        "freshness_when_relevant",
        "content_density",
        "low_junk_signal",
        "novelty_against_retained_evidence"
      ],
      "candidate_enrichment_order": [
        "search_provider_rows",
        "prefetch_link_discovery",
        "head_metadata_preview",
        "structured_result_rows",
        "rendered_result_rows",
        "promising_link_fetch",
        "fit_markdown_or_excerpt_packaging"
      ],
      "retrieval_primitives": {
        "prefetch": {
          "purpose": "discover links and candidate context without committing budget to full page extraction",
          "outputs": [
            "candidate_url",
            "parent_url",
            "link_text",
            "head_metadata",
            "score_distribution",
            "candidate_score",
            "rejection_reason"
          ],
          "normalization": [
            "resolve_relative_urls",
            "dedupe_canonical_urls",
            "ignore_non_fetchable_schemes",
            "block_file_javascript_and_data_schemes",
            "ignore_anchor_only_links",
            "trim_href_whitespace",
            "preserve_query_strings",
            "preserve_fragments_unless_anchor_only",
            "preserve_https_for_internal_links_after_redirect",
            "reject_invalid_base_urls",
            "truncate_long_link_text",
            "handle_protocol_relative_urls",
            "return_empty_links_on_malformed_html",
            "classify_internal_external"
          ],
          "artifact_contract": "html_links_metadata_only_until_selected_for_full_processing",
          "can_reprocess_raw_html_with_base_url": true
        },
        "best_first_candidate_expansion": {
          "purpose": "spend follow-up fetches on the highest expected evidence gain",
          "state": [
            "visited_urls",
            "pending_candidates",
            "depth",
            "parent_url",
            "score",
            "source_domain"
          ]
        },
        "fit_content_packaging": {
          "purpose": "provide compact evidence to synthesis while retaining raw payload out of chat",
          "variants": [
            "raw_markdown",
            "markdown_with_citations",
            "fit_markdown",
            "references_markdown",
            "source_excerpt",
            "cleaned_html",
            "fit_html",
            "table_summary",
            "link_summary",
            "media_summary",
            "page_metadata_summary",
            "document_metadata_summary",
            "pdf_text_excerpt",
            "pdf_page_summary",
            "pdf_link_summary"
          ]
        },
        "chunk_ranked_evidence": {
          "purpose": "rank page sections before synthesis so large pages do not collapse into weak snippets",
          "strategies": [
            "paragraph_or_heading_boundary",
            "fixed_window",
            "sliding_window_with_overlap",
            "semantic_or_similarity_ranked_when_available"
          ],
          "metadata": [
            "chunk_id",
            "source_url",
            "parent_artifact",
            "heading_path",
            "relevance_score",
            "token_estimate",
            "rejection_reason"
          ]
        },
        "structured_artifact_packaging": {
          "purpose": "preserve tables, links, media, metadata, and extracted structures as evidence signals without prescribing user-visible formatting",
          "artifact_kinds": [
            "table_summary",
            "link_summary",
            "media_summary",
            "page_metadata_summary",
            "extracted_content_summary",
            "structured_extract_summary",
            "regex_extract_summary"
          ],
          "quality_fields": [
            "row_count",
            "column_count",
            "caption",
            "headers_present",
            "link_context",
            "media_alt_or_title",
            "artifact_relevance_score",
            "rejection_reason"
          ]
        },
        "deterministic_structured_extraction": {
          "purpose": "preserve repeatable page structures as evidence artifacts before semantic synthesis",
          "strategy_ladder": [
            "css_or_xpath_schema_when_repeating_structure_detected",
            "regex_entity_extraction_for_known_low-risk_patterns",
            "semantic_extraction_when_structure_is_inconsistent_or_inferential"
          ],
          "schema_features": [
            "base_selector",
            "base_fields",
            "nested",
            "list",
            "nested_list",
            "attribute",
            "text",
            "html",
            "default_value",
            "transform"
          ],
          "quality_fields": [
            "strategy",
            "base_selector",
            "element_count",
            "field_count",
            "extracted_row_count",
            "schema_confidence",
            "fallback_reason"
          ],
          "non_goals": [
            "do_not_force_final_answer_json",
            "do_not_hardcode_site_schemas",
            "do_not_expose_raw_schema_to_chat"
          ]
        }
      },
      "cache_contract": {
        "modes": [
          "enabled",
          "disabled",
          "read_only",
          "write_only",
          "bypass"
        ],
        "freshness_signals": [
          "etag",
          "last_modified",
          "head_fingerprint",
          "source_timestamp",
          "cache_status"
        ],
        "cleanup_bound": "system_state_cleanup",
        "testability": "evals_may_bypass_or_isolate_cache_without_changing_user_runtime_defaults"
      },
      "adaptive_state_projection": {
        "purpose": "surface progress and stop reasons for multi-step retrieval without letting crawl state become chat-visible payload",
          "fields": [
            "confidence",
            "previous_confidence",
            "confidence_delta",
            "confidence_components",
            "coverage",
            "consistency",
            "saturation",
            "crawled_url_count",
            "pending_candidate_count",
            "source_domain_count",
            "checkpoint_ref",
            "resume_state_ref",
            "cancelled",
            "relevant_content_refs",
            "stop_reason"
          ],
          "visibility": "telemetry_or_evidence_metadata_only"
        },
        "resource_control": {
        "per_domain_rate_limit": true,
        "backoff_on_status": [
          429,
          503,
          504
        ],
          "memory_pressure_queueing": true,
          "bounded_fanout_required": true,
          "stream_progress_telemetry": true,
          "score_report_fields": [
            "score_threshold",
            "score_min",
            "score_max",
            "score_avg",
            "top_matched_terms"
          ],
          "browser_context_lifecycle": {
            "enabled_for_dynamic_capability_only": true,
            "context_signature_axes": [
              "proxy",
              "locale",
              "timezone",
              "geolocation",
              "navigator_override",
              "storage_state"
            ],
            "ignore_non_context_axes": [
              "word_count_threshold",
              "css_selector",
              "screenshot",
              "pdf",
              "scan_full_page",
              "only_text",
              "wait_until",
              "page_timeout",
              "capture_network_requests"
            ],
            "evict_only_idle_contexts": true,
            "preserve_active_refcounts": true,
            "recycle_when_safe": "threshold_or_memory_pressure_when_no_active_sessions",
            "resource_filtering_default": "off"
          }
        },
      "blocked_recovery_trace": {
        "purpose": "tell synthesis whether retrieval failed because the web is low-signal or because access/readiness blocked the evidence path",
        "quality_flags": [
          "blocked",
          "rate_limited",
          "needs_js",
          "needs_dynamic",
          "proxy_error",
          "structural_empty_shell"
        ],
        "trace_fields": [
          "attempts",
          "retries",
          "fetch_mode",
          "status_code",
          "blocked",
          "reason",
          "resolved_by"
        ],
        "capability_boundary": "diagnose_first_escalate_only_when_admitted_by_policy"
      },
      "source_access_contract": {
        "robots_policy": "respect_and_record",
        "redirect_chain_recording": true,
        "preserve_https_for_internal_links_after_redirect": true,
        "content_type_detection": true,
        "document_type_detection": true,
        "sitemap_namespace_tolerant": true,
        "sitemap_index_children_supported": true,
        "sitemap_relative_locations_normalized": true,
        "failure_lanes": [
          "robots_denied",
          "robots_unknown",
          "redirect_loop",
          "unsupported_document_type",
          "image_only_pdf"
        ],
        "visibility": "telemetry_or_evidence_metadata_only"
      },
      "retrieval_profile_selection": {
        "purpose": "allow different extraction strategies without hardcoding domains or user prompt examples",
        "match_axes": [
          "content_type",
          "document_type",
          "quality_flags",
          "evidence_gap",
          "explicit_user_constraints",
          "available_capabilities"
        ],
        "profiles": [
          "default_markdown_fetch",
          "fit_content_fetch",
          "pdf_document_fetch",
          "structured_artifact_fetch",
          "dynamic_readiness_probe",
          "prefetch_only_discovery"
        ],
        "fallback_profile": "default_markdown_fetch",
        "non_goals": [
          "do_not_match_on_hardcoded_domain",
          "do_not_match_on_golden_case_id",
          "do_not_match_on_example_prompt_phrase"
        ]
      },
      "session_reuse_contract": {
        "default": "stateless",
        "allowed_only_for": [
          "sequential_dynamic_steps",
          "explicit_session_handle",
          "capability_admitted_stateful_fetch"
        ],
        "parallel_reuse_allowed": false,
        "cleanup_required": true,
        "visibility": "handle_and_status_only"
      },
      "dynamic_readiness_diagnostics": {
        "purpose": "summarize why static fetch was incomplete without leaking raw network or console payloads",
        "summary_fields": [
          "lazy_load_required",
          "virtual_scroll_required",
          "scroll_behavior_static",
          "scroll_behavior_appended",
          "scroll_behavior_replaced",
          "wait_condition_timeout",
          "network_request_count",
          "network_failure_count",
          "console_error_count"
        ],
        "raw_payload_chat_visible": false
      },
      "stop_conditions": [
        "usable_evidence_threshold_met",
        "source_diversity_threshold_met",
        "candidate_gain_below_threshold",
        "cancelled_by_user_or_policy",
        "query_budget_exhausted",
        "tool_budget_exhausted"
      ],
      "non_goals": [
        "do_not_add_domain_specific_research_routes",
        "do_not_force_user_visible_answer_format",
        "do_not_make_browser_or_proxy_modes_default",
        "do_not_scrape_provider_pages_as_a_default_search_strategy",
        "do_not_execute_user_supplied_hook_code_without_trusted_local_capability"
      ]
    }
  },
  "contracts": [
    {
      "tool_id": "web_search",
      "capability_family": "web_retrieval",
      "required_args": ["query"],
      "aliases": ["web_lookup", "browse_web"],
      "optional_args": ["aperture", "timeout_ms", "source_scope"],
      "operations": ["search"],
      "retrieval": {
        "mode": "search",
        "supports_bulk": false,
        "max_bulk_items": 1,
        "cost_tier": "low",
        "requires_network": true
      },
      "execution_policy": {
        "request_fingerprint_dedupe": true,
        "fingerprint_identity_fields": [
          "session_scope",
          "http_method",
          "request_body",
          "canonical_url"
        ],
        "fingerprint_include_request_options_default": false,
        "fingerprint_include_headers_default": false,
        "fingerprint_keep_url_fragments_default": false,
        "per_domain_concurrency_default": 0,
        "request_delay_ms_default": 0,
        "blocked_response_retry_allowed": false,
        "max_blocked_retries_default": 0
      },
      "extraction": {
        "default_type": "markdown",
        "allowed_types": ["markdown", "html", "text"],
        "selector_hint_allowed": true,
        "selector_hint_fallback_mode": "whole_page",
        "main_content_only_default": true,
        "max_chars": 12000
      },
      "readiness": {
        "supported_fields": ["timeout_ms"],
        "default_timeout_ms": 30000,
        "dynamic_page_allowed": false
      },
      "resource_policy": {
        "disable_resources_allowed": false,
        "block_ads_allowed": false,
        "blocked_domains_allowed": false,
        "blocked_domains_source": "none"
      },
      "session_policy": {
        "state_scope": "stateless",
        "reuse_allowed": false,
        "pooling_mode": "none",
        "max_pages_default": 1,
        "max_parallel_items_default": 1,
        "request_overrides_allowed": false,
        "close_on_complete_default": true
      },
      "lifecycle": {
        "implicit_session_on_invoke": false,
        "explicit_close_supported": false,
        "explicit_list_supported": false,
        "session_handle_arg": null
      },
      "safety": {
        "ssrf_guard_required": true,
        "redirect_policy": "bounded",
        "prompt_injection_sanitizer_required": true,
        "sanitization": {
          "hidden_content_removed": true,
          "template_content_removed": true,
          "html_comments_removed": true,
          "zero_width_chars_removed": true,
          "script_style_noise_removed": true,
          "raw_payload_quarantined": true
        },
        "raw_payload_chat_visible": false
      },
      "evidence_packaging": {
        "include_content_excerpt": true,
        "include_source_url": true,
        "include_status": true,
        "include_redirect_status": true,
        "include_fetch_mode": true,
        "include_extraction_type": true,
        "include_quality_flags": true,
        "include_content_variants": true,
        "include_structured_artifacts": true,
        "include_discovery_artifacts": true,
        "include_error_envelope": true,
        "include_resource_metadata": false,
        "include_artifact_refs": false,
        "allowed_artifact_kinds": [
          "fit_markdown",
          "markdown_with_citations",
          "references_markdown",
          "table_summary",
          "link_summary",
          "media_summary",
          "page_metadata_summary"
        ]
      },
      "quality_classification": {
        "classifier": "tool_result_quality_v1",
        "status_fields": ["status", "status_code", "http_status"],
        "content_fields": [
          "content",
          "text",
          "summary",
          "body",
          "markdown",
          "raw_markdown",
          "markdown_with_citations",
          "fit_markdown",
          "extracted_content",
          "excerpt"
        ],
        "blocked_status_codes": [401, 403, 407, 429, 444, 500, 502, 503, 504],
        "retryable_status_codes": [403, 407, 429, 444, 500, 502, 503, 504],
        "blocked_error_fragments": [
          "anti_bot_challenge",
          "policy_denied",
          "access denied",
          "captcha",
          "missing_credentials"
        ],
        "proxy_error_fragments": [
          "net::err_proxy",
          "net::err_tunnel",
          "connection refused",
          "connection reset",
          "connection timed out",
          "failed to connect",
          "could not resolve proxy"
        ],
        "blocked_text_fragments": [
          "captcha",
          "unusual traffic",
          "access denied",
          "are you a human",
          "confirm this search was made by a human",
          "login required",
          "sign in to continue"
        ],
        "needs_dynamic_text_fragments": [
          "enable javascript",
          "requires javascript",
          "turn on javascript",
          "javascript is disabled"
        ],
        "low_signal_text_fragments": [
          "no results",
          "nothing found",
          "no relevant",
          "empty result",
          "returned low-signal",
          "limited information"
        ],
        "irrelevant_text_fragments": [
          "irrelevant",
          "off topic",
          "unrelated result",
          "not related"
        ],
        "proxy_metadata_fields": ["proxy", "proxy_url", "proxy_used", "proxy_rotator"],
        "min_partial_content_chars": 80,
        "min_usable_content_chars": 240,
        "emit_on_normalized_result": true
      },
      "quality_lanes": [
        "usable",
        "partial",
        "low_signal",
        "irrelevant_or_off_topic",
        "blocked",
        "needs_js",
        "needs_dynamic",
        "absent"
      ],
      "visibility": {
        "raw_payload_chat_visible": false,
        "tool_trace_chat_visible": false,
        "final_answer_requires_synthesis": true
      }
    },
