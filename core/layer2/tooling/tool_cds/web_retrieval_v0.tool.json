{
  "version": "tool_cd_web_retrieval_v0",
  "source": "scrapling_pattern_assimilation_v0",
  "contracts": [
    {
      "tool_id": "web_search",
      "capability_family": "web_retrieval",
      "required_args": ["query"],
      "aliases": ["web_lookup", "browse_web"],
      "retrieval": {
        "mode": "search",
        "supports_bulk": false,
        "max_bulk_items": 1,
        "cost_tier": "low",
        "requires_network": true
      },
      "extraction": {
        "default_type": "markdown",
        "allowed_types": ["markdown", "html", "text"],
        "selector_hint_allowed": true,
        "main_content_only_default": true,
        "max_chars": 12000
      },
      "readiness": {
        "supported_fields": ["timeout_ms"],
        "default_timeout_ms": 30000,
        "dynamic_page_allowed": false
      },
      "resource_policy": {
        "disable_resources_allowed": false,
        "block_ads_allowed": false,
        "blocked_domains_allowed": false
      },
      "session_policy": {
        "state_scope": "stateless",
        "reuse_allowed": false,
        "pooling_mode": "none",
        "max_pages_default": 1,
        "max_parallel_items_default": 1,
        "request_overrides_allowed": false,
        "close_on_complete_default": true
      },
      "safety": {
        "ssrf_guard_required": true,
        "redirect_policy": "bounded",
        "prompt_injection_sanitizer_required": true,
        "sanitization": {
          "hidden_content_removed": true,
          "template_content_removed": true,
          "html_comments_removed": true,
          "zero_width_chars_removed": true,
          "script_style_noise_removed": true,
          "raw_payload_quarantined": true
        },
        "raw_payload_chat_visible": false
      },
      "evidence_packaging": {
        "include_content_excerpt": true,
        "include_source_url": true,
        "include_status": true,
        "include_fetch_mode": true,
        "include_extraction_type": true,
        "include_quality_flags": true
      },
      "quality_classification": {
        "classifier": "tool_result_quality_v1",
        "status_fields": ["status", "status_code", "http_status"],
        "content_fields": ["content", "text", "summary", "body", "markdown", "excerpt"],
        "blocked_status_codes": [401, 403, 407, 429, 444, 500, 502, 503, 504],
        "retryable_status_codes": [403, 407, 429, 444, 500, 502, 503, 504],
        "blocked_error_fragments": [
          "anti_bot_challenge",
          "policy_denied",
          "access denied",
          "captcha",
          "missing_credentials"
        ],
        "blocked_text_fragments": [
          "captcha",
          "unusual traffic",
          "access denied",
          "are you a human",
          "confirm this search was made by a human",
          "login required",
          "sign in to continue"
        ],
        "needs_dynamic_text_fragments": [
          "enable javascript",
          "requires javascript",
          "turn on javascript",
          "javascript is disabled"
        ],
        "low_signal_text_fragments": [
          "no results",
          "nothing found",
          "no relevant",
          "empty result",
          "returned low-signal",
          "limited information"
        ],
        "irrelevant_text_fragments": [
          "irrelevant",
          "off topic",
          "unrelated result",
          "not related"
        ],
        "proxy_metadata_fields": ["proxy", "proxy_url", "proxy_used", "proxy_rotator"],
        "min_partial_content_chars": 80,
        "min_usable_content_chars": 240,
        "emit_on_normalized_result": true
      },
      "quality_lanes": [
        "usable",
        "partial",
        "low_signal",
        "irrelevant_or_off_topic",
        "blocked",
        "needs_js",
        "needs_dynamic",
        "absent"
      ],
      "visibility": {
        "raw_payload_chat_visible": false,
        "tool_trace_chat_visible": false,
        "final_answer_requires_synthesis": true
      }
    },
