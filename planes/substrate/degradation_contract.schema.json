{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protheus.ai/schemas/degradation_contract.schema.json",
  "title": "DegradationContract",
  "type": "object",
  "required": ["contract_id", "fallbacks"],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "fallbacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "trigger", "policy"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "trigger": { "type": "string" },
          "policy": { "type": "string" },
          "max_error_bound": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
