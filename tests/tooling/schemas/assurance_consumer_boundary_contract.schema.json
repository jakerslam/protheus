{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infring.local/schemas/assurance_consumer_boundary_contract.schema.json",
  "title": "Assurance Consumer Boundary Contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "schema_version", "owner", "global_rules", "consumers"],
  "properties": {
    "type": { "const": "assurance_consumer_boundary_contract" },
    "schema_version": { "type": "integer", "const": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "global_rules": {
      "type": "object",
      "required": [
        "assurance_owns_evidence_truth",
        "consumers_may_cache_projection_only",
        "consumers_must_reference_assurance_artifacts",
        "consumers_must_not_recompute_verdicts",
        "consumers_must_not_auto_apply_patches",
        "raw_assurance_details_require_detail_ref"
      ],
      "properties": {
        "assurance_owns_evidence_truth": { "const": true },
        "consumers_must_not_recompute_verdicts": { "const": true },
        "consumers_must_not_auto_apply_patches": { "const": true }
      }
    },
    "consumers": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "domain",
          "allowed_actions",
          "forbidden_actions",
          "required_fields_when_consuming",
          "projection_contract",
          "todo_id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["consumer.orchestration", "consumer.shell", "consumer.gateway", "consumer.kernel"]
          },
          "allowed_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_fields_when_consuming": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "projection_contract": { "type": "string", "minLength": 1 },
          "todo_id": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
