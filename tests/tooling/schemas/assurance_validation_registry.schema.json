{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infring.local/schemas/assurance_validation_registry.schema.json",
  "title": "Assurance Validation Registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "schema_version", "owner", "registry_policy", "lifecycle_policy", "entries"],
  "properties": {
    "type": { "const": "assurance_validation_registry" },
    "schema_version": { "type": "integer", "const": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "status": { "type": "string" },
    "updated_at": { "type": "string" },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "registry_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["allowed_validation_kinds", "allowed_lifecycle_states", "harness_only_rule"]
    },
    "lifecycle_policy": {
      "type": "object",
      "required": ["experimental", "advisory", "release_gate", "retirement_candidate", "retired"]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "domain",
          "validation_kind",
          "lifecycle_state",
          "signal_class",
          "authority_class",
          "owner_of_truth",
          "source_refs",
          "evidence_output",
          "self_enforcing",
          "harness_only"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "domain": { "const": "validation" },
          "validation_kind": {
            "type": "string",
            "enum": [
              "test_suite",
              "eval_suite",
              "benchmark",
              "conformance_guard",
              "regression_suite",
              "release_proof_check",
              "score_input",
              "harness_only"
            ]
          },
          "lifecycle_state": {
            "type": "string",
            "enum": ["experimental", "advisory", "release_gate", "retirement_candidate", "retired"]
          },
          "signal_class": {
            "type": "string",
            "enum": ["hard_gate", "advisory", "diagnostic"]
          },
          "authority_class": {
            "type": "string",
            "enum": ["controlled_validation", "harness_only"]
          },
          "owner_of_truth": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_output": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "self_enforcing": { "type": "boolean" },
          "harness_only": { "type": "boolean" },
          "retirement_criteria": { "type": "object" },
          "retirement_action": { "type": "string" },
          "strengthen_signal": { "type": "string" }
        }
      }
    }
  }
}
