    "fail_closed_policy_hooks",
    "receipt_schema_helpers",
    "circuit_breaker_behavior",
    "quarantine_hooks"
  ],
  "required_scenarios": [
    "process_never_starts",
    "starts_then_hangs",
    "invalid_schema_response",
    "response_too_large",
    "repeated_flapping"
  ],
  "production_gateway_targets": [
    "ollama",
    "llama_cpp",
    "mcp_baseline",
    "otlp_exporter",
    "durable_memory_local"
  ],
  "support_level_contract": {
    "experimental": {
      "required_checklist_keys": [
        "health_checks",
        "chaos_scenarios",
        "fallback_degradation_declaration",
        "receipt_completeness",
        "recovery_bounds"
