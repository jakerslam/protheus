{
  "type": "assurance_validation_registry",
  "schema_version": 1,
  "owner": "kernel/assurance",
  "status": "initial_seed",
  "updated_at": "2026-04-29",
  "policy_refs": [
    "docs/workspace/assurance_plane_policy.md",
    "docs/workspace/assurance_evidence_envelope_contract.md",
    "tests/tooling/config/test_maturity_registry.json"
  ],
  "registry_policy": {
    "allowed_validation_kinds": [
      "test_suite",
      "eval_suite",
      "benchmark",
      "conformance_guard",
      "regression_suite",
      "release_proof_check",
      "score_input",
      "harness_only"
    ],
    "allowed_lifecycle_states": [
      "experimental",
      "advisory",
      "release_gate",
      "retirement_candidate",
      "retired"
    ],
    "required_for_non_harness_entries": [
      "domain",
      "validation_kind",
      "lifecycle_state",
      "signal_class",
      "authority_class",
      "evidence_output",
      "owner_of_truth"
    ],
    "temporary_entry_requirements": [
      "retirement_criteria",
      "retirement_action",
      "strengthen_signal"
    ],
    "harness_only_rule": "Harness-only entries may execute validation but must not be treated as behavioral truth, release truth, or scorecard input without a referenced validation entry."
  },
  "lifecycle_policy": {
    "experimental": "Check is being shaped and may not block by itself.",
    "advisory": "Check can produce review or issue-candidate signals but cannot block by itself.",
    "release_gate": "Check can block release, promotion, or unsafe operation through Governance.",
    "retirement_candidate": "Check has met or is near declared retirement criteria and should emit cleanup work instead of becoming permanent scaffolding.",
    "retired": "Check is no longer active; retained only for historical reference."
  },
  "entries": [
    {
      "id": "validation.rust_core_regressions",
      "domain": "validation",
      "validation_kind": "regression_suite",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "core/** Rust tests",
      "source_refs": [
        "core/**/tests",
        "core/** #[test] modules",
        "cargo:v8-runtime-proof"
      ],
      "evidence_output": [
        "cargo test output",
        "core/local/artifacts/*runtime_proof*"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Controlled Kernel/Core regression proof. Cargo is the harness; the Rust checks are the validation truth."
    },
    {
      "id": "validation.eval_quality",
      "domain": "validation",
      "validation_kind": "eval_suite",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "Assurance Validation eval definitions",
      "source_refs": [
        "validation/evals/config/eval_quality_thresholds.json",
        "tests/tooling/fixtures/eval_gold_dataset_seed.jsonl",
        "tests/tooling/schemas/eval_gold_dataset.schema.json",
        "ops:eval:quality:gate:v1",
        "ops:eval:regression:guard"
      ],
      "evidence_output": [
        "core/local/artifacts/*eval*",
        "local/workspace/reports/*EVAL*"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Eval scoring belongs to Validation; Orchestration may trigger or consume results but does not own score truth."
    },
    {
      "id": "validation.public_benchmark_harness",
      "domain": "validation",
      "validation_kind": "benchmark",
      "lifecycle_state": "advisory",
      "signal_class": "advisory",
      "authority_class": "controlled_validation",
      "owner_of_truth": "validation/benchmarks",
      "source_refs": [
        "benchmarks/public_harness/run_public_harness.ts",
        "ops:benchmark:public-harness",
        "validation/benchmarks/policies/benchmark_regression_budgets.json"
      ],
      "evidence_output": [
        "core/local/artifacts/*benchmark*"
      ],
      "self_enforcing": false,
      "harness_only": false,
      "promotion_rule": "Governance may promote configured budget breaches to hard_gate after thresholds are declared in release or boundedness budgets."
    },
    {
      "id": "validation.architecture_conformance",
      "domain": "validation",
      "validation_kind": "conformance_guard",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "architecture policy guards",
      "source_refs": [
        "ops:arch:governance",
        "ops:nexus:governance",
        "ops:cross-layer-import:guard",
        "ops:orchestration:ts-boundary:guard"
      ],
      "evidence_output": [
        "core/local/artifacts/*boundary*",
        "core/local/artifacts/*nexus*",
        "local/workspace/reports/*BOUNDARY*",
        "local/workspace/reports/*NEXUS*"
      ],
      "self_enforcing": true,
      "harness_only": false
    },
    {
      "id": "validation.shell_projection_conformance",
      "domain": "validation",
      "validation_kind": "conformance_guard",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "Shell projection policies and guards",
      "source_refs": [
        "ops:shell:projection:guard",
        "ops:shell:ui-message-contract:guard",
        "ops:shell:truth-leak:guard",
        "docs/workspace/shell_ui_projection_policy.md"
      ],
      "evidence_output": [
        "core/local/artifacts/shell_*_current.json",
        "local/workspace/reports/SHELL_*_CURRENT.md"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Shell may display Assurance results but this entry proves Shell cannot infer readiness or health truth."
    },
    {
      "id": "validation.gateway_boundary_conformance",
      "domain": "validation",
      "validation_kind": "conformance_guard",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "Gateway and Conduit boundary policies",
      "source_refs": [
        "ops:gateway:interface:guard",
        "ops:gateway-boundary:guard",
        "ops:conduit:scrambler-posture:guard",
        "tests/tooling/config/gateway_manifest.json",
        "tests/tooling/config/gateway_graduation_manifest.json"
      ],
      "evidence_output": [
        "core/local/artifacts/*gateway*",
        "local/workspace/reports/*GATEWAY*"
      ],
      "self_enforcing": true,
      "harness_only": false
    },
    {
      "id": "validation.release_proof_pack",
      "domain": "validation",
      "validation_kind": "release_proof_check",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "release proof-pack assembly",
      "source_refs": [
        "ops:release:proof-pack",
        "ops:release:verdict",
        "ops:production-closure:gate",
        "validation/release_gates/config/release_gates.yaml"
      ],
      "evidence_output": [
        "core/local/artifacts/*proof_pack*",
        "core/local/artifacts/*release_verdict*",
        "client/runtime/local/state/release/scorecard/release_scorecard.json"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Governance consumes the proof pack for release verdicts; the controlled proof generation is Validation."
    },
    {
      "id": "validation.temporary_scaffolding_maturity",
      "domain": "validation",
      "validation_kind": "conformance_guard",
      "lifecycle_state": "retirement_candidate",
      "signal_class": "advisory",
      "authority_class": "controlled_validation",
      "owner_of_truth": "test maturity registry",
      "source_refs": [
        "tests/tooling/config/test_maturity_registry.json",
        "ops:test-maturity:registry:guard"
      ],
      "evidence_output": [
        "core/local/artifacts/test_maturity_registry_guard_current.json"
      ],
      "self_enforcing": false,
      "harness_only": false,
      "retirement_criteria": {
        "minimum_runs": 30,
        "success_rate_required": 0.98,
        "observation_window_days": 14,
        "consecutive_passes_required": 10,
        "max_regressions_allowed": 0
      },
      "retirement_action": "emit_retirement_backlog_item",
      "strengthen_signal": "If temporary scaffolding persists, the underlying runtime mechanism is weak and should be promoted into Kernel/Orchestration/Gateway authority instead of adding more test code."
    },
    {
      "id": "harness.tooling_registry_runner",
      "domain": "validation",
      "validation_kind": "harness_only",
      "lifecycle_state": "advisory",
      "signal_class": "diagnostic",
      "authority_class": "harness_only",
      "owner_of_truth": "tests/tooling runner infrastructure",
      "source_refs": [
        "tooling:list",
        "tooling:run",
        "tooling:profile",
        "tests/tooling/config/tooling_gate_registry.json"
      ],
      "evidence_output": [
        "tooling runner stdout/stderr and registered gate artifacts"
      ],
      "self_enforcing": false,
      "harness_only": true,
      "notes": "The runner proves execution plumbing only. The registered validation entry owns behavioral truth."
    },
    {
      "id": "validation.runtime_boundedness_budgets",
      "domain": "validation",
      "validation_kind": "benchmark",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "validation/benchmarks",
      "source_refs": [
        "validation/benchmarks/policies/runtime_boundedness_budgets.json",
        "validation/benchmarks/policies/benchmark_regression_budgets.json",
        "ops:boundedness:release-gate",
        "ops:release:scorecard:gate"
      ],
      "evidence_output": [
        "core/local/artifacts/runtime_boundedness_release_gate_current.json",
        "client/runtime/local/state/release/scorecard/release_scorecard.json"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Validation owns performance and boundedness budgets; tooling scripts execute the checks and write generated evidence."
    },
    {
      "id": "validation.runtime_proof_reality_regression",
      "domain": "validation",
      "validation_kind": "regression_suite",
      "lifecycle_state": "release_gate",
      "signal_class": "hard_gate",
      "authority_class": "controlled_validation",
      "owner_of_truth": "validation/regression",
      "source_refs": [
        "validation/regression/policies/runtime_empirical_coverage_policy.json",
        "validation/regression/policies/runtime_soak_scenarios_policy.json",
        "ops:runtime-proof:reality:guard",
        "ops:runtime-soak:scenarios:guard"
      ],
      "evidence_output": [
        "core/local/artifacts/runtime_proof_reality_guard_current.json",
        "core/local/artifacts/runtime_soak_scenarios_current.json"
      ],
      "self_enforcing": true,
      "harness_only": false,
      "notes": "Validation owns empirical coverage and soak scenario regression policy; runtime artifacts remain generated evidence."
    }
  ]
}
