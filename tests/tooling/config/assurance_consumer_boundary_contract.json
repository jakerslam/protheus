{
  "type": "assurance_consumer_boundary_contract",
  "schema_version": 1,
  "owner": "kernel/assurance",
  "status": "initial_seed",
  "updated_at": "2026-04-29",
  "policy_refs": [
    "docs/workspace/assurance_plane_policy.md",
    "docs/workspace/orchestration_ownership_policy.md",
    "docs/workspace/gateway_ingress_egress_policy.md",
    "docs/workspace/shell_ui_projection_policy.md",
    "docs/workspace/shell_ui_message_detail_contract.md"
  ],
  "global_rules": {
    "assurance_owns_evidence_truth": true,
    "consumers_may_cache_projection_only": true,
    "consumers_must_reference_assurance_artifacts": true,
    "consumers_must_not_recompute_verdicts": true,
    "consumers_must_not_auto_apply_patches": true,
    "raw_assurance_details_require_detail_ref": true
  },
  "consumers": [
    {
      "id": "consumer.orchestration",
      "domain": "surface/orchestration",
      "allowed_actions": [
        "request_validation_run",
        "consume_verdict_summary",
        "consume_issue_candidate_summary",
        "adapt_plan_from_assurance_signal",
        "request_bounded_diagnostic"
      ],
      "forbidden_actions": [
        "own_eval_definition",
        "own_release_gate_definition",
        "own_scorecard_truth",
        "waive_assurance_gate",
        "rewrite_assurance_evidence",
        "auto_apply_patch_from_assurance"
      ],
      "required_fields_when_consuming": [
        "assurance_artifact_ref",
        "signal_class",
        "authority_class",
        "generated_at",
        "freshness_status"
      ],
      "projection_contract": "Orchestration consumes Assurance as planning/recovery input. It may trigger checks or diagnostics but cannot own eval scoring, release gates, or scorecard truth.",
      "todo_id": "ASSURANCE-021"
    },
    {
      "id": "consumer.shell",
      "domain": "client/runtime/systems/ui",
      "allowed_actions": [
        "display_assurance_summary",
        "display_signal_class",
        "display_freshness_status",
        "open_detail_ref",
        "collect_operator_ack_or_review_request"
      ],
      "forbidden_actions": [
        "infer_health_truth",
        "infer_release_readiness",
        "branch_on_raw_assurance_payload",
        "cache_full_assurance_evidence",
        "waive_assurance_gate",
        "route_around_assurance_verdict"
      ],
      "required_fields_when_consuming": [
        "summary",
        "signal_class",
        "status",
        "freshness_status",
        "detail_ref"
      ],
      "projection_contract": "Shell displays bounded Assurance projections and lazy detail refs. It never infers readiness, health, release posture, or policy truth.",
      "todo_id": "ASSURANCE-022"
    },
    {
      "id": "consumer.gateway",
      "domain": "adapters/runtime + gateway routes",
      "allowed_actions": [
        "expose_bounded_assurance_summary_route",
        "expose_assurance_detail_ref_route",
        "submit_eval_or_issue_input_through_approved_route",
        "enforce_payload_budget",
        "enforce_scrambler_posture"
      ],
      "forbidden_actions": [
        "decide_assurance_verdict",
        "downgrade_signal_class",
        "expand_raw_evidence_by_default",
        "waive_gate",
        "mutate_assurance_artifact"
      ],
      "required_fields_when_consuming": [
        "route_id",
        "assurance_artifact_ref",
        "bounded_projection",
        "detail_ref",
        "receipt_or_audit_ref"
      ],
      "projection_contract": "Gateway can expose bounded routes for Assurance summaries and details, but verdict ownership remains in Assurance Governance.",
      "todo_id": "ASSURANCE-023"
    },
    {
      "id": "consumer.kernel",
      "domain": "core/**",
      "allowed_actions": [
        "expose_deterministic_fact",
        "expose_receipt",
        "expose_invariant_result",
        "expose_authorized_diagnostic_hook",
        "enforce_kernel_policy"
      ],
      "forbidden_actions": [
        "own_fuzzy_eval_scoring",
        "own_adaptive_eval_interpretation",
        "replace_assurance_governance_verdict",
        "silently_apply_self_modification",
        "treat_shell_telemetry_as_kernel_truth"
      ],
      "required_fields_when_consuming": [
        "receipt_hash_or_fact_id",
        "authority_class",
        "policy_scope",
        "source_artifact_ref"
      ],
      "projection_contract": "Kernel remains deterministic. It exposes facts, receipts, invariants, and authorized hooks; Assurance interprets cross-source confidence and Governance verdicts.",
      "todo_id": "ASSURANCE-024"
    }
  ]
}
