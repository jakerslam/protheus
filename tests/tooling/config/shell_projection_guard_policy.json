{
  "version": "2026-04-28",
  "policy_doc_path": "docs/workspace/shell_ui_projection_policy.md",
  "policy_doc_required_tokens": [
    "The Shell is a lens, not a mirror.",
    "The Shell default data shape is a projection, not a runtime object.",
    "raw tool inputs, raw tool outputs, trace bodies, plan graphs, or eval payloads",
    "Shell event payloads must be minimal and serializable"
  ],
  "scan_roots": [
    "client/runtime/systems/ui/infring_static/js/chat_store.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/040-models-and-cache.part02.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/050-conversation-cache.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/080-normalize-and-context.part02.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/090-init-hooks-and-shortcuts.part01.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/110-failover-and-health.part01.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/140-session-and-ws.part01.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat_agent_live_status_helpers.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat_context_helpers.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat_thinking_display_helpers.ts",
    "client/runtime/systems/ui/infring_static/js/pages/chat_ws_phase_event_helpers.ts",
    "client/runtime/systems/ui/infring_static/js/shell/app_store_shell_services.ts",
    "client/runtime/systems/ui/infring_static/js/svelte/chat_thread_shell_svelte_source.ts"
  ],
  "scan_extensions": [".ts", ".tsx", ".html", ".css"],
  "ignore_path_contains": [".bundle.ts", "/vendor/"],
  "forbidden_patterns": [
    {
      "id": "shell_app_store_raw_or_root_event_reference",
      "description": "Shell app-store snapshots/events must not retain raw/root store references.",
      "regex": "\\b(?:raw\\s*:\\s*store|root\\s*:\\s*rootState)\\b"
    },
    {
      "id": "shell_default_search_raw_tool_payload",
      "description": "Shell search must not stringify raw tool inputs/results.",
      "regex": "String\\(tool\\.(?:input|result)\\)"
    },
    {
      "id": "shell_chat_store_full_filtered_source_retention",
      "description": "The Svelte chat store must not retain the full filtered message source as Shell-owned state.",
      "regex": "lastFilteredMessageSource\\s*=\\s*Array\\.isArray\\(filteredMessages\\)\\s*\\?\\s*filteredMessages"
    },
    {
      "id": "shell_conversation_cache_deep_clone",
      "description": "Conversation cache sanitization must not deep-clone full message objects.",
      "regex": "JSON\\.parse\\(JSON\\.stringify\\(msg\\)\\)"
    },
    {
      "id": "shell_conversation_cache_full_state_persist",
      "description": "Shell localStorage must not persist the full conversation cache object.",
      "regex": "localStorage\\.setItem\\(this\\.conversationCacheKey,\\s*JSON\\.stringify\\(this\\.conversationCache\\s*\\|\\|\\s*\\{\\}\\)\\)"
    },
    {
      "id": "shell_window_full_cache_mirror",
      "description": "Window globals must not mirror full conversation cache state.",
      "regex": "window\\.__infringChatCache\\s*=\\s*this\\.conversationCache"
    },
    {
      "id": "shell_window_cache_projection_mirror",
      "description": "Window globals must not mirror conversation cache projections; use bounded persisted preview cache or store-owned projections instead.",
      "regex": "window\\.__infringChatCacheProjection"
    },
    {
      "id": "shell_normalized_full_messages_cache",
      "description": "Shell session cache must not store JSON-cloned normalized full message arrays.",
      "regex": "messages:\\s*JSON\\.parse\\(JSON\\.stringify\\(normalized\\s*\\|\\|\\s*\\[\\]\\)\\)"
    },
    {
      "id": "shell_tool_raw_payload_row_retention",
      "description": "Default message rows must not retain raw tool input/result fields.",
      "regex": "\\b(?:input|result):\\s*t\\.(?:input|result)\\s*\\|\\|\\s*''"
    },
    {
      "id": "shell_tool_expanded_raw_payload_render",
      "description": "Collapsed default tool cards must move raw input/result rendering behind lazy detail fetches.",
      "regex": "\\b(?:tool|t|row|card|candidate|prior|next)\\.(?:input|result)\\b|\\b(?:input|result):\\s*(?:t|tool|row)\\.(?:input|result)\\b",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_message_normalization_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_message_preview_map_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_response_tool_payload_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_tool_card_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_tool_label_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_agent_message_dedupe_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_source_trace_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/170-grouping-and-day-map.part01.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/190-drawer-and-queue.part02.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/190-drawer-and-queue.part03.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/195-structured-tool-cards.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/215-rendering-and-metadata-upgrades.ts"
      ]
    },
    {
      "id": "shell_phase_status_fallback_text",
      "description": "Shell must not author fallback workflow status text; backend/orchestration status projections must supply display labels.",
      "regex": "Waiting for workflow completion\\.\\.\\."
    },
    {
      "id": "shell_phase_detail_label_inference",
      "description": "Shell must not infer workflow phase labels from raw detail fields; it should render backend/orchestration status projection labels.",
      "regex": "var\\s+phaseDetailText\\s*=\\s*String\\(data\\s*&&\\s*data\\.detail\\s*\\?\\s*data\\.detail\\s*:\\s*''\\)\\.trim\\(\\)"
    },
    {
      "id": "shell_phase_detail_status_fallback",
      "description": "Shell must not promote raw phase detail text into status candidates; it should consume display_label/status_text from orchestration projection envelopes.",
      "regex": "\\|\\|\\s*phaseDetailText\\s*\\|\\|"
    },
    {
      "id": "shell_agent_activity_literal_transition",
      "description": "Shell must not author agent activity truth from literal working/typing/idle transitions; it should render backend/core activity projections or explicitly optimistic state.",
      "regex": "setAgentLiveActivity\\([^\\n]*(?:'working'|'typing'|'idle')\\)"
    },
    {
      "id": "shell_live_activity_missing_projection_metadata",
      "description": "Shell live activity rows must preserve source/optimistic projection metadata instead of anonymous state/timestamp objects.",
      "regex": "agentLiveActivity\\s*=\\s*Object\\.assign\\([^\\n]*\\n\\s*\\[id\\]:\\s*\\{\\s*\\n\\s*state:\\s*normalized,\\s*\\n\\s*ts:\\s*(?:Date\\.now\\(\\)|ts)\\s*\\n\\s*\\}",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/app_agent_preview_helpers.ts"
      ]
    },
    {
      "id": "shell_slash_direct_workspace_endpoint",
      "description": "Slash commands must route workspace reads/exports through the agent/control-plane path, not direct shell endpoint execution.",
      "regex": "/api/agents/[^'\\\"]+/(?:file/read|folder/export)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_command_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/120-slash-and-agent-select.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts"
      ]
    },
    {
      "id": "shell_slash_direct_status_endpoint",
      "description": "Slash commands must not fetch authoritative runtime/network status directly into shell-authored chat text.",
      "regex": "InfringAPI\\.(?:get|post)\\('(?:/api/status|/api/budget|/api/network/status|/api/a2a/agents)'",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_command_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/120-slash-and-agent-select.ts"
      ]
    },
    {
      "id": "shell_slash_direct_session_model_authority",
      "description": "Slash commands must not directly reset/compact sessions or coordinate model switches from shell.",
      "regex": "(?:session/compact|session/reset|switchAgentModelWithGuards|resolveModelCatalogOption|modelCatalogRows\\(\\))",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_command_helpers.ts"
      ]
    },
    {
      "id": "shell_slash_direct_ws_command_authority",
      "description": "Slash commands must not send raw websocket command authority from shell.",
      "regex": "InfringAPI\\.wsSend\\(\\{\\s*type:\\s*['\\\"]command['\\\"]",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_command_helpers.ts"
      ]
    },
    {
      "id": "shell_slash_visible_system_message",
      "description": "Slash command helpers must not inject shell-authored visible system chat rows.",
      "regex": "pushSystemMessage\\(",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_command_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_memprobe_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_alias_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_apikey_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_telemetry_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_proactive_telemetry_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_model_failover_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_send_payload_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_ws_error_event_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_ws_misc_event_helpers.ts"
      ]
    },
    {
      "id": "shell_slash_direct_telemetry_packaging",
      "description": "Telemetry slash helpers must not fetch/package authoritative continuity or telemetry reports directly into chat.",
      "regex": "(?:/api/continuity/pending|fetchProactiveTelemetryAlerts\\(false\\))",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_telemetry_helpers.ts"
      ]
    },
    {
      "id": "shell_slash_apikey_direct_model_discovery",
      "description": "API-key slash helper must route model/provider discovery through agent/control-plane coordination, not direct shell discovery and visible prose.",
      "regex": "(?:/api/models/discover|describeModelDiscoveryResult|injectNoModelsGuidance)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_slash_apikey_helpers.ts"
      ]
    },
    {
      "id": "shell_chat_model_guidance_direct_discovery_or_visible_prose",
      "description": "Chat model guidance must not run model discovery or inject no-models recovery prose into chat.",
      "regex": "(?:/api/models/discover|pushAgentMessageDeduped\\(|system_origin:\\s*['\\\"]models:no_models_available['\\\"]|OpenRouter keys|OpenAI keys|Anthropic keys)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_model_guidance_helpers.ts"
      ]
    },
    {
      "id": "shell_model_failover_direct_selection_authority",
      "description": "Model failover helpers must not select fallback models, inject visible recovery prose, or retry requests automatically from shell.",
      "regex": "(?:collectFailoverModelCandidates|retry_from_failover|model:auto-recover|retrying the last request automatically)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_model_failover_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/100-context-window-and-budget.ts"
      ]
    },
    {
      "id": "shell_agent_selection_direct_session_reset",
      "description": "Agent-selection lifecycle must not directly reset runtime sessions from shell.",
      "regex": "session/reset",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_agent_selection_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/120-slash-and-agent-select.ts"
      ]
    },
    {
      "id": "shell_agent_selection_visible_welcome_message",
      "description": "Agent-selection lifecycle must not inject welcome/help text as visible system chat.",
      "regex": "(?:chat:welcome|Welcome to Infring Chat)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_agent_selection_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/120-slash-and-agent-select.ts"
      ]
    },
    {
      "id": "shell_notice_projection_system_role",
      "description": "Shell notice projections must use role notice, not visible system chat role.",
      "regex": "role:\\s*['\\\"]system['\\\"]",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_notice_message_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_model_usage_notice_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_fresh_init_flow_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_session_load_helpers.ts"
      ]
    },
    {
      "id": "shell_prompt_queue_direct_prompt_execution",
      "description": "Prompt queue helpers must not directly execute queued user prompts or steer injections; they may only project/edit local composer state until backend queue authority is wired.",
      "regex": "(?:_sendPayload\\(|InfringAPI\\.wsSend\\(|/api/agents/[^'\\\"]+/message|steer_injected|from_queue)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_prompt_queue_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_queue_processing_helpers.ts"
      ]
    },
    {
      "id": "shell_terminal_direct_execution_authority",
      "description": "Terminal session helpers must not create/retry sessions, choose websocket/HTTP terminal execution, or synthesize terminal result events from shell.",
      "regex": "(?:/api/terminal/(?:sessions|queue)|/api/agents/[^'\\\"]+/terminal|InfringAPI\\.wsSend\\(\\{\\s*type:\\s*['\\\"]terminal['\\\"]|type:\\s*['\\\"]terminal_(?:output|error)['\\\"]|session_not_found)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_terminal_session_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/199-system-terminal-helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/200-send-pipeline.part01.ts"
      ]
    },
    {
      "id": "shell_terminal_recovery_summary_packaging",
      "description": "Terminal websocket renderers must not package tool summaries or recovery hints as shell-authored transcript rows.",
      "regex": "(?:Tool summary|Recovery hints|deterministic hints|toolSummary(?:ModelLabel|FallbackLines|OutputPreview)\\()",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_ws_terminal_event_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/160-runtime-events-and-render.part01.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_tool_summary_helpers.ts"
      ]
    },
    {
      "id": "shell_tool_completion_raw_result_authority",
      "description": "Shell must not infer authoritative tool completion or status from raw tool result text.",
      "regex": "(?:responseHasAuthoritativeToolCompletion[\\s\\S]*?rows\\.some\\(function\\(tool\\)|txt\\.indexOf\\(|tool\\.result\\.length\\s*>)",
      "scan_roots": [
        "client/runtime/systems/ui/infring_static/js/pages/chat_assistant_text_signal_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_tool_label_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat_tool_card_helpers.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/190-drawer-and-queue.part02.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/190-drawer-and-queue.part03.ts",
        "client/runtime/systems/ui/infring_static/js/pages/chat.ts.parts/210-scroll-hover-sanitize.part02.ts"
      ]
    }
  ],
  "allowed_legacy_occurrences": {}
}
