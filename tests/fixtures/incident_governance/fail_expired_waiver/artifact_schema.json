        "trigger": "string"
      }
    },
    "corrective_actions": {
      "type": "object",
      "required_fields": {
        "actions": "array",
        "owners": "array"
      }
    },
    "evidence_bundle": {
      "type": "object",
      "required_fields": {
        "artifact_paths": "array",
        "generated_at": "string"
      }
    },
    "owner_signoff": {
      "type": "object",
      "required_fields": {
