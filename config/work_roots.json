{
  "version": "1.0",
  "description": "Work roots for sensory capture layer",
  "roots": [
    "/Users/jay/.openclaw/workspace",
    "/Users/jay/projects",
    "/Users/jay/Documents/Protheus",
    "/Users/jay/Documents/Project management"
  ],
  "ignore_patterns": [
    "node_modules",
    ".git",
