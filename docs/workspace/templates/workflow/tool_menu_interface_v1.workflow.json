{
  "name": "example_tool_menu_interface_v1",
  "workflow_type": "hard_agent_workflow",
  "default": false,
  "description": "Example assistant toolbox workflow. The workflow only presents menus or payload fields; final chat text is authored by the LLM.",
  "stages": [
    "gate_1_work_category_menu",
    "gate_2_tool_family_menu",
    "gate_3_tool_menu",
    "gate_4_request_payload_input",
    "gate_4b_tool_confirmation_menu",
    "gate_5_post_tool_menu",
    "gate_6_llm_final_output"
  ],
  "final_response_policy": "llm_authored_only_no_system_injection",
  "gate_contract": "tool_menu_interface_v1",
  "tool_menu_interface_contract": {
    "version": "tool_menu_interface_v1",
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "system_injected_chat_text_allowed": false,
    "gate_shapes_allowed": [
      "multiple_choice",
      "text_input"
    ],
    "gate_order": [
      "gate_1_work_category_menu",
      "gate_2_tool_family_menu",
      "gate_3_tool_menu",
      "gate_4_request_payload_input",
      "gate_4b_tool_confirmation_menu",
      "gate_5_post_tool_menu",
      "gate_6_llm_final_output"
    ],
    "gates": {
      "gate_2_tool_family_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_3_tool_menu"
      },
      "gate_3_tool_menu": {
        "input_kind": "multiple_choice",
        "transition": "gate_4_request_payload_input"
      },
      "gate_4_request_payload_input": {
        "input_kind": "text_input",
        "transition": "gate_4b_tool_confirmation_menu"
      },
      "gate_4b_tool_confirmation_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "confirm",
            "label": "Confirm",
            "private_token": true,
            "visible_chat": false,
            "transition": "execute_tool"
          },
          {
            "key": "cancel",
            "label": "Cancel",
            "private_token": true,
            "visible_chat": false,
            "terminal_state": "cancelled"
          }
        ]
      },
      "gate_5_post_tool_menu": {
        "input_kind": "multiple_choice",
        "options": [
          {
            "key": "finish",
            "label": "Finish and synthesize",
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "another_tool",
            "label": "Another tool",
            "transition": "gate_2_tool_family_menu"
          }
        ]
      },
      "gate_6_llm_final_output": {
        "input_kind": "text_input",
        "final_authority": "llm_only",
        "final_output_contract": {
          "visible_chat_source": "llm_final_answer_only",
          "internal_streams": [
            "workflow_state",
            "agent_internal_notes",
            "tool_trace",
            "eval_trace"
          ],
          "chat_excludes": [
            "workflow_state",
            "agent_internal_notes",
            "tool_trace",
            "eval_trace",
            "prompt_analysis"
          ],
          "chat_requirement": "write only the final user-facing answer"
        }
      },
      "gate_1_work_category_menu": {
        "input_kind": "multiple_choice",
        "question": "What kind of work is this?",
        "submission_contract": {
          "visibility": "private_token_only",
          "accepted_outputs": [
            "Respond directly",
            "Planning from current context",
            "Category: <category>. Tool family: <family>. Tool: <catalog tool key>. Request payload: <JSON>."
          ],
          "forbidden_output_classes": [
            "choice_narration",
            "tool_recommendation_without_submission",
            "visible_chat_text"
          ],
          "chat_injection_allowed": false
        },
        "options": [
          {
            "key": "respond_directly",
            "label": "Respond directly",
            "private_token": true,
            "visible_chat": false,
            "has_tools": false,
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "planning_current_context",
            "label": "Planning from current context",
            "private_token": true,
            "visible_chat": false,
            "has_tools": false,
            "transition": "gate_6_llm_final_output"
          },
          {
            "key": "web_research",
            "label": "Web research",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "workspace_files",
            "label": "Workspace/files",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "code_execution_terminal",
            "label": "Code execution / terminal",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "agent_management",
            "label": "Agent management",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "memory_notes",
            "label": "Memory/notes",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          },
          {
            "key": "external_apps_integrations",
            "label": "External apps/integrations",
            "private_token": true,
            "visible_chat": false,
            "has_tools": true,
            "transition": "gate_2_tool_family_menu"
          }
        ]
      }
    },
    "private_tokens": [
      "confirm",
      "cancel",
      "respond_directly",
      "planning_current_context"
    ],
    "terminal_states": [
      "completed",
      "cancelled",
      "blocked",
      "failed"
    ],
    "declared_loopbacks": [
      {
        "from": "gate_5_post_tool_menu",
        "on": "another_tool",
        "to": "gate_2_tool_family_menu"
      }
    ],
    "llm_gate_instruction": "Private workflow gate submission only. Gate 1: `{gate_question}`. Pick one category: {category_options}. No-tool categories ({no_tool_categories}) go straight to final answer. Tool categories ({tool_bearing_categories}) must submit: `{tool_submission_format}`. Use exact catalog tool keys, e.g. `{example_tool_key}`. Do not narrate or say what you would choose. Visible chat is only Gate 6 final answer."
  }
}
