{
  "version": "web_research_retrieval_policy_v0",
  "kind": "orchestration_web_research_retrieval_policy",
  "authority": "orchestration",
  "client_runtime_role": "compatibility_or_projection_only_no_new_authority",
  "source_pattern_provenance": [
    "exa_advanced_search_surface",
    "tavily_map_crawl_capability_split",
    "jina_reader_search_plus_read",
    "firecrawl_search_result_scrape_merge",
    "firecrawl_url_hygiene_before_fetch_budget",
    "firecrawl_canonical_url_dedupe_before_fetch_budget",
    "firecrawl_crawler_filtering_and_metadata_signals",
    "firecrawl_link_filter_denial_reasons",
    "firecrawl_engine_quality_probe_before_render_budget",
    "firecrawl_unsupported_binary_lane_split",
    "firecrawl_parse_upload_as_no_browse_document_lane",
    "firecrawl_deep_research_gap_loop_without_final_format_hardcoding",
    "firecrawl_llmstxt_map_scrape_corpus_pack_without_output_shape_hardcoding",
    "firecrawl_async_map_crawl_status_projection",
    "firecrawl_high_volume_candidate_map_rerank_filter",
    "firecrawl_queue_backlog_lock_reconcile_lifecycle",
    "firecrawl_incremental_crawl_discovery_enqueue",
    "firecrawl_managed_search_index_modes",
    "firecrawl_precrawl_budgeted_index_backfill",
    "firecrawl_extract_dlq_terminal_projection",
    "firecrawl_browser_session_ttl_concurrency_claim_cleanup",
    "firecrawl_scrape_replay_before_interact",
    "firecrawl_browser_agent_snapshot_action_loop",
    "firecrawl_trace_zdr_sanitization"
  ],
  "selection_rule": "agent_or_policy_selects_from_user_intent_evidence_state_and_admitted_tool_capabilities_without_domain_or_prompt_hardcoding",
  "non_goals": [
    "do_not_place_new_retrieval_authority_under_client_runtime",
    "do_not_route_by_provider_specific_tool_name",
    "do_not_force_user_visible_answer_format",
    "do_not_add_domain_topic_or_golden_case_defaults"
  ],
  "strategy_menu": [
    "one_shot_search_pack",
    "prefetch_then_rank",
    "site_map_then_crawl",
    "search_plus_read",
    "breadth_first_site_slice",
    "depth_first_path_probe",
    "best_first_candidate_expansion"
  ],
  "site_corpus_pack": {
    "enabled": true,
    "source_pattern": "firecrawl_llmstxt_map_scrape_corpus_pack",
    "purpose": "When the user asks about a site, organization, docs set, or URL collection, retrieval may build a bounded corpus pack by mapping candidate URLs, scraping selected pages in batches, and packaging compact page summaries plus full-text refs for synthesis.",
    "pipeline": [
      "map_candidate_urls",
      "dedupe_and_limit_urls",
      "scrape_or_read_pages_in_batches",
      "derive_compact_page_descriptions_for_navigation",
      "store_full_text_as_internal_evidence_refs",
      "expose_ranked_compact_index_plus_detail_refs_to_synthesis"
    ],
    "budget_controls": {
      "default_max_urls": 50,
      "hard_max_urls": 500,
      "default_batch_size": 10,
      "cache_allowed_only_when_policy_and_privacy_permit": true
    },
    "artifact_contract": {
      "compact_index_fields": [
        "title",
        "locator",
        "short_description",
        "source_domain",
        "evidence_ref"
      ],
      "full_text_ref_fields": [
        "locator",
        "heading",
        "text_ref",
        "token_estimate",
        "freshness"
      ],
      "raw_full_text_chat_visible": false
    },
    "non_goals": [
      "do_not_force_llms_txt_as_user_visible_output",
      "do_not_hardcode_page_description_word_counts",
      "do_not_hardcode_model_selection",
      "do_not_cache_when_zero_retention_or_no_storage_policy_applies"
    ]
  },
  "web_research_broker": {
    "enabled": true,
    "primitive_id": "web_research",
    "authority": "orchestration_policy_declares_runtime_records",
    "purpose": "Expose a compact hidden broker report for provider attempts, recovery, evidence-pack quality, source-class coverage, and remaining gaps so synthesis can improve without provider-specific or domain-specific routes.",
    "lanes": [
      "query_planning",
      "provider_retrieval",
      "candidate_enrichment",
      "evidence_packaging",
      "coverage_review"
    ],
    "required_report_fields": [
      "retrieval_broker.lanes",
      "retrieval_broker.provider_attempts",
      "retrieval_broker.second_pass_recovery",
      "source_class_coverage",
      "evidence_pack_quality"
    ],
    "non_goals": [
      "do_not_force_visible_answer_format",
      "do_not_choose_providers_by_prompt_phrase",
      "do_not_treat_broker_diagnostics_as_citable_evidence"
    ]
  },
  "source_diversification": {
    "enabled": true,
    "purpose": "Prefer source-class and source-domain breadth when it helps the user's research objective, while allowing narrow lookups to complete with fewer classes.",
    "min_source_classes": 2,
    "preferred_source_classes": [
      "official_or_primary",
      "scholarly_or_research",
      "news_or_current",
      "independent_analysis",
      "general_web"
    ],
    "non_goals": [
      "do_not_require_every_source_class_for_every_question",
      "do_not_hardcode_domain_topics",
      "do_not_replace relevance_with_diversity"
    ]
  },
  "managed_search_index": {
    "enabled": true,
    "source_patterns": [
      "firecrawl_managed_search_index_modes",
      "firecrawl_precrawl_budgeted_index_backfill"
    ],
    "purpose": "Allow retrieval to use an admitted managed or local search index as one candidate-discovery lane when it can improve coverage, freshness, or source recall without making the index itself a source of truth.",
    "query_modes": [
      "hybrid",
      "keyword",
      "semantic",
      "bm25"
    ],
    "filter_axes": [
      "domain",
      "country",
      "language",
      "freshness",
      "device_or_render_profile"
    ],
    "result_signals": [
      "score",
      "bm25_rank",
      "vector_rank",
      "freshness_score",
      "quality_score",
      "last_crawled_at",
      "snippet"
    ],
    "backfill_policy": {
      "enabled": true,
      "purpose": "When a safe public corpus can be warmed in advance, allocate crawl/read budget by observed demand, source priority, and freshness needs, then publish only completed page refs into evidence packs.",
      "budget_axes": [
        "domain_priority",
        "page_event_count",
        "total_budget",
        "per_domain_budget",
        "resource_pressure"
      ],
      "non_goals": [
        "do_not_crawl_private_or_zero_retention_sources",
        "do_not_treat_cached_index_presence_as_evidence_sufficiency",
        "do_not_make_background_queue_metrics_chat_visible"
      ]
    },
    "failure_behavior": "index_service_unavailable_or_empty_results_becomes_an_empty_candidate_lane_with_internal_diagnostics; retrieval may still use other admitted lanes",
    "non_goals": [
      "do_not_replace_live_fetch_or_primary_source_reads_when_claim_validation_requires_page_context",
      "do_not_bind_policy_to_a_specific_index_provider",
      "do_not_make_index_scores_visible_answer_text",
      "do_not_prescribe_final_answer_format"
    ]
  },
  "iterative_gap_research_loop": {
    "enabled": true,
    "source_pattern": "firecrawl_deep_research_state_manager",
    "purpose": "For broad, current, comparative, or under-covered research, let retrieval learn from collected evidence, generate bounded follow-up lanes, and stop by sufficiency, depth, time, and explicit gap reasons rather than asking the user to narrow immediately.",
    "state_fields": [
      "original_user_goal",
      "current_research_topic",
      "seen_locators",
      "source_refs",
      "finding_refs",
      "coverage_gaps",
      "next_query_lanes",
      "depth",
      "elapsed_time",
      "failed_attempts"
    ],
    "loop_steps": [
      "generate_initial_discovery_lanes_from_user_goal",
      "retrieve_and_read_promising_candidates",
      "dedupe_seen_locators_before_spending_fetch_budget",
      "derive_coverage_gaps_from_evidence_not_provider_telemetry",
      "generate_specific_followup_lanes_from_gaps_and_findings",
      "stop_when_sufficient_or_when_budget_exhausted_with_recorded_gaps",
      "synthesize_only_from_the_collected_evidence_and_recorded_gaps"
    ],
    "budget_controls": {
      "default_depth": 2,
      "max_depth": 4,
      "default_parallel_query_lanes": 3,
      "max_parallel_query_lanes": 4,
      "reserve_final_synthesis_time": true,
      "max_failed_planning_attempts": 3
    },
    "non_goals": [
      "do_not_hardcode_final_report_format",
      "do_not_hardcode_model_selection",
      "do_not_make_all_questions_deep_research",
      "do_not_replace_user_goal_with_unrelated_followup_topics",
      "do_not_hide_followup_lanes_from_trace",
      "do_not_treat_activity_or_provider_logs_as_citable_evidence"
    ]
  },
  "evidence_pack_quality": {
    "enabled": true,
    "min_usable_items": 2,
    "min_source_domains": 2,
    "purpose": "Summarize whether the hidden evidence pack is absent, thin, low-confidence-only, or usable before final synthesis.",
    "non_goals": [
      "do_not_make_quality_metadata_visible_answer_text",
      "do_not_use_candidate_count_as_sufficiency",
      "do_not_prescribe_answer_shape"
    ]
  },
  "provider_result_envelope": {
    "purpose": "preserve safe provider metadata for ranking and synthesis calibration without exposing raw payloads to chat",
    "raw_payload_chat_visible": false,
    "sensitive_key_policy": "strip_known_sensitive_keys_recursively_and_quarantine_raw_payload",
    "search_metadata_fields": [
      "request_id",
      "resolved_search_type",
      "auto_prompt",
      "auto_date",
      "query",
      "provider_answer_candidate",
      "follow_up_questions",
      "image_results",
      "image_descriptions",
      "search_time_ms",
      "cost_summary",
      "provider_statuses"
    ],
    "result_metadata_fields": [
      "provider_score",
      "provider_rank",
      "title",
      "url",
      "published_date",
      "author",
      "summary",
      "text_excerpt",
      "raw_content_available",
      "raw_content_excerpt",
      "favicon",
      "highlights",
      "highlight_scores",
      "entities",
      "links",
      "image_links",
      "subpages"
    ]
  },
  "advanced_search_controls": {
    "authority": "adapter_owned_optional_request_fields_admitted_by_orchestration",
    "controls": [
      "source_class_or_category_hint",
      "search_depth_profile",
      "include_domains",
      "exclude_domains",
      "country_boost",
      "time_range",
      "start_published_date",
      "end_published_date",
      "start_crawl_date",
      "end_crawl_date",
      "exact_match",
      "include_images",
      "include_image_descriptions",
      "include_favicon",
      "include_raw_content",
      "extract_depth_profile",
      "extract_query_rerank",
      "output_content_format",
      "include_text",
      "exclude_text",
      "user_location",
      "additional_queries",
      "text_max_characters",
      "context_max_characters",
      "summary_query",
      "highlights_query",
      "highlights_max_characters",
      "freshness_max_age",
      "live_fetch_preference",
      "live_fetch_timeout_ms",
      "subpage_limit",
      "subpage_target_terms"
    ],
    "use_when": [
      "user_explicitly_requests_source_scope",
      "time_window_or_freshness_is_part_of_task",
      "evidence_state_requires_more_body_context",
      "known_promising_result_needs_subpage_expansion",
      "retrieval_quality_needs_source_class_balance"
    ]
  },
  "site_mapping_and_crawl": {
    "enabled": true,
    "purpose": "treat site mapping as URL discovery and crawling as selected content extraction",
    "map_before_crawl_when": [
      "the_user_supplies_a_site_or_url_and_asks_for_coverage",
      "search_identifies_a_promising_source_site_but_not_enough_specific_pages",
      "documentation_structure_or_site_organization_is_part_of_the_research_target",
      "evidence_coverage_is_weak_and_same_site_candidate_urls_may_fill_the_gap"
    ],
    "controls": [
      "root_url",
      "max_depth",
      "max_breadth",
      "limit",
      "instructions",
      "select_paths",
      "select_domains",
      "allow_external",
      "extract_depth_profile",
      "output_content_format"
    ],
    "projection_fields": [
      "base_url",
      "mapped_url_count",
      "crawled_page_count",
      "selected_path_patterns",
      "selected_domain_patterns",
      "external_link_policy",
      "crawl_depth",
      "crawl_breadth",
      "crawl_limit",
      "instruction_ref"
    ],
    "async_corpus_slice": {
      "source_pattern": "firecrawl_async_map_crawl_status_projection",
      "purpose": "For site-scale or corpus-scale research, discover candidate URLs first, select bounded crawl/read targets, and expose progress/result windows as internal artifacts before synthesis.",
      "steps": [
        "map_candidate_urls_from_index_sitemap_and_search",
        "dedupe_and_filter_by_domain_path_depth_robots_and_budget",
        "enqueue_or_run_selected_reads_with_concurrency_and_ttl_bounds",
        "return_status_projection_with_counts_expiry_next_cursor_and_warnings",
        "package_completed_pages_as_evidence_refs_before_final_synthesis"
      ],
      "status_values": [
        "queued",
        "scraping",
        "completed",
        "failed",
        "cancelled",
        "expired"
      ],
      "windowing_rules": [
        "status_projection_may_page_or_cursor_completed_documents",
        "projection_must_bound_bytes_and_item_count_per_window",
        "raw_queue_state_and_raw_payloads_are_not_chat_visible",
        "robots_or_low_coverage_warnings_are_quality_signals_not_final_answer_text"
      ],
      "high_volume_filtering": {
        "source_pattern": "firecrawl_high_volume_candidate_map_rerank_filter",
        "purpose": "When a site or URL-scope discovery pass produces too little coverage, broaden candidate discovery once, then rerank and filter before spending read/scrape budget.",
        "rules": [
          "do_not_treat_one_or_zero_mapped_urls_as_sufficient_for_site_scope_research",
          "broadening_may_remove_over_specific_search_terms_but_must_preserve_the_original_user_goal_as_context",
          "rerank_again_when_the_candidate_pool_is_large_enough_to_exceed_synthesis_or_fetch_budget",
          "record_candidate_counts_rejection_reasons_and_used_in_synthesis_flags"
        ],
        "non_goals": [
          "do_not_require_llm_query_rewrite_for_every_request",
          "do_not_prescribe_specific_thresholds_as_user_visible_behavior",
          "do_not_fetch_every_candidate_without_ranking"
        ]
      },
      "option_precedence": "explicit_user_or_workflow_options_override_agent_planned_options",
      "non_goals": [
        "do_not_make_natural_language_crawl_option_generation_required",
        "do_not_prescribe_visible_answer_format",
        "do_not_treat_async_handle_creation_as_evidence",
        "do_not_cache_or_reuse_private_or_zero_retention_corpora"
      ]
    }
  },
  "reader_page_conversion": {
    "enabled": true,
    "purpose": "turn promising search rows into processible page or document artifacts before synthesis when snippets are not enough",
    "convert_when": [
      "search_result_followup_fetch_when_matches",
      "broad_research_needs_body_evidence",
      "source_quality_or_claim_validation_requires_page_context",
      "search_rows_are_relevant_but_low_detail",
      "coverage_lane_has_candidates_but_no_evidence",
      "the_user_supplied_url_or_site_needs_content_not_just_structure"
    ],
    "skip_when": [
      "narrow_lookup_is_directly_supported_by_result_metadata",
      "candidate_is_duplicate_or_off_topic",
      "source_access_policy_or_budget_blocks_fetch",
      "candidate_content_type_belongs_to_a_non_web_document_or_media_lane"
    ],
    "artifact_variants": [
      "reader_content",
      "reader_markdown",
      "reader_text",
      "reader_html_excerpt",
      "reader_links_summary",
      "reader_images_summary",
      "reader_heading_chunks",
      "reader_screenshot_ref",
      "document_page_artifact"
    ],
    "readiness_states": [
      "html_ready",
      "visible_content_ready",
      "mutation_idle",
      "resource_idle",
      "media_idle",
      "network_idle",
      "intermediate_snapshot"
    ],
    "selector_controls": [
      "target_selector",
      "wait_for_selector",
      "remove_selector"
    ],
    "cache_admission": {
      "allow_cache_for_public_repeatable_reads": true,
      "disable_cache_when": [
        "cookies_or_private_state_present",
        "script_injection_or_viewport_override_present",
        "instructional_or_schema_transform_present",
        "explicit_no_cache_or_zero_tolerance",
        "intermediate_snapshot_without_final_readiness",
        "captcha_or_low_content_block_signal"
      ],
      "record_fields": [
        "cache_status",
        "cache_freshness_status",
        "cache_tolerance_ms",
        "cache_rejection_reason"
      ]
    }
  },
  "dynamic_interaction_lane": {
    "enabled": true,
    "source_patterns": [
      "firecrawl_browser_session_ttl_concurrency_claim_cleanup",
      "firecrawl_scrape_replay_before_interact",
      "firecrawl_browser_agent_snapshot_action_loop",
      "firecrawl_trace_zdr_sanitization"
    ],
    "purpose": "Use a bounded browser/session lane only when static fetch, reader conversion, or normal rendered fetch cannot produce usable evidence and the admitted tool capability allows interaction.",
    "activate_when": [
      "evidence_quality_flags_include_needs_interaction_or_needs_js",
      "user_or_workflow_explicitly_requests_page_interaction",
      "a_prior_page_read_has_replayable_context_and_the_missing_evidence_requires_stateful_interaction"
    ],
    "session_controls": [
      "bound_ttl_and_activity_ttl",
      "enforce_owner_and_concurrency_limits_before_creation",
      "retry_session_creation_with_short_backoff",
      "clean_up_remote_session_when_persistence_fails",
      "claim_destroyed_state_before_billing_or_final_cleanup",
      "record_activity_as_batched_internal_telemetry"
    ],
    "replay_controls": [
      "reconstruct_from_prior_scrape_or_read_context_when_available",
      "sanitize_replay_actions_before_execution",
      "clamp_wait_and_action_timeouts",
      "skip_output_only_replay_actions",
      "sync_to_one_foreground_content_page_before_interaction"
    ],
    "agent_loop_controls": [
      "start_from_current_url_and_accessibility_snapshot",
      "invalidate_element_refs_after_page_changes",
      "resnapshot_after_interactions",
      "bound_step_count_and_per_step_timeout",
      "block_new_tabs_or_out_of_scope_navigation_unless_explicitly_admitted",
      "return_extracted_evidence_or_action_result_not_raw_accessibility_tree"
    ],
    "privacy_controls": [
      "strip_query_and_fragment_from_trace_urls",
      "make_external_tracing_opt_in",
      "disable_external_tracing_for_zero_retention_or_private_contexts",
      "keep_debug_logs_internal_and_bounded"
    ],
    "non_goals": [
      "do_not_make_browser_interaction_the_default_retrieval_path",
      "do_not_bind_to_a_specific_browser_service_or_agent_model",
      "do_not_expose_cdp_urls_raw_stdout_or_accessibility_refs_as_final_answer_text",
      "do_not_force_visible_answer_format"
    ]
  },
  "async_terminal_failure_projection": {
    "enabled": true,
    "source_pattern": "firecrawl_extract_dlq_terminal_projection",
    "purpose": "Long-running retrieval and extraction work should convert crashed, expired, or dead-lettered jobs into bounded terminal artifacts instead of retrying indefinitely or leaving synthesis without an explicit gap reason.",
    "terminal_values": [
      "completed",
      "failed",
      "expired",
      "cancelled",
      "dead_lettered"
    ],
    "projection_fields": [
      "task_id",
      "terminal_status",
      "error_summary",
      "completed_evidence_refs",
      "missing_evidence_reason",
      "expiry"
    ],
    "non_goals": [
      "do_not_expose_queue_or_dead_letter_payloads_to_chat",
      "do_not_treat_handled_worker_failure_as_user_visible_retrieval_evidence",
      "do_not_retry_terminal_failures_without_a_changed_request_or_recovery_lane"
    ]
  },
  "document_extraction": {
    "source_patterns": [
      "firecrawl_parse_upload_as_no_browse_document_lane",
      "firecrawl_native_document_normalized_model"
    ],
    "handled_types": [
      "html",
      "pdf",
      "text",
      "office_document",
      "spreadsheet",
      "presentation",
      "image",
      "xml"
    ],
    "artifact_model": "normalize_document_like_content_before_synthesis",
    "artifact_contract": "document parsers produce structural text/table/metadata/page artifacts for evidence packing; final answer shape remains unconstrained",
    "parse_only_lane_contract": {
      "purpose": "When the user supplies document bytes or a fetched URL resolves to a document-like artifact, extraction should route through document parsing rather than web browsing controls.",
      "reject_browsing_or_rendering_options": [
        "actions",
        "screenshot",
        "wait_for_interaction",
        "location_override",
        "mobile_rendering"
      ],
      "cache_policy": "no_storage_without_explicit_cache_permission",
      "non_goals": [
        "do_not_prescribe_final_answer_format",
        "do_not_treat_unsupported_binary_as_successful_empty_evidence"
      ]
    },
    "page_artifact_fields": [
      "document_type",
      "page_count",
      "page_span",
      "metadata_title",
      "metadata_author",
      "text_extracted",
      "link_count",
      "image_count",
      "image_only_without_ocr",
      "rejection_reason"
    ]
  },
  "degraded_retrieval_recovery": {
    "purpose": "Recover useful evidence when a structurally successful search returns provider degradation, zero-result rows, low-detail snippets, or high-volume low-yield candidates.",
    "trigger_signals": [
      "provider_degradation",
      "partial_provider_failure",
      "zero_usable_results",
      "low_detail_snippets",
      "candidate_volume_without_facet_coverage",
      "off_topic_top_results"
    ],
    "recovery_actions": [
      "preserve the original user goal and missing coverage lanes",
      "vary source class, page type, exact entity terms, and time window rather than repeating the broad query",
      "prefer primary, official, independent, benchmark, methodology, security, publication, repository, release, advisory, or other directly citable source classes when relevant",
      "read or fetch promising result pages when rows are relevant but snippets are too thin",
      "record remaining gaps explicitly when recovery budget is exhausted"
    ],
    "sufficiency_rule": "do not treat candidate count, provider telemetry, or failure messages as evidence sufficiency; require usable evidence or explicit coverage gaps before final synthesis",
    "non_goals": [
      "do_not_add_domain_specific_sources",
      "do_not_force_user_visible_format",
      "do_not_treat_retrieval_telemetry_as_citable_evidence"
    ]
  },
  "evidence_pack": {
    "chat_visibility": "hidden_until_synthesized",
    "item_schema_version": "evidence_pack_v1",
    "purpose": "Provide the synthesizer a compact, ranked, processible evidence object instead of a raw blob of search rows.",
    "ranking_policy": {
      "objective": "improve final research quality by packing evidence for coverage and decision value, not just provider rank",
      "primary_axes": [
        "relevance_to_user_goal",
        "coverage_facet_match",
        "source_authority",
        "source_diversity",
        "freshness_when_relevant",
        "content_density",
        "novelty_against_selected_evidence"
      ],
      "packing_rules": [
        "preserve at least one strong item for each major requested facet when available",
        "prefer distinct source domains and source classes for broad research when available",
        "do not let near-duplicate high-rank candidates crowd out coverage-critical evidence",
        "label weak raw evidence as weaker than usable evidence"
      ],
      "non_goals": [
        "do_not_force_final_answer_format",
        "do_not_hardcode_research_domains",
        "do_not_treat_provider_rank_as_validation"
      ]
    },
    "required_item_fields": [
      "pack_version",
      "source_kind",
      "source_class",
      "title",
      "locator",
      "source_domain",
      "snippet",
      "claim_hints",
      "term_hints",
      "score",
      "score_components",
      "confidence",
      "quality_flags",
      "coverage_facets",
      "freshness"
    ],
    "synthesis_boundary": "Evidence-pack fields guide reasoning and coverage checks, but do not prescribe tables, lists, sections, phrasing, or any other final answer format.",
    "content_variants": [
      "source_excerpt",
      "search_highlight_excerpt",
      "provider_context_excerpt",
      "provider_raw_content_excerpt",
      "query_reranked_extract_excerpt",
      "reader_content",
      "reader_markdown",
      "reader_text",
      "reader_html_excerpt",
      "reader_links_summary",
      "reader_images_summary",
      "reader_heading_chunks",
      "reader_screenshot_ref",
      "fit_markdown",
      "markdown_with_citations",
      "references_markdown",
      "cleaned_content_excerpt",
      "pdf_text_excerpt",
      "pdf_page_summary"
    ],
    "chunking_strategies": [
      "paragraph_or_heading_boundary",
      "heading_boundary_with_parent_context",
      "fixed_window",
      "sliding_window_with_overlap",
      "semantic_or_similarity_ranked_when_available"
    ]
  },
  "retrieval_status_classification": {
    "purpose": "separate hard retrieval/runtime states from soft evidence-quality states before final synthesis",
    "hard_failure_values": [
      "bad_request_shape",
      "auth_or_permission_blocked",
      "transient_provider_failure",
      "permanent_provider_failure"
    ],
    "soft_failure_values": [
      "low_signal_evidence",
      "irrelevant_evidence",
      "empty_success",
      "partial_success",
      "rate_limited"
    ],
    "synthesis_implication": "artifact_presence_is_not_evidence_usefulness; synthesize normally only from usable evidence, otherwise do bounded low-evidence synthesis after recorded recovery"
  },
  "raw_result_retention": {
    "purpose": "keep weak provider evidence available for diagnosis and bounded low-evidence synthesis without treating it as normal source backing",
    "confidence_values": [
      "usable",
      "low_confidence_raw"
    ],
    "record_fields": [
      "attempted_query",
      "provider",
      "provider_raw_count",
      "provider_filtered_count",
      "failure_reasons",
      "result_quality"
    ],
    "synthesis_rule": "low_confidence_raw rows may support bounded uncertainty and gap analysis, but telemetry is diagnostic context and must not be cited as a source"
  },
  "coverage_aware_evidence": {
    "purpose": "for any research domain, retain and promote evidence across the facets implied by the user's request and submitted query pack rather than relying only on one global ranking",
    "facet_source": [
      "user_research_objective",
      "submitted_query_pack",
      "generic_clause_splitting_when_no_query_pack_exists"
    ],
    "coverage_status_values": [
      "covered",
      "weak",
      "missing"
    ],
    "synthesis_rule": "answer the covered facets, mark weak or missing facets as uncertainty or coverage gaps, and avoid presenting weak raw rows as strong source backing",
    "non_goals": [
      "do_not_hardcode_research_domains",
      "do_not_prescribe_final_answer_format",
      "do_not_hide_query_expansion_or_evidence_gaps"
    ]
  },
  "bounded_second_pass_recovery": {
    "purpose": "when the first pass has no usable synthesis evidence or no provider artifacts, run recorded generic recovery queries before final synthesis",
    "authority": "policy_declares_recovery_shape_agent_or_runtime_records_attempted_queries",
    "non_goals": [
      "do_not_hide_query_expansion",
      "do_not_hardcode_domains_or_research_topics",
      "do_not_force_final_answer_format"
    ]
  },
  "coverage_gap_recovery": {
    "purpose": "when candidate volume exists but usable evidence coverage remains thin, spend bounded follow-up lanes on the uncovered research facets before synthesis",
    "authority": "policy_declares_recovery_shape_agent_or_runtime_records_attempted_queries",
    "trigger": "candidate_volume_exists_but_usable_evidence_or_facet_coverage_is_low",
    "allow_after_policy_query_pack": true,
    "sufficiency_target": "prefer at least three usable evidence refs and roughly three quarters of requested facets before treating high-volume retrieval as sufficient",
    "templates": [
      "{facet} source-backed evidence",
      "{facet} primary or official source",
      "{facet} independent analysis evidence",
      "{facet} examples reports data"
    ],
    "non_goals": [
      "do_not_hide_query_expansion",
      "do_not_hardcode_domains_or_research_topics",
      "do_not_force_final_answer_format",
      "do_not_treat_high_candidate_count_as_evidence_sufficiency"
    ]
  },
  "async_result_lifecycle": {
    "enabled": true,
    "use_for_large_or_long_running_batches": true,
    "source_pattern": "firecrawl_async_map_crawl_status_projection",
    "handle_fields": [
      "task_id",
      "status",
      "created_at",
      "updated_at",
      "expires_at",
      "result_ref",
      "error_summary",
      "poll_interval_ms",
      "poll_backoff_factor",
      "poll_duration_budget_ms"
    ],
    "projection_rules": [
      "status_calls_return_projection_counts_and_bounded_result_windows",
      "followup_windows_use_cursor_or_next_ref_instead_of_full_payload_replay",
      "terminal_failures_include_structured_error_summary_without_raw_provider_payload",
      "cancelled_or_expired_runs_are_failure_states_for_verifier_calibration"
    ],
    "execution_reconciliation": {
      "source_patterns": [
        "firecrawl_queue_backlog_lock_reconcile_lifecycle",
        "firecrawl_incremental_crawl_discovery_enqueue"
      ],
      "purpose": "Large retrieval should have bounded backlog state, lock ownership, retry-safe promotion, and drift reconciliation so high-volume reads remain dependable without becoming chat-visible workflow machinery.",
      "rules": [
        "backlogged_work_must_have_expiry_or_cleanup_bounds",
        "worker_claims_must_use_lock_or_owner_tokens_before_mutating_terminal_state",
        "completion_or_failure_must_release_active_concurrency_markers",
        "reconciliation_may_requeue_or_promote_missing_work_when_durable_backlog_and_runtime_queue_drift",
        "incremental_discovery_may_enqueue_new_page_reads_only_after_dedupe_filtering_and_budget_checks"
      ],
      "projection_boundary": "queue, lock, reconciler, and worker metrics are internal retrieval diagnostics; synthesis receives only evidence refs, status summaries, and explicit gap reasons.",
      "non_goals": [
        "do_not_expose_queue_internals_as_final_answer",
        "do_not_treat_job_success_count_as_evidence_quality",
        "do_not_require_a_specific_queue_backend"
      ]
    },
    "raw_result_payload_chat_visible": false
  },
  "diagnostics": [
    "candidate_count",
    "evidence_count",
    "source_domain_count",
    "coverage_bucket_count",
    "covered_bucket_count",
    "missing_coverage_buckets",
    "provider_answer_present",
    "follow_up_questions_count",
    "image_result_count",
    "map_candidate_count",
    "crawl_page_count",
    "reader_artifact_count",
    "read_success_count",
    "read_partial_failure_count",
    "readiness_status",
    "selector_applied",
    "representation_variant",
    "token_budget_status",
    "exact_match_applied",
    "domain_filter_applied",
    "time_filter_applied",
    "partial_failures",
    "stop_reason"
  ],
  "final_response_verifier": {
    "enabled": true,
    "authority": "workflow_cd_declares_semantic_checks_retrieval_policy_exports_inputs",
    "visibility": "internal_only_not_chat_visible",
    "checks": [
      "answer_covers_user_goal",
      "answer_uses_recorded_evidence_when_available",
      "answer_covers_named_entities_or_records_gaps",
      "answer_leads_with_bounded_decision_value_not_tool_status",
      "answer_separates_evidence_from_inference",
      "answer_avoids_raw_payload_or_trace_leakage"
    ],
    "retry_policy": {
      "max_retrieval_retries": 1,
      "retry_when": [
        "coverage_gap_remains_and_budget_available",
        "evidence_pack_has_candidates_but_major_facets_are_uncovered",
        "final_answer_suggests_user_narrowing_before_bounded_synthesis"
      ],
      "retry_input": "missing_coverage_facets_quality_flags_and_verifier_failure_reason"
    },
    "non_goals": [
      "do_not_prescribe_visible_answer_shape",
      "do_not_hardcode_domain_specific_templates",
      "do_not_treat_telemetry_as_source_evidence"
    ]
  }
}
