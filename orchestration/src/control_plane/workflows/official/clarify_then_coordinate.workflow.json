{
  "name": "clarify_then_coordinate",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "online_research",
        "workflow_id": "research_synthesize_verify",
        "input_contract": "workflow_input_envelope_v1",
        "output_artifact": "research_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "local_coding",
        "workflow_id": "coding_project_operator",
        "input_contract": "workflow_input_envelope_v1",
        "output_artifact": "coding_project_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_inline_child_workflow_internals",
      "do_not_return_raw_tool_payloads_to_parent"
    ]
  },
  "default": false,
  "description": "Clarification-first control-plane template used when request intent is ambiguous or clarification is mandatory before execution.",
  "stages": [
    "intake_normalization",
    "decomposition_planning",
    "coordination_sequencing",
    "recovery_escalation",
    "result_packaging",
    "verification_closure"
  ],
  "final_response_policy": "control_plane_packaged_response",
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact workflow observations for clarification gates, coordination, tools, and terminal outcomes; keep raw payloads out of lifecycle storage.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_force_response_formats"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "intake_normalization->decomposition_planning",
      "decomposition_planning->coordination_sequencing",
      "coordination_sequencing->recovery_escalation",
      "recovery_escalation->result_packaging",
      "result_packaging->verification_closure",
      "verification_closure->completed",
      "recovery_escalation->needs_input",
      "recovery_escalation->blocked",
      "coordination_sequencing->failed",
      "coordination_sequencing->aborted"
    ],
    "timeout_ms": 120000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "recover_or_escalate"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 8,
      "max_tool_calls": 6,
      "token_budget": 16000,
      "loop_signature_detector": "stage_tool_signature_v1"
    }
  },
  "default_for_request_classes": [
    "read_only",
    "tool_call"
  ],
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "recovery_escalation",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "tool_selection_contract": {
    "version": "default_workflow_tool_selection_v1",
    "purpose": "Expose selectable tool slots to the default workflow without hardcoding execution in the router.",
    "selection_stages": {
      "tool_family_menu": "gate_2_tool_family_menu",
      "tool_menu": "gate_3_tool_menu",
      "tool_payload": "gate_4_request_payload_input"
    },
    "tool_families": [
      {
        "family": "workspace",
        "label": "Workspace files",
        "tools": [
          {
            "tool_id": "file_read",
            "aliases": [
              "read_file",
              "workspace.read"
            ],
            "required_permission": "file.read",
            "input_schema": "file_read_request_v1",
            "routes_to_capability": "workspace_file_read"
          },
          {
            "tool_id": "file_read_many",
            "aliases": [
              "read_many_files",
              "workspace.read_many"
            ],
            "required_permission": "file.read",
            "input_schema": "file_read_many_request_v1",
            "routes_to_capability": "workspace_file_read_many"
          }
        ]
      },
      {
        "family": "coding",
        "label": "Local coding files",
        "routes_to_workflow_id": "coding_project_operator",
        "capability_pack": "local-coding-files",
        "tools": [
          {
            "tool_id": "file_read",
            "required_permission": "file.read",
            "input_schema": "file_read_request_v1",
            "routes_to_capability": "safe_file_read"
          },
          {
            "tool_id": "file_write",
            "aliases": [
              "write_file",
              "workspace.write"
            ],
            "required_permission": "file.write",
            "input_schema": "file_write_request_v1",
            "routes_to_capability": "safe_file_write"
          },
          {
            "tool_id": "file_patch",
            "aliases": [
              "apply_patch",
              "patch_file",
              "workspace.patch"
            ],
            "required_permission": "file.patch",
            "input_schema": "file_patch_request_v1",
            "routes_to_capability": "safe_file_patch"
          }
        ]
      }
    ],
    "routing_rules": [
      "read_only_workspace_requests_may_select_workspace_file_read_tools",
      "local_code_mutation_requests_route_to_coding_project_operator",
      "file_write_and_file_patch_require_coding_family_or_explicit_file_permission",
      "selected_tools_must_be_bound_to_runtime_receipts_before_claiming_success"
    ],
    "non_goals": [
      "do_not_execute_file_tools_from_default_router_without_runtime_permission_gate",
      "do_not_expose_raw_tool_payloads_in_visible_chat"
    ]
  }
}
