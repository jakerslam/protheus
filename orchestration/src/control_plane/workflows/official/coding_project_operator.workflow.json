{
  "name": "coding_project_operator",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "local_coding_project_operator",
        "workflow_id": "local_coding_program_builder",
        "input_contract": "local_coding_program_builder_input_envelope_v1",
        "output_artifact": "local_coding_program_builder_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_inline_child_workflow_internals",
      "do_not_return_raw_tool_payloads_to_parent",
      "do_not_bypass_local_coding_program_builder_gates"
    ]
  },
  "workflow_composition": {
    "primitive_level": 4,
    "composed_of_workflow_ids": [
      "local_coding_program_builder"
    ]
  },
  "native_runtime_tooling": {
    "version": "native_runtime_tooling_v1",
    "capability_packs": [
      "local-coding-files"
    ],
    "permission_template": "local-coding-files",
    "permission_keys": [
      "file.read",
      "file.write",
      "file.patch"
    ],
    "tools_bound_by": "capability_pack_registry",
    "non_goals": [
      "do_not_hardcode_tool_names_in_workflow_runner",
      "do_not_execute_file_tools_without_permission_receipts"
    ]
  },
  "default": false,
  "description": "Official runtime-selectable coding category wrapper. It routes local software implementation, refactor, repair, and project-operator requests into the master local coding workflow while keeping the lab workflow itself non-runtime-selectable.",
  "stages": [
    "intake_normalization",
    "decomposition_planning",
    "coordination_sequencing",
    "recovery_escalation",
    "result_packaging",
    "verification_closure"
  ],
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "coding_project_operator_final_output_contract_v1",
    "source": "official_coding_runtime_wrapper",
    "required_terminal_outcome": "coding_result_or_structured_blocker",
    "required_fields": [
      "workflow_id",
      "delegated_workflow_id",
      "changed_files",
      "validation_summary",
      "checkpoint_or_blocker"
    ],
    "diagnostics_visibility": "telemetry_only"
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact workflow observations for coding category routing, local coding delegation, validation, blockers, and terminal outcomes; keep raw payloads out of lifecycle storage.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_force_response_formats"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "intake_normalization->decomposition_planning",
      "decomposition_planning->coordination_sequencing",
      "coordination_sequencing->recovery_escalation",
      "recovery_escalation->result_packaging",
      "result_packaging->verification_closure",
      "verification_closure->completed",
      "recovery_escalation->needs_input",
      "recovery_escalation->blocked",
      "coordination_sequencing->failed",
      "coordination_sequencing->aborted"
    ],
    "timeout_ms": 120000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "recover_or_escalate"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 8,
      "max_tool_calls": 6,
      "token_budget": 16000,
      "loop_signature_detector": "coding_project_operator_v1"
    }
  },
  "default_for_request_classes": [
    "mutation",
    "task_proposal"
  ],
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "recovery_escalation",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
