{
  "name": "coding_project_operator",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals",
      "sidecar_artifact_contract": {
        "artifact_schema": "public_reasoning_trace_bundle_v1",
        "allowed_schemas": [
          "public_reasoning_trace_v1",
          "public_reasoning_rollup_v1"
        ],
        "parent_receives": "public_reasoning_rollup_plus_refs_not_raw_private_notes"
      }
    },
    "child_workflow_calls": [
      {
        "capability": "local_coding_project_operator",
        "workflow_id": "local_coding_program_builder",
        "input_contract": "local_coding_program_builder_input_envelope_v1",
        "output_artifact": "local_coding_program_builder_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "public_reasoning_trace_refs_only"
      }
    ],
    "non_goals": [
      "do_not_inline_child_workflow_internals",
      "do_not_return_raw_tool_payloads_to_parent",
      "do_not_bypass_local_coding_program_builder_gates"
    ]
  },
  "workflow_composition": {
    "primitive_level": 4,
    "composed_of_workflow_ids": [
      "local_coding_program_builder"
    ]
  },
  "native_runtime_tooling": {
    "version": "native_runtime_tooling_v1",
    "capability_packs": [
      "local-coding-files"
    ],
    "permission_template": "local-coding-files",
    "permission_keys": [
      "file.read",
      "file.write",
      "file.patch",
      "command.run"
    ],
    "tools_bound_by": "capability_pack_registry",
    "non_goals": [
      "do_not_hardcode_tool_names_in_workflow_runner",
      "do_not_execute_file_tools_without_permission_receipts"
    ]
  },
  "coding_tool_binding_contract": {
    "version": "coding_tool_binding_contract_v1",
    "purpose": "Bind the coding workflow to native file tools and the safe-file workflow capabilities it delegates to.",
    "capability_pack": "local-coding-files",
    "required_native_tools": [
      "file_list",
      "file_stat",
      "file_read",
      "file_read_many",
      "file_write",
      "file_patch"
    ],
    "tool_to_workflow_capability": {
      "file_list": "safe_file_read",
      "file_stat": "safe_file_read",
      "file_read": "safe_file_read",
      "file_read_many": "safe_file_read",
      "file_write": "safe_file_write",
      "file_patch": "safe_file_patch"
    },
    "runtime_requirements": [
      "native_tool_loop_enabled",
      "file_tool_permissions_granted_or_fail_closed",
      "tool_receipts_attached_to_agent_receipt",
      "final_answer_must_not_claim_unreceipted_file_changes"
    ],
    "delegated_workflow_id": "local_coding_program_builder",
    "non_goals": [
      "do_not_reimplement_safe_file_logic_in_this_wrapper",
      "do_not_allow_unreceipted_file_mutation"
    ]
  },
  "native_execution_success_contract": {
    "version": "native_execution_success_contract_v1",
    "purpose": "Prevent native coding runs from reporting empty or unreceipted success.",
    "applies_to_request_classes": [
      "mutation",
      "task_proposal"
    ],
    "native_success_criteria": {
      "requires_native_tool_use": true,
      "requires_successful_discovery_receipt": false,
      "requires_successful_mutation_receipt": true,
      "successful_discovery_tools": [
        "file_list",
        "file_stat"
      ],
      "successful_mutation_tools": [
        "file_write",
        "file_patch"
      ],
      "min_successful_tool_receipts": 1,
      "min_successful_discovery_receipts": 0,
      "max_context_only_turns": 2,
      "micro_direct_write_enabled": true,
      "micro_direct_write_max_target_files": 1,
      "synthesize_final_after_successful_micro_mutation": true,
      "completion_evidence_required_for_multi_requirement_tasks": true,
      "synthesize_completion_evidence_on_finalization_timeout": true,
      "validation_command_required_when_task_requests_test_status": true,
      "auto_validation_command_detection_enabled": true,
      "validation_failure_repair_uses_command_output": true,
      "generated_test_design_policy": "prompt_faithful_behavior_or_parsed_structure_not_incidental_format",
      "repair_uncovered_requirements_before_final": true,
      "completion_evidence_repair_max_turns": 4,
      "empty_tool_retry_limit": 2,
      "force_discovery_first_turn": false,
      "provider_timeout_seconds": 600,
      "native_wall_timeout_seconds": 1200,
      "partial_progress_on_timeout": true,
      "partial_recovery_max_turns": 3,
      "recovery_provider_timeout_seconds": 120,
      "failure_mode": "structured_failure_with_receipt_summary"
    },
    "non_goals": [
      "do_not_count_process_exit_zero_as_software_success",
      "do_not_count_original_tests_passing_without_mutation_as_success",
      "do_not_count_failed_reads_of_missing_create_targets_as_project_discovery",
      "do_not_repeat_context_only_tool_turns_when_mutation_is_required",
      "do_not_expose_raw_file_contents_in_failure_summaries"
    ]
  },
  "coding_context_mode_policy": {
    "version": "coding_context_mode_policy_v1",
    "purpose": "Let the higher-level coding workflow decide whether local context discovery is required instead of forcing discovery inside every primitive coding run.",
    "decision_owner": "coding_project_operator",
    "modes": {
      "greenfield_or_isolated_create": {
        "applies_when": [
          "task_names_an_explicit_new_target_file_or_small_file_set",
          "task_defines_required_behavior_inline",
          "task_does_not_require_integrating_with_unknown_existing_project_code"
        ],
        "preferred_first_action": "file_write_or_file_patch",
        "discovery_required": false,
        "required_receipts": [
          "successful_mutation_receipt"
        ]
      },
      "existing_project_change": {
        "applies_when": [
          "task_modifies_existing_capability",
          "task_mentions_existing_project_behavior",
          "task_requires_preserving_style_api_tests_or_architecture"
        ],
        "preferred_first_action": "file_list_or_file_stat_then_relevant_file_read",
        "discovery_required": true,
        "required_receipts": [
          "successful_discovery_receipt",
          "successful_mutation_receipt"
        ]
      },
      "unclear_context": {
        "applies_when": [
          "target_files_are_not_named",
          "project_shape_or_stack_is_unknown",
          "safe_mutation_depends_on_local_structure"
        ],
        "preferred_first_action": "file_list_or_file_stat",
        "discovery_required": true,
        "required_receipts": [
          "successful_discovery_receipt_before_mutation_or_structured_blocker"
        ]
      }
    },
    "non_goals": [
      "do_not_force_project_discovery_for_obvious_one_file_greenfield_tasks",
      "do_not_hardcode_specific_filenames_as_required_context",
      "do_not_allow_final_success_without_mutation_receipts_for_mutation_tasks"
    ]
  },
  "completion_evidence_contract": {
    "version": "completion_evidence_contract_v1",
    "purpose": "Prevent false success on multi-requirement coding tasks by requiring receipt-backed evidence coverage for user-stated requirements.",
    "applies_when": [
      "task_contains_numbered_requirements",
      "task_contains_multiple_requested_capabilities",
      "task_requires_changes_across_source_tests_docs_or_configuration",
      "task_is_existing_project_change"
    ],
    "checklist_derivation_policy": {
      "source": "user_prompt_and_normalized_task_plan",
      "derive_from": [
        "numbered_items",
        "bulleted_items",
        "explicit_must_should_require_phrases",
        "requested_outputs",
        "validation_or_documentation_requirements"
      ],
      "item_shape": {
        "id": "stable_short_requirement_id",
        "requirement": "concise user-visible requirement",
        "evidence_needed": [
          "changed_file_receipt",
          "readback_or_validation_receipt_when_available",
          "final_summary_reference"
        ],
        "status": "covered_or_uncovered_or_blocked"
      },
      "non_goals": [
        "do_not_hardcode_domain_specific_file_names",
        "do_not_infer_hidden_requirements_not_supported_by_prompt_or_project_context"
      ]
    },
    "finalization_requirements": [
      "final_public_reasoning_trace_must_include_task_requirement_checklist_for_multi_requirement_tasks",
      "each_checklist_item_must_include_status_and_evidence_refs_or_blocker_reason",
      "completion_status_success_requires_all_checklist_items_covered",
      "if_any_item_is_uncovered_return_partial_or_structured_blocker_not_success"
    ],
    "parent_visibility": "summary_plus_requirement_coverage_refs",
    "redaction_policy": "no_hidden_chain_of_thought"
  },
  "coding_persistence_safety_contract": {
    "version": "coding_persistence_safety_contract_v1",
    "purpose": "General persistence helper rule for local coding tasks that create or modify file-backed state.",
    "applies_when": [
      "task_creates_file_backed_persistence",
      "task_modifies_existing_persistence_helpers",
      "task_uses_json_jsonl_csv_sqlite_or_other_stdlib_storage"
    ],
    "requirements": [
      "load_helpers_must_return_empty_state_for_missing_files",
      "load_helpers_must_return_empty_state_for_empty_files",
      "load_helpers_must_not_throw_for_zero_byte_newly_created_tempfiles",
      "tests_should_cover_missing_file_and_empty_file_when_file_backed_persistence_is_added"
    ],
    "examples": [
      "JSON loader checks path.exists() and path.stat().st_size == 0 before json.load",
      "JSONL/CSV loaders treat missing or empty files as no rows",
      "SQLite stores initialize schema before reads and tolerate a newly created empty database path"
    ],
    "non_goals": [
      "do_not_hardcode_project_names",
      "do_not_hide_malformed_non_empty_data_errors_unless_task_explicitly_requests_recovery"
    ]
  },
  "default": false,
  "description": "Official runtime-selectable coding category wrapper. It routes local software implementation, refactor, repair, and project-operator requests into the master local coding workflow while keeping the lab workflow itself non-runtime-selectable.",
  "stages": [
    "intake_normalization",
    "decomposition_planning",
    "coordination_sequencing",
    "recovery_escalation",
    "result_packaging",
    "verification_closure"
  ],
  "final_response_policy": "control_plane_packaged_response",
  "public_reasoning_trace_contract": {
    "version": "public_reasoning_trace_contract_v1",
    "protocol_ref": "orchestration/src/control_plane/workflows/public_reasoning_trace_protocol.json",
    "workflow_role": "composite_aggregator",
    "emits": [
      "public_reasoning_trace_v1",
      "public_reasoning_rollup_v1"
    ],
    "local_trace_required_fields": [
      "task_summary",
      "plan_summary",
      "decisions",
      "actions",
      "changed_files",
      "validation_summary",
      "risks",
      "blockers",
      "confidence",
      "evidence_refs",
      "tool_receipt_refs",
      "child_trace_refs"
    ],
    "child_trace_policy": {
      "preserve_direct_child_refs": true,
      "summarize_direct_children_only": true,
      "required_child_workflow_ids": [
        "local_coding_program_builder"
      ],
      "missing_child_trace_refs": "record_explicit_missing_trace_ref"
    },
    "parent_visibility": "return_rollup_plus_refs_to_default_workflow",
    "redaction_policy": "no_hidden_chain_of_thought"
  },
  "final_output_contract": {
    "schema_version": "coding_project_operator_final_output_contract_v1",
    "source": "official_coding_runtime_wrapper",
    "required_terminal_outcome": "coding_result_or_structured_blocker",
    "required_fields": [
      "workflow_id",
      "delegated_workflow_id",
      "changed_files",
      "validation_summary",
      "checkpoint_or_blocker",
      "public_reasoning_trace",
      "reasoning_rollup",
      "child_reasoning_trace_refs"
    ],
    "diagnostics_visibility": "public_reasoning_rollup_refs_only"
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact workflow observations for coding category routing, local coding delegation, validation, blockers, and terminal outcomes; keep raw payloads out of lifecycle storage.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_force_response_formats"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "intake_normalization->decomposition_planning",
      "decomposition_planning->coordination_sequencing",
      "coordination_sequencing->recovery_escalation",
      "recovery_escalation->result_packaging",
      "result_packaging->verification_closure",
      "verification_closure->completed",
      "recovery_escalation->needs_input",
      "recovery_escalation->blocked",
      "coordination_sequencing->failed",
      "coordination_sequencing->aborted"
    ],
    "timeout_ms": 120000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "recover_or_escalate"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "public_reasoning_trace",
      "reasoning_rollup",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_plus_public_reasoning_rollup_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 8,
      "max_tool_calls": 6,
      "token_budget": 16000,
      "loop_signature_detector": "coding_project_operator_v1"
    }
  },
  "default_for_request_classes": [
    "mutation",
    "task_proposal"
  ],
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract",
      "public_reasoning_trace_contract",
      "reasoning_rollup_policy"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "recovery_escalation",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
