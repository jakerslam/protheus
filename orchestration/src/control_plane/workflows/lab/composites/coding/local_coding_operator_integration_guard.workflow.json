{
  "name": "local_coding_operator_integration_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "sandbox_worktree_isolation",
        "workflow_id": "sandbox_worktree_isolation",
        "input_contract": "sandbox_worktree_isolation_input_envelope_v1",
        "output_artifact": "sandbox_worktree_isolation_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "operator_command_surface_projection",
        "workflow_id": "operator_command_surface_projection",
        "input_contract": "operator_command_surface_projection_input_envelope_v1",
        "output_artifact": "operator_command_surface_projection_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "external_update_editor_auth_boundary",
        "workflow_id": "external_update_editor_auth_boundary",
        "input_contract": "external_update_editor_auth_boundary_input_envelope_v1",
        "output_artifact": "external_update_editor_auth_boundary_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "schema_data_generation_pipeline",
        "workflow_id": "schema_data_generation_pipeline",
        "input_contract": "schema_data_generation_pipeline_input_envelope_v1",
        "output_artifact": "schema_data_generation_pipeline_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_mutate_source_files",
      "do_not_run_validation",
      "do_not_install_or_authenticate_without_explicit_boundary_receipts",
      "do_not_treat_operator_setup_as_coding_completion"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived operator integration guard for local coding: isolate sandbox worktrees, command projection, update/editor/auth boundaries, and schema data generation from local code-edit execution.",
  "stages": [
    "operator_integration_need_assessment",
    "sandbox_worktree_isolation_route",
    "operator_command_surface_projection_route",
    "external_update_editor_auth_boundary_route",
    "schema_data_generation_pipeline_route",
    "operator_integration_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "sandbox_worktree_isolation",
      "operator_command_surface_projection",
      "external_update_editor_auth_boundary",
      "schema_data_generation_pipeline"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_operator_integration_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "sandbox_status",
      "command_surface_status",
      "external_boundary_status",
      "data_generation_status",
      "operator_action_approval_status",
      "operator_integration_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route operator-facing integrations without weakening local coding safety boundaries",
      "scope_boundary": "do not edit files, run validation, choose architecture, or perform unapproved external-visible actions",
      "validation_calibration": "report operator integration readiness separately from local code correctness",
      "visibility": "do not expose credentials, OAuth codes, raw command registries, or raw provider payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact operator-integration receipts for local coding workflows without storing secrets or raw external payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_operator_boundary_failures",
      "do_not_store_credentials_or_oauth_codes",
      "do_not_replace_local_safety_receipts",
      "do_not_store_raw_provider_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "operator_integration_need_assessment->sandbox_worktree_isolation_route",
      "sandbox_worktree_isolation_route->operator_command_surface_projection_route",
      "operator_command_surface_projection_route->external_update_editor_auth_boundary_route",
      "external_update_editor_auth_boundary_route->schema_data_generation_pipeline_route",
      "schema_data_generation_pipeline_route->operator_integration_receipt_packaging",
      "operator_integration_receipt_packaging->completed",
      "sandbox_worktree_isolation_route->blocked",
      "operator_command_surface_projection_route->blocked",
      "external_update_editor_auth_boundary_route->needs_input",
      "schema_data_generation_pipeline_route->failed"
    ],
    "timeout_ms": 300000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 2,
      "max_tool_calls": 16,
      "token_budget": 16000,
      "loop_signature_detector": "local_coding_operator_integration_guard_v1"
    }
  },
  "operator_integration_guard_contract": {
    "version": "local_coding_operator_integration_guard_v1",
    "source": "forgecode_assimilated_operator_integration_layer",
    "required_primitive_workflow_ids": [
      "sandbox_worktree_isolation",
      "operator_command_surface_projection",
      "external_update_editor_auth_boundary",
      "schema_data_generation_pipeline"
    ],
    "required_receipts": [
      "sandbox_worktree_receipt",
      "operator_command_surface_receipt",
      "external_update_editor_auth_receipt",
      "schema_data_generation_receipt",
      "operator_action_approval_receipt"
    ],
    "activation_policy": "local coding workflows must route sandbox worktree setup, command-surface projection, update/editor/auth boundaries, and schema data generation through this guard when those operator integrations are relevant; local file mutation and validation must still use local safety primitives",
    "stop_or_route_conditions": [
      "sandbox_creation_or_reuse_failed",
      "shell_bypass_requires_permissioned_execution_route",
      "external_action_requires_user_confirmation",
      "oauth_or_provider_secret_boundary_failed",
      "data_generation_provider_or_schema_failed",
      "operator_integration_would_replace_required_local_safety_receipts"
    ],
    "non_goals": [
      "do_not_execute_local_file_mutation",
      "do_not_treat_command_projection_as_command_execution",
      "do_not_treat_external_setup_as_validation",
      "do_not_store_or_emit_secrets"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "operator_integration_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
