{
  "name": "local_runtime_observability_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "chat_response_visibility_router",
        "workflow_id": "chat_response_visibility_router",
        "input_contract": "chat_response_visibility_router_input_envelope_v1",
        "output_artifact": "chat_response_visibility_router_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "streaming_markdown_projection",
        "workflow_id": "streaming_markdown_projection",
        "input_contract": "streaming_markdown_projection_input_envelope_v1",
        "output_artifact": "streaming_markdown_projection_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "tool_output_display_format",
        "workflow_id": "tool_output_display_format",
        "input_contract": "tool_output_display_format_input_envelope_v1",
        "output_artifact": "tool_output_display_format_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "trace_event_rate_limiter",
        "workflow_id": "trace_event_rate_limiter",
        "input_contract": "trace_event_rate_limiter_input_envelope_v1",
        "output_artifact": "trace_event_rate_limiter_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_execute_tools",
      "do_not_modify_files",
      "do_not_replace_runtime_execution_loop",
      "do_not_replace_checkpoint_handoff"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived observability guard for local coding: routes visible response events, renders streaming markdown, formats tool output displays, and bounds telemetry volume.",
  "stages": [
    "observability_input_preparation",
    "chat_response_visibility_routing",
    "streaming_markdown_projection",
    "tool_output_display_formatting",
    "trace_event_rate_limiting",
    "observability_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "chat_response_visibility_router",
      "streaming_markdown_projection",
      "tool_output_display_format",
      "trace_event_rate_limiter"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_runtime_observability_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "visibility_routing_status",
      "streaming_markdown_status",
      "tool_display_status",
      "trace_rate_limit_status",
      "blocked_observability_reasons"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "make local coding runtime output observable without leaking internals or confusing display with execution",
      "scope_boundary": "do not perform planning, coding, validation, or final checkpoint handoff",
      "validation_calibration": "report projection, rendering, formatting, and trace-limit failures separately",
      "visibility": "visible chat remains final-answer-only plus approved runtime/status display artifacts"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact observability receipts for local coding runtime output and telemetry.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_hide_current_output_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_full_markdown_streams"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "observability_input_preparation->chat_response_visibility_routing",
      "chat_response_visibility_routing->streaming_markdown_projection",
      "streaming_markdown_projection->tool_output_display_formatting",
      "tool_output_display_formatting->trace_event_rate_limiting",
      "trace_event_rate_limiting->observability_receipt_packaging",
      "observability_receipt_packaging->completed",
      "chat_response_visibility_routing->blocked",
      "streaming_markdown_projection->failed",
      "tool_output_display_formatting->failed",
      "trace_event_rate_limiting->failed"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 12000,
      "loop_signature_detector": "local_runtime_observability_guard_v1"
    }
  },
  "observability_guard_contract": {
    "version": "local_runtime_observability_guard_v1",
    "source": "forgecode_assimilated_observability_layer",
    "required_primitive_workflow_ids": [
      "chat_response_visibility_router",
      "streaming_markdown_projection",
      "tool_output_display_format",
      "trace_event_rate_limiter"
    ],
    "required_receipts": [
      "visibility_route_receipt",
      "markdown_projection_receipt",
      "display_format_receipt",
      "trace_rate_limit_receipt"
    ],
    "activation_policy": "local coding workflows that run a live runtime loop must attach an observability guard that separates visible user output, runtime status, tool display artifacts, and bounded telemetry",
    "non_goals": [
      "do_not_run_tests_or_validation",
      "do_not_replace_checkpoint_handoff",
      "do_not_emit_raw_payloads_as_visible_chat"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "observability_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
