{
  "name": "local_coding_phase1_mutation_spine",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Phase 1 primitive-first local coding composite for the smallest useful mutation loop: classify task, gate implementation, mutate through native file tools, journal receipts, and synthesize from receipts.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "composite",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.local_coding_phase1_mutation_spine",
    "special_case_policy": "This composite wires generic primitives only. Eval-specific setup, filenames, expected outputs, and scoring must remain in eval fixtures.",
    "monotonic_lower_level_regression_policy": "This spine must preserve Level 1 create-file behavior as higher coding workflows compose additional context, validation, repair, and memory primitives."
  },
  "native_execution_success_contract": {
    "native_success_criteria": {
      "requires_successful_mutation_receipt": true,
      "repair_uncovered_requirements_before_final": true,
      "staged_execution_controller_enabled": true,
      "staged_pre_mutation_read_budget": 4,
      "completion_evidence_repair_max_turns": 3,
      "partial_recovery_max_turns": 4,
      "recovery_provider_timeout_seconds": 180,
      "synthesize_final_after_successful_validation": true,
      "synthesize_completion_evidence_on_finalization_timeout": true
    }
  },
  "provenance_contract": {
    "source_systems": [
      "mini-SWE-agent",
      "SWE-agent",
      "Aider",
      "OpenHands",
      "Cline",
      "Continue",
      "ForgeCode"
    ],
    "import_rule": "compose_primitive_runtime_behavior_not_surface_prompts",
    "artifact_corpus_ref": "references/coding-agent-systems"
  },
  "stages": [
    "coding_task_contract",
    "coding_execution_shape_gate",
    "implementation_entry_gate",
    "single_mutation_execution",
    "deterministic_local_loop",
    "model_manifest_planner",
    "file_mutation_executor",
    "incremental_receipt_journal",
    "final_receipt_synthesis"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "coding_task_contract",
      "coding_execution_shape_gate",
      "implementation_entry_gate",
      "single_mutation_execution",
      "deterministic_local_loop",
      "model_manifest_planner",
      "file_mutation_executor",
      "incremental_receipt_journal",
      "final_receipt_synthesis"
    ]
  },
  "child_workflows": [
    {
      "capability": "coding_task_contract",
      "workflow_id": "coding_task_contract",
      "input_contract": "coding_task_contract_input_envelope_v1",
      "output_artifact": "coding_task_contract_output_envelope_v1"
    },
    {
      "capability": "coding_execution_shape_gate",
      "workflow_id": "coding_execution_shape_gate",
      "input_contract": "coding_execution_shape_gate_input_envelope_v1",
      "output_artifact": "coding_execution_shape_gate_result_artifact_v1"
    },
    {
      "capability": "implementation_entry_gate",
      "workflow_id": "implementation_entry_gate",
      "input_contract": "implementation_entry_gate_input_envelope_v1",
      "output_artifact": "implementation_entry_gate_result_artifact_v1"
    },
    {
      "capability": "single_mutation_execution",
      "workflow_id": "single_mutation_execution",
      "input_contract": "single_mutation_execution_input_envelope_v1",
      "output_artifact": "file_mutation_receipt_v1"
    },
    {
      "capability": "deterministic_local_loop",
      "workflow_id": "deterministic_local_loop",
      "input_contract": "deterministic_local_loop_manifest_v1",
      "output_artifact": "deterministic_local_loop_result_artifact_v1"
    },
    {
      "capability": "model_manifest_planner",
      "workflow_id": "model_manifest_planner",
      "input_contract": "model_manifest_planner_input_envelope_v1",
      "output_artifact": "model_manifest_planner_result_artifact_v1"
    },
    {
      "capability": "file_mutation_executor",
      "workflow_id": "file_mutation_executor",
      "input_contract": "file_mutation_executor_input_envelope_v1",
      "output_artifact": "file_mutation_receipt_v1"
    },
    {
      "capability": "incremental_receipt_journal",
      "workflow_id": "incremental_receipt_journal",
      "input_contract": "incremental_receipt_journal_input_envelope_v1",
      "output_artifact": "incremental_receipt_journal_result_artifact_v1"
    },
    {
      "capability": "final_receipt_synthesis",
      "workflow_id": "final_receipt_synthesis",
      "input_contract": "final_receipt_synthesis_input_envelope_v1",
      "output_artifact": "final_receipt_synthesis_result_artifact_v1"
    }
  ],
  "phase1_spine_contract": {
    "version": "local_coding_phase1_mutation_spine_v1",
    "purpose": "Provide the smallest buildable local coding workflow that can create or mutate a file and truthfully report receipt-backed outcome.",
    "allowed_task_classes": [
      "context_free_create_file",
      "explicit_target_file_write",
      "declared_multi_action_local_manifest",
      "bounded_greenfield_task_requiring_model_manifest_generation",
      "bounded_single_file_patch_when_context_is_already_supplied"
    ],
    "required_behaviors": [
      "produce_task_contract_before_mutation",
      "select_execution_shape_before_provider_startup",
      "route_explicit_safe_single_file_content_to_single_mutation_execution_without_model_call",
      "route_declared_small_local_action_manifests_to_deterministic_local_loop_without_model_call",
      "route_bounded_greenfield_natural_language_tasks_to_model_manifest_planner_then_deterministic_local_loop",
      "do_not_finalize_mutation_tasks_without_successful_file_mutation_receipt",
      "route_explicit_tier0_writes_through_single_mutation_execution_and_other_writes_or_patches_through_file_mutation_executor",
      "append_mutation_receipt_to_incremental_receipt_journal_before_final_synthesis",
      "derive_final_answer_from_receipt_journal",
      "return_structured_blocker_when_scope_or_required_input_is_missing"
    ],
    "explicit_non_goals": [
      "existing_project_context_discovery",
      "validation_command_execution",
      "repair_looping",
      "public_interface_verification",
      "checkpoint_or_memory_handoff",
      "multi_file_architecture_planning"
    ],
    "promotion_gate": {
      "target_eval": "coding_level_1",
      "pass_condition": "multiple_runs_create_or_mutate_one_file_with_mutation_receipt_and_truthful_final_synthesis",
      "regression_policy": "higher_level_coding_changes_must_not_change_this_spine_contract"
    }
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_phase1_mutation_spine_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "status",
      "task_kind",
      "execution_lane",
      "changed_files",
      "mutation_receipts",
      "validation_status",
      "blockers",
      "receipt_refs",
      "phase_latency_ms"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "complete or truthfully block the smallest local coding mutation task",
      "scope_boundary": "do not do existing-project discovery, validation, repair, or memory capture in Phase 1",
      "validation_calibration": "validation is explicitly not run in this phase unless a parent workflow composes validation later",
      "visibility": "report changed files, mutation receipts, and blockers without hidden chain-of-thought"
    }
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "coding_task_contract->implementation_entry_gate",
      "implementation_entry_gate->file_mutation_executor",
      "coding_task_contract->coding_execution_shape_gate",
      "coding_execution_shape_gate->single_mutation_execution",
      "coding_execution_shape_gate->deterministic_local_loop",
      "coding_execution_shape_gate->model_manifest_planner",
      "coding_execution_shape_gate->implementation_entry_gate",
      "single_mutation_execution->incremental_receipt_journal",
      "deterministic_local_loop->incremental_receipt_journal",
      "model_manifest_planner->incremental_receipt_journal",
      "file_mutation_executor->incremental_receipt_journal",
      "incremental_receipt_journal->final_receipt_synthesis",
      "final_receipt_synthesis->completed",
      "coding_task_contract->needs_input",
      "implementation_entry_gate->blocked",
      "coding_execution_shape_gate->structured_blocker",
      "single_mutation_execution->failed",
      "single_mutation_execution->blocked",
      "deterministic_local_loop->failed",
      "deterministic_local_loop->blocked",
      "model_manifest_planner->failed",
      "model_manifest_planner->blocked",
      "file_mutation_executor->failed",
      "file_mutation_executor->blocked"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 5,
      "max_model_turns": 2,
      "max_tool_calls": 2,
      "token_budget": 6000,
      "loop_signature_detector": "local_coding_phase1_mutation_spine_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      "coding_task_contract",
      "coding_execution_shape_gate",
      "implementation_entry_gate",
      "single_mutation_execution",
      "deterministic_local_loop",
      "model_manifest_planner",
      "file_mutation_executor",
      "incremental_receipt_journal",
      "final_receipt_synthesis"
    ],
    "non_goals": [
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace",
      "do_not_run_validation",
      "do_not_perform_existing_project_discovery"
    ]
  }
}
