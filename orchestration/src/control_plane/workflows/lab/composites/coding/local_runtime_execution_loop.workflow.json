{
  "name": "local_runtime_execution_loop",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "agent_request_transform_pipeline",
        "workflow_id": "agent_request_transform_pipeline",
        "input_contract": "agent_request_transform_pipeline_input_envelope_v1",
        "output_artifact": "agent_request_transform_pipeline_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "turn_retry_stream_runner",
        "workflow_id": "turn_retry_stream_runner",
        "input_contract": "turn_retry_stream_runner_input_envelope_v1",
        "output_artifact": "turn_retry_stream_runner_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "tool_call_execution_dispatch",
        "workflow_id": "tool_call_execution_dispatch",
        "input_contract": "tool_call_execution_dispatch_input_envelope_v1",
        "output_artifact": "tool_call_execution_dispatch_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "lifecycle_hook_dispatch",
        "workflow_id": "lifecycle_hook_dispatch",
        "input_contract": "lifecycle_hook_dispatch_input_envelope_v1",
        "output_artifact": "lifecycle_hook_dispatch_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "conversation_state_persistence",
        "workflow_id": "conversation_state_persistence",
        "input_contract": "conversation_state_persistence_input_envelope_v1",
        "output_artifact": "conversation_state_persistence_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_replace_policy_permission_guard",
      "do_not_replace_tooling_surface_guard",
      "do_not_replace_safe_file_edit_primitives",
      "do_not_expand_checkpoint_scope"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived runtime execution loop for local coding: transform requests, run retry-streamed chat turns, dispatch tool calls, fire lifecycle hooks, persist conversation state, and stop or yield on bounded runtime conditions.",
  "stages": [
    "runtime_input_preparation",
    "conversation_state_preflight",
    "lifecycle_start_dispatch",
    "request_transform_pipeline",
    "retry_streamed_chat_turn",
    "response_lifecycle_dispatch",
    "tool_call_execution_dispatch",
    "conversation_state_persistence",
    "completion_yield_or_interrupt_resolution",
    "runtime_result_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "agent_request_transform_pipeline",
      "turn_retry_stream_runner",
      "tool_call_execution_dispatch",
      "lifecycle_hook_dispatch",
      "conversation_state_persistence"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_runtime_execution_loop_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "runtime_loop_status",
      "request_transform_status",
      "chat_turn_status",
      "tool_dispatch_status",
      "lifecycle_hook_status",
      "state_persistence_status",
      "yield_or_interrupt_reason"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "execute a bounded local coding agent runtime loop and return only the terminal runtime artifact to its parent workflow",
      "scope_boundary": "do not decide the product architecture, checkpoint, or future scope; execute only the current parent-approved coding slice",
      "validation_calibration": "report runtime completion, yield, interruption, retries, and tool failures without claiming product validation unless validation receipts exist",
      "visibility": "do not expose private runtime state, raw tool payloads, or hidden reasoning"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact runtime-loop observations for local coding agent execution.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_provider_payloads",
      "do_not_store_raw_tool_payloads",
      "do_not_hide_current_interrupts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "runtime_input_preparation->conversation_state_preflight",
      "conversation_state_preflight->lifecycle_start_dispatch",
      "lifecycle_start_dispatch->request_transform_pipeline",
      "request_transform_pipeline->retry_streamed_chat_turn",
      "retry_streamed_chat_turn->response_lifecycle_dispatch",
      "response_lifecycle_dispatch->tool_call_execution_dispatch",
      "response_lifecycle_dispatch->conversation_state_persistence",
      "tool_call_execution_dispatch->conversation_state_persistence",
      "conversation_state_persistence->completion_yield_or_interrupt_resolution",
      "completion_yield_or_interrupt_resolution->request_transform_pipeline",
      "completion_yield_or_interrupt_resolution->runtime_result_packaging",
      "runtime_result_packaging->completed",
      "conversation_state_preflight->blocked",
      "request_transform_pipeline->blocked",
      "retry_streamed_chat_turn->failed",
      "tool_call_execution_dispatch->failed",
      "conversation_state_persistence->interrupted",
      "completion_yield_or_interrupt_resolution->interrupted"
    ],
    "timeout_ms": 240000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "interrupted",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 24,
      "max_model_turns": 8,
      "max_tool_calls": 24,
      "token_budget": 32000,
      "loop_signature_detector": "local_runtime_execution_loop_v1"
    }
  },
  "runtime_execution_loop_contract": {
    "version": "local_runtime_execution_loop_v1",
    "source": "forgecode_assimilated_runtime_layer",
    "required_primitive_workflow_ids": [
      "agent_request_transform_pipeline",
      "turn_retry_stream_runner",
      "tool_call_execution_dispatch",
      "lifecycle_hook_dispatch",
      "conversation_state_persistence"
    ],
    "required_receipts": [
      "request_transform_receipt",
      "retry_stream_turn_receipt",
      "tool_dispatch_receipt",
      "lifecycle_hook_receipt",
      "conversation_state_receipt",
      "yield_or_interrupt_receipt"
    ],
    "activation_policy": "local coding workflows that run a live coding agent must route provider requests, retries, streaming, tool dispatch, lifecycle hooks, and conversation persistence through this ForgeCode-derived runtime loop",
    "stop_or_yield_conditions": [
      "finish_reason_stop_with_no_tool_calls",
      "tool_call_requests_parent_followup",
      "max_request_per_turn_reached",
      "max_tool_failure_per_turn_reached",
      "end_hook_added_messages_and_loop_continues",
      "provider_retry_budget_exhausted",
      "conversation_persistence_failed"
    ],
    "non_goals": [
      "do_not_make_architecture_decisions_inside_runtime_loop",
      "do_not_bypass_permission_gate_or_safe_file_tools",
      "do_not_hide_retry_attempts_or_interruptions"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "runtime_result_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
