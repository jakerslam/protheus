{
  "name": "local_coding_prompt_template_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "embedded_template_registry",
        "workflow_id": "embedded_template_registry",
        "input_contract": "embedded_template_registry_input_envelope_v1",
        "output_artifact": "embedded_template_registry_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "system_skill_prompt_projection",
        "workflow_id": "system_skill_prompt_projection",
        "input_contract": "system_skill_prompt_projection_input_envelope_v1",
        "output_artifact": "system_skill_prompt_projection_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "recovery_command_template_projection",
        "workflow_id": "recovery_command_template_projection",
        "input_contract": "recovery_command_template_projection_input_envelope_v1",
        "output_artifact": "recovery_command_template_projection_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_execute_rendered_commands",
      "do_not_mutate_files",
      "do_not_override_parent_policy",
      "do_not_store_full_hidden_prompts_by_default"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived prompt-template guard for local coding: isolates embedded template registration, system/skill prompt projection, and recovery/command template projection from runtime execution.",
  "stages": [
    "prompt_template_need_assessment",
    "embedded_template_registry_route",
    "system_skill_prompt_projection_route",
    "recovery_command_template_projection_route",
    "prompt_template_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "embedded_template_registry",
      "system_skill_prompt_projection",
      "recovery_command_template_projection"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_prompt_template_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "template_registry_status",
      "system_skill_prompt_status",
      "recovery_command_template_status",
      "prompt_artifact_status",
      "prompt_template_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare prompt-template artifacts needed by ForgeCode-style local coding without executing tools",
      "scope_boundary": "do not perform coding edits, shell validation, permission decisions, command execution, or final handoff",
      "validation_calibration": "report template registry, projection, and command-template status separately",
      "visibility": "do not expose hidden prompt payloads unless returned as explicit artifact references"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact prompt-template receipts for local coding workflows without storing full hidden prompts by default.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_hide_template_render_failures",
      "do_not_store_full_hidden_prompt_payloads_by_default",
      "do_not_treat_templates_as_runtime_success"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "prompt_template_need_assessment->embedded_template_registry_route",
      "embedded_template_registry_route->system_skill_prompt_projection_route",
      "system_skill_prompt_projection_route->recovery_command_template_projection_route",
      "recovery_command_template_projection_route->prompt_template_receipt_packaging",
      "prompt_template_receipt_packaging->completed",
      "embedded_template_registry_route->failed",
      "system_skill_prompt_projection_route->blocked",
      "recovery_command_template_projection_route->needs_input"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 2,
      "max_tool_calls": 8,
      "token_budget": 12000,
      "loop_signature_detector": "local_coding_prompt_template_guard_v1"
    }
  },
  "prompt_template_guard_contract": {
    "version": "local_coding_prompt_template_guard_v1",
    "source": "forgecode_assimilated_prompt_template_layer",
    "required_primitive_workflow_ids": [
      "embedded_template_registry",
      "system_skill_prompt_projection",
      "recovery_command_template_projection"
    ],
    "required_receipts": [
      "embedded_template_registry_receipt",
      "system_skill_prompt_projection_receipt",
      "recovery_command_template_projection_receipt"
    ],
    "activation_policy": "local coding workflows must route ForgeCode-style embedded templates, prompt partials, skill instructions, recovery templates, summary frames, title prompts, and command frontmatter templates through this guard before runtime prompt assembly uses them",
    "stop_or_route_conditions": [
      "embedded_template_registration_failed",
      "prompt_context_missing_required_fields",
      "skill_inventory_missing",
      "command_frontmatter_invalid",
      "rendered_command_requires_parent_action_route"
    ],
    "non_goals": [
      "do_not_execute_rendered_commands",
      "do_not_replace_tool_call_normalization",
      "do_not_replace_context_compaction_execution",
      "do_not_override_parent_system_or_developer_policy"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "prompt_template_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
