{
  "name": "local_coding_shell_terminal_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "zsh_terminal_context_capture",
        "workflow_id": "zsh_terminal_context_capture",
        "input_contract": "zsh_terminal_context_capture_input_envelope_v1",
        "output_artifact": "zsh_terminal_context_capture_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "zsh_command_dispatcher",
        "workflow_id": "zsh_command_dispatcher",
        "input_contract": "zsh_command_dispatcher_input_envelope_v1",
        "output_artifact": "zsh_command_dispatcher_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "zsh_completion_buffer_projection",
        "workflow_id": "zsh_completion_buffer_projection",
        "input_contract": "zsh_completion_buffer_projection_input_envelope_v1",
        "output_artifact": "zsh_completion_buffer_projection_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "zsh_environment_doctor",
        "workflow_id": "zsh_environment_doctor",
        "input_contract": "zsh_environment_doctor_input_envelope_v1",
        "output_artifact": "zsh_environment_doctor_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_execute_unknown_shell_commands",
      "do_not_mutate_user_shell_configuration",
      "do_not_treat_completion_or_buffer_projection_as_execution",
      "do_not_store_unbounded_terminal_history"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived shell terminal guard for local coding: isolates zsh terminal context capture, colon-command dispatch, completion/buffer projection, and environment diagnostics.",
  "stages": [
    "shell_terminal_need_assessment",
    "terminal_context_capture_route",
    "command_dispatcher_route",
    "completion_buffer_projection_route",
    "environment_doctor_route",
    "shell_terminal_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "zsh_terminal_context_capture",
      "zsh_command_dispatcher",
      "zsh_completion_buffer_projection",
      "zsh_environment_doctor"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_shell_terminal_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "terminal_context_status",
      "command_dispatch_status",
      "completion_buffer_status",
      "environment_doctor_status",
      "shell_terminal_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare and diagnose ForgeCode shell-terminal integration without weakening coding safety boundaries",
      "scope_boundary": "do not edit source files, run validation, commit changes, or modify shell config",
      "validation_calibration": "report shell integration readiness separately from local code correctness",
      "visibility": "do not expose unbounded shell history or sensitive environment values"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact shell-terminal integration receipts for local coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_unbounded_terminal_history",
      "do_not_mutate_user_shell_configuration",
      "do_not_replace_local_safety_receipts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "shell_terminal_need_assessment->terminal_context_capture_route",
      "terminal_context_capture_route->command_dispatcher_route",
      "command_dispatcher_route->completion_buffer_projection_route",
      "completion_buffer_projection_route->environment_doctor_route",
      "environment_doctor_route->shell_terminal_receipt_packaging",
      "shell_terminal_receipt_packaging->completed",
      "terminal_context_capture_route->blocked",
      "command_dispatcher_route->blocked",
      "completion_buffer_projection_route->blocked",
      "environment_doctor_route->needs_input"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 2,
      "max_tool_calls": 12,
      "token_budget": 12000,
      "loop_signature_detector": "local_coding_shell_terminal_guard_v1"
    }
  },
  "shell_terminal_guard_contract": {
    "version": "local_coding_shell_terminal_guard_v1",
    "source": "forgecode_assimilated_shell_terminal_layer",
    "required_primitive_workflow_ids": [
      "zsh_terminal_context_capture",
      "zsh_command_dispatcher",
      "zsh_completion_buffer_projection",
      "zsh_environment_doctor"
    ],
    "required_receipts": [
      "terminal_context_capture_receipt",
      "zsh_command_dispatch_receipt",
      "completion_buffer_projection_receipt",
      "environment_doctor_receipt"
    ],
    "activation_policy": "local coding workflows may route ForgeCode zsh plugin behavior through this guard when shell-integrated invocation, terminal context, completion, or diagnostics are relevant; local file mutation and validation remain owned by safety primitives",
    "stop_or_route_conditions": [
      "shell_plugin_not_loaded",
      "terminal_context_capture_disabled",
      "command_dispatch_requires_external_action_boundary",
      "completion_dependency_missing",
      "doctor_reports_blocking_shell_dependency"
    ],
    "non_goals": [
      "do_not_execute_unknown_shell_commands",
      "do_not_mutate_user_shell_configuration",
      "do_not_treat_terminal_history_as_exact_file_context",
      "do_not_treat_buffer_projection_as_command_execution"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "shell_terminal_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
