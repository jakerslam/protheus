{
  "name": "local_coding_remote_service_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "workspace_remote_auth",
        "workflow_id": "workspace_remote_auth_boundary",
        "input_contract": "workspace_remote_auth_boundary_input_envelope_v1",
        "output_artifact": "workspace_remote_auth_boundary_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "workspace_sync_indexing",
        "workflow_id": "workspace_sync_indexing",
        "input_contract": "workspace_sync_indexing_input_envelope_v1",
        "output_artifact": "workspace_sync_indexing_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "codebase_semantic_search",
        "workflow_id": "codebase_semantic_search",
        "input_contract": "codebase_semantic_search_input_envelope_v1",
        "output_artifact": "codebase_semantic_search_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "provider_transport_boundary",
        "workflow_id": "provider_transport_boundary",
        "input_contract": "provider_transport_boundary_input_envelope_v1",
        "output_artifact": "provider_transport_boundary_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_replace_safe_local_file_reads",
      "do_not_mutate_local_files",
      "do_not_treat_remote_indexing_as_validation",
      "do_not_store_credentials_or_raw_uploaded_payloads"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived remote service guard for local coding: isolate workspace auth, remote sync/indexing, semantic search, and provider transport boundaries from local code-edit execution.",
  "stages": [
    "remote_service_need_assessment",
    "workspace_remote_auth_boundary",
    "workspace_sync_indexing_route",
    "codebase_semantic_search_route",
    "provider_transport_boundary",
    "remote_service_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "workspace_remote_auth_boundary",
      "workspace_sync_indexing",
      "codebase_semantic_search",
      "provider_transport_boundary"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_remote_service_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "remote_auth_status",
      "workspace_sync_status",
      "semantic_search_status",
      "provider_transport_status",
      "freshness_dependency_status",
      "remote_service_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route optional remote service capabilities without weakening local coding safety boundaries",
      "scope_boundary": "do not edit files, run validation, choose architecture, or expose secrets",
      "validation_calibration": "report remote service readiness and freshness separately from local code correctness",
      "visibility": "do not expose credentials, raw provider payloads, or full uploaded file contents"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact remote-service receipts for local coding workflows without storing secrets or uploaded source payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_remote_failures",
      "do_not_store_credentials",
      "do_not_store_raw_uploaded_payloads",
      "do_not_replace_local_safety_receipts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "remote_service_need_assessment->workspace_remote_auth_boundary",
      "workspace_remote_auth_boundary->workspace_sync_indexing_route",
      "workspace_sync_indexing_route->codebase_semantic_search_route",
      "codebase_semantic_search_route->provider_transport_boundary",
      "provider_transport_boundary->remote_service_receipt_packaging",
      "remote_service_receipt_packaging->completed",
      "workspace_remote_auth_boundary->needs_input",
      "workspace_sync_indexing_route->blocked",
      "codebase_semantic_search_route->blocked",
      "provider_transport_boundary->failed"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 2,
      "max_tool_calls": 16,
      "token_budget": 16000,
      "loop_signature_detector": "local_coding_remote_service_guard_v1"
    }
  },
  "remote_service_guard_contract": {
    "version": "local_coding_remote_service_guard_v1",
    "source": "forgecode_assimilated_remote_service_layer",
    "required_primitive_workflow_ids": [
      "workspace_remote_auth_boundary",
      "workspace_sync_indexing",
      "codebase_semantic_search",
      "provider_transport_boundary"
    ],
    "required_receipts": [
      "workspace_remote_auth_receipt",
      "workspace_sync_indexing_receipt",
      "codebase_semantic_search_receipt",
      "provider_transport_receipt",
      "remote_freshness_dependency_receipt"
    ],
    "activation_policy": "local coding workflows may route remote workspace auth, sync, semantic search, and provider transport through this guard when those capabilities are needed, but local file mutation and validation must still use local safety primitives",
    "stop_or_route_conditions": [
      "remote_auth_requires_user_action",
      "workspace_not_indexed_or_not_fresh",
      "remote_search_failed",
      "provider_transport_unavailable",
      "remote_service_would_replace_required_local_read_receipts"
    ],
    "non_goals": [
      "do_not_execute_local_file_mutation",
      "do_not_treat_semantic_search_as_exact_file_context",
      "do_not_treat_workspace_sync_as_validation",
      "do_not_store_or_emit_secrets"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "remote_service_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
