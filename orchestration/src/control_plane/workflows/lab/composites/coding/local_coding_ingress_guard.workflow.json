{
  "name": "local_coding_ingress_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "cli_intent_ingress",
        "workflow_id": "cli_intent_argument_ingress",
        "input_contract": "cli_intent_argument_ingress_input_envelope_v1",
        "output_artifact": "cli_intent_argument_ingress_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "interactive_session_state",
        "workflow_id": "interactive_input_session_state",
        "input_contract": "interactive_input_session_state_input_envelope_v1",
        "output_artifact": "interactive_input_session_state_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "command_prompt_generation",
        "workflow_id": "command_prompt_generation",
        "input_contract": "command_prompt_generation_input_envelope_v1",
        "output_artifact": "command_prompt_generation_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "user_prompt_context_assembly",
        "workflow_id": "user_prompt_context_assembly",
        "input_contract": "user_prompt_context_assembly_input_envelope_v1",
        "output_artifact": "user_prompt_context_assembly_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_execute_generated_commands",
      "do_not_apply_operation_permissions",
      "do_not_mutate_local_files",
      "do_not_replace_runtime_execution_loop"
    ]
  },
  "default": false,
  "description": "Composite ForgeCode-derived ingress guard for local coding: normalize CLI/session input, project interactive state, expand command prompts, assemble user prompt context, and produce receipts before policy, tooling, planning, or coding begins.",
  "stages": [
    "ingress_input_collection",
    "cli_intent_argument_ingress",
    "interactive_session_state_projection",
    "command_prompt_generation_route",
    "user_prompt_context_assembly",
    "ingress_guard_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 1,
    "composed_of_workflow_ids": [
      "cli_intent_argument_ingress",
      "interactive_input_session_state",
      "command_prompt_generation",
      "user_prompt_context_assembly"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_ingress_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "prompt_source",
      "interactive_state_status",
      "command_route_status",
      "rendered_user_prompt_status",
      "conversation_resume_status",
      "attachment_context_status",
      "ingress_stop_or_route"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare a normalized local coding ingress envelope before policy, planning, and runtime execution",
      "scope_boundary": "do not choose architecture, write code, run validation, or execute generated commands",
      "validation_calibration": "report ingress receipts without claiming runtime, policy, or coding success",
      "visibility": "do not expose raw prompts, terminal traces, attachment payloads, or hidden templates"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact ingress guard observations for local coding runs before policy, context, tooling, runtime, and planning layers.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_invalid_ingress",
      "do_not_store_raw_prompt_payloads",
      "do_not_store_raw_terminal_or_attachment_payloads",
      "do_not_mutate_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "ingress_input_collection->cli_intent_argument_ingress",
      "cli_intent_argument_ingress->interactive_session_state_projection",
      "interactive_session_state_projection->command_prompt_generation_route",
      "command_prompt_generation_route->user_prompt_context_assembly",
      "user_prompt_context_assembly->ingress_guard_receipt_packaging",
      "ingress_guard_receipt_packaging->completed",
      "cli_intent_argument_ingress->blocked",
      "interactive_session_state_projection->needs_input",
      "command_prompt_generation_route->blocked",
      "user_prompt_context_assembly->blocked"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 12,
      "max_model_turns": 2,
      "max_tool_calls": 8,
      "token_budget": 12000,
      "loop_signature_detector": "local_coding_ingress_guard_v1"
    }
  },
  "coding_ingress_guard_contract": {
    "version": "local_coding_ingress_guard_v1",
    "source": "forgecode_assimilated_ingress_layer",
    "required_primitive_workflow_ids": [
      "cli_intent_argument_ingress",
      "interactive_input_session_state",
      "command_prompt_generation",
      "user_prompt_context_assembly"
    ],
    "required_receipts": [
      "cli_ingress_receipt",
      "interactive_session_state_receipt",
      "command_prompt_generation_receipt",
      "user_prompt_context_receipt",
      "ingress_route_receipt"
    ],
    "activation_policy": "local coding workflows must normalize ForgeCode-style CLI/session input, command prompt generation, and user prompt context assembly before policy permission, context, tooling, runtime, planning, or local code-edit execution",
    "stop_or_route_conditions": [
      "interactive_exit_requested",
      "invalid_directory_or_sandbox",
      "unsupported_subcommand_for_local_coding",
      "command_generation_requires_execution_permission",
      "attachment_parse_failed_for_required_local_context",
      "prompt_context_empty_or_unusable"
    ],
    "non_goals": [
      "do_not_execute_generated_commands",
      "do_not_choose_product_architecture",
      "do_not_apply_operation_permissions",
      "do_not_mutate_files"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "ingress_guard_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
