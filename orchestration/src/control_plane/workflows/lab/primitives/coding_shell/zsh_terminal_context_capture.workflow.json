{
  "name": "zsh_terminal_context_capture",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for zsh preexec/precmd terminal command context capture and OSC 133 marker boundaries.",
  "stages": [
    "terminal_context_need_assessment",
    "osc133_support_detection",
    "preexec_command_start_capture",
    "precmd_exit_code_capture",
    "ring_buffer_export_projection",
    "terminal_context_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "zsh_terminal_context_capture_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "terminal_capture_status",
      "osc133_status",
      "ring_buffer_status",
      "export_status",
      "terminal_context_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "capture recent terminal command context without leaking shell state globally",
      "scope_boundary": "do not execute commands, mutate files, or treat terminal history as exact repo context",
      "validation_calibration": "report captured command metadata separately from command output correctness",
      "visibility": "do not expose full terminal history beyond the bounded command-context receipt"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record bounded terminal context capture receipts for shell-integrated coding sessions.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_unbounded_terminal_history",
      "do_not_emit_osc133_when_terminal_support_is_unknown",
      "do_not_export_context_variables_outside_child_process"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "terminal_context_need_assessment->osc133_support_detection",
      "osc133_support_detection->preexec_command_start_capture",
      "preexec_command_start_capture->precmd_exit_code_capture",
      "precmd_exit_code_capture->ring_buffer_export_projection",
      "ring_buffer_export_projection->terminal_context_receipt_packaging",
      "terminal_context_receipt_packaging->completed",
      "osc133_support_detection->completed",
      "preexec_command_start_capture->blocked",
      "precmd_exit_code_capture->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 5000,
      "loop_signature_detector": "zsh_terminal_context_capture_v1"
    }
  },
  "shell_terminal_primitive_contract": {
    "version": "zsh_terminal_context_capture_v1",
    "source_evidence": [
      "shell-plugin/lib/context.zsh",
      "shell-plugin/lib/config.zsh",
      "shell-plugin/lib/helpers.zsh"
    ],
    "required_behaviors": [
      "respect_forge_term_master_switch_before_recording_terminal_context",
      "cache_osc133_support_detection_per_shell_session",
      "emit_osc133_only_for_supported_or_explicitly_enabled_terminals",
      "capture_preexec_command_text_and_timestamp_before_command_execution",
      "capture_precmd_exit_code_as_first_operation_after_command_completion",
      "emit_osc133_d_marker_even_when_context_capture_is_disabled_to_keep_marker_pairs_balanced",
      "trim_command_exit_code_and_timestamp_ring_buffers_to_configured_max_command_count",
      "export_commands_exit_codes_and_timestamps_as_ascii_unit_separator_delimited_env_vars_only_to_child_forge_processes",
      "preserve_session_model_provider_and_reasoning_overrides only for child forge invocations"
    ],
    "output_receipts": [
      "osc133_detection_receipt",
      "preexec_capture_receipt",
      "precmd_exit_capture_receipt",
      "ring_buffer_trim_receipt",
      "child_env_export_receipt"
    ],
    "stop_conditions": [
      "terminal_context_capture_disabled",
      "unsupported_terminal_for_osc133",
      "zsh_hook_registration_failed",
      "ring_buffer_export_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "terminal_context_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
