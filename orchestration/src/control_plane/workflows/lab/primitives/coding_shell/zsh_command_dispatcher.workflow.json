{
  "name": "zsh_command_dispatcher",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for zsh colon-command parsing, command dispatch, active-agent selection, and conversation-aware invocation.",
  "stages": [
    "zle_buffer_route_classification",
    "colon_command_parse",
    "command_alias_and_type_resolution",
    "conversation_id_boundary",
    "action_dispatch_projection",
    "dispatcher_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "zsh_command_dispatcher_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "buffer_route",
      "command_route",
      "active_agent_status",
      "conversation_status",
      "action_dispatch_status",
      "dispatcher_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route zsh colon commands to the appropriate ForgeCode action boundary",
      "scope_boundary": "do not perform unapproved side effects or treat command dispatch as coding completion",
      "validation_calibration": "distinguish command route selection from action execution success",
      "visibility": "surface command-not-found and missing-conversation blockers compactly"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact zsh command-dispatch receipts without leaking shell internals.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_execute_unknown_commands",
      "do_not_commit_or_authenticate_without_external_action_boundary",
      "do_not_mutate_buffer_without_buffer_projection_receipt"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "zle_buffer_route_classification->colon_command_parse",
      "colon_command_parse->command_alias_and_type_resolution",
      "command_alias_and_type_resolution->conversation_id_boundary",
      "conversation_id_boundary->action_dispatch_projection",
      "action_dispatch_projection->dispatcher_receipt_packaging",
      "dispatcher_receipt_packaging->completed",
      "zle_buffer_route_classification->completed",
      "command_alias_and_type_resolution->blocked",
      "conversation_id_boundary->needs_input",
      "action_dispatch_projection->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 5000,
      "loop_signature_detector": "zsh_command_dispatcher_v1"
    }
  },
  "shell_terminal_primitive_contract": {
    "version": "zsh_command_dispatcher_v1",
    "source_evidence": [
      "shell-plugin/lib/dispatcher.zsh",
      "shell-plugin/lib/actions/core.zsh",
      "shell-plugin/lib/actions/git.zsh",
      "shell-plugin/lib/actions/auth.zsh",
      "shell-plugin/lib/actions/editor.zsh"
    ],
    "required_behaviors": [
      "leave_non_colon_buffers_to_normal_accept_line",
      "parse_colon_command_with_optional_parameters",
      "support_default_colon_space_prompt_route",
      "save_original_buffer_to_shell_history_before_transformation",
      "map_ask_alias_to_sage_and_plan_alias_to_muse",
      "validate_user_action_against_cached_show_commands_when_present",
      "route_custom_commands_to_cmd_execute_with_conversation_id",
      "set_active_agent_when_agent_command_has_no_input_text",
      "generate_conversation_id_when_prompt_execution_needs_one",
      "require_active_conversation_for_dump_compact_and_retry_actions",
      "start_background_workspace_sync_and_update_check_after_interactive_prompt_execution",
      "keep_commit_preview_and_suggest_as_buffer_projection_routes_instead_of immediate execution"
    ],
    "output_receipts": [
      "zle_buffer_route_receipt",
      "colon_command_parse_receipt",
      "active_agent_selection_receipt",
      "conversation_id_receipt",
      "action_dispatch_receipt"
    ],
    "stop_conditions": [
      "command_not_found",
      "custom_command_requires_conversation_creation",
      "conversation_required_but_missing",
      "external_action_requires_operator_boundary",
      "interactive_tty_unavailable"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "dispatcher_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
