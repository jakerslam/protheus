{
  "name": "zsh_environment_doctor",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for zsh environment diagnostics, dependency checks, keyboard/meta guidance, and shell setup status.",
  "stages": [
    "doctor_request_classification",
    "shell_and_plugin_status_checks",
    "dependency_version_checks",
    "keyboard_meta_configuration_checks",
    "font_and_theme_projection",
    "doctor_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "zsh_environment_doctor_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "shell_status",
      "plugin_status",
      "dependency_status",
      "keyboard_status",
      "font_status",
      "doctor_exit_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "diagnose shell integration readiness with actionable setup guidance",
      "scope_boundary": "do not modify user shell configuration unless routed through explicit setup action",
      "validation_calibration": "report pass, warning, and failure counts separately",
      "visibility": "show setup instructions without leaking unrelated shell configuration"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact shell environment diagnostic receipts.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_source_or_emit_sensitive_shell_values",
      "do_not_modify_zshrc_inside_doctor",
      "do_not_treat_environment_readiness_as_coding_success"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "doctor_request_classification->shell_and_plugin_status_checks",
      "shell_and_plugin_status_checks->dependency_version_checks",
      "dependency_version_checks->keyboard_meta_configuration_checks",
      "keyboard_meta_configuration_checks->font_and_theme_projection",
      "font_and_theme_projection->doctor_receipt_packaging",
      "doctor_receipt_packaging->completed",
      "shell_and_plugin_status_checks->blocked",
      "dependency_version_checks->blocked",
      "keyboard_meta_configuration_checks->needs_input"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 7000,
      "loop_signature_detector": "zsh_environment_doctor_v1"
    }
  },
  "shell_terminal_primitive_contract": {
    "version": "zsh_environment_doctor_v1",
    "source_evidence": [
      "shell-plugin/doctor.zsh",
      "shell-plugin/keyboard.zsh",
      "shell-plugin/forge.setup.zsh"
    ],
    "required_behaviors": [
      "check_zsh_version_and_warn_below_recommended_version",
      "detect_terminal_program_or_term_value",
      "check_forge_binary_presence_and_version",
      "check_forge_plugin_loaded_status",
      "detect_plugin_loading_order_relative_to_oh_my_zsh_plugins_array",
      "check_theme_loaded_or_powerlevel10k_override_status",
      "check_fzf_fd_or_fdfind_and_bat_dependency_versions",
      "check_zsh_autosuggestions_and_zsh_syntax_highlighting_availability",
      "report_editor_configuration_precedence_from_forge_editor_then_editor",
      "inspect_platform_specific_alt_or_option_meta_key_configuration",
      "report_nerd_font_enablement_and_manual_visual_check_guidance",
      "exit_zero_when_only_warnings_are_present_and_nonzero_when_failures_are_present"
    ],
    "output_receipts": [
      "shell_version_receipt",
      "plugin_status_receipt",
      "dependency_version_receipt",
      "keyboard_meta_receipt",
      "doctor_summary_receipt"
    ],
    "stop_conditions": [
      "forge_binary_missing",
      "required_fzf_dependency_missing_or_too_old",
      "plugin_not_loaded",
      "shell_configuration_unreadable",
      "manual_keyboard_verification_required"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "doctor_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
