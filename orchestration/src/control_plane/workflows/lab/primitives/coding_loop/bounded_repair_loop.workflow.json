{
  "name": "bounded_repair_loop",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "composite",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [
      {
        "capability": "failure_diagnosis",
        "workflow_id": "failure_diagnosis",
        "input_contract": "failure_diagnosis_input_envelope_v1",
        "output_artifact": "failure_diagnosis_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "safe_code_edit",
        "workflow_id": "local_code_edit_execution",
        "input_contract": "local_code_edit_slice_input_envelope_v1",
        "output_artifact": "local_code_edit_execution_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "validation_command",
        "workflow_id": "validation_command_runner",
        "input_contract": "validation_command_runner_input_envelope_v1",
        "output_artifact": "validation_command_runner_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "undo_recovery",
        "workflow_id": "safe_file_undo",
        "input_contract": "safe_file_undo_input_envelope_v1",
        "output_artifact": "safe_file_undo_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      },
      {
        "capability": "followup_gate",
        "workflow_id": "followup_clarification_gate",
        "input_contract": "followup_clarification_gate_input_envelope_v1",
        "output_artifact": "followup_clarification_gate_result_artifact_v1",
        "return_policy": "return_single_terminal_artifact_to_parent",
        "internal_trace_visibility": "refs_only"
      }
    ],
    "non_goals": [
      "do_not_expand_beyond_current_checkpoint",
      "do_not_retry_without_new_diagnosis",
      "do_not_hide_repair_budget_exhaustion"
    ]
  },
  "default": false,
  "description": "ForgeCode-derived composite repair loop that diagnoses a failed coding slice, retries within the smallest safe scope, validates, and stops on explicit barriers.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "composite",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.bounded_repair_loop",
    "special_case_policy": "Repair behavior must be driven by failure classes, receipts, child workflow outputs, and policy budgets rather than named eval cases.",
    "monotonic_lower_level_regression_policy": "Repair-loop changes must not alter child primitive semantics or make unrelated lower-level coding tasks enter repair."
  },
  "stages": [
    "failure_receipt_ingest",
    "diagnosis",
    "repair_scope_confirmation",
    "safe_repair_edit",
    "validation_rerun",
    "undo_or_escalate_if_worse",
    "repair_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 2,
    "composed_of_workflow_ids": [
      "failure_diagnosis",
      "local_code_edit_execution",
      "validation_command_runner",
      "safe_file_undo",
      "followup_clarification_gate"
    ]
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "bounded_repair_loop_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "failure_class",
      "repair_attempts",
      "changed_files",
      "validation_results",
      "undo_actions",
      "stop_reason",
      "failure_result_envelope"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "repair the failing slice or state the precise stop reason",
      "scope_boundary": "repair only the smallest diagnosed scope",
      "validation_calibration": "report validation reruns and failures exactly",
      "architecture_calibration": "stop if repair would change architecture or product scope",
      "failure_routing": "return coding_failure_result_envelope_v1 when repair is blocked, fails, needs user input, or exhausts budget",
      "visibility": "do not expose raw workflow state or hidden reasoning"
    }
  },
  "failure_result_envelope_contract": {
    "schema_version": "coding_failure_result_envelope_v1",
    "required_when_terminal_state_in": [
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "required_fields": [
      "status",
      "failure_class",
      "user_summary",
      "recommended_next_action",
      "safe_to_retry",
      "requires_user_input",
      "repair_scope",
      "repair_attempts",
      "evidence_refs",
      "schema_version",
      "breakpoint_validity",
      "internal_repair_attempted",
      "repair_result",
      "user_visible_summary"
    ],
    "repair_outcomes": {
      "repair_succeeded": {
        "status": "passed",
        "failure_class": "none",
        "recommended_next_action": "continue"
      },
      "runtime_unavailable": {
        "status": "blocked",
        "recommended_next_action": "ask_user_to_install_runtime_or_switch_stack"
      },
      "repair_budget_exhausted": {
        "status": "failed",
        "recommended_next_action": "stop_and_report"
      },
      "user_decision_required": {
        "status": "needs_user_input",
        "recommended_next_action": "ask_user_for_decision"
      }
    },
    "repair_result_values": [
      "repaired",
      "not_repaired",
      "not_attempted",
      "blocked_by_environment",
      "blocked_by_user_decision"
    ],
    "required_behavior": [
      "normalize_failure_result_before_returning_to_parent",
      "mark_invalid_user_feedback_requests_as_requires_user_input_false",
      "include_internal_repair_attempted_and_repair_result"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact repair-loop attempts, failure classes, validation reruns, and stop reasons.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_suppress_failed_repairs",
      "do_not_continue_after_budget_exhaustion"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "failure_receipt_ingest->diagnosis",
      "diagnosis->repair_scope_confirmation",
      "repair_scope_confirmation->safe_repair_edit",
      "safe_repair_edit->validation_rerun",
      "validation_rerun->repair_receipt_packaging",
      "validation_rerun->safe_repair_edit",
      "validation_rerun->undo_or_escalate_if_worse",
      "undo_or_escalate_if_worse->repair_receipt_packaging",
      "repair_receipt_packaging->completed",
      "diagnosis->blocked",
      "repair_scope_confirmation->needs_input",
      "safe_repair_edit->failed",
      "validation_rerun->failed"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 2,
      "on_failure": "stop_with_repair_budget_exhausted"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 14,
      "max_model_turns": 8,
      "max_tool_calls": 20,
      "token_budget": 24000,
      "loop_signature_detector": "bounded_repair_loop_v1"
    }
  },
  "loop_primitive_contract": {
    "version": "bounded_repair_loop_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/fs_undo.rs",
      "crates/forge_services/src/tool_services/followup.rs",
      "crates/forge_services/src/tool_services/shell.rs",
      "crates/forge_tracker/src/event.rs"
    ],
    "required_behaviors": [
      "diagnose_before_retry",
      "normalize_failure_result_before_returning_to_parent",
      "retry_only_smallest_repair_scope",
      "rerun_validation_after_repair",
      "undo_or_escalate_if_repair_makes_state_worse",
      "stop_after_repair_budget_exhausted",
      "ask_followup_only_for_blocking_decisions"
    ],
    "stop_conditions": [
      "repair_budget_exhausted",
      "runtime_unavailable",
      "repair_scope_would_expand_checkpoint",
      "user_decision_required",
      "undo_required_but_snapshot_missing",
      "validation_still_failing"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "repair_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "breakpoint_repair_contract": {
    "schema_version": "coding_bad_breakpoint_repair_v1",
    "purpose": "Convert invalid user-feedback breakpoints into bounded internal repair actions before returning to the parent workflow.",
    "selection_policy": "Select repairs by generalized repair class first; use observed repairable breakpoints only as regression examples and compatibility fixtures.",
    "repair_strategy_classes": [
      {
        "class": "setup_boundary_recovery",
        "repair": "prepare_local_workspace_boundary_and_continue",
        "applies_to": [
          "missing_or_uninitialized_assigned_root",
          "project_boundary_or_workspace_detection_problem",
          "local_output_path_not_prepared",
          "current_working_directory_not_locked_to_assigned_root",
          "generated_files_detected_outside_assigned_root"
        ]
      },
      {
        "class": "runtime_or_language_compatibility_recovery",
        "repair": "adapt_implementation_to_available_runtime_without_changing_user_visible_behavior",
        "applies_to": [
          "language_api_not_supported_by_available_runtime",
          "toolchain_invocation_needs_local_environment_adjustment",
          "stdlib_or_dependency_mode_constraint_requires_equivalent_implementation",
          "runtime_command_alias_needs_resolution",
          "behavior_preserving_language_api_substitution_available"
        ]
      },
      {
        "class": "validation_and_evidence_completion",
        "repair": "complete_or_regenerate_validation_evidence_before_returning",
        "applies_to": [
          "validation_was_not_run",
          "validation_passed_but_receipt_is_missing",
          "worker_report_omits_required_evidence",
          "validation_command_did_not_discover_tests",
          "validation_command_uses_missing_runtime_alias",
          "receipt_or_artifact_write_needs_compaction"
        ]
      },
      {
        "class": "environment_availability_with_viable_fallback",
        "repair": "choose_available_compatible_runtime_or_tooling_path_and_record_substitution",
        "applies_to": [
          "required_runtime_missing_with_alternate_allowed",
          "required_tool_missing_with_compatible_builtin_or_stdlib_path"
        ]
      }
    ],
    "mandatory_internal_repair_rules": {
      "behavior_preserving_compatibility_fix": "must_repair_without_user_feedback",
      "runtime_command_alias_resolution": "must_resolve_available_alias_before_returning_environment_blocker",
      "assigned_root_or_cwd_fix": "must_prepare_or_lock_root_before_escalation",
      "zero_test_validation_fix": "must_replace_with_explicit_test_discovery_before_counting_validation",
      "receipt_or_artifact_compaction": "must_compact_evidence_before_escalating_disk_or_artifact_size_issue"
    },
    "observed_repairable_breakpoints": [
      {
        "breakpoint": "assigned_root_missing",
        "repair": "create_assigned_root_and_continue",
        "max_attempts": 1
      },
      {
        "breakpoint": "parent_workspace_or_project_boundary_conflict",
        "repair": "isolate_project_boundary_or_set_local_target_dir",
        "max_attempts": 1
      },
      {
        "breakpoint": "runtime_api_compatibility_bug",
        "repair": "replace_api_with_runtime_compatible_equivalent",
        "max_attempts": 1
      },
      {
        "breakpoint": "validation_receipt_missing_or_incomplete",
        "repair": "rerun_or_summarize_validation_and_emit_receipt",
        "max_attempts": 1
      },
      {
        "breakpoint": "worker_report_missing_validation_summary",
        "repair": "request_or_regenerate_validation_summary_before_counting_attempt",
        "max_attempts": 1
      }
    ],
    "non_repairable_user_feedback_breakpoints": [
      "ambiguous_acceptance_criteria",
      "conflicting_requirements",
      "missing_credentials_or_secret",
      "destructive_or_externally_visible_action_required",
      "unavailable_required_runtime_with_no_acceptable_fallback",
      "architecture_or_stack_choice_requires_product_decision",
      "legal_security_privacy_or_data_retention_decision_required"
    ],
    "return_policy": {
      "repaired_and_validated": "return_success_with_repair_note_and_evidence",
      "repair_failed_but_user_not_needed": "return_failure_envelope_with_requires_user_input_false",
      "user_decision_required": "return_failure_envelope_with_requires_user_input_true"
    }
  },
  "quality_contracts": [
    "bad_breakpoint_repair",
    "bounded_internal_recovery",
    "no_invalid_user_feedback_escalation"
  ],
  "loop_contract": {
    "setup_and_evidence_repairs_are_in_scope": true,
    "safe_repairs_do_not_consume_user_feedback_checkpoint": true,
    "stop_conditions": [
      "repair_budget_exhausted",
      "valid_user_feedback_checkpoint",
      "true_environment_blocker_without_fallback",
      "validation_passed_with_evidence"
    ]
  }
}
