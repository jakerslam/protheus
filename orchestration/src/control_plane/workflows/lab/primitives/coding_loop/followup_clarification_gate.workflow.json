{
  "name": "followup_clarification_gate",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for stopping a coding loop to ask a bounded clarification only when ambiguity blocks safe progress.",
  "stages": [
    "ambiguity_detection",
    "question_scope_check",
    "option_packaging",
    "user_followup_request",
    "answer_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "followup_clarification_gate_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "question",
      "options",
      "multiple_allowed",
      "blocking_reason",
      "answer_receipt",
      "failure_result_envelope"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "ask the smallest question needed to proceed safely",
      "scope_boundary": "do not use follow-up for questions that can be answered from local context",
      "validation_calibration": "state what decision is blocked",
      "failure_routing": "emit coding_failure_result_envelope_v1 with needs_user_input so the parent workflow can pause and ask the user",
      "visibility": "make the question visible and keep internal traces hidden"
    }
  },
  "failure_result_envelope_contract": {
    "schema_version": "coding_failure_result_envelope_v1",
    "required_fields": [
      "status",
      "failure_class",
      "user_summary",
      "recommended_next_action",
      "safe_to_retry",
      "requires_user_input",
      "repair_scope",
      "evidence_refs"
    ],
    "fixed_values": {
      "status": "needs_user_input",
      "failure_class": "user_decision_required",
      "recommended_next_action": "ask_user_for_decision",
      "safe_to_retry": false,
      "requires_user_input": true
    },
    "user_summary_policy": "state the blocked decision in user-facing language and offer bounded options when available",
    "fixed_values_when_gate_accepts": {
      "breakpoint_validity": "valid_user_feedback_request",
      "requires_user_input": true,
      "recommended_next_action": "ask_user_for_decision"
    },
    "required_rejection_behavior": [
      "do_not_ask_user_for_repairable_local_failure",
      "do_not_ask_user_for_workflow_or_agent_defect",
      "do_not_ask_user_for_environment_blocker_when_viable_fallback_exists"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact follow-up gates and blocking reasons for coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "failure_lifecycle_archive",
      "hot_ring_buffer",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_ask_open_ended_questions_when_options_are_available",
      "do_not_continue_past_blocking_user_decisions"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "ambiguity_detection->question_scope_check",
      "question_scope_check->option_packaging",
      "option_packaging->user_followup_request",
      "user_followup_request->answer_receipt_packaging",
      "answer_receipt_packaging->completed",
      "question_scope_check->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 3000,
      "loop_signature_detector": "followup_clarification_gate_v1"
    }
  },
  "loop_primitive_contract": {
    "version": "followup_clarification_gate_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/followup.rs"
    ],
    "required_behaviors": [
      "question_required",
      "options_supported",
      "single_or_multi_select_supported",
      "result_returned_as_receipt",
      "use_judiciously_only_for_blocking_ambiguity"
    ],
    "stop_conditions": [
      "question_not_blocking",
      "question_too_broad",
      "user_answer_missing"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "answer_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  },
  "user_feedback_gate_contract": {
    "schema_version": "coding_user_feedback_gate_v1",
    "purpose": "Allow user-facing clarification only for decisions the user must make; reject repairable or workflow-defect breakpoints.",
    "entry_requirements": {
      "breakpoint_triage_completed": true,
      "bounded_repair_attempted_when_safe": true,
      "failure_envelope_has_breakpoint_class": true,
      "failure_envelope_has_breakpoint_validity": true
    },
    "reject_as_invalid_user_feedback_classes": [
      "setup_boundary_recovery",
      "runtime_or_language_compatibility_recovery",
      "validation_and_evidence_completion",
      "environment_availability_with_viable_fallback",
      "behavior_preserving_runtime_compatibility_recovery",
      "validation_command_discovery_recovery",
      "workspace_root_lock_recovery",
      "artifact_hygiene_recovery",
      "repairable_local_failure",
      "workflow_or_agent_defect"
    ],
    "observed_rejected_breakpoints": [
      "assigned_root_missing",
      "parent_workspace_or_project_boundary_conflict",
      "runtime_api_compatibility_bug",
      "validation_receipt_missing_or_incomplete",
      "worker_report_missing_validation_summary",
      "repairable_local_failure",
      "workflow_or_agent_defect"
    ],
    "allow_user_feedback_only_for": [
      "ambiguous_acceptance_criteria",
      "conflicting_requirements",
      "missing_credentials_or_secret",
      "destructive_or_externally_visible_action_required",
      "unavailable_required_runtime_with_no_acceptable_fallback",
      "architecture_or_stack_choice_requires_product_decision",
      "legal_security_privacy_or_data_retention_decision_required"
    ],
    "on_rejected_breakpoint": "return_to_failure_diagnosis_or_bounded_repair_loop",
    "forbidden_user_question_policy": {
      "do_not_ask_for_behavior_preserving_local_repair": true,
      "do_not_ask_for_runtime_alias_substitution_when_available": true,
      "do_not_ask_for_explicit_test_discovery_repair": true,
      "do_not_ask_for_assigned_root_creation_or_cwd_lock": true,
      "do_not_ask_for_compact_receipt_or_artifact_rewrite": true
    },
    "required_user_prompt_shape": {
      "include_concrete_decision_needed": true,
      "include_why_agent_cannot_safely_choose": true,
      "include_2_to_3_recommended_options_when_possible": true,
      "avoid_exposing_internal_workflow_errors_as_user_tasks": true
    }
  },
  "quality_contracts": [
    "user_feedback_allowlist_enforced",
    "invalid_breakpoint_rejection",
    "concrete_user_decision_only"
  ]
}
