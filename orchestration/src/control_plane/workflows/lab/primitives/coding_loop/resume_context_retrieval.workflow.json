{
  "name": "resume_context_retrieval",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive for retrieving prior coding memory for the current project before checkpoint planning.",
  "stages": [
    "project_identity_ingest",
    "memory_query_plan",
    "memory_read_request",
    "resume_candidate_filtering",
    "resume_context_summary_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "resume_context_retrieval_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "project_id",
      "project_fingerprint",
      "memory_query",
      "memory_hits",
      "resume_context_summary",
      "memory_confidence_score",
      "memory_refs"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "retrieve useful prior project context without treating it as authoritative",
      "scope_boundary": "retrieve only coding memory for the current project identity and tags",
      "validation_calibration": "report no-hit and low-confidence states explicitly",
      "visibility": "return a compact resume summary and memory refs"
    }
  },
  "resume_context_retrieval_contract": {
    "version": "resume_context_retrieval_v1",
    "memory_backend_candidates": [
      "core/local/state/memory/runtime_memory.sqlite",
      "INFRING_MEMORY_DB_PATH",
      "core/local/state/memory/pure_workspace_memory_v1.jsonl"
    ],
    "query_keys": [
      "project_fingerprint",
      "project_root",
      "repo_name",
      "branch_name",
      "coding",
      "checkpoint",
      "resume"
    ],
    "required_behavior": [
      "prefer_project_fingerprint_matches",
      "fall_back_to_project_root_and_tags",
      "return_no_memory_found_as_non_blocking",
      "never_skip_memory_freshness_guard"
    ],
    "confidence_scoring": {
      "exact_project_fingerprint": 0.95,
      "project_root_match": 0.75,
      "repo_name_only": 0.45,
      "tag_only": 0.25
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact memory retrieval attempts and resume candidate refs for coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "failure_lifecycle_archive",
      "hot_ring_buffer"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_claim_memory_freshness_before_guard"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "project_identity_ingest->memory_query_plan",
      "memory_query_plan->memory_read_request",
      "memory_read_request->resume_candidate_filtering",
      "resume_candidate_filtering->resume_context_summary_packaging",
      "resume_context_summary_packaging->completed",
      "memory_read_request->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_no_memory_found_non_blocking"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "resume_context_retrieval_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "resume_context_summary_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_override_current_files",
      "do_not_write_checkpoint_memory",
      "do_not_expand_scope_from_old_memory"
    ]
  }
}
