{
  "name": "memory_freshness_guard",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive for comparing retrieved coding memory against current project context before it can influence planning.",
  "stages": [
    "current_context_ingest",
    "retrieved_memory_ingest",
    "fingerprint_comparison",
    "architecture_and_validation_delta_check",
    "freshness_status_decision",
    "freshness_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "memory_freshness_guard_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "memory_freshness_status",
      "memory_confidence_score",
      "freshness_reasons",
      "allowed_memory_use",
      "stale_memory_refs",
      "current_files_source_of_truth"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "allow useful resume context while preventing stale memory from controlling code decisions",
      "scope_boundary": "judge memory freshness only for the current project and checkpoint",
      "validation_calibration": "downgrade stale or conflicting memory to hints only",
      "visibility": "state memory status and allowed use concisely"
    }
  },
  "memory_freshness_guard_contract": {
    "version": "memory_freshness_guard_v1",
    "statuses": [
      "fresh",
      "probably_fresh",
      "stale_hints_only",
      "conflicting_ignore_for_decisions",
      "no_memory_found"
    ],
    "source_of_truth_rule": "current_workspace_files_are_authoritative",
    "freshness_inputs": [
      "project_fingerprint",
      "architecture_summary",
      "stack_summary",
      "validation_commands",
      "key_file_fingerprints",
      "memory_updated_at",
      "checkpoint_memory_refs"
    ],
    "allowed_memory_use": {
      "fresh": "seed_checkpoint_definition_and_slice_planning",
      "probably_fresh": "seed_planning_after_current_file_confirmation",
      "stale_hints_only": "use_only_as_search_hints",
      "conflicting_ignore_for_decisions": "ignore_for_architecture_and_implementation_decisions",
      "no_memory_found": "continue_without_memory"
    },
    "required_behavior": [
      "run_before_checkpoint_definition",
      "never_skip_current_file_confirmation_for_targeted_edits",
      "emit_freshness_receipt_even_when_no_memory_found",
      "record_conflicts_for_checkpoint_memory_write"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact memory freshness decisions and stale-memory safeguards.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "failure_lifecycle_archive",
      "hot_ring_buffer"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_allow_stale_memory_to_override_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "current_context_ingest->retrieved_memory_ingest",
      "retrieved_memory_ingest->fingerprint_comparison",
      "fingerprint_comparison->architecture_and_validation_delta_check",
      "architecture_and_validation_delta_check->freshness_status_decision",
      "freshness_status_decision->freshness_receipt_packaging",
      "freshness_receipt_packaging->completed",
      "current_context_ingest->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "continue_without_memory"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 2,
      "token_budget": 5000,
      "loop_signature_detector": "memory_freshness_guard_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "freshness_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_write_code",
      "do_not_retrieve_memory",
      "do_not_treat_memory_as_authoritative"
    ]
  }
}
