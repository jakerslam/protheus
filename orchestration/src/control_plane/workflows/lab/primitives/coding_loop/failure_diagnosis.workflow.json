{
  "name": "failure_diagnosis",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive for classifying coding-slice failures into stale context, ambiguous patch, validation failure, user decision, or unrecoverable blocker.",
  "stages": [
    "failure_receipt_ingest",
    "failure_classification",
    "repairability_assessment",
    "smallest_scope_selection",
    "diagnosis_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "failure_diagnosis_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "failure_class",
      "repairable",
      "smallest_repair_scope",
      "requires_user_input",
      "diagnosis_evidence"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "explain the actionable failure class without overgeneralizing",
      "scope_boundary": "diagnose only the current coding slice/checkpoint",
      "validation_calibration": "preserve raw exit/failure status as evidence refs",
      "visibility": "summarize diagnosis without exposing raw hidden reasoning"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact failure diagnosis receipts for coding repair loops.",
    "required_lanes": [
      "compact_ledger",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_expand_repair_scope",
      "do_not_hide_unrecoverable_blockers"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "failure_diagnosis_input_envelope_v1",
    "allowed_transitions": [
      "failure_receipt_ingest->failure_classification",
      "failure_classification->repairability_assessment",
      "repairability_assessment->smallest_scope_selection",
      "smallest_scope_selection->diagnosis_receipt_packaging",
      "diagnosis_receipt_packaging->completed",
      "failure_receipt_ingest->blocked",
      "repairability_assessment->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "memory"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 2,
      "max_tool_calls": 2,
      "token_budget": 6000,
      "loop_signature_detector": "failure_diagnosis_v1"
    }
  },
  "loop_primitive_contract": {
    "version": "failure_diagnosis_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/fs_patch.rs",
      "crates/forge_services/src/tool_services/shell.rs",
      "crates/forge_tracker/src/event.rs"
    ],
    "failure_classes": [
      "stale_context_no_match",
      "ambiguous_multiple_matches",
      "validation_command_failed",
      "snapshot_restore_required",
      "user_decision_required",
      "unrecoverable_blocker"
    ],
    "required_behaviors": [
      "classify_from_structured_receipts",
      "select_smallest_repair_scope",
      "preserve_failure_evidence_refs",
      "escalate_user_decision_when_safe_default_missing"
    ],
    "stop_conditions": [
      "missing_failure_receipt",
      "failure_class_unknown",
      "repair_scope_would_expand_checkpoint"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  }
}
