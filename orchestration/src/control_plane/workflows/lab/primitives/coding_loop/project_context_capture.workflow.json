{
  "name": "project_context_capture",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive for capturing compact current-project context for resumable coding workflows.",
  "stages": [
    "project_root_identification",
    "architecture_marker_scan",
    "stack_and_runtime_detection",
    "source_boundary_capture",
    "validation_command_capture",
    "project_fingerprint_projection",
    "context_capture_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "project_context_capture_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "project_id",
      "project_root",
      "project_fingerprint",
      "architecture_summary",
      "stack_summary",
      "source_boundaries",
      "validation_commands",
      "context_artifact_refs"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "capture reusable project context without performing implementation work",
      "scope_boundary": "summarize current project shape only; do not infer unstated product requirements",
      "validation_calibration": "record validation commands as discovered or unknown, not as executed",
      "visibility": "return compact refs and summaries only"
    }
  },
  "project_context_capture_contract": {
    "version": "project_context_capture_v1",
    "required_fields": [
      "project_id",
      "project_root",
      "project_fingerprint",
      "architecture_summary",
      "stack_summary",
      "source_boundaries",
      "validation_commands",
      "key_files",
      "captured_at"
    ],
    "fingerprint_inputs": [
      "project_root",
      "package_or_manifest_files",
      "architecture_files",
      "validation_commands",
      "source_boundary_file_list"
    ],
    "artifact_policy": {
      "large_context_artifacts": "write_under_core_local_state_coding_memory_project_id",
      "memory_row_payload": "compact_summary_plus_artifact_refs_only"
    },
    "non_goals": [
      "do_not_store_full_source_files",
      "do_not_skip_later_targeted_reads",
      "do_not_mutate_project_code"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact project-context captures for resumable coding sessions.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "failure_lifecycle_archive",
      "hot_ring_buffer"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_large_source_bodies"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "project_root_identification->architecture_marker_scan",
      "architecture_marker_scan->stack_and_runtime_detection",
      "stack_and_runtime_detection->source_boundary_capture",
      "source_boundary_capture->validation_command_capture",
      "validation_command_capture->project_fingerprint_projection",
      "project_fingerprint_projection->context_capture_receipt_packaging",
      "context_capture_receipt_packaging->completed",
      "project_root_identification->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 8000,
      "loop_signature_detector": "project_context_capture_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "context_capture_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_write_code",
      "do_not_replace_local_file_reads",
      "do_not_store_raw_source_bodies"
    ]
  }
}
