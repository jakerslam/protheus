{
  "name": "checkpoint_memory_write",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive for writing compact coding checkpoint memory after validation, evidence packaging, or structured failure.",
  "stages": [
    "checkpoint_result_ingest",
    "memory_write_eligibility_gate",
    "compact_checkpoint_summary_projection",
    "artifact_ref_packaging",
    "memory_write_request",
    "memory_write_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "checkpoint_memory_write_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "memory_write_status",
      "memory_row_id",
      "memory_tags",
      "checkpoint_summary",
      "artifact_refs",
      "next_checkpoint",
      "checkpoint_memory_receipt"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "persist a compact resumable checkpoint summary without storing large raw source files",
      "scope_boundary": "write only current checkpoint context and refs",
      "validation_calibration": "write pass, fail, blocked, and needs-input states honestly",
      "visibility": "return memory write status and refs only"
    }
  },
  "checkpoint_memory_write_contract": {
    "version": "checkpoint_memory_write_v1",
    "write_after": [
      "validation_passed",
      "structured_failure_emitted",
      "legitimate_user_input_checkpoint",
      "repair_budget_exhausted_checkpoint"
    ],
    "do_not_write_before": [
      "unvalidated_success_claim",
      "missing_changed_files",
      "missing_checkpoint_handoff",
      "unknown_project_fingerprint"
    ],
    "memory_row_id_patterns": [
      "coding_memory::<project_fingerprint>::checkpoint::<checkpoint_id>",
      "coding_memory::<project_fingerprint>::project_context::latest",
      "coding_memory::<project_fingerprint>::resume_index::latest"
    ],
    "required_payload_fields": [
      "project_id",
      "project_fingerprint",
      "completed_checkpoint",
      "changed_files",
      "validation_results",
      "known_risks",
      "intentionally_excluded_scope",
      "recommended_next_checkpoint",
      "artifact_refs",
      "memory_freshness_status"
    ],
    "required_tags": [
      "coding",
      "checkpoint",
      "resume",
      "project_context"
    ],
    "large_artifact_policy": "store_large_artifacts_under_core_local_state_coding_memory_and_reference_paths",
    "source_of_truth_rule": "memory_guides_resume_current_workspace_files_remain_authoritative"
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact checkpoint memory writes for resumable coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "failure_lifecycle_archive",
      "hot_ring_buffer"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_large_source_bodies",
      "do_not_claim_memory_write_success_without_receipt"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "checkpoint_result_ingest->memory_write_eligibility_gate",
      "memory_write_eligibility_gate->compact_checkpoint_summary_projection",
      "compact_checkpoint_summary_projection->artifact_ref_packaging",
      "artifact_ref_packaging->memory_write_request",
      "memory_write_request->memory_write_receipt_packaging",
      "memory_write_receipt_packaging->completed",
      "memory_write_eligibility_gate->blocked",
      "memory_write_request->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_memory_write_failed_non_blocking_unless_resume_required"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "checkpoint_memory_write_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "memory_write_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_read_memory",
      "do_not_execute_code_repairs",
      "do_not_store_raw_source_bodies"
    ]
  }
}
