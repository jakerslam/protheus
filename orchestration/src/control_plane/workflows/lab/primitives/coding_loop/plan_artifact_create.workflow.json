{
  "name": "plan_artifact_create",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for creating non-overwriting plan artifacts that can be referenced through a coding session.",
  "stages": [
    "input_normalization",
    "plan_name_validation",
    "plans_directory_creation",
    "duplicate_plan_guard",
    "plan_write",
    "plan_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "plan_artifact_create_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "plan_name",
      "version",
      "path",
      "created",
      "duplicate_guard"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "create a durable plan artifact for the current bounded checkpoint",
      "scope_boundary": "do not overwrite existing plan artifacts",
      "validation_calibration": "report duplicate plan names as blocked",
      "visibility": "show only the plan path and summary unless content is requested"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact planning artifact receipts for coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "hot_ring_buffer",
      "failure_lifecycle_archive"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_overwrite_plans",
      "do_not_expand_scope_inside_plan_creation"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "input_normalization->plan_name_validation",
      "plan_name_validation->plans_directory_creation",
      "plans_directory_creation->duplicate_plan_guard",
      "duplicate_plan_guard->plan_write",
      "plan_write->plan_receipt_packaging",
      "plan_receipt_packaging->completed",
      "plan_name_validation->blocked",
      "duplicate_plan_guard->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "plan_artifact_create_v1"
    }
  },
  "loop_primitive_contract": {
    "version": "plan_artifact_create_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/plan_create.rs"
    ],
    "required_behaviors": [
      "plans_directory_created",
      "date_plan_name_and_version_in_filename",
      "existing_plan_rejected",
      "plan_path_returned"
    ],
    "stop_conditions": [
      "plan_name_missing",
      "plan_already_exists",
      "plan_write_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "plan_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  },
  "tactical_planning_contract": {
    "schema_version": "forgecode_tactical_slice_planning_v1",
    "purpose": "Create or update implementation-level plan artifacts for a handed-off slice without reopening parent-owned strategic decisions.",
    "owns_decisions": [
      "files_to_read_or_edit_for_slice",
      "implementation_order",
      "local_test_or_validation_commands",
      "local_repair_strategy",
      "evidence_to_return"
    ],
    "does_not_own": [
      "product_goal",
      "architecture_direction",
      "stack_choice",
      "checkpoint_scope",
      "acceptance_criteria",
      "data_persistence_strategy_when_specified"
    ],
    "input_contract": {
      "requires_slice_handoff_contract": true,
      "parent_owned_decisions_must_be_marked_immutable": true,
      "tactical_plan_must_reference_parent_plan": true
    },
    "output_contract": {
      "required_fields": [
        "tactical_plan_summary",
        "files_expected_to_touch",
        "implementation_order",
        "validation_steps",
        "local_assumptions",
        "slice_execution_readiness_score",
        "readiness_rationale",
        "escalation_if_not_ready"
      ]
    },
    "collision_rule": "If tactical planning discovers that the slice requires changing parent-owned strategy, return needs_parent_planning instead of silently changing scope."
  },
  "slice_execution_readiness_gate": {
    "schema_version": "forgecode_slice_execution_readiness_gate_v1",
    "purpose": "Check whether ForgeCode can execute the handed-off slice without altering strategic intent.",
    "score_range": "0.0_to_1.0",
    "execute_threshold": 0.8,
    "repair_plan_threshold": 0.6,
    "required_checks": [
      "slice_goal_is_clear",
      "immutable_parent_decisions_are_present",
      "acceptance_criteria_are_testable",
      "validation_contract_is_actionable",
      "required_files_or_roots_are_available_or_repairable",
      "runtime_constraints_are_satisfied_or_have_allowed_fallback",
      "runtime_command_aliases_are_resolved_or_repairable",
      "validation_commands_have_explicit_test_discovery_when_needed",
      "artifact_budget_is_compatible_with_available_disk_space",
      "current_working_directory_is_locked_to_assigned_root_before_writes",
      "no_parent_owned_decision_needs_revision"
    ],
    "allowed_when_not_ready": [
      "repair_local_setup_boundary",
      "tighten_tactical_file_plan",
      "choose_internal_implementation_default_that_preserves_parent_contract",
      "resolve_runtime_command_aliases",
      "replace_behavior_preserving_unsupported_runtime_api",
      "repair_validation_discovery_command",
      "compact_validation_receipts_or_generated_artifacts",
      "return_needs_parent_planning_envelope",
      "return_needs_user_decision_envelope_only_after_followup_gate"
    ],
    "forbidden_when_not_ready": [
      "change_stack_choice",
      "expand_checkpoint_scope",
      "change_architecture_direction",
      "ask_user_about_tactical_agent_solvable_details",
      "silently_ignore_acceptance_criteria"
    ],
    "return_envelopes": {
      "ready": "execute_slice",
      "locally_repairable": "repair_then_execute_slice",
      "parent_plan_gap": "needs_parent_planning",
      "user_owned_gap": "needs_user_decision",
      "unrecoverable_environment_gap": "environment_blocker"
    }
  },
  "quality_contracts": [
    "tactical_planning_only",
    "slice_execution_readiness_gate",
    "parent_owned_decision_immutability",
    "planning_collision_prevention"
  ]
}
