{
  "name": "plan_artifact_create",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for creating non-overwriting plan artifacts that can be referenced through a coding session.",
  "stages": [
    "input_normalization",
    "plan_name_validation",
    "plans_directory_creation",
    "duplicate_plan_guard",
    "plan_write",
    "plan_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "plan_artifact_create_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "plan_name",
      "version",
      "path",
      "created",
      "duplicate_guard"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "create a durable plan artifact for the current bounded checkpoint",
      "scope_boundary": "do not overwrite existing plan artifacts",
      "validation_calibration": "report duplicate plan names as blocked",
      "visibility": "show only the plan path and summary unless content is requested"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact planning artifact receipts for coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "artifact_ref_retention",
      "hot_ring_buffer",
      "failure_lifecycle_archive"
    ],
    "non_goals": [
      "do_not_overwrite_plans",
      "do_not_expand_scope_inside_plan_creation",
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "input_normalization->plan_name_validation",
      "plan_name_validation->plans_directory_creation",
      "plans_directory_creation->duplicate_plan_guard",
      "duplicate_plan_guard->plan_write",
      "plan_write->plan_receipt_packaging",
      "plan_receipt_packaging->completed",
      "plan_name_validation->blocked",
      "duplicate_plan_guard->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "plan_artifact_create_v1"
    }
  },
  "loop_primitive_contract": {
    "version": "plan_artifact_create_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/plan_create.rs"
    ],
    "required_behaviors": [
      "plans_directory_created",
      "date_plan_name_and_version_in_filename",
      "existing_plan_rejected",
      "plan_path_returned"
    ],
    "stop_conditions": [
      "plan_name_missing",
      "plan_already_exists",
      "plan_write_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "plan_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
