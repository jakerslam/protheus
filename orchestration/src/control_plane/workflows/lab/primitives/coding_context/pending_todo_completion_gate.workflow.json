{
  "name": "pending_todo_completion_gate",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive that prevents premature task completion when pending or in-progress todos remain.",
  "stages": [
    "active_todo_scan",
    "pending_or_in_progress_filter",
    "duplicate_reminder_detection",
    "reminder_rendering",
    "completion_gate_decision",
    "todo_gate_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "pending_todo_completion_gate_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "active_todos",
      "completion_allowed",
      "reminder_added",
      "duplicate_reminder_suppressed"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "block finalization until active coding todos are complete or explicitly canceled",
      "scope_boundary": "do not invent todos not present in run state",
      "validation_calibration": "report whether completion was allowed, blocked, or reminder-suppressed",
      "visibility": "do not expose hidden run state beyond compact todo summaries"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact pending-todo gate receipts for coding checkpoints.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_claim_completion_with_pending_todos",
      "do_not_duplicate_identical_reminders"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "active_todo_scan->pending_or_in_progress_filter",
      "pending_or_in_progress_filter->duplicate_reminder_detection",
      "duplicate_reminder_detection->reminder_rendering",
      "duplicate_reminder_detection->completion_gate_decision",
      "reminder_rendering->completion_gate_decision",
      "completion_gate_decision->todo_gate_receipt_packaging",
      "todo_gate_receipt_packaging->completed"
    ],
    "timeout_ms": 15000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 2000,
      "loop_signature_detector": "pending_todo_completion_gate_v1"
    }
  },
  "context_primitive_contract": {
    "version": "pending_todo_completion_gate_v1",
    "source_evidence": [
      "crates/forge_app/src/hooks/pending_todos.rs",
      "templates/forge-pending-todos-reminder.md"
    ],
    "required_behaviors": [
      "scan_conversation_metrics_for_active_todos",
      "include_only_pending_and_in_progress_todos",
      "suppress_duplicate_reminders_for_same_todo_set",
      "add_new_reminder_when_active_todo_set_changes",
      "block_completion_when_active_todos_remain"
    ],
    "output_receipts": [
      "active_todo_receipt",
      "duplicate_reminder_receipt",
      "completion_gate_receipt"
    ],
    "stop_conditions": [
      "pending_todos_remain",
      "in_progress_todos_remain"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "todo_gate_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
