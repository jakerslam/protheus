{
  "name": "doom_loop_interrupt",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for detecting repeated tool-call signatures and injecting a progress-reset reminder before the next request.",
  "stages": [
    "assistant_tool_signature_extraction",
    "recent_pattern_detection",
    "threshold_gate",
    "alternate_approach_prompting",
    "doom_loop_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "doom_loop_interrupt_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "loop_detected",
      "pattern_length",
      "repetition_count",
      "interruption_action",
      "next_action_bias"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prevent repeated identical or patterned tool attempts from wasting coding budget",
      "scope_boundary": "do not interrupt productive distinct tool progress",
      "validation_calibration": "report the signature pattern and reminder action",
      "visibility": "do not expose raw hidden tool arguments beyond compact receipts"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact loop-interruption receipts for local coding workflows.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_mask_real_failures",
      "do_not_continue_repeating_failed_tool_calls"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "assistant_tool_signature_extraction->recent_pattern_detection",
      "recent_pattern_detection->threshold_gate",
      "threshold_gate->alternate_approach_prompting",
      "alternate_approach_prompting->doom_loop_receipt_packaging",
      "threshold_gate->doom_loop_receipt_packaging",
      "doom_loop_receipt_packaging->completed"
    ],
    "timeout_ms": 15000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "continue_without_interruption"
    },
    "terminal_states": [
      "completed",
      "failed",
      "needs_input",
      "blocked",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 5,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 2000,
      "loop_signature_detector": "doom_loop_interrupt_v1"
    }
  },
  "context_primitive_contract": {
    "version": "doom_loop_interrupt_v1",
    "source_evidence": [
      "crates/forge_app/src/hooks/doom_loop.rs",
      "templates/forge-doom-loop-reminder.md"
    ],
    "required_behaviors": [
      "extract_assistant_tool_call_name_and_arguments",
      "detect_consecutive_identical_calls",
      "detect_repeating_recent_call_patterns",
      "trigger_at_threshold_three_by_default",
      "inject_system_reminder_before_next_request",
      "bias_agent_toward_different_tool_arguments_or_clarification"
    ],
    "output_receipts": [
      "tool_signature_receipt",
      "pattern_detection_receipt",
      "interruption_receipt"
    ],
    "stop_conditions": [
      "loop_detected_and_no_safe_alternate_available",
      "clarification_required_to_escape_loop"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "doom_loop_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
