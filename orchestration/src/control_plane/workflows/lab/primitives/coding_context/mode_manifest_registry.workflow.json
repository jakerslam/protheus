      "answer_user_goal": "Primitive contract for declaring coding modes as manifests with role, allowed tools, model/profile hints, stop conditions, and handoff boundaries.",
      "scope_boundary": "emit a reusable primitive artifact only; do not perform unrelated project execution",
      "validation_calibration": "separate primitive contract failure from downstream implementation failure",
      "visibility": "return compact refs and summaries without raw hidden reasoning"
    }
  },
  "mode_manifest_registry_contract": {
    "version": "mode_manifest_registry_v1",
    "purpose": "Avoid prompt-level role hardcoding by making Code, Architect, Ask, Debug, Orchestrator, and custom roles data-driven manifests.",
    "required_manifest_fields": [
      "mode_id",
      "role",
      "allowed_tool_families",
      "input_contract",
      "output_contract",
      "stop_conditions",
      "handoff_policy"
    ],
    "required_behaviors": [
      "resolve_mode_from_parent_intent_or_explicit_profile",
      "do_not_embed_role_policy_in_runtime_code",
      "record_mode_receipt",
      "fail_closed_when_required_mode_tools_are_unavailable"
    ],
    "output_artifacts": [
      "mode_manifest_ref",
      "mode_resolution_receipt",
      "handoff_boundary_receipt"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
