      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 4,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
