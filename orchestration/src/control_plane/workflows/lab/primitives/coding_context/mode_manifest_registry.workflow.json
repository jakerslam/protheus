  },
  "provenance_contract": {
    "source_systems": [
      "Roo Code",
      "Cline",
      "OpenFang",
      "ForgeCode"
    ],
    "import_rule": "assimilate_mechanics_not_product_specific_hacks",
    "artifact_corpus_ref": "references/coding-agent-systems"
  },
  "stages": [
    "mode_request_normalization",
    "mode_manifest_resolution",
    "tool_and_boundary_projection",
