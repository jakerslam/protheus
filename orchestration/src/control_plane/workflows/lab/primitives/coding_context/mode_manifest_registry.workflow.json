      "mode_manifest_resolution->tool_and_boundary_projection",
      "tool_and_boundary_projection->mode_manifest_artifact_packaging",
      "mode_manifest_artifact_packaging->completed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
