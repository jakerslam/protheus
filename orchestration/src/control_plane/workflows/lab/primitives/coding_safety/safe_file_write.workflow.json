{
  "name": "safe_file_write",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for guarded local file creation and overwrite with snapshots, validation, and content-hash receipts.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "primitive",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.safe_file_write",
    "special_case_policy": "File names, app types, languages, and benchmark fixtures must not change write semantics inside this primitive.",
    "monotonic_lower_level_regression_policy": "Write-safety changes must preserve simple new-file creation and guarded overwrite behavior for lower-level consumers."
  },
  "stages": [
    "input_normalization",
    "absolute_path_validation",
    "overwrite_policy_check",
    "pre_write_validation",
    "parent_directory_creation",
    "snapshot_existing_content",
    "line_ending_normalization",
    "content_write",
    "write_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "safe_file_write_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "path",
      "created_or_overwritten",
      "overwrite_allowed",
      "snapshot_ref",
      "previous_content_hash",
      "new_content_hash",
      "validation_errors"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "write the requested file only inside the allowed scope",
      "scope_boundary": "do not overwrite existing files unless the overwrite policy permits it",
      "validation_calibration": "report validation errors and hashes without claiming semantic correctness",
      "visibility": "do not leak full previous file content in visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact guarded-write receipts for coding workflows with snapshot references.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_full_previous_content_in_chat",
      "do_not_bypass_snapshot_before_overwrite"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "input_normalization->absolute_path_validation",
      "absolute_path_validation->overwrite_policy_check",
      "overwrite_policy_check->pre_write_validation",
      "pre_write_validation->parent_directory_creation",
      "parent_directory_creation->snapshot_existing_content",
      "snapshot_existing_content->line_ending_normalization",
      "line_ending_normalization->content_write",
      "content_write->write_receipt_packaging",
      "write_receipt_packaging->completed",
      "absolute_path_validation->blocked",
      "overwrite_policy_check->blocked",
      "pre_write_validation->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 10,
      "max_model_turns": 1,
      "max_tool_calls": 5,
      "token_budget": 6000,
      "loop_signature_detector": "safe_file_write_v1"
    }
  },
  "safety_primitive_contract": {
    "version": "safe_file_write_v1",
    "source_evidence": [
      "crates/forge_fs/src/write.rs",
      "crates/forge_services/src/tool_services/fs_write.rs"
    ],
    "required_behaviors": [
      "absolute_path_required",
      "parent_directories_created",
      "existing_file_rejected_without_overwrite_permission",
      "existing_file_snapshotted_before_overwrite",
      "previous_content_hash_recorded_when_overwriting",
      "line_endings_preserved_for_existing_files",
      "content_hash_returned_after_write",
      "validation_errors_returned_as_receipts"
    ],
    "output_receipts": [
      "path_receipt",
      "overwrite_policy_receipt",
      "snapshot_receipt",
      "previous_hash_receipt",
      "new_hash_receipt",
      "validation_receipt"
    ],
    "stop_conditions": [
      "path_not_absolute",
      "overwrite_requested_without_permission",
      "pre_write_validation_blocks_write",
      "snapshot_failed_for_existing_file"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "write_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
