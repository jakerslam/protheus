{
  "name": "safe_file_patch",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for exact-match local file patches with stale-context and ambiguity detection.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "primitive",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.safe_file_patch",
    "special_case_policy": "Source-shape preservation rules must be general patch invariants or caller-owned policy, not fixture-specific branches.",
    "monotonic_lower_level_regression_policy": "Patch robustness changes must preserve exact-match generic editing behavior for lower-level consumers."
  },
  "stages": [
    "input_normalization",
    "absolute_path_validation",
    "source_read",
    "line_ending_detection",
    "exact_match_resolution",
    "patch_application",
    "snapshot_existing_content",
    "post_patch_validation",
    "patch_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "safe_file_patch_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "path",
      "operation",
      "match_status",
      "snapshot_ref",
      "previous_content_hash",
      "new_content_hash",
      "validation_errors"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "apply only the requested exact contextual edit",
      "scope_boundary": "reject ambiguous or stale-context edits instead of guessing",
      "validation_calibration": "report no-match and multiple-match failures as repair inputs",
      "visibility": "do not expose raw internal patch state in final chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact patch receipts and stale-context signals for repair loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_guess_on_multiple_matches",
      "do_not_patch_without_snapshot"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "input_normalization->absolute_path_validation",
      "absolute_path_validation->source_read",
      "source_read->line_ending_detection",
      "line_ending_detection->exact_match_resolution",
      "exact_match_resolution->patch_application",
      "patch_application->snapshot_existing_content",
      "snapshot_existing_content->post_patch_validation",
      "post_patch_validation->patch_receipt_packaging",
      "patch_receipt_packaging->completed",
      "absolute_path_validation->blocked",
      "exact_match_resolution->stale_context",
      "exact_match_resolution->ambiguous_match",
      "post_patch_validation->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "stale_context",
      "ambiguous_match",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 10,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 8000,
      "loop_signature_detector": "safe_file_patch_v1"
    }
  },
  "safety_primitive_contract": {
    "version": "safe_file_patch_v1",
    "source_evidence": [
      "crates/forge_services/src/tool_services/fs_patch.rs"
    ],
    "required_behaviors": [
      "absolute_path_required",
      "source_file_read_before_patch",
      "line_endings_normalized_to_source_style",
      "exact_match_required_for_replace_and_swap",
      "multiple_matches_rejected",
      "no_match_reported_as_stale_context",
      "range_out_of_bounds_rejected",
      "existing_file_snapshotted_before_patch",
      "post_patch_hash_returned",
      "validation_errors_returned_as_receipts"
    ],
    "output_receipts": [
      "path_receipt",
      "operation_receipt",
      "match_receipt",
      "snapshot_receipt",
      "previous_hash_receipt",
      "new_hash_receipt",
      "validation_receipt"
    ],
    "stop_conditions": [
      "path_not_absolute",
      "search_text_missing",
      "multiple_matches_found",
      "no_match_found_stale_context",
      "swap_target_missing",
      "patch_validation_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "patch_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
