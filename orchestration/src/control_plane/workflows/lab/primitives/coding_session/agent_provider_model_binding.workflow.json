{
  "name": "agent_provider_model_binding",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for binding the active agent to a provider and model before local coding runtime execution.",
  "stages": [
    "active_agent_resolution",
    "agent_provider_lookup",
    "agent_model_lookup",
    "session_default_fallback",
    "provider_credential_refresh_route",
    "agent_provider_model_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "agent_provider_model_binding_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "agent_resolution_status",
      "provider_source",
      "model_source",
      "session_default_status",
      "credential_refresh_route",
      "binding_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "bind a local coding run to a provider and model without starting a chat turn",
      "scope_boundary": "do not call the provider for coding, do not mutate config, and do not execute tools",
      "validation_calibration": "report whether provider and model came from the requested agent or session defaults",
      "visibility": "do not expose credentials, provider secrets, or hidden agent configuration"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact agent/provider/model binding receipts before local coding runtime execution.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_credentials",
      "do_not_hide_missing_default_session",
      "do_not_start_provider_chat",
      "do_not_mutate_agent_config"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "active_agent_resolution->agent_provider_lookup",
      "agent_provider_lookup->agent_model_lookup",
      "agent_model_lookup->session_default_fallback",
      "session_default_fallback->provider_credential_refresh_route",
      "provider_credential_refresh_route->agent_provider_model_receipt_packaging",
      "agent_provider_model_receipt_packaging->completed",
      "active_agent_resolution->blocked",
      "session_default_fallback->blocked",
      "provider_credential_refresh_route->needs_input"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 3,
      "token_budget": 4000,
      "loop_signature_detector": "agent_provider_model_binding_v1"
    }
  },
  "session_primitive_contract": {
    "version": "agent_provider_model_binding_v1",
    "source_evidence": [
      "crates/forge_app/src/agent_provider_resolver.rs",
      "crates/forge_app/src/services.rs",
      "crates/forge_app/src/git_app.rs"
    ],
    "required_behaviors": [
      "requested_agent_provider_takes_precedence_when_agent_exists",
      "requested_agent_model_takes_precedence_when_agent_exists",
      "missing_requested_agent_falls_back_to_default_session_config",
      "missing_agent_and_missing_session_config_returns_no_default_session",
      "provider_templates_are_resolved_before_use",
      "credential_refresh_is_explicit_when_required_by_call_site"
    ],
    "output_receipts": [
      "agent_lookup_receipt",
      "provider_binding_receipt",
      "model_binding_receipt",
      "session_default_fallback_receipt",
      "credential_refresh_route_receipt"
    ],
    "stop_conditions": [
      "no_default_session_config",
      "provider_unavailable",
      "credential_refresh_requires_user_login",
      "agent_configuration_conflicts_with_requested_runtime"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "agent_provider_model_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
