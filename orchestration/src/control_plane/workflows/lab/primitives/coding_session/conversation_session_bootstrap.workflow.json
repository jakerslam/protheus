{
  "name": "conversation_session_bootstrap",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for preparing conversation state before runtime execution: conversation id, metrics start time, tunable parameters, reasoning, max tokens, and tool definitions.",
  "stages": [
    "conversation_context_load",
    "conversation_id_projection",
    "started_at_metric_initialization",
    "agent_tunable_parameter_projection",
    "tool_definition_attachment",
    "conversation_bootstrap_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "conversation_session_bootstrap_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "conversation_id_status",
      "metrics_started_at_status",
      "temperature_status",
      "sampling_parameter_status",
      "reasoning_status",
      "max_tokens_status",
      "tool_definition_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare conversation runtime state without executing a model turn",
      "scope_boundary": "do not add user prompt content, run tools, or persist final conversation output",
      "validation_calibration": "report applied tunables and missing optional values separately",
      "visibility": "do not expose raw tool schemas or hidden conversation internals"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact conversation bootstrap receipts for local coding sessions.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_raw_tool_schemas",
      "do_not_hide_missing_conversation_context",
      "do_not_execute_runtime_loop",
      "do_not_mutate_local_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "conversation_context_load->conversation_id_projection",
      "conversation_id_projection->started_at_metric_initialization",
      "started_at_metric_initialization->agent_tunable_parameter_projection",
      "agent_tunable_parameter_projection->tool_definition_attachment",
      "tool_definition_attachment->conversation_bootstrap_receipt_packaging",
      "conversation_bootstrap_receipt_packaging->completed",
      "conversation_context_load->blocked",
      "tool_definition_attachment->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 3,
      "token_budget": 4000,
      "loop_signature_detector": "conversation_session_bootstrap_v1"
    }
  },
  "session_primitive_contract": {
    "version": "conversation_session_bootstrap_v1",
    "source_evidence": [
      "crates/forge_app/src/set_conversation_id.rs",
      "crates/forge_app/src/init_conversation_metrics.rs",
      "crates/forge_app/src/apply_tunable_parameters.rs"
    ],
    "required_behaviors": [
      "context_conversation_id_matches_conversation_id",
      "metrics_started_at_is_set_from_current_local_time_converted_to_utc",
      "agent_temperature_is_applied_when_present",
      "agent_top_p_and_top_k_are_applied_when_present",
      "agent_max_tokens_is_applied_when_present",
      "agent_reasoning_config_is_applied_when_present",
      "resolved_tool_definitions_are_attached_to_context"
    ],
    "output_receipts": [
      "conversation_id_projection_receipt",
      "started_at_metric_receipt",
      "tunable_parameter_receipt",
      "reasoning_projection_receipt",
      "tool_definition_attachment_receipt"
    ],
    "stop_conditions": [
      "conversation_context_unloadable",
      "tool_definitions_missing_for_required_local_coding",
      "agent_tunable_parameters_invalid_for_provider"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "conversation_bootstrap_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
