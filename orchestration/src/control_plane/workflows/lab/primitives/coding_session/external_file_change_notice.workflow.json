{
  "name": "external_file_change_notice",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for detecting files modified outside the agent since their last tracked hash and injecting a droppable re-read notice.",
  "stages": [
    "tracked_file_metric_collection",
    "parallel_hash_recheck",
    "deterministic_change_sorting",
    "metric_hash_update",
    "droppable_reread_notice_projection",
    "external_change_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "external_file_change_notice_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "tracked_file_count",
      "changed_file_count",
      "unreadable_file_count",
      "updated_hash_status",
      "droppable_notice_status",
      "reread_required_paths"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "warn the coding agent when previously tracked files changed outside the agent",
      "scope_boundary": "do not repair files, overwrite files, or treat notification as validation",
      "validation_calibration": "report changed, unchanged, and unreadable tracked files separately",
      "visibility": "do not expose full file contents in the notice or receipt"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact external file change receipts before local coding continues.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_file_contents",
      "do_not_hide_unreadable_files",
      "do_not_mutate_files",
      "do_not_clear_safety_receipts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "tracked_file_metric_collection->parallel_hash_recheck",
      "parallel_hash_recheck->deterministic_change_sorting",
      "deterministic_change_sorting->metric_hash_update",
      "metric_hash_update->droppable_reread_notice_projection",
      "droppable_reread_notice_projection->external_change_receipt_packaging",
      "external_change_receipt_packaging->completed",
      "parallel_hash_recheck->blocked",
      "droppable_reread_notice_projection->blocked"
    ],
    "timeout_ms": 45000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 5000,
      "loop_signature_detector": "external_file_change_notice_v1"
    }
  },
  "session_primitive_contract": {
    "version": "external_file_change_notice_v1",
    "source_evidence": [
      "crates/forge_app/src/changed_files.rs",
      "crates/forge_app/src/file_tracking.rs"
    ],
    "required_behaviors": [
      "tracked_files_are_loaded_from_conversation_metrics",
      "current_hash_uses_raw_full_file_content_hash",
      "parallel_file_reads_use_configured_max_parallel_file_reads",
      "unreadable_files_are_reported_with_none_hash",
      "changes_are_sorted_by_path_for_deterministic_order",
      "metrics_hashes_are_updated_after_notification_to_prevent_duplicates",
      "notification_is_added_as_droppable_user_message",
      "notification_uses_cwd_relative_display_paths"
    ],
    "output_receipts": [
      "tracked_file_metric_receipt",
      "hash_recheck_receipt",
      "external_change_receipt",
      "metric_hash_update_receipt",
      "droppable_notice_receipt"
    ],
    "stop_conditions": [
      "tracked_file_read_budget_exhausted",
      "changed_file_notice_cannot_be_added_to_context",
      "external_change_invalidates_current_checkpoint"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "external_change_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
