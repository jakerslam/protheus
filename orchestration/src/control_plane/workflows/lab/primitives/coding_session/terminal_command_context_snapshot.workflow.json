{
  "name": "terminal_command_context_snapshot",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for reading recent terminal command context from zsh-exported environment variables and producing a compact sorted command trace.",
  "stages": [
    "terminal_env_collection",
    "unit_separator_split",
    "exit_code_and_timestamp_padding",
    "timestamp_sorting",
    "empty_trace_filtering",
    "terminal_context_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "terminal_command_context_snapshot_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "terminal_context_status",
      "command_count",
      "exit_code_status",
      "timestamp_status",
      "sort_order",
      "projection_targets"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return a compact terminal command trace for prompt assembly or command generation",
      "scope_boundary": "do not execute terminal commands and do not infer validation success from command history",
      "validation_calibration": "report missing exit codes or timestamps as padded defaults",
      "visibility": "do not expose raw terminal history as visible chat unless explicitly routed by parent workflow"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact terminal context receipts without storing unrestricted terminal history.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_execute_terminal_commands",
      "do_not_store_full_terminal_history",
      "do_not_treat_history_as_validation",
      "do_not_hide_malformed_exit_codes"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "terminal_env_collection->unit_separator_split",
      "unit_separator_split->exit_code_and_timestamp_padding",
      "exit_code_and_timestamp_padding->timestamp_sorting",
      "timestamp_sorting->empty_trace_filtering",
      "empty_trace_filtering->terminal_context_receipt_packaging",
      "terminal_context_receipt_packaging->completed",
      "terminal_env_collection->completed",
      "unit_separator_split->blocked"
    ],
    "timeout_ms": 15000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 3000,
      "loop_signature_detector": "terminal_command_context_snapshot_v1"
    }
  },
  "session_primitive_contract": {
    "version": "terminal_command_context_snapshot_v1",
    "source_evidence": [
      "crates/forge_app/src/terminal_context.rs"
    ],
    "required_behaviors": [
      "commands_are_read_from_forge_term_commands_env_var",
      "exit_codes_are_read_from_forge_term_exit_codes_env_var_when_present",
      "timestamps_are_read_from_forge_term_timestamps_env_var_when_present",
      "lists_are_split_on_ascii_unit_separator",
      "empty_segments_are_filtered",
      "missing_exit_codes_and_timestamps_are_padded_with_zero",
      "invalid_exit_codes_and_timestamps_parse_to_zero",
      "commands_are_sorted_by_timestamp_oldest_first",
      "missing_or_empty_commands_return_no_terminal_context"
    ],
    "output_receipts": [
      "terminal_env_presence_receipt",
      "split_separator_receipt",
      "padding_receipt",
      "timestamp_sort_receipt",
      "terminal_context_projection_receipt"
    ],
    "stop_conditions": [
      "terminal_env_values_malformed_beyond_recovery",
      "terminal_context_projection_budget_exceeded"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "terminal_context_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
