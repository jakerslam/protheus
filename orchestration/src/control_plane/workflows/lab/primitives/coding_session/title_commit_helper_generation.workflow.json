{
  "name": "title_commit_helper_generation",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for title and commit helper generation, including schema-constrained title responses, git diff selection, commit config fallback, retryable empty messages, and explicit commit execution envelopes.",
  "stages": [
    "helper_request_classification",
    "title_generation_route",
    "git_diff_context_collection",
    "commit_provider_model_resolution",
    "commit_message_schema_generation",
    "commit_execution_envelope_projection",
    "title_commit_helper_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "title_commit_helper_generation_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "helper_request_kind",
      "title_generation_status",
      "diff_source",
      "commit_provider_source",
      "commit_message_status",
      "commit_execution_requires_approval",
      "git_output_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare title or commit helper artifacts without silently mutating git state",
      "scope_boundary": "do not commit, stage, push, or update PRs unless a parent workflow explicitly routes an approved external-visible action",
      "validation_calibration": "distinguish generated helper text from executed git actions and git command receipts",
      "visibility": "do not expose raw provider payloads or hidden prompt templates"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact title and commit helper receipts while preserving git mutation boundaries.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_commit_without_explicit_parent_approval",
      "do_not_store_raw_diffs_when_truncated",
      "do_not_hide_empty_commit_message_failures",
      "do_not_push_or_create_prs"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "helper_request_classification->title_generation_route",
      "title_generation_route->git_diff_context_collection",
      "git_diff_context_collection->commit_provider_model_resolution",
      "commit_provider_model_resolution->commit_message_schema_generation",
      "commit_message_schema_generation->commit_execution_envelope_projection",
      "commit_execution_envelope_projection->title_commit_helper_receipt_packaging",
      "title_commit_helper_receipt_packaging->completed",
      "git_diff_context_collection->blocked",
      "commit_provider_model_resolution->needs_input",
      "commit_message_schema_generation->failed",
      "commit_execution_envelope_projection->needs_input"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 7,
      "max_model_turns": 2,
      "max_tool_calls": 8,
      "token_budget": 10000,
      "loop_signature_detector": "title_commit_helper_generation_v1"
    }
  },
  "session_primitive_contract": {
    "version": "title_commit_helper_generation_v1",
    "source_evidence": [
      "crates/forge_app/src/title_generator.rs",
      "crates/forge_app/src/git_app.rs",
      "templates/forge-system-prompt-title-generation.md",
      "templates/forge-commit-message-prompt.md"
    ],
    "required_behaviors": [
      "title_generation_uses_title_template_and_user_prompt_wrapper",
      "title_generation_prefers_json_schema_response_and_falls_back_to_plain_text",
      "title_context_uses_temperature_one_and_generated_conversation_id",
      "commit_message_uses_piped_diff_when_provided",
      "commit_message_prefers_staged_diff_over_unstaged_diff",
      "empty_git_diff_returns_nothing_to_commit",
      "diff_content_is_truncated_at_character_boundary_when_budgeted",
      "recent_commit_messages_and_branch_name_are_collected_for_commit_context",
      "commit_config_provider_model_takes_precedence_then_falls_back_to_active_agent",
      "empty_generated_commit_message_is_retryable",
      "commit_execution_envelope_sets_forgecode_committer_and_user_author",
      "commit_execution_is_external_visible_and_requires_parent_approval"
    ],
    "output_receipts": [
      "title_generation_receipt",
      "git_context_receipt",
      "diff_source_receipt",
      "commit_provider_model_receipt",
      "commit_message_generation_receipt",
      "commit_execution_envelope_receipt"
    ],
    "stop_conditions": [
      "nothing_to_commit",
      "commit_provider_requires_login",
      "empty_commit_message_after_retry",
      "commit_execution_not_approved",
      "git_commit_command_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "title_commit_helper_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
