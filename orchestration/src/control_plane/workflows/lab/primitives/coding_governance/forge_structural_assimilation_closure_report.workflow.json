{
  "name": "forge_structural_assimilation_closure_report",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_run_evals",
      "do_not_promote_workflows",
      "do_not_claim_runtime_parity",
      "do_not_add_new_source_families_without_evidence"
    ]
  },
  "default": false,
  "description": "ForgeCode-derived structural assimilation closure primitive: confirms source-family coverage, workflow registry wiring, receipt-chain coherence, and remaining executable-proof gaps after structural assimilation.",
  "stages": [
    "closure_input_receipt_collection",
    "source_family_coverage_accounting",
    "workflow_chain_coherence_check",
    "remaining_gap_classification",
    "structural_assimilation_closure_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "forge_structural_assimilation_closure_report_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "structural_assimilation_status",
      "source_family_coverage_status",
      "workflow_chain_coherence_status",
      "remaining_structural_gaps",
      "remaining_executable_proof_gaps",
      "closure_next_action"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "close structural ForgeCode assimilation with an evidence-backed status and explicit remaining proof gaps",
      "scope_boundary": "do not execute evals, edit source code, promote workflows, publish releases, or claim runtime parity",
      "validation_calibration": "structural closure means source-family and receipt-chain coverage, not executable behavior proof",
      "visibility": "surface concise closure status, gaps, and next action without exposing raw traces"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact structural-assimilation closure receipts for ForgeCode-derived local coding workflow work.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_unbounded_eval_logs",
      "do_not_store_provider_credentials",
      "do_not_store_secret_release_inputs"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "closure_input_receipt_collection->source_family_coverage_accounting",
      "source_family_coverage_accounting->workflow_chain_coherence_check",
      "workflow_chain_coherence_check->remaining_gap_classification",
      "remaining_gap_classification->structural_assimilation_closure_receipt_packaging",
      "structural_assimilation_closure_receipt_packaging->completed",
      "closure_input_receipt_collection->needs_input",
      "source_family_coverage_accounting->blocked",
      "workflow_chain_coherence_check->blocked",
      "remaining_gap_classification->failed"
    ],
    "timeout_ms": 120000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 5,
      "max_model_turns": 2,
      "max_tool_calls": 4,
      "token_budget": 8000,
      "loop_signature_detector": "forge_structural_assimilation_closure_report_v1"
    }
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "structural_assimilation_closure_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "structural_assimilation_closure_contract": {
    "version": "forge_structural_assimilation_closure_report_v1",
    "source": "forgecode_assimilation_ledger_and_workflow_registry",
    "required_input_receipts": [
      "project_local_governance_receipt",
      "ci_release_boundary_receipt",
      "benchmark_eval_harness_receipt",
      "controlled_eval_run_boundary_receipt",
      "executable_eval_result_receipt",
      "distribution_package_inventory_receipt",
      "executable_eval_coverage_receipt",
      "promotion_readiness_receipt",
      "promotion_decision_report_receipt"
    ],
    "required_output_receipt": "structural_assimilation_closure_receipt",
    "source_family_groups": [
      "core_coding_execution",
      "ingress_session_and_prompt_context",
      "policy_permissions_and_tooling",
      "runtime_loop_and_observability",
      "operator_shell_remote_and_template_integration",
      "project_governance_and_ci_release",
      "benchmark_eval_and_promotion_governance",
      "distribution_package_and_provider_inventory"
    ],
    "closure_statuses": [
      "structurally_closed",
      "structurally_closed_pending_executable_proof",
      "structural_gap_remaining",
      "blocked_by_inconsistent_receipts"
    ],
    "coherence_checks": [
      "each_registered_forgecode_assimilation_workflow_has_ledger_row",
      "each_composite_child_workflow_has_registry_entry",
      "each_promotion_receipt_dependency_has_upstream_producer",
      "workflow_level_tracking_is_consistent_with_composed_workflow_ids",
      "governance_evaluation_chain_does_not_pollute_raw_coding_execution",
      "remaining_work_is_classified_as_structural_or_executable_proof"
    ],
    "remaining_gap_rules": [
      "missing_workflow_or_ledger_entry_is_structural_gap",
      "missing_eval_execution_receipt_is_executable_proof_gap",
      "missing_operator_approval_is_promotion_gap",
      "raw_log_without_normalized_result_receipt_is_evidence_gap",
      "newly_discovered_source_family_requires_new_structural_pass"
    ],
    "report_requirements": [
      "emit_source_family_coverage_status",
      "emit_workflow_chain_coherence_status",
      "list_remaining_structural_gaps",
      "list_remaining_executable_proof_gaps",
      "list_promotion_gaps",
      "emit_closure_next_action",
      "emit_no_runtime_parity_claim_without_executable_eval_receipts"
    ],
    "blocked_conditions": [
      "required_receipt_missing_without_gap_classification",
      "registry_and_ledger_disagree",
      "composite_chain_missing_child_producer",
      "workflow_level_tracking_inconsistent",
      "runtime_parity_claim_present_without_eval_evidence"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  }
}
