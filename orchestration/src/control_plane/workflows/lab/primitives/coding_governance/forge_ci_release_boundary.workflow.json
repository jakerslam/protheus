{
  "name": "forge_ci_release_boundary",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for CI, generated GitHub workflow, release, package-distribution, and bounty-label automation boundaries.",
  "stages": [
    "ci_release_inventory",
    "generated_workflow_boundary",
    "ci_validation_boundary",
    "release_matrix_boundary",
    "github_automation_boundary",
    "ci_release_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "forge_ci_release_boundary_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "generated_workflow_status",
      "ci_validation_status",
      "release_matrix_status",
      "distribution_status",
      "github_automation_status",
      "ci_release_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "surface CI and release automation boundaries without running release actions implicitly",
      "scope_boundary": "do not publish releases, upload binaries, mutate labels, or push package repositories unless routed by explicit release workflow",
      "validation_calibration": "report configured automation separately from successful CI or release execution",
      "visibility": "do not expose GitHub, npm, Homebrew, PostHog, or provider secrets"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact CI/release automation receipts without storing secrets.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_edit_generated_workflow_files_by_hand",
      "do_not_publish_release_artifacts",
      "do_not_store_release_or_package_manager_secrets"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "ci_release_inventory->generated_workflow_boundary",
      "generated_workflow_boundary->ci_validation_boundary",
      "ci_validation_boundary->release_matrix_boundary",
      "release_matrix_boundary->github_automation_boundary",
      "github_automation_boundary->ci_release_receipt_packaging",
      "ci_release_receipt_packaging->completed",
      "generated_workflow_boundary->blocked",
      "ci_validation_boundary->failed",
      "release_matrix_boundary->needs_input",
      "github_automation_boundary->blocked"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 7000,
      "loop_signature_detector": "forge_ci_release_boundary_v1"
    }
  },
  "governance_primitive_contract": {
    "version": "forge_ci_release_boundary_v1",
    "source_evidence": [
      ".github/workflows/ci.yml",
      ".github/workflows/release.yml",
      ".github/release-drafter.yml",
      ".github/dependabot.yml",
      ".github/labels.json",
      ".github/scripts/bounty/src/rules.ts",
      ".forge/skills/write-release-notes/SKILL.md"
    ],
    "required_behaviors": [
      "treat_generated_github_workflows_as_generated_artifacts_not_hand_edited_sources",
      "run_ci_on_pull_requests_main_pushes_and_version_tags",
      "enforce_rustflags_dwarnings_for_ci_validation",
      "generate_coverage_with_cargo_llvm_cov",
      "run_zsh_rprompt_performance_benchmark_with_threshold",
      "draft_releases_only_on_main_push_and_pr_release_builds_only_when_label_is_present",
      "build_release_matrix_for_linux_musl_linux_gnu_macos_windows_and_android_targets",
      "upload_release_binaries_to_github_release_only_inside release workflow",
      "update_npm_and_homebrew_distribution_repositories_only_after_release_builds",
      "compute_bounty_label_patches_as_pure_label_diff_rules_before applying GitHub mutations",
      "generate_release_notes_from_release_and_linked_pr_data_with_length_validation"
    ],
    "output_receipts": [
      "generated_workflow_boundary_receipt",
      "ci_validation_contract_receipt",
      "release_matrix_receipt",
      "distribution_boundary_receipt",
      "github_automation_rule_receipt",
      "secret_redaction_receipt"
    ],
    "stop_conditions": [
      "manual_edit_to_generated_workflow_requested",
      "release_secret_required",
      "release_target_matrix_requires_decision",
      "github_label_mutation_requires_explicit_route",
      "release_notes_length_validation_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "ci_release_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
