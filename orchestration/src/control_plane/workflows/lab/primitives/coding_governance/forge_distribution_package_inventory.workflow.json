{
  "name": "forge_distribution_package_inventory",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for top-level workspace, package, toolchain, formatting, config-schema, README mode, and provider-model inventory boundaries.",
  "stages": [
    "distribution_inventory_collection",
    "cargo_workspace_projection",
    "node_eval_package_projection",
    "toolchain_and_build_fixture_projection",
    "config_schema_and_guideline_projection",
    "distribution_inventory_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "forge_distribution_package_inventory_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "cargo_workspace_status",
      "node_eval_package_status",
      "toolchain_build_status",
      "format_lint_snapshot_status",
      "config_schema_status",
      "distribution_inventory_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "surface top-level distribution and package metadata needed for parity and promotion decisions",
      "scope_boundary": "do not update dependencies, regenerate lockfiles, publish packages, or rewrite public docs unless routed by an explicit parent workflow",
      "validation_calibration": "report declared package/toolchain state separately from successful build or release execution",
      "visibility": "do not expose provider secrets, private package tokens, or full lockfile payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact distribution/package inventory receipts without storing full lockfiles.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_full_lockfiles",
      "do_not_publish_or_install_distribution_artifacts",
      "do_not_claim_build_success_from_metadata_inventory"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "distribution_inventory_collection->cargo_workspace_projection",
      "cargo_workspace_projection->node_eval_package_projection",
      "node_eval_package_projection->toolchain_and_build_fixture_projection",
      "toolchain_and_build_fixture_projection->config_schema_and_guideline_projection",
      "config_schema_and_guideline_projection->distribution_inventory_receipt_packaging",
      "distribution_inventory_receipt_packaging->completed",
      "distribution_inventory_collection->blocked",
      "cargo_workspace_projection->failed",
      "toolchain_and_build_fixture_projection->needs_input",
      "config_schema_and_guideline_projection->failed"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 7000,
      "loop_signature_detector": "forge_distribution_package_inventory_v1"
    }
  },
  "governance_primitive_contract": {
    "version": "forge_distribution_package_inventory_v1",
    "source_evidence": [
      "Cargo.toml",
      "package.json",
      "rust-toolchain.toml",
      "Cross.toml",
      "flake.nix",
      ".rustfmt.toml",
      "clippy.toml",
      "insta.yaml",
      "forge.schema.json",
      "README.md",
      "AGENTS.md",
      "vertex.json",
      "renovate.json"
    ],
    "required_behaviors": [
      "project_cargo_workspace_members_and_internal_crate_paths_without_rewriting_workspace_metadata",
      "project_release_profile_lto_codegen_opt_level_and_strip_preferences_as_build_metadata",
      "project_node_package_scripts_for_eval_and_bounty_automation_without_running_them",
      "project_rust_toolchain_channel_and_profile_as_toolchain_pin",
      "project_cross_target_images_env_passthrough_and_protoc_prebuild_setup",
      "project_nix_package_app_and_dev_shell_dependencies_for_unix_platforms",
      "project_rustfmt_clippy_and_insta_preferences_as_validation_environment_metadata",
      "project_forge_config_schema_fields_as_config_contract_reference",
      "project_readme_public_modes_for_interactive_one_shot_and_zsh_plugin_usage",
      "project_agent_guidelines_for_error_management_tests_docs_refactoring_git_and_services",
      "project_vertex_model_metadata_for_context_length_tools_parallel_calls_reasoning_and_modalities",
      "project_renovate_automerge_policy_as_dependency_automation_metadata"
    ],
    "output_receipts": [
      "cargo_workspace_inventory_receipt",
      "node_eval_package_inventory_receipt",
      "toolchain_build_fixture_receipt",
      "format_lint_snapshot_fixture_receipt",
      "config_schema_inventory_receipt",
      "public_mode_and_agent_guideline_receipt",
      "provider_model_metadata_receipt"
    ],
    "stop_conditions": [
      "workspace_package_metadata_missing",
      "toolchain_or_cross_fixture_conflict",
      "config_schema_missing_or_invalid",
      "provider_model_metadata_invalid",
      "dependency_update_or_lockfile_regeneration_requested"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "distribution_inventory_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
