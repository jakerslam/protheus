{
  "name": "forge_benchmark_eval_harness",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for benchmark/eval task definitions, execution logs, timeout/early-exit behavior, and tool-use validation rules.",
  "stages": [
    "benchmark_eval_inventory",
    "task_definition_parse_boundary",
    "task_execution_logging_boundary",
    "validation_rule_projection",
    "performance_script_projection",
    "benchmark_eval_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "forge_benchmark_eval_harness_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "eval_inventory_status",
      "task_parse_status",
      "execution_log_status",
      "validation_rule_status",
      "performance_threshold_status",
      "benchmark_eval_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "surface benchmark/eval rules that measure ForgeCode-style agent behavior",
      "scope_boundary": "do not run benchmarks or mutate repositories unless parent workflow explicitly requests eval execution",
      "validation_calibration": "distinguish configured eval expectations from passing eval results",
      "visibility": "summarize validation rules without exposing full run logs unless requested"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact benchmark/eval harness receipts for promotion decisions.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_claim_eval_success_without_execution",
      "do_not_store_unbounded_eval_logs",
      "do_not_clone_external_repositories_without_parent_route"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "benchmark_eval_inventory->task_definition_parse_boundary",
      "task_definition_parse_boundary->task_execution_logging_boundary",
      "task_execution_logging_boundary->validation_rule_projection",
      "validation_rule_projection->performance_script_projection",
      "performance_script_projection->benchmark_eval_receipt_packaging",
      "benchmark_eval_receipt_packaging->completed",
      "task_definition_parse_boundary->failed",
      "task_execution_logging_boundary->blocked",
      "validation_rule_projection->failed",
      "performance_script_projection->needs_input"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 7000,
      "loop_signature_detector": "forge_benchmark_eval_harness_v1"
    }
  },
  "governance_primitive_contract": {
    "version": "forge_benchmark_eval_harness_v1",
    "source_evidence": [
      "benchmarks/parse.ts",
      "benchmarks/task-executor.ts",
      "benchmarks/evals/read_over_cat/task.yml",
      "benchmarks/evals/patch_exact_match/task.yml",
      "benchmarks/evals/parallel_tool_calls/task.yml",
      "scripts/benchmark.sh",
      "scripts/list-all-porcelain.sh"
    ],
    "required_behaviors": [
      "parse_eval_name_as_directory_or_direct_task_yml_path",
      "require_eval_name_argument_before_eval_execution",
      "stream_stdout_and_stderr_to_log_files_after_stripping_ansi_sequences",
      "write_command_started_finished_exit_code_timeout_and_early_exit_metadata_to_logs",
      "support_task_timeout_with_sigkill_and_partial_output_capture",
      "support_early_exit_when_all_validations_pass_on_streaming_output",
      "validate_read_tasks_prefer_read_tools_over_shell_cat_antipatterns",
      "validate_patch_tasks_use_patch_tool_with_exact_search_text_and_no_missing_operation_errors",
      "validate_parallel_tool_call_tasks_emit_messages_with_multiple_tool_calls",
      "measure_cli_performance_across_ten_iterations_and_fail_when_average_exceeds_threshold",
      "project_porcelain_list_command_columns_and_runtime_without treating listing as behavior success"
    ],
    "output_receipts": [
      "eval_task_parse_receipt",
      "eval_execution_log_contract_receipt",
      "eval_validation_rule_receipt",
      "performance_threshold_receipt",
      "porcelain_inventory_receipt"
    ],
    "stop_conditions": [
      "eval_name_missing",
      "task_yml_missing_or_invalid",
      "validation_rule_missing",
      "eval_execution_requires_external_clone",
      "performance_threshold_exceeded"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "benchmark_eval_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
