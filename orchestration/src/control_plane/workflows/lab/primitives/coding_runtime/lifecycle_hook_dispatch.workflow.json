{
  "name": "lifecycle_hook_dispatch",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for dispatching ordered lifecycle hooks around start, request, response, tool call, and end events.",
  "stages": [
    "hook_chain_resolution",
    "start_event_dispatch",
    "request_event_dispatch",
    "response_event_dispatch",
    "toolcall_start_event_dispatch",
    "toolcall_end_event_dispatch",
    "end_event_dispatch",
    "hook_mutation_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "lifecycle_hook_dispatch_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "registered_hooks",
      "events_dispatched",
      "conversation_mutations",
      "end_hook_continuation_status",
      "hook_failure_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "run ordered lifecycle hooks and capture their conversation effects",
      "scope_boundary": "do not perform the provider request or tool execution directly",
      "validation_calibration": "report hook ordering, hook failures, and whether end hooks extended the run",
      "visibility": "do not expose private hook payloads or raw internal conversation state"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact lifecycle hook receipts for local coding runtime loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_raw_conversation_messages",
      "do_not_hide_hook_inserted_messages",
      "do_not_replace_context_loop_guard"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "hook_chain_resolution->start_event_dispatch",
      "start_event_dispatch->request_event_dispatch",
      "request_event_dispatch->response_event_dispatch",
      "response_event_dispatch->toolcall_start_event_dispatch",
      "toolcall_start_event_dispatch->toolcall_end_event_dispatch",
      "toolcall_end_event_dispatch->end_event_dispatch",
      "end_event_dispatch->hook_mutation_receipt_packaging",
      "hook_mutation_receipt_packaging->completed",
      "hook_chain_resolution->blocked",
      "request_event_dispatch->failed",
      "response_event_dispatch->failed",
      "end_event_dispatch->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 6000,
      "loop_signature_detector": "lifecycle_hook_dispatch_v1"
    }
  },
  "runtime_primitive_contract": {
    "version": "lifecycle_hook_dispatch_v1",
    "source_evidence": [
      "crates/forge_app/src/app.rs",
      "crates/forge_app/src/hooks/mod.rs",
      "crates/forge_domain/src/hook.rs",
      "crates/forge_app/src/orch.rs"
    ],
    "required_behaviors": [
      "compose_hook_handlers_sequentially",
      "dispatch_start_before_first_request",
      "dispatch_request_with_request_count_before_each_model_call",
      "dispatch_response_with_full_message_after_each_model_call",
      "dispatch_toolcall_start_and_toolcall_end_around_each_tool_execution",
      "dispatch_end_when_the_runtime_is_about_to_yield",
      "persist_conversation_after_hook_mutations",
      "continue_runtime_loop_when_end_hook_adds_messages",
      "support_tracing_title_generation_doom_loop_compaction_pending_todo_handlers"
    ],
    "output_receipts": [
      "hook_chain_receipt",
      "lifecycle_event_receipt",
      "hook_mutation_receipt",
      "end_hook_continuation_receipt",
      "hook_failure_receipt"
    ],
    "stop_conditions": [
      "hook_chain_missing_required_handler",
      "hook_execution_failed",
      "end_hook_repeatedly_extends_without_progress"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "hook_mutation_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
