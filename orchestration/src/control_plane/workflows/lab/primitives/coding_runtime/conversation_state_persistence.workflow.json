{
  "name": "conversation_state_persistence",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for persisting conversation context, metrics, turn counts, completion/yield state, and final task-complete signaling.",
  "stages": [
    "conversation_lookup_and_context_load",
    "system_and_user_prompt_insertion",
    "changed_file_notice_insertion",
    "metrics_initialization",
    "conversation_update_before_request",
    "conversation_update_after_tool_results",
    "request_and_tool_failure_limit_check",
    "completion_yield_or_interrupt_resolution",
    "final_conversation_upsert",
    "state_persistence_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "conversation_state_persistence_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "conversation_id_status",
      "prompt_insertion_status",
      "metrics_status",
      "request_count_status",
      "interrupt_status",
      "final_persistence_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "persist runtime state and decide whether a coding turn should continue, yield, or interrupt",
      "scope_boundary": "do not execute model calls, tool calls, or file mutations directly",
      "validation_calibration": "report persistence success, request limits, tool failure limits, and completion/yield decisions",
      "visibility": "do not expose raw conversation messages or private context internals"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact state persistence and loop-control receipts for local coding runtime loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_raw_conversation_payloads",
      "do_not_override_policy_or_safety_decisions",
      "do_not_continue_after_interrupt",
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "conversation_lookup_and_context_load->system_and_user_prompt_insertion",
      "system_and_user_prompt_insertion->changed_file_notice_insertion",
      "changed_file_notice_insertion->metrics_initialization",
      "metrics_initialization->conversation_update_before_request",
      "conversation_update_before_request->conversation_update_after_tool_results",
      "conversation_update_after_tool_results->request_and_tool_failure_limit_check",
      "request_and_tool_failure_limit_check->completion_yield_or_interrupt_resolution",
      "completion_yield_or_interrupt_resolution->final_conversation_upsert",
      "final_conversation_upsert->state_persistence_receipt_packaging",
      "state_persistence_receipt_packaging->completed",
      "conversation_lookup_and_context_load->blocked",
      "conversation_update_before_request->failed",
      "conversation_update_after_tool_results->failed",
      "request_and_tool_failure_limit_check->interrupted",
      "completion_yield_or_interrupt_resolution->interrupted",
      "final_conversation_upsert->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "interrupted",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "memory",
      "agent",
      "web",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 10,
      "max_model_turns": 1,
      "max_tool_calls": 2,
      "token_budget": 10000,
      "loop_signature_detector": "conversation_state_persistence_v1"
    }
  },
  "runtime_primitive_contract": {
    "version": "conversation_state_persistence_v1",
    "source_evidence": [
      "crates/forge_app/src/app.rs",
      "crates/forge_app/src/orch.rs",
      "crates/forge_domain/src/chat_response.rs"
    ],
    "required_behaviors": [
      "load_existing_conversation_by_id_before_chat",
      "insert_system_prompt_user_prompt_changed_file_notice_metrics_tunables_and_conversation_id",
      "persist_conversation_before_each_request",
      "append_assistant_message_and_tool_results_after_each_turn",
      "update_model_id_on_context_after_each_request",
      "copy_tool_context_metrics_back_to_conversation",
      "interrupt_when_max_request_per_turn_is_reached",
      "interrupt_when_max_tool_failure_per_turn_is_reached",
      "yield_when_finish_reason_is_stop_and_no_tool_calls_remain",
      "yield_when_a_tool_call_requires_parent_followup",
      "send_task_complete_only_when_the_turn_completed_cleanly",
      "always_upsert_conversation_after_runtime_dispatch_finishes"
    ],
    "output_receipts": [
      "conversation_lookup_receipt",
      "prompt_insertion_receipt",
      "changed_file_notice_receipt",
      "metrics_receipt",
      "request_count_receipt",
      "tool_failure_limit_receipt",
      "yield_decision_receipt",
      "final_upsert_receipt"
    ],
    "stop_conditions": [
      "conversation_not_found",
      "max_request_per_turn_reached",
      "max_tool_failure_per_turn_reached",
      "conversation_persistence_failed",
      "runtime_completed_current_turn"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "state_persistence_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
