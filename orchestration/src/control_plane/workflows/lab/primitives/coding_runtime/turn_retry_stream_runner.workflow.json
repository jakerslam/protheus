{
  "name": "turn_retry_stream_runner",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for running one transformed chat turn with retry, streaming deltas, and full message reconstruction.",
  "stages": [
    "retry_policy_resolution",
    "provider_chat_turn_start",
    "stream_delta_forwarding",
    "retry_attempt_event_forwarding",
    "full_message_reconstruction",
    "finish_reason_capture",
    "turn_result_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "turn_retry_stream_runner_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "retry_policy",
      "retry_attempts",
      "streaming_status",
      "message_reconstruction_status",
      "finish_reason",
      "turn_result_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "run a single provider chat turn while preserving stream and retry observability",
      "scope_boundary": "do not execute tool calls emitted by the turn",
      "validation_calibration": "report retry attempts, retry causes, stream completion, and finish reason without overstating success",
      "visibility": "do not expose raw provider payloads beyond allowed streamed assistant content"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact retry and streaming receipts for local coding runtime loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_persist_raw_provider_payloads",
      "do_not_hide_retryable_failures",
      "do_not_execute_tools_from_turn_result"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "retry_policy_resolution->provider_chat_turn_start",
      "provider_chat_turn_start->stream_delta_forwarding",
      "provider_chat_turn_start->retry_attempt_event_forwarding",
      "retry_attempt_event_forwarding->provider_chat_turn_start",
      "stream_delta_forwarding->full_message_reconstruction",
      "full_message_reconstruction->finish_reason_capture",
      "finish_reason_capture->turn_result_receipt_packaging",
      "turn_result_receipt_packaging->completed",
      "provider_chat_turn_start->failed",
      "retry_attempt_event_forwarding->failed",
      "full_message_reconstruction->failed"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "failed",
      "needs_input",
      "blocked",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 7,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 16000,
      "loop_signature_detector": "turn_retry_stream_runner_v1"
    }
  },
  "runtime_primitive_contract": {
    "version": "turn_retry_stream_runner_v1",
    "source_evidence": [
      "crates/forge_app/src/orch.rs",
      "crates/forge_app/src/retry.rs",
      "crates/forge_domain/src/chat_response.rs"
    ],
    "required_behaviors": [
      "apply_exponential_retry_with_configured_min_delay_factor_max_attempts_and_jitter",
      "retry_only_domain_retryable_errors",
      "emit_retry_attempt_events_with_cause_and_duration",
      "forward_markdown_streaming_deltas_as_visible_assistant_content",
      "reconstruct_full_chat_completion_message_from_stream",
      "preserve_finish_reason_tool_calls_usage_reasoning_and_phase",
      "return_structured_failure_when_stream_or_reconstruction_fails"
    ],
    "output_receipts": [
      "retry_config_receipt",
      "retry_attempt_receipt",
      "stream_forwarding_receipt",
      "message_reconstruction_receipt",
      "finish_reason_receipt"
    ],
    "stop_conditions": [
      "retry_budget_exhausted",
      "provider_stream_failed",
      "message_reconstruction_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "turn_result_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
