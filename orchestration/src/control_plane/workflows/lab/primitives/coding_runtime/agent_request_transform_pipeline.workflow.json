{
  "name": "agent_request_transform_pipeline",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for preparing each agent request by applying model/tool capability transforms before the chat turn is sent.",
  "stages": [
    "agent_model_capability_resolution",
    "tool_definition_sorting",
    "persisted_tool_argument_normalization",
    "native_or_text_tool_mode_transform",
    "image_content_transform",
    "reasoning_support_transform",
    "model_specific_reasoning_transform",
    "request_transform_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "agent_request_transform_pipeline_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "model_tool_support",
      "tool_order_status",
      "tool_call_argument_status",
      "image_handling_status",
      "reasoning_transform_status",
      "request_ready_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "prepare a provider-compatible agent request without changing user intent",
      "scope_boundary": "do not execute the model request or any tool calls",
      "validation_calibration": "report which request transforms were applied, skipped, or blocked",
      "visibility": "do not expose hidden thought signatures, reasoning details, or transformed raw provider payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact request-transform receipts for local coding runtime loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_raw_provider_payloads",
      "do_not_expose_private_reasoning",
      "do_not_mutate_workspace_files",
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "agent_model_capability_resolution->tool_definition_sorting",
      "tool_definition_sorting->persisted_tool_argument_normalization",
      "persisted_tool_argument_normalization->native_or_text_tool_mode_transform",
      "native_or_text_tool_mode_transform->image_content_transform",
      "image_content_transform->reasoning_support_transform",
      "reasoning_support_transform->model_specific_reasoning_transform",
      "model_specific_reasoning_transform->request_transform_receipt_packaging",
      "request_transform_receipt_packaging->completed",
      "agent_model_capability_resolution->blocked",
      "persisted_tool_argument_normalization->failed",
      "native_or_text_tool_mode_transform->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "agent",
      "workspace",
      "web",
      "memory",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 6000,
      "loop_signature_detector": "agent_request_transform_pipeline_v1"
    }
  },
  "runtime_primitive_contract": {
    "version": "agent_request_transform_pipeline_v1",
    "source_evidence": [
      "crates/forge_app/src/orch.rs",
      "crates/forge_domain/src/transformer/normalize_tool_args.rs",
      "crates/forge_domain/src/transformer/transform_tool_calls.rs"
    ],
    "required_behaviors": [
      "resolve_agent_model_tool_support_before_each_request",
      "sort_tools_using_agent_tool_order_when_available",
      "normalize_persisted_unparsed_tool_call_arguments",
      "convert_tool_call_context_for_models_without_native_tool_support",
      "apply_image_handling_for_model_capabilities",
      "drop_reasoning_details_when_model_does_not_support_reasoning",
      "normalize_reasoning_fields_for_provider_compatibility",
      "apply_claude_specific_reasoning_transform",
      "drop_reasoning_only_messages_when_required_by_provider"
    ],
    "output_receipts": [
      "model_tool_support_receipt",
      "tool_sort_receipt",
      "tool_argument_normalization_receipt",
      "tool_mode_projection_receipt",
      "image_transform_receipt",
      "reasoning_transform_receipt"
    ],
    "stop_conditions": [
      "model_capability_unknown",
      "tool_definition_projection_failed",
      "request_transform_would_drop_required_user_content"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "request_transform_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
