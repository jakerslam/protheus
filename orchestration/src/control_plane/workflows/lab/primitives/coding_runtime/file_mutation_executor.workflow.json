{
  "name": "file_mutation_executor",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive contract for executing scoped local file writes and patches through native tools and emitting authoritative mutation receipts.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "primitive",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.file_mutation_executor",
    "special_case_policy": "Mutation behavior may vary by generic operation, scope policy, and adapter; it must not branch on eval tasks, fixture filenames, or prompt phrases.",
    "monotonic_lower_level_regression_policy": "The executor must keep create-file writes cheap while preserving exact-context patch safety for existing files."
  },
  "provenance_contract": {
    "source_systems": [
      "SWE-agent",
      "Aider",
      "Cline",
      "ForgeCode"
    ],
    "import_rule": "assimilate_file_mutation_contracts_not_tool_branding",
    "artifact_corpus_ref": "references/coding-agent-systems"
  },
  "stages": [
    "mutation_request_intake",
    "allowed_scope_check",
    "operation_shape_validation",
    "native_file_tool_dispatch",
    "hash_and_byte_delta_projection",
    "mutation_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "file_mutation_executor_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "tool",
      "status",
      "path",
      "operation",
      "old_hash",
      "new_hash",
      "bytes_written",
      "scope_decision",
      "error"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "execute one scoped file mutation and produce a mutation receipt",
      "scope_boundary": "do not infer whole-task success, run validation, or synthesize the final answer",
      "validation_calibration": "tool success means mutation success only, not software correctness",
      "visibility": "return compact mutation receipt fields and safe error envelopes"
    }
  },
  "file_mutation_executor_contract": {
    "version": "file_mutation_executor_v1",
    "input_contract": {
      "schema": "file_mutation_executor_input_envelope_v1",
      "required_fields": [
        "operation",
        "path",
        "allowed_write_scope"
      ],
      "optional_fields": [
        "content",
        "old_text",
        "new_text",
        "expected_old_hash",
        "task_contract_ref"
      ],
      "allowed_operations": [
        "write",
        "patch"
      ]
    },
    "required_behaviors": [
      "deny_paths_outside_allowed_write_scope",
      "use_file_write_for_write_operations",
      "use_file_patch_for_patch_operations",
      "require_old_text_and_new_text_for_patch_operations",
      "emit_failed_receipt_for_non_unique_or_missing_patch_context",
      "emit_success_receipt_with_path_operation_scope_decision_and_hashes_when_available",
      "never_treat_mutation_receipt_as_final_task_success"
    ],
    "output_receipts": [
      "file_mutation_receipt_v1"
    ],
    "failure_modes": [
      "path_out_of_scope",
      "patch_context_not_unique",
      "file_missing_for_patch",
      "permission_denied",
      "io_error"
    ],
    "native_tool_mapping": {
      "write": "file_write",
      "patch": "file_patch"
    },
    "non_goals": [
      "do_not_select_context",
      "do_not_run_validation",
      "do_not_generate_architecture",
      "do_not_branch_on_eval_level_or_fixture_name"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "mutation_request_intake->allowed_scope_check",
      "allowed_scope_check->operation_shape_validation",
      "operation_shape_validation->native_file_tool_dispatch",
      "native_file_tool_dispatch->hash_and_byte_delta_projection",
      "hash_and_byte_delta_projection->mutation_receipt_packaging",
      "mutation_receipt_packaging->completed",
      "allowed_scope_check->blocked",
      "operation_shape_validation->blocked",
      "native_file_tool_dispatch->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 3000,
      "loop_signature_detector": "file_mutation_executor_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace",
      "do_not_decide_task_success"
    ]
  }
}
