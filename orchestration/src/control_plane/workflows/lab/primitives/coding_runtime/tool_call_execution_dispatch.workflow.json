{
  "name": "tool_call_execution_dispatch",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for dispatching emitted tool calls with task parallelism, non-task sequencing, lifecycle events, UI handshakes, and retry reflection.",
  "stages": [
    "tool_call_partitioning",
    "task_tool_parallel_dispatch",
    "non_task_tool_sequential_dispatch",
    "system_tool_start_handshake",
    "tool_lifecycle_event_dispatch",
    "tool_result_order_reconstruction",
    "tool_error_attempt_tracking",
    "tool_dispatch_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "tool_call_execution_dispatch_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "tool_calls_received",
      "task_dispatch_status",
      "sequential_dispatch_status",
      "system_tool_event_status",
      "tool_error_status",
      "ordered_result_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "execute approved tool calls in ForgeCode-compatible order while preserving receipts",
      "scope_boundary": "do not authorize operations or repair failed tool calls by itself",
      "validation_calibration": "report which tool calls succeeded, failed, were denied, or require reflection",
      "visibility": "do not expose raw hidden tool payloads or private nested-agent internals"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact tool dispatch receipts for local coding runtime loops.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_execute_unregistered_tools",
      "do_not_hide_tool_failures",
      "do_not_bypass_permission_or_file_safety_primitives",
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "tool_call_partitioning->task_tool_parallel_dispatch",
      "tool_call_partitioning->non_task_tool_sequential_dispatch",
      "task_tool_parallel_dispatch->non_task_tool_sequential_dispatch",
      "non_task_tool_sequential_dispatch->system_tool_start_handshake",
      "system_tool_start_handshake->tool_lifecycle_event_dispatch",
      "tool_lifecycle_event_dispatch->tool_result_order_reconstruction",
      "tool_result_order_reconstruction->tool_error_attempt_tracking",
      "tool_error_attempt_tracking->tool_dispatch_receipt_packaging",
      "tool_dispatch_receipt_packaging->completed",
      "tool_call_partitioning->blocked",
      "task_tool_parallel_dispatch->failed",
      "non_task_tool_sequential_dispatch->failed",
      "tool_error_attempt_tracking->blocked"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "shell",
      "agent",
      "web",
      "memory",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 16,
      "token_budget": 12000,
      "loop_signature_detector": "tool_call_execution_dispatch_v1"
    }
  },
  "runtime_primitive_contract": {
    "version": "tool_call_execution_dispatch_v1",
    "source_evidence": [
      "crates/forge_app/src/orch.rs",
      "crates/forge_app/src/tool_registry.rs",
      "crates/forge_domain/src/chat_response.rs",
      "templates/forge-tool-retry-message.md"
    ],
    "required_behaviors": [
      "detect_task_tool_calls_case_insensitively",
      "execute_task_tool_calls_in_parallel",
      "execute_non_task_tool_calls_sequentially",
      "send_tool_call_start_and_end_events_for_system_tools",
      "wait_for_system_tool_start_notifier_before_executing_to_preserve_ui_order",
      "dispatch_toolcall_start_and_toolcall_end_lifecycle_events",
      "reconstruct_tool_results_in_original_model_call_order",
      "track_tool_error_counts_per_tool_name",
      "append_attempts_left_retry_guidance_to_tool_error_outputs",
      "interrupt_when_max_tool_failure_per_turn_is_reached"
    ],
    "output_receipts": [
      "tool_partition_receipt",
      "task_parallel_dispatch_receipt",
      "sequential_dispatch_receipt",
      "system_tool_event_receipt",
      "lifecycle_toolcall_receipt",
      "ordered_tool_result_receipt",
      "tool_error_attempt_receipt"
    ],
    "stop_conditions": [
      "tool_not_registered",
      "operation_permission_denied",
      "tool_timeout",
      "max_tool_failure_per_turn_reached",
      "system_tool_start_notifier_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "tool_dispatch_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
