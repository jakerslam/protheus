{
  "name": "implementation_entry_gate",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive gate that decides whether a coding task may mutate, validate, finalize, ask for input, or block based on the task contract, context state, receipts, and proposed next action.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "primitive",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.implementation_entry_gate",
    "special_case_policy": "Gate decisions must use generic task contract fields and receipt state; benchmark-specific paths and task text are forbidden.",
    "monotonic_lower_level_regression_policy": "The gate must keep the single-file create fast path short while preventing final success without mutation receipts."
  },
  "provenance_contract": {
    "source_systems": [
      "mini-SWE-agent",
      "OpenHands",
      "SWE-agent",
      "ForgeCode"
    ],
    "import_rule": "assimilate_state_gate_behavior_not_case_specific_prompts",
    "artifact_corpus_ref": "references/coding-agent-systems"
  },
  "stages": [
    "task_contract_intake",
    "context_state_intake",
    "receipt_state_projection",
    "proposed_action_classification",
    "mutation_before_success_gate",
    "context_before_existing_project_mutation_gate",
    "validation_after_mutation_gate",
    "allowed_action_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "implementation_entry_gate_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "allowed",
      "allowed_actions",
      "blocked_reason",
      "repair_reason",
      "earliest_unsatisfied_state"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return the safe next execution gate decision for a coding task",
      "scope_boundary": "do not execute tools or synthesize task success",
      "validation_calibration": "treat validation before mutation as baseline evidence only",
      "visibility": "return compact gate reason fields without hidden chain-of-thought"
    }
  },
  "implementation_entry_gate_contract": {
    "version": "implementation_entry_gate_v1",
    "input_contract": {
      "schema": "implementation_entry_gate_input_envelope_v1",
      "required_fields": [
        "task_contract_ref",
        "receipt_journal_ref",
        "proposed_action"
      ],
      "optional_fields": [
        "context_pack_ref",
        "context_state",
        "repair_reasons"
      ]
    },
    "required_behaviors": [
      "forbid_finalize_when_requires_mutation_and_no_successful_mutation_receipt_exists",
      "allow_file_write_or_file_patch_when_mutation_required_and_scope_is_safe",
      "forbid_existing_project_mutation_when_context_required_and_context_pack_is_missing",
      "allow_context_free_create_file_fast_path_when_contract_marks_context_unnecessary",
      "forbid_validation_as_completion_when_validation_ran_before_mutation",
      "return_repair_reason_missing_product_mutation_receipt_when_finalization_is_early",
      "return_repair_reason_mutation_blocked_by_missing_context_when_existing_project_context_is_missing"
    ],
    "output_receipts": [
      "implementation_entry_gate_receipt_v1"
    ],
    "non_goals": [
      "do_not_mutate_files",
      "do_not_run_validation",
      "do_not_select_project_architecture",
      "do_not_branch_on_eval_level_or_fixture_name"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "task_contract_intake->context_state_intake",
      "context_state_intake->receipt_state_projection",
      "receipt_state_projection->proposed_action_classification",
      "proposed_action_classification->mutation_before_success_gate",
      "mutation_before_success_gate->context_before_existing_project_mutation_gate",
      "context_before_existing_project_mutation_gate->validation_after_mutation_gate",
      "validation_after_mutation_gate->allowed_action_packaging",
      "allowed_action_packaging->completed",
      "mutation_before_success_gate->blocked",
      "context_before_existing_project_mutation_gate->blocked"
    ],
    "timeout_ms": 15000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 0,
      "token_budget": 3000,
      "loop_signature_detector": "implementation_entry_gate_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace",
      "do_not_decide_task_success"
    ]
  }
}
