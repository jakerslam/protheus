{
  "name": "coding_task_contract",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "Primitive contract for converting a user coding request into mutation, context, validation, public-surface, write-scope, confidence, and stop-condition requirements before execution.",
  "primitive_first_contract": {
    "case_specific_hardcoding_allowed": false,
    "specificity_owner": "primitive",
    "extension_surface": "workflow_cd",
    "registered_capability_id": "workflow.coding_task_contract",
    "special_case_policy": "Task classes may be configured as generic contract fields; eval names, fixture paths, and benchmark prompt strings must not appear in production routing.",
    "monotonic_lower_level_regression_policy": "The contract must allow context-free single-file creation without forcing existing-project discovery."
  },
  "provenance_contract": {
    "source_systems": [
      "mini-SWE-agent",
      "OpenHands",
      "Continue",
      "ForgeCode"
    ],
    "import_rule": "assimilate_runtime_contract_shape_not_prompt_phrasing",
    "artifact_corpus_ref": "references/coding-agent-systems"
  },
  "stages": [
    "prompt_intake",
    "task_kind_classification",
    "write_scope_projection",
    "context_requirement_projection",
    "mutation_requirement_projection",
    "validation_requirement_projection",
    "public_surface_requirement_projection",
    "confidence_and_open_question_gate",
    "task_contract_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "coding_task_contract_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "task_kind",
      "requires_context",
      "requires_mutation",
      "requires_validation",
      "requires_public_interface_check",
      "allowed_write_scope",
      "target_artifacts",
      "confidence",
      "open_questions",
      "stop_conditions"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "produce a compact coding task contract that downstream primitives can execute",
      "scope_boundary": "do not inspect large source files, mutate files, run validation, or decide final success",
      "validation_calibration": "separate user-owned missing information from locally discoverable uncertainty",
      "visibility": "return contract fields and safe rationale without hidden chain-of-thought"
    }
  },
  "coding_task_contract": {
    "version": "coding_task_contract_v1",
    "input_contract": {
      "schema": "coding_task_contract_input_envelope_v1",
      "required_fields": [
        "user_prompt",
        "workspace_root",
        "allowed_write_roots",
        "permissions",
        "workflow_profile"
      ]
    },
    "output_contract": {
      "schema": "coding_task_contract_output_envelope_v1",
      "required_fields": [
        "task_id",
        "task_kind",
        "requires_context",
        "requires_mutation",
        "requires_validation",
        "requires_public_interface_check",
        "allowed_write_scope",
        "target_artifacts",
        "public_surface_requirements",
        "stop_conditions",
        "confidence",
        "open_questions"
      ],
      "allowed_task_kinds": [
        "create_file",
        "existing_project_patch",
        "debug_repair",
        "refactor",
        "project_slice",
        "explanation_only"
      ]
    },
    "required_behaviors": [
      "classify_context_free_create_file_without_forcing_file_reads",
      "classify_existing_project_mutation_as_context_required",
      "mark_mutation_required_for_create_edit_debug_refactor_and_project_slice_tasks",
      "project_requested_tests_or_validation_into_requires_validation",
      "project_user_named_functions_classes_attrs_modules_and_constructor_args_into_public_surface_requirements",
      "return_needs_user_input_when_low_confidence_depends_on_user_owned_facts",
      "continue_to_context_pack_when_low_confidence_facts_are_locally_discoverable"
    ],
    "output_receipts": [
      "task_contract_receipt_v1"
    ],
    "non_goals": [
      "do_not_mutate_files",
      "do_not_run_validation",
      "do_not_choose_full_project_architecture",
      "do_not_branch_on_eval_level_or_fixture_name"
    ]
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "prompt_intake->task_kind_classification",
      "task_kind_classification->write_scope_projection",
      "write_scope_projection->context_requirement_projection",
      "context_requirement_projection->mutation_requirement_projection",
      "mutation_requirement_projection->validation_requirement_projection",
      "validation_requirement_projection->public_surface_requirement_projection",
      "public_surface_requirement_projection->confidence_and_open_question_gate",
      "confidence_and_open_question_gate->task_contract_receipt_packaging",
      "task_contract_receipt_packaging->completed",
      "confidence_and_open_question_gate->needs_input",
      "write_scope_projection->blocked"
    ],
    "timeout_ms": 20000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "needs_input",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "memory"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 9,
      "max_model_turns": 1,
      "max_tool_calls": 0,
      "token_budget": 4000,
      "loop_signature_detector": "coding_task_contract_v1"
    }
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace",
      "do_not_decide_task_success"
    ]
  }
}
