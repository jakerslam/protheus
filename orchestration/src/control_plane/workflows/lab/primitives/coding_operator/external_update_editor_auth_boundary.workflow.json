{
  "name": "external_update_editor_auth_boundary",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for update checks, VS Code extension setup, and localhost OAuth callback handling as explicit operator boundaries.",
  "stages": [
    "external_boundary_need_assessment",
    "update_check_boundary",
    "editor_extension_boundary",
    "localhost_oauth_callback_boundary",
    "external_action_confirmation_gate",
    "external_boundary_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "external_update_editor_auth_boundary_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "update_check_status",
      "editor_extension_status",
      "oauth_callback_status",
      "confirmation_status",
      "secret_redaction_status",
      "external_boundary_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route externally visible update, editor, and auth callback actions through explicit operator boundaries",
      "scope_boundary": "do not install updates, install extensions, bind callback servers, or mutate credentials without the configured confirmation path",
      "validation_calibration": "report readiness and user-action requirements separately from coding progress",
      "visibility": "do not expose OAuth codes, tokens, credential params, or raw auth payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact receipts for update checks, editor integration, and auth callback boundaries without storing secrets.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_install_without_confirmation",
      "do_not_store_oauth_codes_or_tokens",
      "do_not_bind_non_loopback_callback_servers",
      "do_not_treat_external_setup_as_code_validation"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "external_boundary_need_assessment->update_check_boundary",
      "update_check_boundary->editor_extension_boundary",
      "editor_extension_boundary->localhost_oauth_callback_boundary",
      "localhost_oauth_callback_boundary->external_action_confirmation_gate",
      "external_action_confirmation_gate->external_boundary_receipt_packaging",
      "external_boundary_receipt_packaging->completed",
      "update_check_boundary->blocked",
      "editor_extension_boundary->needs_input",
      "localhost_oauth_callback_boundary->needs_input",
      "external_action_confirmation_gate->aborted"
    ],
    "timeout_ms": 300000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 8,
      "token_budget": 7000,
      "loop_signature_detector": "external_update_editor_auth_boundary_v1"
    }
  },
  "operator_primitive_contract": {
    "version": "external_update_editor_auth_boundary_v1",
    "source_evidence": [
      "crates/forge_main/src/update.rs",
      "crates/forge_main/src/vscode.rs",
      "crates/forge_main/src/oauth_callback.rs"
    ],
    "required_behaviors": [
      "skip_update_checks_for_dev_builds_and_version_zero_one_zero",
      "check_latest_version_from_github_registry_only_when_frequency_policy_allows",
      "require_interactive_confirmation_unless_auto_update_is_enabled",
      "run_official_installer_command_only_through_confirmed_external_action_route",
      "treat_update_failures_as_logged_or_silent_without_claiming_success",
      "detect_vscode_terminal_from_term_program_or_vscode_environment_variables",
      "check_code_extension_list_for_forgecode_extension_before_install",
      "install_forgecode_vscode_extension_only_when_in_vscode_and_missing",
      "start_oauth_callback_server_only_for_localhost_or_loopback_redirect_uris_with_explicit_port",
      "accept_only_loopback_get_requests_on_expected_callback_path",
      "require_oauth_state_match_and_code_presence",
      "surface_oauth_error_parameters_as_structured_auth_errors",
      "timeout_oauth_callback_wait_after_three_hundred_seconds",
      "return_success_or_error_html_with_no_store_and_nosniff_headers"
    ],
    "output_receipts": [
      "update_check_receipt",
      "update_confirmation_receipt",
      "editor_extension_receipt",
      "oauth_callback_boundary_receipt",
      "secret_redaction_receipt"
    ],
    "stop_conditions": [
      "update_requires_user_confirmation",
      "installer_route_not_confirmed",
      "vscode_cli_unavailable",
      "oauth_redirect_uri_not_loopback",
      "oauth_state_mismatch",
      "oauth_callback_timeout"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "external_boundary_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
