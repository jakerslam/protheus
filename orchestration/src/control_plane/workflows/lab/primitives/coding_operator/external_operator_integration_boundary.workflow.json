{
  "name": "external_operator_integration_boundary",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for external operator integrations: update checks, VS Code extension detection/install route, and localhost OAuth callback handling.",
  "stages": [
    "external_integration_need_assessment",
    "update_check_route",
    "vscode_extension_route",
    "localhost_oauth_callback_route",
    "external_action_confirmation_boundary",
    "external_integration_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "external_operator_integration_boundary_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "update_check_status",
      "vscode_detection_status",
      "extension_install_route",
      "oauth_callback_status",
      "external_action_requires_confirmation",
      "integration_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route external operator integrations without silently changing the user environment",
      "scope_boundary": "do not install extensions, update binaries, or complete OAuth without explicit parent/user route",
      "validation_calibration": "report integration readiness and external actions separately from coding progress",
      "visibility": "do not expose OAuth codes, states, tokens, or raw callback payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact external integration receipts while preventing silent environment mutation.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_oauth_codes_or_state",
      "do_not_silently_install_extensions",
      "do_not_silently_update_cli",
      "do_not_mutate_local_source_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "external_integration_need_assessment->update_check_route",
      "update_check_route->vscode_extension_route",
      "vscode_extension_route->localhost_oauth_callback_route",
      "localhost_oauth_callback_route->external_action_confirmation_boundary",
      "external_action_confirmation_boundary->external_integration_receipt_packaging",
      "external_integration_receipt_packaging->completed",
      "update_check_route->needs_input",
      "vscode_extension_route->needs_input",
      "localhost_oauth_callback_route->blocked",
      "external_action_confirmation_boundary->needs_input"
    ],
    "timeout_ms": 300000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 6,
      "token_budget": 5000,
      "loop_signature_detector": "external_operator_integration_boundary_v1"
    }
  },
  "operator_primitive_contract": {
    "version": "external_operator_integration_boundary_v1",
    "source_evidence": [
      "crates/forge_main/src/update.rs",
      "crates/forge_main/src/vscode.rs",
      "crates/forge_main/src/oauth_callback.rs"
    ],
    "required_behaviors": [
      "update_checks_are_skipped_for_dev_or_0_1_0_versions",
      "update_frequency_and_auto_update_are_config_driven",
      "manual_update_requires_user_confirmation_before_exit",
      "update_failures_are_reported_silently_to_tracking_error_path",
      "vscode_detection_uses_term_program_vscode_pid_git_askpass_or_ipc_env_vars",
      "vscode_extension_install_route_requires_vscode_terminal_and_missing_extension",
      "localhost_oauth_callback_only_starts_for_http_loopback_redirect_with_explicit_port",
      "oauth_callback_accepts_only_loopback_get_requests",
      "oauth_callback_requires_expected_path_matching_state_and_non_empty_code",
      "oauth_callback_errors_are_returned_as_failure_pages_and_do_not_leak_codes"
    ],
    "output_receipts": [
      "update_check_receipt",
      "vscode_detection_receipt",
      "extension_install_route_receipt",
      "oauth_callback_receipt",
      "external_confirmation_receipt"
    ],
    "stop_conditions": [
      "update_requires_user_exit_confirmation",
      "extension_install_requires_user_visible_external_action",
      "oauth_state_mismatch",
      "oauth_callback_timeout",
      "non_loopback_oauth_callback_request"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "external_integration_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
