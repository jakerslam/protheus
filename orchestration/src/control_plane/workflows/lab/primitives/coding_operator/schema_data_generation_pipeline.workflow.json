{
  "name": "schema_data_generation_pipeline",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for schema-constrained JSONL data generation as a bounded operator workflow.",
  "stages": [
    "data_generation_request_classification",
    "schema_and_prompt_file_resolution",
    "jsonl_input_loading",
    "output_tool_schema_binding",
    "concurrent_generation_execution_boundary",
    "json_output_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "schema_data_generation_pipeline_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "schema_status",
      "input_status",
      "prompt_template_status",
      "concurrency_status",
      "output_stream_status",
      "data_generation_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "generate schema-constrained output records from local JSONL inputs when explicitly routed",
      "scope_boundary": "do not mutate source code, choose coding architecture, or treat generated records as validation",
      "validation_calibration": "report schema binding, input parse, generation, and output extraction separately",
      "visibility": "do not expose provider internals or raw failed tool payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact schema data-generation receipts without storing raw provider payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_raw_provider_payloads",
      "do_not_treat_generation_as_code_validation",
      "do_not_expand_beyond_declared_input_jsonl"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "data_generation_request_classification->schema_and_prompt_file_resolution",
      "schema_and_prompt_file_resolution->jsonl_input_loading",
      "jsonl_input_loading->output_tool_schema_binding",
      "output_tool_schema_binding->concurrent_generation_execution_boundary",
      "concurrent_generation_execution_boundary->json_output_receipt_packaging",
      "json_output_receipt_packaging->completed",
      "schema_and_prompt_file_resolution->blocked",
      "jsonl_input_loading->failed",
      "output_tool_schema_binding->failed",
      "concurrent_generation_execution_boundary->failed"
    ],
    "timeout_ms": 240000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 4,
      "max_tool_calls": 12,
      "token_budget": 16000,
      "loop_signature_detector": "schema_data_generation_pipeline_v1"
    }
  },
  "operator_primitive_contract": {
    "version": "schema_data_generation_pipeline_v1",
    "source_evidence": [
      "crates/forge_app/src/data_gen.rs"
    ],
    "required_behaviors": [
      "resolve_relative_schema_system_user_and_input_paths_against_current_working_directory",
      "load_schema_system_user_and_input_files_before_generation",
      "parse_input_jsonl_as_one_json_value_per_nonempty_line",
      "require_session_config_provider_and_model_before_generation",
      "bind_output_tool_schema_from_requested_json_schema",
      "include_optional_system_prompt_when_present",
      "render_optional_user_prompt_template_per_input_record",
      "fallback_to_input_json_as_user_content_when_no_template_is_present",
      "execute_generation_with_configured_concurrency",
      "extract_output_from_output_tool_call_arguments",
      "emit_each_output_as_json_object_with_input_and_output_fields"
    ],
    "output_receipts": [
      "data_generation_file_resolution_receipt",
      "jsonl_input_parse_receipt",
      "output_tool_schema_receipt",
      "generation_concurrency_receipt",
      "json_output_stream_receipt"
    ],
    "stop_conditions": [
      "schema_file_missing_or_invalid",
      "input_jsonl_invalid",
      "session_config_missing",
      "provider_generation_failed",
      "output_tool_call_missing_or_invalid"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "json_output_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
