{
  "name": "operator_command_surface_projection",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for projecting slash/colon commands, command lists, Info sections, and tool overview display without executing side effects.",
  "stages": [
    "command_input_classification",
    "slash_colon_command_parse",
    "shell_bypass_route",
    "workflow_and_agent_command_projection",
    "info_and_tools_display_projection",
    "command_surface_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "operator_command_surface_projection_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "input_route",
      "command_name",
      "command_registry_status",
      "display_projection_status",
      "shell_bypass_status",
      "command_surface_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "classify operator command input and project visible command/tool status",
      "scope_boundary": "do not execute command side effects, run shell commands, mutate files, or choose coding architecture",
      "validation_calibration": "distinguish parsed command display from executed command success",
      "visibility": "surface compact command/tool status without leaking raw internal command registry payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact operator command-surface projection receipts.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_execute_shell_bypass_inside_projection",
      "do_not_mutate_files_from_command_projection",
      "do_not_expose_raw_failed_mcp_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "command_input_classification->slash_colon_command_parse",
      "slash_colon_command_parse->shell_bypass_route",
      "shell_bypass_route->workflow_and_agent_command_projection",
      "workflow_and_agent_command_projection->info_and_tools_display_projection",
      "info_and_tools_display_projection->command_surface_receipt_packaging",
      "command_surface_receipt_packaging->completed",
      "slash_colon_command_parse->completed",
      "workflow_and_agent_command_projection->blocked",
      "info_and_tools_display_projection->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 5000,
      "loop_signature_detector": "operator_command_surface_projection_v1"
    }
  },
  "operator_primitive_contract": {
    "version": "operator_command_surface_projection_v1",
    "source_evidence": [
      "crates/forge_main/src/model.rs",
      "crates/forge_main/src/info.rs",
      "crates/forge_main/src/tools_display.rs"
    ],
    "required_behaviors": [
      "parse_slash_and_colon_prefixed_commands",
      "route_bang_prefixed_input_as_shell_bypass_without_executing_it",
      "pass_non_command_messages_through_to_normal_chat",
      "register_workflow_commands_after_replacing_prior_workflow_marker_entries",
      "register_agent_commands_with_sanitized_agent_dash_prefix",
      "skip_reserved_command_conflicts",
      "sort_command_registry_before_display",
      "render_info_sections_with_title_case_keys_and_placeholder_empty_values",
      "format_tool_overview_with_enabled_and_disabled_checkbox_markers",
      "include_failed_mcp_server_sections_with_error_text_truncated_to_eighty_characters"
    ],
    "output_receipts": [
      "command_parse_receipt",
      "shell_bypass_route_receipt",
      "command_registry_projection_receipt",
      "info_display_receipt",
      "tool_overview_display_receipt"
    ],
    "stop_conditions": [
      "command_name_reserved_or_conflicting",
      "command_registry_projection_failed",
      "display_projection_failed",
      "shell_bypass_requires_permissioned_execution_route"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "command_surface_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
