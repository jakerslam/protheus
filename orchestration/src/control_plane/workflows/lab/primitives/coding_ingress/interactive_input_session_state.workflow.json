{
  "name": "interactive_input_session_state",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for interactive console prompt state, editor buffer handling, app command parsing, UI cwd/conversation state, and conversation selection display.",
  "stages": [
    "console_prompt_loop",
    "editor_buffer_state_projection",
    "app_command_parse",
    "ui_prompt_state_projection",
    "conversation_selector_projection",
    "interactive_state_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "interactive_input_session_state_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "interactive_mode_status",
      "editor_buffer_status",
      "parsed_app_command",
      "prompt_cwd",
      "prompt_agent_model_projection",
      "conversation_selection_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return interactive session state that can safely feed a local coding run",
      "scope_boundary": "do not execute parsed commands or mutate conversations directly",
      "validation_calibration": "report prompt loop exits, empty input, parsed commands, and selected conversation receipts",
      "visibility": "do not leak raw history, hidden editor state, or private prompt internals"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact interactive session receipts for local coding requests without storing raw history buffers.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_raw_history",
      "do_not_execute_app_commands",
      "do_not_hide_exit_or_empty_input",
      "do_not_mutate_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "console_prompt_loop->editor_buffer_state_projection",
      "editor_buffer_state_projection->app_command_parse",
      "app_command_parse->ui_prompt_state_projection",
      "ui_prompt_state_projection->conversation_selector_projection",
      "conversation_selector_projection->interactive_state_receipt_packaging",
      "interactive_state_receipt_packaging->completed",
      "console_prompt_loop->needs_input",
      "app_command_parse->blocked",
      "conversation_selector_projection->needs_input"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 2,
      "token_budget": 4000,
      "loop_signature_detector": "interactive_input_session_state_v1"
    }
  },
  "ingress_primitive_contract": {
    "version": "interactive_input_session_state_v1",
    "source_evidence": [
      "crates/forge_main/src/input.rs",
      "crates/forge_main/src/prompt.rs",
      "crates/forge_main/src/state.rs",
      "crates/forge_main/src/conversation_selector.rs",
      "crates/forge_main/src/porcelain.rs"
    ],
    "required_behaviors": [
      "console_prompt_loop_continues_on_continue_or_empty_input",
      "console_prompt_loop_returns_exit_command_on_exit",
      "successful_text_input_is_tracked_then_parsed_as_app_command",
      "editor_buffer_can_be_seeded_for_next_prompt",
      "prompt_projects_cwd_agent_usage_model_and_git_branch",
      "ui_state_tracks_cwd_and_optional_conversation_id",
      "conversation_selector_filters_to_titled_contextful_conversations",
      "conversation_selector_uses_porcelain_table_without_uuid_column"
    ],
    "output_receipts": [
      "prompt_loop_receipt",
      "app_command_parse_receipt",
      "editor_buffer_receipt",
      "ui_state_receipt",
      "conversation_selector_receipt"
    ],
    "stop_conditions": [
      "user_exits_interactive_prompt",
      "parsed_command_is_not_supported_for_coding_ingress",
      "conversation_selection_cancelled_when_required"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "interactive_state_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
