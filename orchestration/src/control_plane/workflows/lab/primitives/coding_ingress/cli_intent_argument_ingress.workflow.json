{
  "name": "cli_intent_argument_ingress",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for normalizing CLI and process ingress before a local coding run, including prompt source, piped input, cwd, sandbox, conversation id, event JSON, and subcommand route.",
  "stages": [
    "cli_argument_collection",
    "stdin_prompt_merge",
    "directory_and_sandbox_resolution",
    "conversation_mode_resolution",
    "subcommand_route_classification",
    "cli_ingress_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "cli_intent_argument_ingress_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "prompt_source",
      "piped_input_status",
      "cwd_resolution",
      "sandbox_mode",
      "conversation_id_policy",
      "execution_mode",
      "routed_subcommand"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return a normalized local coding request envelope before planning starts",
      "scope_boundary": "do not perform coding, validation, permission approval, or tool execution",
      "validation_calibration": "report prompt source, cwd, sandbox, conversation, and subcommand decisions as receipts",
      "visibility": "do not expose raw event JSON, config secrets, or hidden prompt internals as visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact CLI/session ingress receipts for local coding without storing raw prompt or environment payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_raw_prompt_text",
      "do_not_store_raw_event_json",
      "do_not_hide_invalid_cwd_or_sandbox_failures",
      "do_not_mutate_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "cli_argument_collection->stdin_prompt_merge",
      "stdin_prompt_merge->directory_and_sandbox_resolution",
      "directory_and_sandbox_resolution->conversation_mode_resolution",
      "conversation_mode_resolution->subcommand_route_classification",
      "subcommand_route_classification->cli_ingress_receipt_packaging",
      "cli_ingress_receipt_packaging->completed",
      "directory_and_sandbox_resolution->blocked",
      "conversation_mode_resolution->needs_input",
      "subcommand_route_classification->blocked"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 2,
      "token_budget": 4000,
      "loop_signature_detector": "cli_intent_argument_ingress_v1"
    }
  },
  "ingress_primitive_contract": {
    "version": "cli_intent_argument_ingress_v1",
    "source_evidence": [
      "crates/forge_main/src/cli.rs",
      "crates/forge_main/src/main.rs",
      "crates/forge_main/src/state.rs"
    ],
    "required_behaviors": [
      "prompt_flag_and_piped_input_are_distinct_prompt_sources",
      "interactive_mode_requires_no_prompt_no_piped_input_and_no_subcommand",
      "stdin_is_trimmed_and_empty_stdin_is_ignored",
      "directory_flag_sets_canonical_runtime_cwd",
      "sandbox_flag_creates_isolated_worktree_before_session",
      "conversation_id_can_resume_or_continue_existing_session",
      "event_json_can_dispatch_structured_workflow_event",
      "top_level_subcommands_route_before_interactive_session"
    ],
    "output_receipts": [
      "prompt_source_receipt",
      "cwd_resolution_receipt",
      "sandbox_resolution_receipt",
      "conversation_mode_receipt",
      "subcommand_route_receipt"
    ],
    "stop_conditions": [
      "invalid_directory_path",
      "sandbox_creation_failed",
      "conversation_id_unusable_for_requested_session",
      "subcommand_route_not_supported_for_coding"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "cli_ingress_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
