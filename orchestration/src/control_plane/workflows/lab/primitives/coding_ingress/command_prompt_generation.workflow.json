{
  "name": "command_prompt_generation",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for command and prompt generation ingress, including shell suggest prompts, command templates, schema-constrained command responses, terminal trace projection, and PR/commit prompt templates.",
  "stages": [
    "command_request_classification",
    "environment_and_file_snapshot",
    "suggest_model_config_resolution",
    "terminal_command_trace_projection",
    "schema_constrained_command_generation",
    "custom_command_template_projection",
    "command_prompt_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "command_prompt_generation_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "command_request_kind",
      "prompt_template_id",
      "environment_snapshot_status",
      "model_config_source",
      "terminal_trace_status",
      "response_format",
      "generated_command_or_prompt_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return a generated command or command-expanded prompt envelope when the coding request enters through command routes",
      "scope_boundary": "do not execute generated commands, commit changes, update PRs, or mutate files",
      "validation_calibration": "report model config source, prompt template, JSON schema parsing, and terminal trace projection receipts",
      "visibility": "do not expose raw provider payloads, hidden templates, or terminal traces as visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact command generation receipts while keeping generated commands separate from execution approval.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_execute_generated_commands",
      "do_not_store_raw_provider_payloads",
      "do_not_hide_schema_parse_failures",
      "do_not_mutate_git_or_pr_state"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "command_request_classification->environment_and_file_snapshot",
      "environment_and_file_snapshot->suggest_model_config_resolution",
      "suggest_model_config_resolution->terminal_command_trace_projection",
      "terminal_command_trace_projection->schema_constrained_command_generation",
      "schema_constrained_command_generation->custom_command_template_projection",
      "custom_command_template_projection->command_prompt_receipt_packaging",
      "command_prompt_receipt_packaging->completed",
      "suggest_model_config_resolution->blocked",
      "schema_constrained_command_generation->failed",
      "custom_command_template_projection->blocked"
    ],
    "timeout_ms": 45000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 7,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "command_prompt_generation_v1"
    }
  },
  "ingress_primitive_contract": {
    "version": "command_prompt_generation_v1",
    "source_evidence": [
      "crates/forge_app/src/command_generator.rs",
      "templates/forge-command-generator-prompt.md",
      "templates/forge-commit-message-prompt.md",
      "commands/github-pr-description.md"
    ],
    "required_behaviors": [
      "shell_suggest_uses_environment_and_current_directory_file_snapshot",
      "suggest_config_is_preferred_over_default_session_config",
      "terminal_command_trace_is_projected_when_available",
      "shell_command_response_is_schema_constrained_json",
      "invalid_schema_response_is_a_generation_failure_not_a_shell_execution",
      "dangerous_shell_suggestions_are_represented_as_safe_echo_warnings",
      "commit_message_generation_returns_single_raw_text_line",
      "custom_command_markdown_expands_parameters_without_executing_side_effects"
    ],
    "output_receipts": [
      "command_request_classification_receipt",
      "environment_file_snapshot_receipt",
      "model_config_source_receipt",
      "terminal_trace_projection_receipt",
      "schema_response_receipt",
      "template_projection_receipt"
    ],
    "stop_conditions": [
      "no_suggest_or_session_model_config",
      "schema_constrained_response_parse_failed",
      "command_template_missing_or_invalid",
      "generated_command_requires_execution_permission"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "command_prompt_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
