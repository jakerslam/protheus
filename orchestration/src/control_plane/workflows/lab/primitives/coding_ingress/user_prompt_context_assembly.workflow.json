{
  "name": "user_prompt_context_assembly",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for assembling the user prompt and droppable context before the runtime loop, including task/feedback classification, command template expansion, terminal context, piped input, resume todos, attachments, and file-read metrics.",
  "stages": [
    "resume_detection",
    "event_context_classification",
    "command_template_expansion",
    "terminal_context_injection",
    "rendered_user_message_append",
    "droppable_context_append",
    "attachment_and_metric_projection",
    "user_prompt_context_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "user_prompt_context_assembly_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "rendered_user_message_status",
      "event_context_phase",
      "terminal_context_status",
      "additional_context_status",
      "resume_todo_status",
      "attachment_receipts",
      "file_metric_receipts"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return a model-ready user prompt context envelope before local coding starts",
      "scope_boundary": "do not execute tools, mutate files, or claim attachments were validated beyond parsed receipts",
      "validation_calibration": "report rendered prompt, droppable context, attachments, and file-read metric receipts separately",
      "visibility": "do not expose raw attachment payloads, hidden templates, or private terminal traces as visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact prompt assembly receipts without storing full prompt, attachment, or terminal payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_raw_attachment_content",
      "do_not_store_raw_terminal_context",
      "do_not_hide_attachment_parse_failures",
      "do_not_mutate_files"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "resume_detection->event_context_classification",
      "event_context_classification->command_template_expansion",
      "command_template_expansion->terminal_context_injection",
      "terminal_context_injection->rendered_user_message_append",
      "rendered_user_message_append->droppable_context_append",
      "droppable_context_append->attachment_and_metric_projection",
      "attachment_and_metric_projection->user_prompt_context_receipt_packaging",
      "user_prompt_context_receipt_packaging->completed",
      "command_template_expansion->blocked",
      "attachment_and_metric_projection->blocked"
    ],
    "timeout_ms": 45000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 6000,
      "loop_signature_detector": "user_prompt_context_assembly_v1"
    }
  },
  "ingress_primitive_contract": {
    "version": "user_prompt_context_assembly_v1",
    "source_evidence": [
      "crates/forge_app/src/user_prompt.rs",
      "crates/forge_app/src/terminal_context.rs",
      "templates/forge-custom-agent-template.md",
      "templates/forge-partial-summary-frame.md"
    ],
    "required_behaviors": [
      "existing_user_messages_mark_new_event_as_feedback",
      "first_user_message_marks_event_as_task",
      "agent_user_prompt_template_renders_event_context_with_current_date",
      "command_events_render_command_template_before_user_prompt_template",
      "terminal_context_is_injected_when_available",
      "piped_input_is_added_as_droppable_additional_context",
      "resume_todos_are_added_as_droppable_user_context",
      "attachments_are_parsed_only_from_rendered_user_content",
      "file_content_attachments_are_recorded_as_read_metrics_with_hashes"
    ],
    "output_receipts": [
      "event_context_phase_receipt",
      "template_render_receipt",
      "terminal_context_receipt",
      "droppable_context_receipt",
      "attachment_parse_receipt",
      "file_read_metric_receipt"
    ],
    "stop_conditions": [
      "user_prompt_template_render_failed",
      "command_template_render_failed",
      "attachment_parse_failed_for_required_local_context",
      "rendered_prompt_empty_for_required_coding_task"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "user_prompt_context_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
