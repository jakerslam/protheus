{
  "name": "system_skill_prompt_projection",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for system-info, tool-use, skill, and custom-agent prompt template projection.",
  "stages": [
    "system_prompt_context_collection",
    "system_info_partial_projection",
    "tool_usage_instruction_projection",
    "skill_instruction_projection",
    "custom_agent_template_projection",
    "system_skill_prompt_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "system_skill_prompt_projection_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "system_info_status",
      "tool_instruction_status",
      "skill_instruction_status",
      "custom_agent_status",
      "prompt_projection_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "assemble prompt instructions from measured system, tool, skill, and custom-agent context",
      "scope_boundary": "do not invent available skills, tools, files, or project rules that were not supplied by upstream context receipts",
      "validation_calibration": "report missing optional prompt sections separately from hard prompt assembly failures",
      "visibility": "do not expose hidden prompt payloads as chat unless requested as an artifact"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact prompt-template projection receipts without storing full hidden prompt text by default.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_full_system_prompt_by_default",
      "do_not_invent_skills_or_tool_support",
      "do_not_override_parent_developer_policy"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "system_prompt_context_collection->system_info_partial_projection",
      "system_info_partial_projection->tool_usage_instruction_projection",
      "tool_usage_instruction_projection->skill_instruction_projection",
      "skill_instruction_projection->custom_agent_template_projection",
      "custom_agent_template_projection->system_skill_prompt_receipt_packaging",
      "system_skill_prompt_receipt_packaging->completed",
      "system_prompt_context_collection->blocked",
      "tool_usage_instruction_projection->failed",
      "skill_instruction_projection->blocked",
      "custom_agent_template_projection->failed"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 7000,
      "loop_signature_detector": "system_skill_prompt_projection_v1"
    }
  },
  "prompt_template_primitive_contract": {
    "version": "system_skill_prompt_projection_v1",
    "source_evidence": [
      "templates/forge-partial-system-info.md",
      "templates/forge-partial-skill-instructions.md",
      "templates/forge-partial-tool-use-example.md",
      "templates/forge-custom-agent-template.md"
    ],
    "required_behaviors": [
      "project_operating_system_current_working_directory_shell_and_home_directory_from_environment_receipts",
      "include_file_list_only_when_file_context_is_supplied",
      "include_workspace_extension_stats_only_when_extension_context_is_supplied",
      "list_available_skills_with_name_and_description_only_from_supplied_skill_inventory",
      "instruct_skill_invocation_only_for_skills_present_in_available_skills",
      "render_tool_usage_example_only_when_native_tool_support_is_unavailable",
      "when_native_tool_support_is_available_prefer_parallel_independent_tool_invocation_guidance",
      "include_custom_project_guidelines_only_when_custom_rules_are_supplied",
      "preserve_non_negotiable_rules_about_scope_file_creation_and_citation_format_as_template_payload",
      "do_not_attempt_to_reread_user_tagged_files_in_prompt_projection"
    ],
    "output_receipts": [
      "system_info_projection_receipt",
      "tool_usage_instruction_receipt",
      "skill_instruction_projection_receipt",
      "custom_agent_template_receipt"
    ],
    "stop_conditions": [
      "required_environment_context_missing",
      "skill_inventory_missing_when_skill_instruction_requested",
      "tool_information_missing_when_tool_support_false",
      "custom_agent_template_render_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "system_skill_prompt_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
