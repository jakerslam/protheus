{
  "name": "embedded_template_registry",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for registering embedded Handlebars templates and rendering XML-like prompt elements safely.",
  "stages": [
    "embedded_template_inventory",
    "template_name_resolution",
    "template_utf8_validation",
    "handlebars_registration",
    "prompt_element_rendering",
    "template_registry_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "embedded_template_registry_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "template_inventory_status",
      "registration_status",
      "utf8_status",
      "element_render_status",
      "template_registry_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "make embedded prompt templates available through a validated registry before runtime prompt assembly",
      "scope_boundary": "do not execute tools, mutate files, or render unregistered templates as trusted instructions",
      "validation_calibration": "report missing, invalid, registered, or renderable template states separately",
      "visibility": "do not expose hidden template internals unless the parent workflow explicitly requests a prompt artifact"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact embedded-template registry receipts without storing full prompt payloads by default.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_full_system_prompts_by_default",
      "do_not_treat_template_registration_as_runtime_execution",
      "do_not_accept_non_utf8_template_paths_or_contents"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "embedded_template_inventory->template_name_resolution",
      "template_name_resolution->template_utf8_validation",
      "template_utf8_validation->handlebars_registration",
      "handlebars_registration->prompt_element_rendering",
      "prompt_element_rendering->template_registry_receipt_packaging",
      "template_registry_receipt_packaging->completed",
      "template_name_resolution->failed",
      "template_utf8_validation->failed",
      "handlebars_registration->failed",
      "prompt_element_rendering->blocked"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 5000,
      "loop_signature_detector": "embedded_template_registry_v1"
    }
  },
  "prompt_template_primitive_contract": {
    "version": "embedded_template_registry_v1",
    "source_evidence": [
      "crates/forge_embed/src/lib.rs",
      "crates/forge_template/src/element.rs"
    ],
    "required_behaviors": [
      "walk_embedded_template_directories_recursively",
      "register_template_names_from_relative_embedded_file_paths",
      "reject_or_fail_non_utf8_template_paths",
      "reject_or_fail_non_utf8_template_contents",
      "fail_registration_when_handlebars_template_parse_fails",
      "render_element_names_with_dot_suffixes_as_css_classes",
      "html_escape_text_content_by_default",
      "allow_cdata_content_only_through_explicit_cdata_route",
      "append_children_and_iterable_children_preserving_order",
      "render_attributes_on_separate_lines_when_present"
    ],
    "output_receipts": [
      "embedded_template_inventory_receipt",
      "template_registration_receipt",
      "template_utf8_validation_receipt",
      "prompt_element_render_receipt"
    ],
    "stop_conditions": [
      "embedded_template_path_not_utf8",
      "embedded_template_content_not_utf8",
      "handlebars_registration_failed",
      "prompt_element_render_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "template_registry_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
