{
  "name": "codebase_semantic_search",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for remote semantic codebase search against an indexed workspace.",
  "stages": [
    "semantic_search_request_normalization",
    "workspace_lookup",
    "codebase_query_construction",
    "remote_search_execution",
    "node_result_projection",
    "semantic_search_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "codebase_semantic_search_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "workspace_lookup_status",
      "query_count",
      "use_case",
      "result_count",
      "ranking_metadata_status",
      "search_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "return semantic codebase search results as context for local coding decisions",
      "scope_boundary": "do not mutate files, sync files, validate behavior, or treat search results as authoritative over local reads",
      "validation_calibration": "report workspace/search status and result counts without claiming freshness unless sync receipts exist",
      "visibility": "do not expose raw auth tokens or full hidden service payloads"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact semantic search receipts for indexed workspace queries.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_auth_tokens",
      "do_not_hide_workspace_not_found",
      "do_not_mutate_index_or_files",
      "do_not_replace_safe_file_read_receipts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "semantic_search_request_normalization->workspace_lookup",
      "workspace_lookup->codebase_query_construction",
      "codebase_query_construction->remote_search_execution",
      "remote_search_execution->node_result_projection",
      "node_result_projection->semantic_search_receipt_packaging",
      "semantic_search_receipt_packaging->completed",
      "workspace_lookup->blocked",
      "remote_search_execution->failed",
      "node_result_projection->blocked"
    ],
    "timeout_ms": 90000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 5,
      "token_budget": 7000,
      "loop_signature_detector": "codebase_semantic_search_v1"
    }
  },
  "remote_service_primitive_contract": {
    "version": "codebase_semantic_search_v1",
    "source_evidence": [
      "crates/forge_services/src/context_engine.rs",
      "crates/forge_domain/src/repo.rs",
      "crates/forge_domain/src/node.rs"
    ],
    "required_behaviors": [
      "workspace_search_requires_remote_workspace_auth",
      "workspace_lookup_uses_exact_or_closest_ancestor_match",
      "missing_workspace_returns_workspace_not_found",
      "search_query_wraps_user_id_workspace_id_and_search_params",
      "search_params_include_query_use_case_limit_top_k_starts_with_and_ends_with",
      "remote_search_results_preserve_node_id_node_data_relevance_and_distance",
      "search_result_freshness_depends_on_prior_workspace_sync_receipts",
      "semantic_search_does_not_replace_local_file_reads_for_edits"
    ],
    "output_receipts": [
      "workspace_lookup_receipt",
      "codebase_query_receipt",
      "remote_search_receipt",
      "node_result_projection_receipt",
      "freshness_dependency_receipt"
    ],
    "stop_conditions": [
      "workspace_not_found",
      "remote_search_auth_missing",
      "remote_search_failed",
      "search_results_stale_without_sync_for_required_edit"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "semantic_search_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
