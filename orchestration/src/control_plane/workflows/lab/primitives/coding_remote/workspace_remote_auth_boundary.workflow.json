{
  "name": "workspace_remote_auth_boundary",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for remote workspace and provider authentication boundaries before semantic search or remote indexing.",
  "stages": [
    "auth_request_classification",
    "forge_services_credential_lookup",
    "workspace_auth_initialization",
    "provider_auth_context_initialization",
    "credential_refresh_boundary",
    "remote_auth_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "workspace_remote_auth_boundary_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "workspace_auth_status",
      "provider_auth_status",
      "credential_source",
      "user_id_status",
      "refresh_status",
      "auth_stop_or_continue"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "establish whether remote workspace/search/provider actions are authenticated before routing them",
      "scope_boundary": "do not upload files, search codebases, call chat providers, or mutate local source files",
      "validation_calibration": "report missing, initialized, refreshed, or blocked credentials separately",
      "visibility": "do not expose API keys, OAuth tokens, credential params, or provider secrets"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact remote authentication receipts without storing secrets.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_credentials_or_tokens",
      "do_not_silently_start_oauth_without_user_visible_route",
      "do_not_upload_workspace_files",
      "do_not_call_provider_chat"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "auth_request_classification->forge_services_credential_lookup",
      "forge_services_credential_lookup->workspace_auth_initialization",
      "workspace_auth_initialization->provider_auth_context_initialization",
      "provider_auth_context_initialization->credential_refresh_boundary",
      "credential_refresh_boundary->remote_auth_receipt_packaging",
      "remote_auth_receipt_packaging->completed",
      "forge_services_credential_lookup->needs_input",
      "workspace_auth_initialization->blocked",
      "provider_auth_context_initialization->needs_input",
      "credential_refresh_boundary->needs_input"
    ],
    "timeout_ms": 60000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 6,
      "max_model_turns": 1,
      "max_tool_calls": 4,
      "token_budget": 5000,
      "loop_signature_detector": "workspace_remote_auth_boundary_v1"
    }
  },
  "remote_service_primitive_contract": {
    "version": "workspace_remote_auth_boundary_v1",
    "source_evidence": [
      "crates/forge_services/src/context_engine.rs",
      "crates/forge_services/src/auth.rs",
      "crates/forge_services/src/provider_auth.rs",
      "crates/forge_domain/src/repo.rs",
      "crates/forge_domain/src/node.rs"
    ],
    "required_behaviors": [
      "forge_services_workspace_auth_is_stored_as_api_key_with_user_id_url_param",
      "missing_forge_services_credential_blocks_remote_workspace_actions",
      "workspace_auth_initialization_authenticates_remote_indexing_service_then_stores_credential",
      "api_key_and_google_adc_auth_prefill_existing_credential_params_when_available",
      "oauth_code_and_device_contexts_are_preserved_as_explicit_user_visible_auth_routes",
      "provider_refresh_uses_five_minute_expiry_buffer",
      "refresh_failures_keep_existing_credentials_without_claiming_refresh_success",
      "auth_receipts_never_include_secret_values"
    ],
    "output_receipts": [
      "workspace_credential_lookup_receipt",
      "workspace_auth_initialization_receipt",
      "provider_auth_context_receipt",
      "credential_refresh_receipt",
      "secret_redaction_receipt"
    ],
    "stop_conditions": [
      "workspace_auth_missing_and_user_auth_required",
      "provider_not_available",
      "oauth_flow_requires_user_completion",
      "credential_storage_failed",
      "remote_auth_secret_redaction_failed"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "remote_auth_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
