{
  "name": "workspace_sync_indexing",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for remote workspace sync and indexing, including path canonicalization, workspace lookup, file discovery, hash comparison, delete/upload batching, and progress receipts.",
  "stages": [
    "workspace_path_canonicalization",
    "workspace_lookup_or_initialization",
    "file_discovery_route",
    "local_hash_pass",
    "remote_hash_comparison",
    "delete_and_upload_plan",
    "batched_upload_execution_receipts",
    "workspace_sync_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "workspace_sync_indexing_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "workspace_id",
      "canonical_workspace_root",
      "discovered_file_count",
      "added_modified_deleted_counts",
      "failed_file_count",
      "upload_batch_status",
      "sync_progress_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "sync local source files to the remote semantic index when explicitly required",
      "scope_boundary": "do not use remote sync as a substitute for local file reads, local edits, validation, or permission gates",
      "validation_calibration": "report indexed/synced files and failures without claiming code correctness",
      "visibility": "do not expose full uploaded file contents in visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact workspace sync/indexing receipts without storing uploaded source payloads.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_uploaded_file_contents",
      "do_not_hide_failed_file_reads",
      "do_not_auto_create_workspace_during_sync",
      "do_not_treat_indexing_as_validation"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "workspace_path_canonicalization->workspace_lookup_or_initialization",
      "workspace_lookup_or_initialization->file_discovery_route",
      "file_discovery_route->local_hash_pass",
      "local_hash_pass->remote_hash_comparison",
      "remote_hash_comparison->delete_and_upload_plan",
      "delete_and_upload_plan->batched_upload_execution_receipts",
      "batched_upload_execution_receipts->workspace_sync_receipt_packaging",
      "workspace_sync_receipt_packaging->completed",
      "workspace_path_canonicalization->blocked",
      "workspace_lookup_or_initialization->blocked",
      "file_discovery_route->blocked",
      "batched_upload_execution_receipts->failed"
    ],
    "timeout_ms": 180000,
    "retry_policy": {
      "max_retries": 1,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 12,
      "token_budget": 8000,
      "loop_signature_detector": "workspace_sync_indexing_v1"
    }
  },
  "remote_service_primitive_contract": {
    "version": "workspace_sync_indexing_v1",
    "source_evidence": [
      "crates/forge_services/src/context_engine.rs",
      "crates/forge_services/src/sync.rs",
      "crates/forge_services/src/fd.rs",
      "crates/forge_services/src/fd_git.rs",
      "crates/forge_app/src/workspace_status.rs",
      "crates/forge_domain/src/node.rs"
    ],
    "required_behaviors": [
      "sync_path_is_canonicalized_with_contextual_error",
      "sync_requires_existing_workspace_and_does_not_auto_create",
      "workspace_initialization_reuses_exact_or_ancestor_workspace_or_creates_new",
      "workspace_lookup_prefers_exact_path_then_closest_ancestor_prefix",
      "workspace_root_uses_remote_workspace_working_dir_for_consistent_relative_paths",
      "file_discovery_prefers_git_ls_files_then_falls_back_to_walker",
      "sync_filters_extensions_lockfiles_and_symlinks",
      "first_pass_hashes_files_without_retaining_full_contents",
      "remote_hashes_are_compared_to_local_hashes_before_delete_or_upload",
      "delete_operations_are_batched",
      "uploads_are_batched_by_configured_max_file_read_batch_size_and_processed_sequentially",
      "failed_file_reads_are_reported_as_failed_statuses",
      "completed_progress_reports_total_uploaded_and_failed_counts"
    ],
    "output_receipts": [
      "canonical_path_receipt",
      "workspace_lookup_receipt",
      "file_discovery_receipt",
      "hash_comparison_receipt",
      "delete_upload_plan_receipt",
      "sync_progress_receipt",
      "failed_file_receipt"
    ],
    "stop_conditions": [
      "workspace_not_indexed_for_sync",
      "no_source_files_found",
      "remote_workspace_auth_missing",
      "remote_delete_or_upload_failed",
      "sync_completed_with_failed_files"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "workspace_sync_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
