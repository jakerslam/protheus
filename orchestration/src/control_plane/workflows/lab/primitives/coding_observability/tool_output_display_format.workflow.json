{
  "name": "tool_output_display_format",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for formatting tool outputs such as diffs, grep/search results, markdown, code blocks, todos, and plan creation status for user-visible display.",
  "stages": [
    "tool_operation_output_classification",
    "diff_summary_formatting",
    "search_result_grouping",
    "markdown_static_formatting",
    "code_block_highlighting",
    "todo_output_projection",
    "plan_status_projection",
    "display_format_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "tool_output_display_format_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "operation_kind",
      "display_format_kind",
      "diff_line_counts",
      "search_grouping_status",
      "syntax_highlight_status",
      "suppressed_output_reason"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "format tool observations into concise display artifacts without confusing display with execution receipts",
      "scope_boundary": "do not execute the tool or modify receipts",
      "validation_calibration": "report when output is intentionally suppressed versus displayed",
      "visibility": "do not expose full raw tool payloads when a compact display artifact is sufficient"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact display formatting receipts for local coding tool output.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_treat_display_diff_as_patch_receipt",
      "do_not_display_raw_large_file_reads",
      "do_not_leak_hidden_tool_metadata"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "tool_operation_output_classification->diff_summary_formatting",
      "tool_operation_output_classification->search_result_grouping",
      "tool_operation_output_classification->markdown_static_formatting",
      "diff_summary_formatting->display_format_receipt_packaging",
      "search_result_grouping->display_format_receipt_packaging",
      "markdown_static_formatting->code_block_highlighting",
      "code_block_highlighting->display_format_receipt_packaging",
      "tool_operation_output_classification->todo_output_projection",
      "todo_output_projection->display_format_receipt_packaging",
      "tool_operation_output_classification->plan_status_projection",
      "plan_status_projection->display_format_receipt_packaging",
      "display_format_receipt_packaging->completed",
      "tool_operation_output_classification->blocked",
      "diff_summary_formatting->failed",
      "search_result_grouping->failed",
      "markdown_static_formatting->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 8,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 8000,
      "loop_signature_detector": "tool_output_display_format_v1"
    }
  },
  "observability_primitive_contract": {
    "version": "tool_output_display_format_v1",
    "source_evidence": [
      "crates/forge_display/src/markdown.rs",
      "crates/forge_display/src/code.rs",
      "crates/forge_display/src/diff.rs",
      "crates/forge_display/src/grep.rs",
      "crates/forge_app/src/fmt/fmt_output.rs"
    ],
    "required_behaviors": [
      "format_overwrite_write_patch_and_multi_patch_outputs_as_colored_context_diffs",
      "include_added_and_removed_line_counts_in_diff_receipts",
      "show_no_changes_applied_when_diff_has_no_grouped_ops",
      "calculate_line_number_width_from_displayed_diff_not_total_file_size",
      "group_search_results_by_file_path_and_align_line_number_width",
      "highlight_search_matches_when_regex_is_available",
      "treat_non_grep_search_lines_as_raw_paths",
      "strip_excessive_markdown_newlines_to_configured_limit",
      "extract_code_blocks_before_markdown_rendering_and_restore_syntax_highlighted_blocks",
      "detect_terminal_dark_or_light_theme_once_and_fallback_to_dark",
      "suppress_display_output_for read_create_remove_search_shell_followup_skill_when_no_compact_display_is_defined",
      "render_plan_creation_as_a_debug_title_with_relative_display_path"
    ],
    "output_receipts": [
      "operation_classification_receipt",
      "diff_display_receipt",
      "search_display_receipt",
      "markdown_display_receipt",
      "syntax_highlight_receipt",
      "suppressed_output_receipt"
    ],
    "stop_conditions": [
      "display_formatter_failed",
      "regex_highlight_invalid",
      "display_output_would_exceed_visibility_budget"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "display_format_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
