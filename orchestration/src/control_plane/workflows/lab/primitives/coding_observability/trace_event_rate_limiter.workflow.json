{
  "name": "trace_event_rate_limiter",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for deciding when trace/log/usage events may be emitted and how trace volume is bounded.",
  "stages": [
    "tracking_environment_resolution",
    "event_kind_classification",
    "fixed_window_rate_limit_check",
    "trace_target_filtering",
    "tracking_destination_projection",
    "dropped_event_receipt_packaging",
    "trace_rate_limit_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "trace_event_rate_limiter_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "tracking_enabled_status",
      "event_kind",
      "rate_limit_status",
      "trace_filter_status",
      "destination_status",
      "dropped_event_count"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "bound telemetry volume and keep trace dispatch auditable",
      "scope_boundary": "do not alter visible chat or workflow execution decisions",
      "validation_calibration": "report allowed, dropped, and disabled trace events separately",
      "visibility": "do not expose raw trace payloads or analytics transport details to the visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact telemetry rate-limit receipts for local coding runs.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_store_raw_trace_payloads",
      "do_not_send_dev_build_tracking",
      "do_not_hide_dropped_event_counts"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "tracking_environment_resolution->event_kind_classification",
      "event_kind_classification->fixed_window_rate_limit_check",
      "fixed_window_rate_limit_check->trace_target_filtering",
      "trace_target_filtering->tracking_destination_projection",
      "tracking_destination_projection->dropped_event_receipt_packaging",
      "dropped_event_receipt_packaging->trace_rate_limit_receipt_packaging",
      "trace_rate_limit_receipt_packaging->completed",
      "tracking_environment_resolution->disabled",
      "fixed_window_rate_limit_check->dropped",
      "trace_target_filtering->dropped",
      "tracking_destination_projection->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "disabled",
      "dropped",
      "failed",
      "needs_input",
      "blocked",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 7,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 4000,
      "loop_signature_detector": "trace_event_rate_limiter_v1"
    }
  },
  "observability_primitive_contract": {
    "version": "trace_event_rate_limiter_v1",
    "source_evidence": [
      "crates/forge_tracker/src/can_track.rs",
      "crates/forge_tracker/src/rate_limit.rs",
      "crates/forge_tracker/src/log.rs",
      "crates/forge_tracker/src/dispatch.rs",
      "crates/forge_tracker/src/event.rs"
    ],
    "required_behaviors": [
      "disable_external_tracking_for_dev_versions_and_version_0_1_0",
      "use_fixed_sixty_second_windows_for_event_rate_limits",
      "drop_events_after_max_per_minute_without_blocking_runtime",
      "filter_json_logs_to_forge_targets",
      "send_tracking_enabled_logs_to_tracker_destination",
      "write_dev_or_disabled_logs_to_daily_local_file",
      "preserve dropped_event_counts_as_observability_receipts"
    ],
    "output_receipts": [
      "tracking_enabled_receipt",
      "event_kind_receipt",
      "rate_limit_receipt",
      "trace_filter_receipt",
      "destination_receipt",
      "dropped_event_receipt"
    ],
    "stop_conditions": [
      "tracking_destination_failed",
      "local_log_writer_failed",
      "event_payload_exceeds_trace_budget"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "trace_rate_limit_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
