{
  "name": "chat_response_visibility_router",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for routing ChatResponse variants into visible user output, spinner/status output, retry/interrupt prompts, or internal telemetry.",
  "stages": [
    "empty_response_filter",
    "task_message_projection",
    "tool_start_handshake_projection",
    "tool_end_telemetry_projection",
    "retry_attempt_projection",
    "interrupt_projection",
    "reasoning_projection",
    "task_complete_projection",
    "visibility_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "chat_response_visibility_router_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "visible_markdown_status",
      "tool_status_projection",
      "retry_status_projection",
      "interrupt_status_projection",
      "reasoning_visibility_status",
      "task_completion_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "route runtime response events to the correct visible or internal channel",
      "scope_boundary": "do not execute tools, mutate files, or synthesize final answer content",
      "validation_calibration": "report visible, suppressed, and telemetry-only response variants",
      "visibility": "do not expose raw tool payloads, hidden reasoning, or private runtime state"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact response visibility routing receipts for local coding runs.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_leak_raw_tool_payloads",
      "do_not_expose_hidden_reasoning",
      "do_not_block_tool_start_notification"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "empty_response_filter->task_message_projection",
      "task_message_projection->tool_start_handshake_projection",
      "tool_start_handshake_projection->tool_end_telemetry_projection",
      "tool_end_telemetry_projection->retry_attempt_projection",
      "retry_attempt_projection->interrupt_projection",
      "interrupt_projection->reasoning_projection",
      "reasoning_projection->task_complete_projection",
      "task_complete_projection->visibility_receipt_packaging",
      "visibility_receipt_packaging->completed",
      "tool_start_handshake_projection->failed",
      "interrupt_projection->blocked",
      "task_complete_projection->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "blocked",
      "failed",
      "needs_input",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 9,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 6000,
      "loop_signature_detector": "chat_response_visibility_router_v1"
    }
  },
  "observability_primitive_contract": {
    "version": "chat_response_visibility_router_v1",
    "source_evidence": [
      "crates/forge_main/src/ui.rs",
      "crates/forge_main/src/stream_renderer.rs",
      "crates/forge_domain/src/chat_response.rs"
    ],
    "required_behaviors": [
      "ignore_empty_chat_response_events",
      "render_tool_input_titles_after_finishing_active_markdown_stream",
      "render_tool_output_text_after_finishing_active_markdown_stream",
      "stream_markdown_deltas_without forcing_finalization_per_delta",
      "notify_tool_start_guard_even_when_ui_rendering_fails",
      "stop_spinner_for_tools_that_require_stdout_before_tool_execution",
      "track_tool_end_success_by_tool_name_and_failures_with_error_cause",
      "suppress_retry_errors_when_configured_otherwise_render_retry_status",
      "on_interrupt_finish_stream_stop_spinner_show_action_title_and_request_continue_decision",
      "render_reasoning_deltas_dimmed_separately_from_answer_markdown",
      "on_task_complete_finish_stream_show_finished_conversation_id_and_optionally_auto_dump"
    ],
    "output_receipts": [
      "visibility_route_receipt",
      "tool_start_notification_receipt",
      "retry_projection_receipt",
      "interrupt_projection_receipt",
      "reasoning_projection_receipt",
      "task_complete_projection_receipt"
    ],
    "stop_conditions": [
      "tool_start_notification_failed",
      "interrupt_requires_user_continue_decision",
      "auto_dump_failed",
      "visible_channel_unavailable"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "visibility_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
