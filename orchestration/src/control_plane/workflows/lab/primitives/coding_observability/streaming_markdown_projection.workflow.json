{
  "name": "streaming_markdown_projection",
  "workflow_type": "control_plane_orchestration_workflow",
  "workflow_role": "assistant_response_workflow",
  "default": false,
  "description": "ForgeCode-derived primitive for repairing and rendering streaming markdown deltas with spinner-safe output boundaries.",
  "stages": [
    "stream_delta_buffering",
    "line_completion_detection",
    "malformed_markdown_repair",
    "streamdown_parse_event_projection",
    "terminal_width_and_margin_resolution",
    "syntax_highlight_projection",
    "spinner_pause_resume_projection",
    "stream_finish_flush",
    "markdown_projection_receipt_packaging"
  ],
  "workflow_composition": {
    "primitive_level": 0,
    "composed_of_workflow_ids": []
  },
  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "streaming_markdown_projection_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "buffering_status",
      "repair_status",
      "parse_event_status",
      "rendering_status",
      "spinner_status",
      "flush_status"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "render streamed assistant markdown safely and readably",
      "scope_boundary": "do not modify assistant content semantics or synthesize final handoff",
      "validation_calibration": "report repaired lines, parser finalization, and output channel failures",
      "visibility": "do not expose parser internals or hidden runtime metadata"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Record compact streaming markdown rendering receipts for local coding output.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_store_full_markdown_streams",
      "do_not_corrupt_code_fence_content",
      "do_not_leave_spinner_active_while_writing_content",
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "stream_delta_buffering->line_completion_detection",
      "line_completion_detection->malformed_markdown_repair",
      "malformed_markdown_repair->streamdown_parse_event_projection",
      "streamdown_parse_event_projection->terminal_width_and_margin_resolution",
      "terminal_width_and_margin_resolution->syntax_highlight_projection",
      "syntax_highlight_projection->spinner_pause_resume_projection",
      "spinner_pause_resume_projection->stream_finish_flush",
      "stream_finish_flush->markdown_projection_receipt_packaging",
      "markdown_projection_receipt_packaging->completed",
      "malformed_markdown_repair->failed",
      "streamdown_parse_event_projection->failed",
      "stream_finish_flush->failed"
    ],
    "timeout_ms": 30000,
    "retry_policy": {
      "max_retries": 0,
      "on_failure": "return_structured_failure"
    },
    "terminal_states": [
      "completed",
      "failed",
      "needs_input",
      "blocked",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "agent",
      "workspace",
      "web",
      "memory",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 9,
      "max_model_turns": 1,
      "max_tool_calls": 1,
      "token_budget": 8000,
      "loop_signature_detector": "streaming_markdown_projection_v1"
    }
  },
  "observability_primitive_contract": {
    "version": "streaming_markdown_projection_v1",
    "source_evidence": [
      "crates/forge_markdown_stream/src/lib.rs",
      "crates/forge_markdown_stream/src/renderer.rs",
      "crates/forge_markdown_stream/src/repair.rs",
      "crates/forge_main/src/stream_renderer.rs"
    ],
    "required_behaviors": [
      "buffer_tokens_until_complete_lines_before_parsing",
      "repair_embedded_code_fence_closures_only_when_inside_code_blocks",
      "parse_lines_into_streamdown_events",
      "render_headings_code_blocks_lists_tables_blockquotes_links_images_horizontal_rules_and_think_blocks",
      "adjust_width_for_terminal_size_and_blockquote_margin",
      "syntax_highlight_code_lines_with_language_when_available",
      "finish_and_flush_remaining_buffer_on_stream_completion",
      "pause_spinner_before_writing_content_and_resume_only_at_line_boundaries",
      "preserve_writer_byte_consumption_semantics_when_styling_adds_ansi_codes"
    ],
    "output_receipts": [
      "delta_buffer_receipt",
      "line_repair_receipt",
      "parse_event_receipt",
      "render_event_receipt",
      "spinner_boundary_receipt",
      "stream_flush_receipt"
    ],
    "stop_conditions": [
      "output_writer_failed",
      "parser_finalize_failed",
      "spinner_boundary_unavailable"
    ]
  },
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "markdown_projection_receipt_packaging",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  },
  "workflow_composition_contract": {
    "version": "workflow_composition_contract_v1",
    "cd_kind": "primitive",
    "returns_exactly_one_terminal_artifact": true,
    "terminal_artifact_contract": {
      "artifact_schema": "workflow_terminal_artifact_v1",
      "allowed_kinds": [
        "completed_final_answer",
        "clarification_request",
        "structured_failure",
        "delegated_workflow_result"
      ],
      "parent_receives": "terminal_artifact_only_refs_for_internals"
    },
    "child_workflow_calls": [],
    "non_goals": [
      "do_not_call_child_workflows",
      "do_not_return_raw_tool_payloads",
      "do_not_expose_internal_trace"
    ]
  }
}
