  "final_response_policy": "control_plane_packaged_response",
  "final_output_contract": {
    "schema_version": "local_coding_program_builder_final_output_contract_v1",
    "source": "workflow_cd",
    "visible_chat_source": "llm_final_answer_only",
    "required_summary_fields": [
      "completed_checkpoint",
      "changed_files",
      "validation_results",
      "known_risks",
      "intentionally_excluded_scope",
      "recommended_next_checkpoint"
    ],
    "internal_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace"
    ],
    "quality_contract": {
      "answer_user_goal": "final handoff states what was built or why the checkpoint stopped",
      "scope_boundary": "final handoff distinguishes completed scope from excluded future scope",
      "validation_calibration": "final handoff reports validation performed, skipped, failed, or blocked without overstating confidence",
      "architecture_calibration": "final handoff reports material architecture decisions and any drift risks",
      "visibility": "do not expose raw workflow state, private reasoning, or raw tool payloads as visible chat"
    }
  },
  "gate_contract": "control_plane_lifecycle_v1",
  "observation_lifecycle_contract": {
    "version": "run_observation_lifecycle_v1",
    "policy_ref": "orchestration/config/run_observation_lifecycle_policy.json",
    "purpose": "Emit compact workflow observations for coding checkpoints, project initialization, architecture contracts, safe local code-edit slices, validation, repair loops, and terminal outcomes; keep raw payloads out of lifecycle storage.",
    "required_lanes": [
      "compact_ledger",
      "hot_ring_buffer",
      "failure_lifecycle_archive",
      "artifact_ref_retention"
    ],
    "non_goals": [
      "do_not_hide_current_failures",
      "do_not_store_raw_tool_payloads",
      "do_not_force_response_formats"
    ]
  },
  "typed_execution_contract": {
    "gate_kind": "structured_control_plane_gate",
    "input_kind": "multiple_choice_or_text_input",
    "allowed_transitions": [
      "intake_normalization->coding_ingress_guard_initialization",
      "coding_ingress_guard_initialization->session_bootstrap_guard_initialization",
      "session_bootstrap_guard_initialization->remote_service_guard_initialization",
      "remote_service_guard_initialization->operator_integration_guard_initialization",
      "operator_integration_guard_initialization->policy_permission_guard_initialization",
      "policy_permission_guard_initialization->context_and_tool_guard_initialization",
      "context_and_tool_guard_initialization->checkpoint_definition",
      "context_and_tool_guard_initialization->tooling_surface_guard_initialization",
      "tooling_surface_guard_initialization->checkpoint_definition",
      "tooling_surface_guard_initialization->runtime_execution_loop_initialization",
      "runtime_execution_loop_initialization->checkpoint_definition",
      "runtime_execution_loop_initialization->runtime_observability_guard_initialization",
      "runtime_observability_guard_initialization->checkpoint_definition",
      "checkpoint_definition->project_initialization_assessment",
      "project_initialization_assessment->architecture_contract_definition",
      "architecture_contract_definition->slice_planning",
      "slice_planning->local_code_execution_loop",
      "local_code_execution_loop->integration_review",
      "integration_review->validation_routing",
      "validation_routing->repair_loop",
      "repair_loop->local_code_execution_loop",
      "validation_routing->result_packaging",
      "repair_loop->result_packaging",
      "result_packaging->verification_closure",
      "verification_closure->completed",
      "coding_ingress_guard_initialization->blocked",
      "coding_ingress_guard_initialization->failed",
      "session_bootstrap_guard_initialization->blocked",
      "session_bootstrap_guard_initialization->failed",
      "remote_service_guard_initialization->blocked",
      "remote_service_guard_initialization->failed",
      "operator_integration_guard_initialization->blocked",
      "operator_integration_guard_initialization->failed",
      "policy_permission_guard_initialization->blocked",
      "context_and_tool_guard_initialization->blocked",
      "tooling_surface_guard_initialization->blocked",
      "runtime_execution_loop_initialization->blocked",
      "runtime_execution_loop_initialization->failed",
      "runtime_observability_guard_initialization->blocked",
      "runtime_observability_guard_initialization->failed",
      "project_initialization_assessment->needs_input",
      "architecture_contract_definition->needs_input",
      "slice_planning->needs_input",
      "repair_loop->blocked",
      "local_code_execution_loop->failed",
      "local_code_execution_loop->aborted"
    ],
    "timeout_ms": 240000,
    "retry_policy": {
      "max_retries": 2,
      "on_failure": "focused_repair_or_escalate"
    },
    "terminal_states": [
      "completed",
      "needs_input",
      "blocked",
      "failed",
      "aborted"
    ],
    "telemetry_streams": [
      "workflow_state",
      "agent_internal_notes",
      "tool_trace",
      "eval_trace",
      "final_answer"
    ],
    "tool_family_contracts": [
      "workspace",
      "web",
      "memory",
      "agent",
      "shell",
      "browser"
    ],
    "visible_chat_policy": "llm_final_only_no_system_injection",
    "run_budgets": {
      "max_stages": 32,
      "max_model_turns": 16,
      "max_tool_calls": 24,
      "token_budget": 32000,
      "loop_signature_detector": "checkpoint_slice_tool_signature_v1"
    }
  },
  "program_builder_contract": {
    "version": "local_coding_program_builder_v1",
    "checkpoint_policy": {
      "if_user_checkpoint_missing": "define the smallest coherent checkpoint that satisfies the user goal",
      "checkpoint_required_fields": [
        "name",
        "goal",
        "included_scope",
        "excluded_scope",
        "acceptance_criteria",
        "validation",
        "stop_conditions"
      ],
      "default_checkpoint_bias": "bounded_mvp_or_next_increment_not_full_imagined_product",
      "scope_expansion_policy": "do not expand beyond the checkpoint unless the user explicitly requests it"
    },
    "project_initialization_policy": {
      "assessment_states": [
        "initialized",
        "partial",
        "uninitialized"
      ],
      "if_initialized": "adapt to the existing stack, architecture, package manager, test runner, and naming patterns",
      "if_partial": "stabilize missing foundations before feature work",
      "if_uninitialized": "define stack, architecture, directories, validation commands, and growth rules before implementation",
      "initialization_contract_required_fields": [
        "project_type",
        "stack",
        "runtime",
        "package_manager",
        "source_dirs",
        "test_runner",
        "formatter",
        "linter",
        "validation_commands",
        "architecture_pattern",
        "boundary_rules",
        "dependency_policy"
      ]
    },
    "architecture_contract_policy": {
      "required": true,
      "purpose": "prevent codebase decay by giving each code-edit slice explicit module, boundary, dependency, and validation rules",
      "growth_rules": [
        "avoid giant files by splitting stable concepts into named modules",
        "avoid duplicate service layers or parallel state models",
        "keep domain logic out of UI glue unless the project architecture already requires it",
        "prefer existing repo conventions over new abstractions",
        "update the architecture contract before making material boundary changes"
      ],
      "dependency_policy": {
        "allow_if": [
          "the project already uses the dependency family",
          "the dependency solves a hard domain problem",
          "the dependency is maintained, common, and proportionate to the checkpoint"
        ],
        "stop_if": [
          "auth, payment, storage, hosting, analytics, or external service choice is required",
          "license, security, privacy, or vendor-lock risk is unclear",
          "dependency choice would effectively choose the product architecture"
        ]
      }
    },
    "coding_safety_layer_contract": {
      "source": "forgecode_assimilated_safety_layer",
      "required_primitive_workflow_ids": [
        "repo_context_assessment",
        "safe_file_read",
        "safe_file_write",
        "safe_file_patch",
        "validation_command_runner",
        "safe_file_undo",
        "plan_artifact_create",
        "followup_clarification_gate",
        "failure_diagnosis",
        "local_code_edit_execution",
        "bounded_repair_loop",
        "checkpoint_handoff"
      ],
      "activation_policy": "local coding execution must route repo assessment, file reads, file writes, file patches, undo/snapshot recovery, plan artifact creation, bounded failure repair, clarification gates, checkpoint handoff, and validation through ForgeCode-assimilated primitives before this workflow can be promoted beyond lab candidate",
      "required_receipts": [
        "repo_context_receipt",
        "read_receipts_with_content_hashes",
        "write_or_patch_receipts_with_snapshots",
        "undo_receipts_when_recovery_is_used",
        "plan_artifact_receipt",
        "changed_files_receipt",
        "repair_loop_receipts",
        "validation_command_receipts",
        "checkpoint_handoff_receipt"
      ],
      "non_goals": [
        "do_not_overwrite_files_without_snapshot",
        "do_not_patch_ambiguous_matches",
        "do_not_treat_file_materialization_as_agent_coding_parity"
      ]
    },
    "slice_policy": {
      "default_max_slices": 16,
      "slice_required_fields": [
        "name",
        "goal",
        "allowed_files_or_areas",
        "acceptance_criteria",
        "validation_expectation",
        "code_edit_prompt_payload"
      ],
      "code_edit_payload_required_fields": [
        "task",
        "architecture_contract",
        "slice_acceptance_criteria",
        "allowed_files_or_areas",
        "expected_outputs",
        "validation_expectation",
        "stop_conditions"
      ],
      "completion_rule": "mark a slice complete only when it meets acceptance criteria and does not make the project less coherent"
    },
    "loop_policy": {
      "loop_until": "current_checkpoint_complete",
      "max_repair_attempts_per_slice": 2,
      "max_integration_repair_attempts": 2,
      "max_validation_attempts": 3,
      "repair_prompt_policy": "route focused failures through bounded_repair_loop, diagnose the failure class, retry the smallest failing scope through local_code_edit_execution, rerun the relevant validation command, and undo or escalate if the repair makes the checkpoint worse",
      "do_not_continue_to": "future product scope outside the checkpoint"
    },
    "coding_ingress_guard_contract": {
      "source": "forgecode_assimilated_ingress_layer",
      "required_composite_workflow_id": "local_coding_ingress_guard",
      "required_primitive_workflow_ids": [
        "cli_intent_argument_ingress",
        "interactive_input_session_state",
        "command_prompt_generation",
        "user_prompt_context_assembly"
      ],
      "activation_policy": "local coding tasks must normalize ForgeCode-style CLI/session input, interactive state, command prompt generation, and user prompt context assembly before permission, context, tooling, runtime, planning, or local code-edit execution",
      "required_receipts": [
        "cli_ingress_receipt",
        "interactive_session_state_receipt",
        "command_prompt_generation_receipt",
        "user_prompt_context_receipt",
        "ingress_route_receipt"
      ],
      "non_goals": [
        "do_not_execute_generated_commands",
        "do_not_choose_architecture_inside_ingress",
        "do_not_apply_permission_policy_inside_ingress",
        "do_not_mutate_files_inside_ingress"
      ]
    },
    "session_bootstrap_guard_contract": {
      "source": "forgecode_assimilated_session_layer",
      "required_composite_workflow_id": "local_coding_session_bootstrap_guard",
      "required_primitive_workflow_ids": [
        "agent_provider_model_binding",
        "conversation_session_bootstrap",
        "terminal_command_context_snapshot",
        "external_file_change_notice",
        "title_commit_helper_generation"
      ],
      "activation_policy": "local coding tasks must bind provider/model, initialize conversation state, snapshot terminal context, detect external file changes, and route title/commit helper behavior before permission, context, tooling, runtime, planning, or local code-edit execution",
      "required_receipts": [
        "agent_provider_model_binding_receipt",
        "conversation_session_bootstrap_receipt",
        "terminal_context_receipt",
        "external_file_change_receipt",
        "title_commit_helper_receipt",
        "session_bootstrap_route_receipt"
      ],
      "non_goals": [
        "do_not_start_runtime_loop_inside_session_bootstrap",
        "do_not_choose_architecture_inside_session_bootstrap",
        "do_not_apply_permission_policy_inside_session_bootstrap",
        "do_not_mutate_files_or_git_state_inside_session_bootstrap"
      ]
    },
    "remote_service_guard_contract": {
      "source": "forgecode_assimilated_remote_service_layer",
      "required_composite_workflow_id": "local_coding_remote_service_guard",
      "required_primitive_workflow_ids": [
        "workspace_remote_auth_boundary",
        "workspace_sync_indexing",
        "codebase_semantic_search",
        "provider_transport_boundary"
      ],
      "activation_policy": "local coding tasks may route remote workspace auth, sync/indexing, semantic search, and provider transport through ForgeCode-style remote service boundaries, but local file mutation and validation must remain owned by local safety primitives",
      "required_receipts": [
        "workspace_remote_auth_receipt",
        "workspace_sync_indexing_receipt",
        "codebase_semantic_search_receipt",
        "provider_transport_receipt",
        "remote_freshness_dependency_receipt"
      ],
      "non_goals": [
        "do_not_replace_safe_local_file_reads",
        "do_not_treat_semantic_search_as_exact_file_context",
        "do_not_treat_workspace_sync_as_validation",
        "do_not_store_or_emit_remote_service_secrets"
      ]
    },
    "operator_integration_guard_contract": {
      "source": "forgecode_assimilated_operator_integration_layer",
      "required_composite_workflow_id": "local_coding_operator_integration_guard",
      "required_primitive_workflow_ids": [
        "sandbox_worktree_isolation",
        "operator_command_surface_projection",
        "external_update_editor_auth_boundary",
        "schema_data_generation_pipeline",
        "local_coding_shell_terminal_guard"
      ],
      "activation_policy": "local coding tasks must route sandbox worktree setup, command-surface projection, update/editor/auth callbacks, schema data generation, and shell-terminal integration through ForgeCode-style operator integration boundaries when those features are relevant, while local file mutation and validation remain owned by local safety primitives",
      "required_receipts": [
        "sandbox_worktree_receipt",
        "operator_command_surface_receipt",
        "external_update_editor_auth_receipt",
        "schema_data_generation_receipt",
        "shell_terminal_guard_receipt",
        "operator_action_approval_receipt"
      ],
      "non_goals": [
        "do_not_treat_command_projection_as_command_execution",
        "do_not_install_update_or_editor_extension_without_confirmation",
        "do_not_bind_non_loopback_oauth_callbacks",
        "do_not_treat_schema_data_generation_as_code_validation",
        "do_not_treat_shell_completion_or_buffer_projection_as_execution",
        "do_not_store_or_emit_operator_secrets"
      ]
    },
    "context_loop_guard_contract": {
      "source": "forgecode_assimilated_context_layer",
      "required_composite_workflow_id": "local_context_loop_guard",
      "required_primitive_workflow_ids": [
        "tool_access_resolver",
        "doom_loop_interrupt",
        "pending_todo_completion_gate",
        "context_compaction_summary",
        "tool_error_reflection",
        "agent_task_delegation"
      ],
      "activation_policy": "long-running local coding tasks must initialize tool access, loop-interruption, pending-todo, compaction, tool-error reflection, and delegated-agent guards before planning or implementation loops",
      "required_receipts": [
        "tool_access_receipt",
        "doom_loop_receipt",
        "pending_todo_gate_receipt",
        "compaction_receipt",
        "tool_error_reflection_receipt",
        "agent_task_delegation_receipt"
      ],
      "non_goals": [
        "do_not_use_context_guard_for_file_mutation",
        "do_not_use_context_guard_as_validation_runner",
        "do_not_hide_blocking_user_decisions"
      ]
    },
    "policy_permission_guard_contract": {
      "source": "forgecode_assimilated_policy_layer",
      "required_composite_workflow_id": "local_policy_permission_guard",
      "required_primitive_workflow_ids": [
        "forge_config_resolution",
        "operation_permission_gate"
      ],
      "activation_policy": "local coding tasks must resolve ForgeCode-style runtime config and operation permission decisions before local reads, writes, shell validation, fetches, or delegated execution",
      "required_receipts": [
        "config_resolution_receipt",
        "restricted_mode_receipt",
        "operation_permission_receipt",
        "policy_path_receipt"
      ],
      "non_goals": [
        "do_not_treat_permission_allow_as_execution_success",
        "do_not_skip_safety_receipts_after_permission_allow",
        "do_not_silently_persist_accept_and_remember"
      ]
    },
    "tooling_surface_guard_contract": {
      "source": "forgecode_assimilated_tooling_layer",
      "required_composite_workflow_id": "local_tooling_surface_guard",
      "required_primitive_workflow_ids": [
        "tool_schema_registry",
        "tool_call_normalization",
        "mcp_tool_bridge",
        "custom_command_skill_loader",
        "local_coding_prompt_template_guard"
      ],
      "activation_policy": "local coding tasks must establish ForgeCode-style tool schemas, call normalization, MCP bridge status, command/skill inventory, and prompt-template artifacts before invoking live local coding tools",
      "required_receipts": [
        "tool_schema_registry_receipt",
        "tool_call_normalization_receipt",
        "mcp_tool_bridge_receipt",
        "custom_command_skill_loader_receipt",
        "prompt_template_guard_receipt"
      ],
      "non_goals": [
        "do_not_treat_tool_surface_readiness_as_permission",
        "do_not_execute_loaded_commands_without_explicit routing",
        "do_not_execute_rendered_command_templates_without_parent_route",
        "do_not_skip_operation_permission_or_safety_receipts"
      ]
    },
    "runtime_execution_loop_contract": {
      "source": "forgecode_assimilated_runtime_layer",
      "required_composite_workflow_id": "local_runtime_execution_loop",
      "required_primitive_workflow_ids": [
        "agent_request_transform_pipeline",
        "turn_retry_stream_runner",
        "tool_call_execution_dispatch",
        "lifecycle_hook_dispatch",
        "conversation_state_persistence"
      ],
      "activation_policy": "live local coding execution must route provider request transforms, retry streaming, tool dispatch, lifecycle hooks, and conversation persistence through ForgeCode-assimilated runtime primitives after policy, context, and tooling guards are initialized",
      "required_receipts": [
        "request_transform_receipt",
        "retry_stream_turn_receipt",
        "tool_dispatch_receipt",
        "lifecycle_hook_receipt",
        "conversation_state_receipt",
        "yield_or_interrupt_receipt"
      ],
      "stop_or_yield_conditions": [
        "finish_reason_stop_with_no_tool_calls",
        "tool_call_requests_parent_followup",
        "max_request_per_turn_reached",
        "max_tool_failure_per_turn_reached",
        "end_hook_added_messages_and_loop_continues",
        "provider_retry_budget_exhausted",
        "conversation_persistence_failed"
      ],
      "non_goals": [
        "do_not_choose_product_architecture_inside_runtime_loop",
        "do_not_bypass_policy_permission_or_safe_file_primitives",
        "do_not_hide_retry_attempts_tool_failures_or_interruptions"
      ]
    },
    "runtime_observability_guard_contract": {
      "source": "forgecode_assimilated_observability_layer",
      "required_composite_workflow_id": "local_runtime_observability_guard",
      "required_primitive_workflow_ids": [
        "chat_response_visibility_router",
        "streaming_markdown_projection",
        "tool_output_display_format",
        "trace_event_rate_limiter"
      ],
      "activation_policy": "live local coding execution must attach ForgeCode-assimilated observability primitives that route ChatResponse visibility, render streaming markdown, format compact tool display output, and bound telemetry volume without owning planning, coding, validation, or checkpoint handoff",
      "required_receipts": [
        "visibility_route_receipt",
        "markdown_projection_receipt",
        "display_format_receipt",
        "trace_rate_limit_receipt"
      ],
      "non_goals": [
        "do_not_treat_display_artifacts_as_execution_receipts",
        "do_not_store_raw_tool_payloads_or_full_markdown_streams",
        "do_not_run_tests_or_validation_from_observability"
      ]
    },
    "stop_conditions": [
      "user decision required for stack, architecture, auth, persistence, payment, deployment, external API, or destructive migration",
      "existing project architecture conflicts with requested implementation",
      "required local files or dependencies are missing and cannot be inferred safely",
      "validation fails after repair budget is exhausted",
      "implementation exceeds slice or complexity budget",
      "tooling cannot read, write, or execute required local work",
      "security, privacy, licensing, or data-loss risk is discovered",
      "request expands beyond the current checkpoint"
    ],
    "unexpected_discovery_policy": {
      "continue_if": [
        "discovery only changes implementation details",
        "existing project pattern clearly answers the decision",
        "a conservative local default is safe"
      ],
      "stop_if": [
        "discovery changes product scope",
        "discovery changes architecture or stack",
        "discovery introduces migration or data-loss risk",
        "discovery invalidates the checkpoint"
      ]
    },
    "validation_tiers": [
      "syntax",
      "behavioral",
      "product_smoke",
      "architecture_drift",
      "release"
    ],
    "metrics": [
      "slices_planned",
      "slices_completed",
      "repair_attempts",
      "validation_failures",
      "stop_reason",
      "files_created",
      "files_edited",
      "architecture_drift_events",
      "user_decisions_required"
    ]
  },
  "state_tracking_contract": {
    "version": "local_coding_program_builder_state_v1",
    "required_state_fields": [
      "checkpoint",
      "ingress_context",
      "session_bootstrap",
      "remote_service_context",
      "operator_integration_context",
      "architecture_contract",
      "completed_slices",
      "active_slice",
      "known_issues",
      "validation_results",
      "files_changed",
      "decisions_made",
      "next_actions"
    ],
    "code_edit_slice_return_contract": {
      "changed_files": "path, reason, and kind for each created, edited, or deleted file",
      "interfaces_changed": "exports, APIs, schemas, commands, or data contracts changed by the slice",
      "validation_run": "commands or manual checks run, skipped, failed, or blocked",
      "remaining_risks": "known issues that affect the checkpoint or future slices"
    }
  },
  "default_for_request_classes": [
    "mutation",
    "task_proposal"
  ],
  "workflow_source_of_truth_contract": {
    "interaction_source": "json_workflow_spec",
    "rust_reader_role": "validate_execute_trace_only",
    "hardcoded_interaction_behavior_allowed": false,
    "json_owns": [
      "interaction_gates",
      "gate_options",
      "gate_transitions",
      "tool_family_menus",
      "tool_input_schemas",
      "confirmation_states",
      "loopbacks",
      "final_output_contract"
    ],
    "rust_owns": [
      "json_loading",
      "schema_validation",
      "state_transition_execution",
      "tool_execution_handoff",
      "receipt_binding",
      "trace_export",
      "kernel_policy_enforcement"
    ]
  },
  "interaction_gate_contract": {
    "version": "llm_toolbox_gate_contract_v1",
    "tool_family_menu_stage": "gate_2_tool_family_menu",
    "tool_request_payload_stage": "gate_4_request_payload_input",
    "tool_observation_stage": "tool_observation",
    "final_answer_stage": "gate_6_llm_final_output",
    "recovery_stage": "repair_loop",
    "gates": [
      {
        "stage": "gate_1_need_tool_access_menu",
        "parser_kind": "need_tools",
        "true_values": [
          "yes",
          "y",
          "true",
          "t",
          "1"
        ],
        "false_values": [
          "no",
          "n",
          "false",
          "f",
          "0"
        ]
      },
      {
        "stage": "gate_2_tool_family_menu",
        "parser_kind": "tool_family",
        "choice_base": 1
      },
      {
        "stage": "gate_3_tool_menu",
        "parser_kind": "tool_name"
      },
      {
        "stage": "gate_4_request_payload_input",
        "parser_kind": "request_payload"
      },
      {
        "stage": "gate_5_post_tool_menu",
        "parser_kind": "post_tool",
        "finish_values": [
          "finish",
          "done",
          "submit"
        ],
        "another_tool_values": [
          "another",
          "another tool",
          "use another tool"
        ]
      }
    ]
  }
}
