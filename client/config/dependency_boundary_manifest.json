{
  "version": "1.0",
  "enabled": true,
  "layers": {
    "core": ["client/lib", "client/bin"],
    "config": ["client/config"],
    "systems": ["client/systems"],
    "adaptive": ["client/adaptive"],
    "habits": ["client/habits"],
    "memory": ["client/memory"],
    "state": ["client/local/state", "core/local/state", "state"],
    "docs": ["docs"],
    "tests": ["client/tests", "client/memory/tools/tests"]
  },
  "allow_imports": {
    "core": ["core", "config", "systems"],
    "config": ["config", "core"],
    "systems": ["core", "config", "systems", "adaptive", "state", "habits", "memory", "tests"],
    "adaptive": ["core", "config", "systems", "adaptive", "state"],
    "habits": ["core", "config", "systems", "adaptive", "habits", "state"],
    "memory": ["core", "config", "systems", "memory", "state"],
    "state": ["core", "config", "state"],
    "docs": ["core", "config", "docs"],
    "tests": ["core", "config", "systems", "adaptive", "habits", "memory", "state", "docs", "tests"]
  },
  "enforce_layers": ["core", "systems", "adaptive"],
  "enforce_cycles": false,
  "scan": {
    "include_dirs": ["client/systems", "client/lib", "client/adaptive", "client/habits", "client/memory/tools", "client/tests"],
    "include_ext": [".ts", ".js"],
    "exclude_contains": [".bak.", ".tmp", "node_modules", "dist/"]
  },
  "conduit_boundary": {
    "enabled": true,
    "include_dirs": ["client/systems", "client/lib"],
    "include_ext": [".ts", ".js"],
    "exclude_contains": [".bak.", ".tmp", "node_modules", "dist/", "/tests/", ".test."],
    "allowlisted_files": [
      "client/lib/direct_conduit_lane_bridge.js",
      "client/lib/legacy_retired_lane_bridge.js",
      "client/lib/spine_conduit_bridge.ts",
      "client/lib/ops_domain_conduit_runner.ts",
      "client/lib/conduit_full_lifecycle_probe.js",
      "client/systems/ops/dependency_boundary_guard.ts",
      "client/systems/ops/rust50_conf001_execution_cutover.ts",
      "client/systems/ops/rust50_sprint1_batch.ts",
      "client/systems/ops/rust50_sprint_contract.js",
      "client/systems/ops/rust_hybrid_migration_program.ts",
      "client/systems/conduit/conduit-client.ts",
      "client/systems/conduit/conduit-client.js"
    ],
    "forbidden_patterns": [
      "path.join(ROOT, 'target', 'release'",
      "path.join(ROOT, 'target', 'debug'",
      "--manifest-path",
      "spawnSync('cargo'",
      "spawnSync(\"cargo\"",
      "execSync('cargo",
      "execSync(\"cargo",
      "target', 'release', 'protheus-ops'",
      "target', 'debug', 'protheus-ops'",
      "target\", \"release\", \"protheus-ops\"",
      "target\", \"debug\", \"protheus-ops\"",
      "--bin', 'protheus-ops'",
      "--bin\", \"protheus-ops\"",
      "--package', 'protheus-ops-core'",
      "--package\", \"protheus-ops-core\""
    ]
  },
  "paths": {
    "latest_path": "client/local/state/ops/dependency_boundary_guard/latest.json",
    "receipts_path": "client/local/state/ops/dependency_boundary_guard/receipts.jsonl"
  }
}
