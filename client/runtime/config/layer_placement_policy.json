{
  "version": "2026-03-10",
  "authority_client_roots": [
    "client/runtime/systems/security/",
    "client/runtime/systems/spine/",
    "client/runtime/systems/memory/",
    "client/runtime/systems/autonomy/",
    "client/runtime/systems/workflow/"
  ],
  "wrapper_markers": [
    "createLegacyRetiredModule",
    "runAsMain",
    "legacy_retired_wrapper"
  ],
  "ownership_required_globs": [
    "core/layer0/**/*.rs",
    "core/layer1/**/*.rs",
    "core/layer2/**/*.rs",
    "orchestration/**/*.ts",
    "orchestration/**/*.rs",
    "orchestration/**/*.ts",
    "orchestration/**/*.js",
    "client/runtime/systems/**/*.ts",
    "client/runtime/systems/**/*.js",
    "apps/**/*.ts",
    "apps/**/*.js",
    "apps/**/*.rs"
  ],
  "ownership_markers": [
    "Layer ownership:",
    "App ownership:"
  ],
  "ownership_header_scan_lines": 12,
  "forbidden_concept_markers_by_prefix": [
    {
      "path_prefix": "core/layer0/",
      "case_insensitive": true,
      "markers": [
        "coding_project_operator",
        "local_coding_program_builder",
        "public_reasoning_trace",
        "reasoning_rollup",
        "completion_evidence",
        "task_requirement_checklist",
        "checkpoint handoff",
        "handoff receipt",
        "checkpoint memory",
        "checkpoint_002",
        "checkpoint_003",
        "recommended_next_checkpoint",
        "runtime_synthesized_handoff_artifacts",
        "expected new memory row id",
        "deliveryattemptledger",
        "infring_agent_surface",
        "agent surface",
        "provider orchestration",
        "native tool loop",
        "runtime lane"
      ],
      "allow_exact_paths": [],
      "allow_path_prefixes": [],
      "hint": "Layer 0 is the safety plane. Move workflow-specific coding policy, checkpoint handoff semantics, public reasoning rollups, and task-specific evidence heuristics to orchestration or a higher core execution/policy layer; Layer 0 should consume only generic contracts and receipt primitives."
    }
  ]
}
