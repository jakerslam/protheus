{
  "version": "1.0",
  "target_roots": [
    "systems"
  ],
  "file_extensions": [
    ".js"
  ],
  "exclude_paths": [
    "client/runtime/systems/security/architecture_guard.ts"
  ],
  "banned_tokens": [
    "moltbook",
    "moltstack",
    "twitter",
    "api.x.com",
    "hnrss.org",
    "/api/v1/",
    "submolt",
    "gmail",
    "bird"
  ],
  "allow_paths": [
    "client/runtime/systems/autonomy/autonomy_controller.ts",
    "client/runtime/systems/spine/spine.ts"
  ],
  "allow_token_overrides": {
    "client/runtime/systems/security/guard.ts": [
      "moltbook"
    ],
    "client/runtime/systems/security/request_ingress.ts": [
      "moltbook"
    ],
    "client/runtime/systems/sensory/eyes_intake.ts": [
      "hnrss.org",
      "moltbook",
      "twitter",
      "bird"
    ],
    "client/runtime/systems/sensory/eyes_collectors/bird_x.ts": [
      "bird"
    ]
  }
}
