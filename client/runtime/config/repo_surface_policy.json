{
  "version": "2026-04-10",
  "code_roots": [
    "core",
    "surface",
    "client",
    "packages",
    "apps",
    "adapters",
    "tests"
  ],
  "root_rules": {
    "core": {
      "allowed_extensions": [
        "rs",
        "c",
        "cc",
        "cpp",
        "h",
        "hpp",
        "sh"
      ],
      "notes": "Rust-first authority substrate. C/C++ only for low-level and hardware-adjacent paths."
    },
    "surface": {
      "target_extensions": [
        "rs",
        "ts",
        "tsx"
      ],
      "legacy_debt_extensions": [
        "js",
        "py",
        "sh"
      ],
      "allowed_extensions": [
        "rs",
        "ts",
        "tsx",
        "sh"
      ],
      "notes": "Orchestration Surface is non-canonical coordination. Durable truth remains in core contracts."
    },
    "client": {
      "target_extensions": [
        "ts",
        "tsx",
        "html",
        "css",
        "scss"
      ],
      "legacy_debt_extensions": [
        "js",
        "py",
        "sh",
        "ps1"
      ],
      "notes": "Presentation/runtime wrappers and UX only."
    },
    "packages": {
      "allowed_extensions": [
        "ts",
        "tsx",
        "js",
        "jsx",
        "py",
        "sh",
        "html",
        "css",
        "scss"
      ],
      "notes": "Public SDK/package distribution surfaces; non-authoritative."
    },
    "apps": {
      "allowed_extensions": [
        "ts",
        "tsx",
        "js",
        "jsx",
        "py",
        "rs",
        "html",
        "css",
        "scss",
        "sh",
        "toml",
        "json",
        "yaml",
        "yml"
      ],
      "notes": "Standalone app surfaces that remain deletable without changing system authority behavior."
    },
    "adapters": {
      "allowed_extensions": [
        "ts",
        "tsx",
        "js",
        "jsx",
        "py",
        "rs",
        "sh",
        "toml",
        "json",
        "yaml",
        "yml"
      ],
      "notes": "Polyglot integration shims for external systems."
    },
    "tests": {
      "allowed_extensions": [
        "ts",
        "tsx",
        "js",
        "jsx",
        "py",
        "rs",
        "sh"
      ],
      "notes": "Integration, regression, and CI tooling verification surfaces."
    }
  },
  "runtime_exceptions": [
    "scripts/",
    "examples/",
    "setup/",
    "benchmarks/",
    "docs/",
    "local/",
    "tools/",
    "core/local/",
    "client/local/",
    "core/local/artifacts/",
    "local/state/",
    "planes/",
    "proofs/",
    "xtask/",
    "core/layer1/memory_runtime/adaptive/",
    "node_modules/"
  ],
  "ignore_path_prefixes": [
    "client/runtime/local/",
    "client/cognition/habits/scripts/",
    "core/layer1/memory_runtime/adaptive/",
    "client/pure-workspace/"
  ],
  "ignore_exact_paths": [
    "install.ps1",
    "install.sh",
    "verify.sh",
    "vitest.config.ts"
  ],
  "forbidden_path_prefixes": [
    "client/cli/apps/"
  ]
}
