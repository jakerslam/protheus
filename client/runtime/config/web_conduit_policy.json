{
  "mode": "production",
  "version": "v1",
  "web_conduit": {
    "allow_domains": [],
    "deny_domains": [
      "127.0.0.1",
      "localhost",
      "metadata.google.internal",
      "169.254.169.254"
    ],
    "enabled": true,
    "max_response_bytes": 350000,
    "rate_limit_per_minute": 30,
    "require_human_for_sensitive": true,
    "search_provider_order": [
      "serperdev",
      "duckduckgo",
      "duckduckgo_lite",
      "bing_rss"
    ],
    "provider_circuit_breaker": {
      "enabled": true,
      "failure_threshold": 3,
      "open_for_secs": 300
    },
    "sensitive_domains": [
      "accounts.google.com",
      "api.stripe.com",
      "paypal.com",
      "chase.com",
      "bankofamerica.com"
    ],
    "timeout_ms": 9000
  }
}
