{
  "version": "1.0",
  "policy": {
    "mode": "fail_on_growth",
    "srs_id": "V13-CODEX-SHELL-ALPINE-001",
    "rule": "No new Alpine bindings, Alpine runtime API calls, or Alpine magic helpers may be added to the Shell UI without an explicit migration waiver and baseline update."
  },
  "scan_roots": [
    "client/runtime/systems/ui/infring_static"
  ],
  "scan_extensions": [
    ".html",
    ".ts",
    ".css"
  ],
  "ignore_path_contains": [
    "client/runtime/systems/ui/infring_static/js/svelte/",
    ".generated.",
    ".min."
  ],
  "required_policy_docs": [
    {
      "path": "docs/workspace/shell_alpine_retirement_policy.md",
      "must_include": [
        "V13-CODEX-SHELL-ALPINE-001",
        "No new Alpine",
        "Svelte/shared shell services"
      ]
    }
  ],
  "patterns": [
    {
      "id": "alpine_direct_api",
      "description": "Direct Alpine runtime API use.",
      "regex": "\\bAlpine\\s*\\."
    },
    {
      "id": "alpine_x_directives",
      "description": "Alpine x-* attributes in shell templates.",
      "regex": "\\bx-[A-Za-z0-9:_-]+\\s*="
    },
    {
      "id": "alpine_shorthand_events",
      "description": "Alpine shorthand event bindings in shell templates.",
      "regex": "\\s@[A-Za-z0-9:_-]+(?:\\.[A-Za-z0-9:_-]+)*\\s*="
    },
    {
      "id": "alpine_shorthand_bindings",
      "description": "Alpine shorthand bound attributes in shell templates.",
      "regex": "\\s:[A-Za-z0-9:_-]+\\s*="
    },
    {
      "id": "alpine_magic_store",
      "description": "Alpine $store access.",
      "regex": "\\$store\\b"
    },
    {
      "id": "alpine_magic_watch_next_tick",
      "description": "Alpine magic helpers such as $watch, $nextTick, $dispatch, $refs, and $el.",
      "regex": "\\$(?:watch|nextTick|dispatch|refs|el)\\b"
    },
    {
      "id": "alpine_x_data",
      "description": "Alpine x-data component roots in shell templates.",
      "regex": "\\bx-data\\s*="
    },
    {
      "id": "alpine_x_for",
      "description": "Alpine x-for collection loops in shell templates.",
      "regex": "\\bx-for\\s*="
    },
    {
      "id": "alpine_x_model",
      "description": "Alpine x-model form bindings in shell templates.",
      "regex": "\\bx-model(?:\\.[A-Za-z0-9:_-]+)*\\s*="
    },
    {
      "id": "alpine_x_bind",
      "description": "Alpine x-bind attribute bindings in shell templates.",
      "regex": "\\bx-bind(?::[A-Za-z0-9:_-]+|\\.[A-Za-z0-9:_-]+)*\\s*="
    },
    {
      "id": "alpine_x_on",
      "description": "Alpine x-on event bindings in shell templates.",
      "regex": "\\bx-on(?::[A-Za-z0-9:_-]+|\\.[A-Za-z0-9:_-]+)*\\s*="
    },
    {
      "id": "alpine_store_api",
      "description": "Direct Alpine.store runtime API access.",
      "regex": "\\bAlpine\\s*\\.\\s*store\\b"
    }
  ],
