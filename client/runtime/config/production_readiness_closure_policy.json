{
  "schema_id": "production_readiness_closure_policy",
  "schema_version": "1.0",
  "canonical_release_channel": "stable",
  "release_candidate_topology": {
    "transport_mode": "resident_ipc_authoritative",
    "require_ipc_daemon": true,
    "require_ipc_strict": true,
    "forbid_process_transport_in_production": true
  },
  "production_surface_contract": {
    "canonical_surface": "rich",
    "constrained_profiles": [
      "pure",
      "tiny-max"
    ],
    "command_tiers": {
      "production_supported": [
        "gateway",
        "status",
        "doctor",
        "memory",
        "task",
        "receipts",
        "update"
      ],
      "experimental": [
        "assimilate"
      ],
      "internal": [
        "runtime-systems",
        "backlog-delivery-plane"
      ]
    }
  },
  "assimilation_v1": {
    "contract_path": "client/runtime/config/assimilation_v1_support_contract.json",
    "support_level": "experimental_opt_in",
    "frozen_vertical_slice": "runtime_ingress_to_assimilation_kernel"
  },
  "legacy_process_runner_transition": {
    "status": "dev_only_quarantined",
    "deletion_target": "Delete after one stable release cycle beyond v0.3.10-alpha unless a release blocker remains open.",
    "owner": "ops"
  },
  "support_bundle_contract": {
    "single_incident_truth_package": true,
    "script": "ops:support-bundle:export"
  },
  "release_candidate_rehearsal": {
    "script": "ops:release:rc-rehearsal",
    "strict": true
  },
  "numeric_thresholds": {
    "ipc_success_rate_min": 0.95,
    "receipt_completeness_rate_min": 1,
    "supported_command_latency_ms_max": 2500,
    "recovery_rto_minutes_max": 30,
    "recovery_rpo_hours_max": 24
  },
  "required_files": [
    "client/runtime/config/release_channel_policy.json",
    "client/runtime/config/release_compatibility_policy.json",
    "client/runtime/config/schema_versioning_gate_policy.json",
    "client/runtime/config/supply_chain_trust_policy.json",
    ".github/workflows/release-security-artifacts.yml",
    "docs/client/RELEASE_SECURITY_CHECKLIST.md",
    "docs/client/releases/v0.2.0_migration_guide.md",
    "client/runtime/config/runtime_telemetry_policy.json",
    "client/runtime/config/production_readiness_closure_policy.json",
    "tests/tooling/config/tooling_gate_registry.json",
    "tests/tooling/config/verify_profiles.json",
    "tests/tooling/scripts/ci/tooling_registry_runner.ts",
    "docs/client/RECOVERY_TRUTH_TABLE.md",
    "client/runtime/config/assimilation_v1_support_contract.json",
    "client/runtime/config/release_blocker_rubric.json",
    "client/runtime/config/release_hardening_window_policy.json",
    "tests/tooling/scripts/ci/legacy_process_runner_release_guard.ts"
    ,
    "tests/tooling/scripts/ci/transport_spawn_audit.ts",
    "tests/tooling/scripts/ci/assimilation_v1_support_guard.ts",
    "tests/tooling/scripts/ci/release_candidate_dress_rehearsal.ts"
  ],
  "required_package_scripts": [
    "ops:legacy-runner:release-guard",
    "ops:transport:topology:gate",
    "ops:transport:spawn-audit",
    "ops:production-topology:status",
    "ops:production-topology:gate",
    "ops:release-contract:gate",
    "ops:stateful-upgrade-rollback:gate",
    "ops:assimilation:v1:support:guard",
    "ops:release-blockers:gate",
    "ops:release-hardening-window:guard",
    "ops:release:scorecard:gate",
    "ops:release:rc-rehearsal",
    "ops:reliability:gauntlet",
    "ops:ipc-bridge:soak",
    "ops:f100-enterprise-baseline",
    "dr:gameday:gate",
    "chaos:continuous:gate",
    "ops:runtime-telemetry:status",
    "ops:support-bundle:export",
    "ops:production-closure:gate",
    "tooling:list",
    "tooling:run",
    "tooling:profile"
  ],
  "required_ci_invocations": [
    "ops:legacy-runner:release-guard",
    "ops:transport:spawn-audit",
    "ops:stateful-upgrade-rollback:gate",
    "ops:assimilation:v1:support:guard",
    "ops:release-blockers:gate",
    "ops:release-contract:gate",
    "ops:release:rc-rehearsal",
    "ops:reliability:gauntlet",
    "ops:ipc-bridge:soak",
    "ops:production-closure:gate"
  ],
  "required_verify_invocations": [
    "tooling_registry_runner.ts",
    "tests/tooling/config/verify_profiles.json",
    "--id=\"$VERIFY_PROFILE\""
  ],
  "required_verify_profile_gate_ids": {
      "release": [
        "ops:top1:proof-coverage",
        "ops:origin-integrity:run",
        "ops:origin-integrity:certificate",
        "ops:production-topology:gate",
        "ops:release-hardening-window:guard",
        "ops:release:scorecard:gate"
      ]
  },
  "required_readme_markers": [
    "Production Support Contract",
    "Canonical production profile: rich",
    "Constrained profiles: `--pure`, `--tiny-max`",
    "Experimental lanes (explicit opt-in): `assimilate`",
    "Resident IPC is the only supported production topology; the legacy process runner is dev-only.",
    "Release entrypoints quarantine the legacy runner under `adapters/runtime/dev_only/**`.",
    "Legacy runner deletion target: after one stable release cycle beyond `v0.3.10-alpha` unless a release blocker remains.",
    "Operator topology diagnostic: `npm run -s ops:production-topology:status`",
    "Transport spawn audit: `npm run -s ops:transport:spawn-audit`",
    "Assimilation v1 support guard: `npm run -s ops:assimilation:v1:support:guard`",
    "Frozen assimilation v1 slice: one ingress -> orchestration -> assimilation-kernel -> receipt-output path is hardened; broader assimilation surfaces remain experimental.",
    "Numeric release thresholds are enforced by `npm run -s ops:release:scorecard:gate`.",
    "Release-candidate dress rehearsal: `npm run -s ops:release:rc-rehearsal`.",
    "Support bundle is the single incident truth package for release closure.",
    "`npm run -s ops:support-bundle:export`"
  ],
  "smoke_scripts": [
    "ops:legacy-runner:release-guard",
    "ops:transport:topology:gate",
    "ops:transport:spawn-audit",
    "ops:production-topology:gate",
    "ops:stateful-upgrade-rollback:gate",
    "ops:assimilation:v1:support:guard",
    "ops:release-blockers:gate",
    "ops:release-hardening-window:guard",
    "dr:gameday",
    "dr:gameday:gate",
    "ops:release-contract:gate",
    "ops:support-bundle:export",
    "ops:release:scorecard:gate"
  ]
}
