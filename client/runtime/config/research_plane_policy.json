{
  "version": "v1",
  "kind": "research_plane_policy",
  "default_mode": "auto",
  "timeouts": {
    "fetch_ms": 12000,
    "crawl_fetch_ms": 8000
  },
  "headers": {
    "http": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
    },
    "stealth": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "en-US,en;q=0.9",
      "DNT": "1",
      "Upgrade-Insecure-Requests": "1"
    },
    "browser": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "en-US,en;q=0.9",
      "DNT": "1",
      "Sec-Fetch-Dest": "document",
      "Sec-Fetch-Mode": "navigate",
      "Sec-Fetch-Site": "none"
    }
  },
  "crawler": {
    "max_concurrency": 100,
    "per_domain_qps": 2,
    "max_retries": 3,
    "checkpoint_every": 10,
    "rate_limit": {
      "backoff_status_codes": [
        429,
        503,
        504
      ],
      "base_delay_ms": [
        1000,
        3000
      ],
      "max_delay_ms": 60000,
      "jitter": true,
      "per_domain_state": true
    },
    "resource_guard": {
      "memory_pressure_mode": true,
      "max_parallel_dynamic_pages": 4,
      "requeue_on_pressure": true,
      "record_wait_time": true
    }
  },
  "safety_plane": {
    "enabled": true,
    "required_modes": [
      "stealth",
      "browser"
    ],
    "allow_actions": [
      "research_fetch:*",
      "research_crawl:*",
      "research:*"
    ],
    "max_requests_per_mode": {
      "stealth": 20000,
      "browser": 5000,
      "http": 50000,
      "auto": 50000
    }
  },
  "blocked_recovery": {
    "enabled": true,
    "default": "diagnose_only",
    "escalate_only_from_quality_flags": [
      "blocked",
      "needs_js",
      "needs_dynamic",
      "rate_limited"
    ],
    "detection_signals": [
      "status_code",
      "structural_block_marker",
      "captcha_marker",
      "minimal_visible_text",
      "script_heavy_shell",
      "provider_error"
    ],
    "attempt_trace_fields": [
      "attempts",
      "retries",
      "fetch_mode",
      "status_code",
      "blocked",
      "reason",
      "resolved_by"
    ],
    "non_goals": [
      "do_not_enable_stealth_by_default",
      "do_not_rotate_proxy_without_permission",
      "do_not_hide_blocked_state_from_synthesis"
    ]
  },
  "conduit_enforcement": {
    "reject_bypass_flags": [
      "bypass",
      "direct",
      "unsafe-client-route",
      "client-bypass"
    ],
    "strict_fail_closed": true
  },
  "goal_crawl": {
    "default_max_pages": 5,
    "default_max_discovery": 10
  },
  "adaptive_retrieval": {
    "enabled": true,
    "authority": "policy_owned_research_primitive",
    "default_strategy": "best_first_when_candidates_are_scored",
    "confidence_threshold": 0.7,
    "max_pages": 20,
    "top_k_links": 3,
    "min_gain_threshold": 0.08,
    "strategy_menu": [
      "one_shot_search_pack",
      "prefetch_then_rank",
      "breadth_first_site_slice",
      "depth_first_path_probe",
      "best_first_candidate_expansion"
    ],
    "strategy_selection": {
      "authority": "agent_or_policy_may_select_by_task_and_evidence_state",
      "non_goal": "do_not_select_by_hardcoded_user_prompt_phrases",
      "prefer_best_first_when": [
        "candidate_scores_available",
        "budget_is_limited",
        "evidence_coverage_is_partial"
      ],
      "prefer_prefetch_then_rank_when": [
        "search_rows_are_thin",
        "source_pages_have_many_links",
        "tool_needs_candidate_pool_before_fetch"
      ]
    },
    "signals": [
      "coverage",
      "consistency",
      "saturation",
      "source_diversity",
      "freshness_when_relevant",
      "candidate_gain"
    ],
    "state_projection": {
      "enabled": true,
      "purpose": "make adaptive retrieval progress resumable and diagnosable without exposing raw crawl state to chat",
      "fields": [
        "confidence",
        "coverage",
        "saturation",
        "crawled_url_count",
        "pending_candidate_count",
        "source_domain_count",
        "crawl_order",
        "new_terms_history",
        "stop_reason"
      ],
      "export_policy": "telemetry_or_evidence_metadata_only"
    },
    "stop_conditions": [
      "confidence_threshold_met",
      "saturation_threshold_met",
      "candidate_gain_below_threshold",
      "max_pages_reached",
      "budget_exhausted"
    ]
  },
  "url_seeding": {
    "enabled": true,
    "sources": [
      "search_provider_rows",
      "sitemap",
      "robots_sitemap",
      "common_crawl_when_available"
    ],
    "mode_guidance": {
      "deep_crawl": "fresh_real_time_discovery",
      "url_seeding": "bulk_discovery_before_fetch",
      "combined": "seed_for_candidate_pool_then_deep_crawl_promising_sections"
    },
    "head_preview": {
      "enabled": true,
      "scoring": "bm25_or_equivalent",
      "include_fields": [
        "title",
        "description",
        "keywords",
        "canonical",
        "lang",
        "jsonld"
      ]
    },
    "cache": {
      "ttl_hours": 24,
      "validate_lastmod": true,
      "cleanup_bound": "system_cache_cleanup"
    },
    "queue": {
      "bounded": true,
      "dedupe_urls": true,
      "rate_limit_by_domain": true,
      "record_parent_url": true,
      "record_depth": true,
      "record_candidate_score": true,
      "record_rejection_reason": true,
      "stream_progress_to_telemetry": true
    },
    "link_normalization": {
      "resolve_relative_urls": true,
      "dedupe_canonical_urls": true,
      "ignore_non_fetchable_schemes": [
        "javascript",
        "mailto",
        "tel"
      ],
      "ignore_anchor_only_links": true,
      "trim_href_whitespace": true,
      "preserve_query_strings": true,
      "preserve_fragments_unless_anchor_only": true,
      "preserve_https_for_internal_links_after_redirect": true,
      "reject_invalid_base_urls": true,
      "classify_internal_external": true
    }
  },
  "source_access": {
    "robots_policy": "respect_and_record",
    "robots_cache": {
      "ttl_hours": 24,
      "handle_empty_or_malformed_as": "unknown_access_state",
      "handle_timeout_as": "unknown_access_state",
      "max_robots_bytes": "bounded_by_tool_budget"
    },
    "redirect_policy": {
      "record_chain": true,
      "preserve_original_scheme_for_internal_link_resolution": true,
      "classify_http_downgrade": true
    },
    "diagnostic_fields": [
      "robots_status",
      "robots_allowed",
      "robots_error",
      "redirect_chain",
      "final_url",
      "content_type",
      "document_type"
    ],
    "chat_visibility": "hidden_until_synthesized"
  },
  "retrieval_profiles": {
    "enabled": true,
    "authority": "cd_policy_selects_by_content_and_evidence_state_not_domain_routes",
    "match_axes": [
      "content_type",
      "document_type",
      "quality_flags",
      "evidence_gap",
      "explicit_user_constraints",
      "available_capabilities"
    ],
    "profile_names": [
      "default_markdown_fetch",
      "fit_content_fetch",
      "pdf_document_fetch",
      "structured_artifact_fetch",
      "dynamic_readiness_probe",
      "prefetch_only_discovery"
    ],
    "fallback_profile": "default_markdown_fetch",
    "record_selected_profile": true,
    "non_goals": [
      "do_not_select_profiles_by_hardcoded_domain",
      "do_not_select_profiles_by_example_prompt_phrase",
      "do_not_silently_enable_browser_or_proxy_modes"
    ]
  },
  "session_reuse": {
    "default": "stateless",
    "allowed_for": [
      "sequential_dynamic_steps",
      "explicit_session_handle",
      "capability_admitted_stateful_fetch"
    ],
    "parallel_reuse_allowed": false,
    "cleanup_required": true,
    "projection_fields": [
      "session_state",
      "session_reused",
      "session_closed",
      "session_error"
    ],
    "raw_session_state_chat_visible": false
  },
  "evidence_extraction": {
    "default_output": "markdown",
    "variants": [
      "raw_markdown",
      "markdown_with_citations",
      "fit_markdown",
      "references",
      "references_markdown",
      "source_excerpt",
      "cleaned_html",
      "fit_html",
      "table_summary",
      "page_metadata_summary",
      "link_summary",
      "media_summary",
      "document_metadata_summary",
      "pdf_text_excerpt",
      "pdf_page_summary",
      "pdf_link_summary",
      "error_summary",
      "dispatch_summary"
    ],
    "source_selection": {
      "default": "cleaned_content",
      "allowed_sources": [
        "raw_content",
        "cleaned_content",
        "fit_content",
        "structured_artifact_summary"
      ],
      "fallback_order": [
        "fit_content",
        "markdown_with_citations",
        "cleaned_content",
        "structured_artifact_summary",
        "raw_content_excerpt"
      ]
    },
    "result_envelope": {
      "purpose": "preserve retrieval state for synthesis without exposing raw payloads to chat",
      "fields": [
        "source_url",
        "final_url",
        "canonical_url",
        "success",
        "status_code",
        "redirected_status_code",
        "fetch_mode",
        "cache_status",
        "cache_freshness_status",
        "head_fingerprint",
        "robots_status",
        "robots_allowed",
        "content_type",
        "document_type",
        "quality_flags",
        "error_message",
        "safe_response_header_summary"
      ],
      "resource_fields": [
        "task_id",
        "duration_ms",
        "memory_usage_mb",
        "peak_memory_mb",
        "dispatcher_error"
      ],
      "network_console_capture": "diagnostic_only_and_hidden_from_chat"
    },
    "chunking": {
      "enabled": true,
      "purpose": "make large or noisy pages usable by synthesis through ranked evidence chunks instead of whole-page dumps",
      "strategies": [
        "paragraph_or_heading_boundary",
        "fixed_window",
        "sliding_window_with_overlap",
        "semantic_or_similarity_ranked_when_available"
      ],
      "selection": {
        "prefer_query_relevant_fit_chunks": true,
        "retain_adjacent_context": true,
        "avoid_single_chunk_overconfidence": true
      },
      "metadata_fields": [
        "chunk_id",
        "source_url",
        "parent_artifact",
        "heading_path",
        "relevance_score",
        "token_estimate",
        "rejection_reason"
      ]
    },
    "structured_artifacts": {
      "enabled": true,
      "purpose": "retain non-prose evidence signals without forcing a final answer shape",
      "artifact_kinds": [
        "tables",
        "links",
        "media",
        "metadata",
        "documents",
        "citations",
        "extracted_content"
      ],
      "table_quality_fields": [
        "caption",
        "summary",
        "headers",
        "row_count",
        "column_count",
        "has_headers",
        "data_table_score",
        "rejection_reason"
      ],
      "link_quality_fields": [
        "href",
        "text",
        "title",
        "context",
        "domain",
        "intrinsic_score",
        "contextual_score",
        "total_score"
      ],
      "media_quality_fields": [
        "src",
        "alt",
        "title",
        "score",
        "surrounding_context"
      ],
      "document_quality_fields": [
        "document_type",
        "page_count",
        "page_span",
        "metadata_title",
        "metadata_author",
        "text_extracted",
        "link_count",
        "image_count",
        "image_only_without_ocr",
        "rejection_reason"
      ]
    },
    "dynamic_readiness_diagnostics": {
      "enabled": true,
      "purpose": "diagnose pages where static retrieval misses content without making browser behavior the default",
      "signals": [
        "wait_condition_timeout",
        "lazy_load_required",
        "virtual_scroll_required",
        "scroll_behavior_static",
        "scroll_behavior_appended",
        "scroll_behavior_replaced",
        "network_request_counts",
        "failed_request_counts",
        "console_error_counts"
      ],
      "scroll_probe": {
        "bounded": true,
        "distinguish_append_vs_replace": true,
        "requires_dynamic_capability_for_full_capture": true
      },
      "raw_network_and_console_payloads_chat_visible": false
    },
    "content_filters": [
      "query_relevance",
      "text_density",
      "low_link_density",
      "source_provenance",
      "attribute_pruning",
      "script_style_noise_removal",
      "media_quality_signal"
    ],
    "raw_payload_chat_visible": false
  },
  "site_map": {
    "default_depth": 2,
    "default_max_nodes": 256
  },
  "monitor": {
    "notify_on_change": true
  },
  "js_scrape": {
    "max_wait_ms": 15000,
    "default_mode": "js-render"
  },
  "parallel_workers": {
    "default_max_concurrency": 8,
    "default_max_retries": 1
  },
  "decode": {
    "allowed_proxy_modes": [
      "none",
      "http",
      "https",
      "socks"
    ],
    "default_proxy_mode": "none",
    "default_interval_ms": 250,
    "default_backoff_ms": 500,
    "default_max_attempts": 2
  }
}
