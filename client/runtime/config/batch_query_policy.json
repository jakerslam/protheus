{
  "version": "v1",
  "batch_query": {
    "enabled_sources": [
      "web"
    ],
    "allow_large": false,
    "max_parallel_subqueries": 4,
    "query_recovery": {
      "broad_current_research": {
        "enabled": true,
        "max_queries": 4,
        "templates": [
          "{query}",
          "{query} {current_year}",
          "{query} research news",
          "{query} primary source"
        ]
      }
    }
  }
}
