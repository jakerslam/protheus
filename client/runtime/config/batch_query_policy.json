{
  "version": "v1",
  "batch_query": {
    "enabled_sources": [
      "web"
    ],
    "allow_large": false,
    "max_parallel_subqueries": 3,
    "query_timeout_ms": 20000,
    "cache": {
      "mode": "enabled",
      "ttl_success_seconds": 1800,
      "ttl_no_results_seconds": 120,
      "max_entries": 240,
      "lifecycle": {
        "cleanup_bound": "state_cleanup_policy:local/state/batch_query",
        "validation_metadata": [
          "etag",
          "last_modified",
          "head_fingerprint",
          "source_timestamp"
        ],
        "freshness_check": "conditional_headers_or_head_fingerprint_when_available"
      }
    },
    "page_extraction": {
      "enabled": true,
      "extract_mode": "markdown",
      "max_links_per_stage": 3,
      "max_total_fetches": 8,
      "min_link_score": 0.0,
      "trigger": "low_or_empty_candidates",
      "prefetch": {
        "enabled": true,
        "goal": "discover_and_rank_links_before_full_fetch",
        "mode": "fast_link_and_head_discovery_before_selected_full_fetch",
        "skip_heavy_processing_during_discovery": true,
        "max_prefetch_links": 24,
        "include_link_text": true,
        "include_parent_context": true,
        "artifact_contract": "html_links_metadata_only_until_selected_for_full_processing",
        "skip_outputs": [
          "cleaned_html",
          "markdown",
          "extracted_content",
          "screenshots",
          "pdf"
        ],
        "can_reprocess_raw_html_with_base_url": true,
        "link_normalization": {
          "resolve_relative_urls": true,
          "dedupe_canonical_urls": true,
          "ignore_schemes": [
            "javascript",
            "mailto",
            "tel",
            "file",
            "data"
          ],
          "ignore_anchor_only_links": true,
          "trim_href_whitespace": true,
          "preserve_query_strings": true,
          "preserve_fragments_unless_anchor_only": true,
          "preserve_https_for_internal_links_after_redirect": true,
          "reject_invalid_base_urls": true,
          "truncate_link_text_chars": 200,
          "record_internal_external_classification": true,
          "handle_protocol_relative_urls": true,
          "treat_subdomains_as_configurable_same_site": true,
          "return_empty_links_on_malformed_html": true
        }
      },
      "source_access": {
        "robots_policy": "respect_and_record",
        "robots_cache_ttl_seconds": 86400,
        "robots_failure_lane": "unknown_or_error_not_success",
        "record_access_fields": [
          "robots_status",
          "robots_allowed",
          "robots_error",
          "redirect_chain",
          "content_type",
          "document_type"
        ]
      },
      "document_extraction": {
        "enabled": true,
        "handled_types": [
          "html",
          "pdf",
          "text"
        ],
        "pdf": {
          "extract_text": true,
          "extract_metadata": true,
          "extract_links": true,
          "extract_images_default": false,
          "page_batching": true,
          "scanned_pdf_without_ocr_quality_flag": "image_only_pdf"
        }
      },
      "head_preview": {
        "enabled": true,
        "max_candidates": 16,
        "timeout_ms": 5000,
        "fields": [
          "title",
          "description",
          "canonical",
          "lang",
          "jsonld",
          "open_graph",
          "jsonld_schema_types",
          "head_fingerprint",
          "status"
        ]
      },
      "candidate_selection": {
        "strategy": "score_then_fetch_best_available",
        "score_axes": [
          "query_relevance",
          "link_text_signal",
          "head_metadata_signal",
          "source_diversity",
          "freshness_when_relevant",
          "content_density",
          "low_junk_signal"
        ],
        "record_rejection_reasons": true,
        "score_report": {
          "record_threshold": true,
          "record_min_max_avg": true,
          "record_top_matched_terms": true,
          "normalize_scores": true,
          "deterministic_for_same_cached_inputs": true,
          "empty_query_returns_unscored_discovery": true
        }
      },
      "retrieval_profile_selection": {
        "enabled": true,
        "authority": "content_and_evidence_state_not_domain_routes",
        "match_axes": [
          "content_type",
          "document_type",
          "quality_flags",
          "evidence_gap",
          "explicit_user_constraints"
        ],
        "fallback_profile": "default_markdown_fetch",
        "first_match_wins": true,
        "record_selected_profile": true,
        "disallow_match_axes": [
          "hardcoded_domain_name",
          "golden_case_id",
          "example_prompt_phrase"
        ]
      },
      "dynamic_escalation": {
        "enabled": true,
        "default": "off",
        "allowed_when_quality_flags_include": [
          "needs_js",
          "needs_dynamic",
          "blocked_but_retryable"
        ],
        "requires_capability": "web_fetch.dynamic_page_allowed"
      },
      "session_reuse": {
        "default": "stateless",
        "allowed_when": [
          "sequential_dynamic_steps_required",
          "explicit_session_handle_supplied",
          "capability_policy_admits_session_state"
        ],
        "parallel_session_reuse_allowed": false,
        "close_or_expire_on_completion": true,
        "record_session_state": "handle_only"
      }
    },
    "structured_results": {
      "enabled": true,
      "max_rows_per_stage": 16,
      "deterministic_extraction_first": true,
      "strategy_ladder": [
        "schema_selector_when_repeating_structure_detected",
        "regex_entity_extraction_for_known_low-risk_patterns",
        "semantic_extraction_when_structure_is_inconsistent"
      ],
      "record_fields": [
        "strategy",
        "base_selector",
        "element_count",
        "schema_confidence",
        "field_count",
        "extracted_row_count",
        "fallback_reason"
      ],
      "schema_safety": {
        "sample_before_full_extract": true,
        "validate_parent_selector_not_singleton_when_list_expected": true,
        "retain_base_attributes": true,
        "support_nested_and_list_fields": true,
        "raw_schema_chat_visible": false
      }
    },
    "adaptive_sufficiency": {
      "enabled": true,
      "authority": "policy_owned_retrieval_primitive",
      "min_evidence_items": 4,
      "min_source_domains": 3,
      "candidate_gain_threshold": 0.08,
      "stop_when": [
        "evidence_threshold_met",
        "source_diversity_threshold_met",
        "candidate_gain_below_threshold",
        "query_budget_exhausted",
        "tool_budget_exhausted"
      ],
      "diagnostics": [
        "candidate_count",
        "evidence_count",
        "source_domain_count",
        "quality_flags",
        "partial_failures",
        "query_plan_source",
        "candidate_rejection_reasons",
        "cache_status",
        "cache_freshness_status",
        "structured_artifact_counts",
        "chunk_relevance_scores",
        "result_envelope_quality",
        "confidence_components",
        "previous_confidence",
        "confidence_delta",
        "score_distribution",
        "score_threshold",
        "checkpoint_ref",
        "resume_state_ref",
        "cancelled",
        "stop_reason"
      ]
    },
    "evidence_pack": {
      "enabled": true,
      "max_items": 6,
      "max_snippet_words": 72,
      "result_envelope": {
        "include_source_url": true,
        "include_final_url": true,
        "include_status_code": true,
        "include_redirect_status": true,
        "include_fetch_mode": true,
        "include_cache_status": true,
        "include_cache_freshness_status": true,
        "include_head_fingerprint": true,
        "include_quality_flags": true,
        "include_access_status": true,
        "include_document_type": true,
        "include_error_summary": true
      },
      "content_variants": [
        "source_excerpt",
        "fit_markdown",
        "markdown_with_citations",
        "references_markdown",
        "cleaned_content_excerpt",
        "pdf_text_excerpt",
        "pdf_page_summary"
      ],
      "chunking": {
        "enabled": true,
        "selection": "rank_query_relevant_chunks_with_adjacent_context",
        "metadata_fields": [
          "chunk_id",
          "source_url",
          "parent_artifact",
          "heading_path",
          "relevance_score",
          "token_estimate",
          "rejection_reason"
        ]
      },
      "structured_artifacts": {
        "enabled": true,
        "artifact_kinds": [
          "table_summary",
          "link_summary",
          "media_summary",
          "page_metadata_summary",
          "document_metadata_summary",
          "pdf_link_summary",
          "structured_extract_summary",
          "regex_extract_summary"
        ],
        "summaries_only": true,
        "raw_payload_chat_visible": false
      }
    },
    "streaming_progress": {
      "enabled": true,
      "visibility": "telemetry_only_until_synthesized",
      "fields": [
        "queued",
        "active",
        "completed",
        "failed",
        "urls_per_second",
        "memory_pressure",
        "wait_time_ms",
        "rate_limit_backoff_ms",
        "checkpoint_ref",
        "cancelled",
        "active_context_count",
        "recycle_count"
      ]
    },
    "async_result_lifecycle": {
      "enabled": true,
      "use_for_large_or_long_running_batches": true,
      "status_values": [
        "queued",
        "processing",
        "completed",
        "failed",
        "expired",
        "cancelled"
      ],
      "handle_fields": [
        "task_id",
        "status",
        "created_at",
        "updated_at",
        "expires_at",
        "result_ref",
        "error_summary"
      ],
      "cleanup_bound": "state_cleanup_policy:local/state/batch_query",
      "callback_payload_includes_data_default": false,
      "raw_result_payload_chat_visible": false
    },
    "quality_gate": {
      "enabled": true,
      "provider_recovery": {
        "enabled": true,
        "max_providers": 2,
        "providers": [
          "gdelt_doc"
        ],
        "current_intent_providers": [
          "gdelt_doc"
        ]
      }
    },
    "query_recovery": {
      "broad_current_research": {
        "enabled": true,
        "max_queries": 10,
        "intent_markers": [
          "breakthrough",
          "breakthroughs",
          "changes",
          "current state",
          "developments",
          "landscape",
          "milestone",
          "milestones",
          "news",
          "overview",
          "state of",
          "trend",
          "trends"
        ],
        "templates": [
          "{query}",
          "{query} primary evidence",
          "{query} primary sources",
          "{query} official sources",
          "{query} recent publications",
          "{query} institution announcements",
          "{query} research publications",
          "{query} official announcements",
          "{query} technical reports",
          "{query} datasets",
          "{query} methodology evidence",
          "{query} peer reviewed evidence",
          "{query} source list"
        ]
      },
      "general_research": {
        "enabled": true,
        "max_queries": 10,
        "intent_markers": [
          "assess",
          "avoid",
          "benchmark",
          "best ",
          "choose",
          "compare",
          "comparison",
          "current state",
          "ecosystem",
          "evaluate",
          "evaluation",
          "fit ",
          "landscape",
          "limitation",
          "limitations",
          "mature",
          "maturity",
          "production",
          "recommend",
          "recommendation",
          "reliability",
          "risk",
          "risks",
          "security",
          "strength",
          "strengths",
          "versus",
          " vs ",
          "weakness",
          "weaknesses",
          "which "
        ],
        "templates": [
          "{query}",
          "{query} primary source evidence",
          "{query} official documentation project sources",
          "{query} independent analysis comparison evidence",
          "{query} risks limitations security reliability evidence",
          "{query} production usage examples case studies",
          "{query} methodology evidence",
          "{query} technical report",
          "{query} source diversity evidence",
          "{query} changelog release notes",
          "{query} repository issues adoption evidence",
          "{query} benchmark methodology evidence",
          "{query} security advisory evidence"
        ]
      }
    }
  }
}
