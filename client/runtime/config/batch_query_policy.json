{
  "version": "v1",
  "batch_query": {
    "enabled_sources": [
      "web"
    ],
    "allow_large": false,
    "max_parallel_subqueries": 4,
    "query_timeout_ms": 20000,
    "cache": {
      "mode": "enabled",
      "ttl_success_seconds": 1800,
      "ttl_no_results_seconds": 120,
      "max_entries": 240,
      "lifecycle": {
        "cleanup_bound": "state_cleanup_policy:local/state/batch_query",
        "validation_metadata": [
          "etag",
          "last_modified",
          "head_fingerprint",
          "source_timestamp"
        ],
        "freshness_check": "conditional_headers_or_head_fingerprint_when_available"
      }
    },
    "coverage_aware_query_planning": {
      "enabled": true,
      "authority": "agent_submitted_query_pack_with_policy_scoring",
      "trigger": "multi_entity_or_multi_aspect_or_open_ended_research",
      "budget": {
        "min_lanes_for_multi_entity": 4,
        "default_max_lanes": 8,
        "reserve_recovery_lanes": 2,
        "parallel_lane_limit": 4
      },
      "two_phase_retrieval": {
        "enabled": true,
        "initial_discovery_pass": {
          "allowed": true,
          "purpose": "learn vocabulary, candidate entities, source classes, and likely coverage gaps from a cheap broad pass",
          "completion_status": "non_terminal_for_research_shaped_requests_unless_sufficiency_signals_are_met"
        },
        "targeted_followup_pass": {
          "required_when": [
            "broad_or_open_ended_research",
            "comparative_or_evaluative_research",
            "multi_entity_or_multi_aspect_research",
            "initial_results_are_low_signal_or_off_topic",
            "named_entities_or_user_stated_aspects_are_missing_from_results"
          ],
          "query_source": "combine_user_request_with_discovery_terms_and_gap_signals",
          "minimum_followup_lanes": 3,
          "maximum_followup_lanes": 8,
          "lane_allocation": "cover_major_entities_user_stated_aspects_source_classes_time_windows_and_cross_comparison_before_repeating_broad_topic_queries"
        },
        "finish_rule": "synthesis may proceed only after coverage is sufficient or after bounded followup records explicit gap reasons for missing lanes"
      },
      "lane_types": [
        "overall_objective",
        "entity_or_candidate",
        "user_stated_aspect_or_criterion",
        "cross_comparison_or_source_diversity",
        "coverage_gap_recovery"
      ],
      "planning_rules": [
        "preserve the user's original research objective as the top-level query",
        "a single broad query may start discovery, but it is not enough to finish broad, comparative, current, evaluative, multi-entity, or multi-aspect research unless evidence sufficiency is already met",
        "after a weak discovery pass, use the observed snippets, off-topic terms, and missing buckets to submit targeted follow-up queries instead of asking the user to narrow",
        "when the prompt names multiple entities or candidates, allocate at least one retrieval lane to each major entity before synthesis",
        "when the prompt names aspects, criteria, risks, time windows, or source constraints, allocate retrieval lanes to those dimensions instead of using only generic topic searches",
        "when the prompt is open-ended, use discovery lanes for category, source class, and decision criteria before relying on prior-memory candidates",
        "do not drop a major entity, criterion, or requested scope without recording a coverage gap"
      ],
      "coverage_buckets": {
        "enabled": true,
        "bucket_kinds": [
          "entity",
          "aspect",
          "source_class",
          "time_window",
          "cross_comparison"
        ],
        "status_values": [
          "covered",
          "weak",
          "missing",
          "not_applicable"
        ],
        "record_fields": [
          "bucket_id",
          "bucket_kind",
          "requested_text",
          "query_refs",
          "evidence_count",
          "source_domain_count",
          "quality_flags",
          "gap_reason"
        ]
      },
      "non_goals": [
        "do_not_hardcode_domain_candidates",
        "do_not_force_user_visible_answer_format",
        "do_not_expand_queries_hidden_from_submitted_payload"
      ]
    },
    "semantic_query_planning": {
      "enabled": true,
      "source_pattern": "exa_semantic_search_guidance",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "authority": "agent_submitted_query_pack_visible_to_trace",
      "query_style": "describe_target_sources_pages_or_evidence_not_keywords_only",
      "diversity_axes": [
        "entity_or_candidate",
        "user_stated_aspect_or_criterion",
        "source_class",
        "time_window",
        "stance_or_failure_mode",
        "implementation_or_methodology",
        "cross_comparison"
      ],
      "anti_patterns": [
        "synonym_only_rewrites",
        "single_word_or_two_word_broad_queries",
        "boolean_operator_assumptions",
        "quoted_phrase_assumptions",
        "provider_specific_category_syntax_as_required_behavior"
      ],
      "sizing_policy": {
        "precise_named_entity": {
          "suggested_result_window": [
            5,
            8
          ]
        },
        "narrow_constrained_research": {
          "suggested_result_window": [
            8,
            12
          ]
        },
        "broad_discovery": {
          "suggested_result_window": [
            12,
            16
          ],
          "prefer_more_distinct_queries_over_one_large_query": true
        }
      },
      "record_fields": [
        "query_intent",
        "target_source_description",
        "diversity_axis",
        "expected_evidence_type",
        "coverage_bucket_ref",
        "provider_filter_hints"
      ],
      "non_goals": [
        "do_not_make_provider_specific_query_syntax_required",
        "do_not_force_subagent_or_parallel_agent_usage",
        "do_not_force_user_visible_output_format"
      ]
    },
    "page_extraction": {
      "enabled": true,
      "extract_mode": "markdown",
      "max_links_per_stage": 3,
      "max_total_fetches": 8,
      "min_link_score": 0.0,
      "trigger": "low_or_empty_candidates",
      "prefetch": {
        "enabled": true,
        "goal": "discover_and_rank_links_before_full_fetch",
        "mode": "fast_link_and_head_discovery_before_selected_full_fetch",
        "skip_heavy_processing_during_discovery": true,
        "max_prefetch_links": 24,
        "include_link_text": true,
        "include_parent_context": true,
        "artifact_contract": "html_links_metadata_only_until_selected_for_full_processing",
        "skip_outputs": [
          "cleaned_html",
          "markdown",
          "extracted_content",
          "screenshots",
          "pdf"
        ],
        "can_reprocess_raw_html_with_base_url": true,
        "link_normalization": {
          "resolve_relative_urls": true,
          "dedupe_canonical_urls": true,
          "ignore_schemes": [
            "javascript",
            "mailto",
            "tel",
            "file",
            "data"
          ],
          "ignore_anchor_only_links": true,
          "trim_href_whitespace": true,
          "preserve_query_strings": true,
          "preserve_fragments_unless_anchor_only": true,
          "preserve_https_for_internal_links_after_redirect": true,
          "reject_invalid_base_urls": true,
          "truncate_link_text_chars": 200,
          "record_internal_external_classification": true,
          "handle_protocol_relative_urls": true,
          "treat_subdomains_as_configurable_same_site": true,
          "return_empty_links_on_malformed_html": true
        }
      },
      "source_access": {
        "robots_policy": "respect_and_record",
        "robots_cache_ttl_seconds": 86400,
        "robots_failure_lane": "unknown_or_error_not_success",
        "record_access_fields": [
          "robots_status",
          "robots_allowed",
          "robots_error",
          "redirect_chain",
          "content_type",
          "document_type"
        ]
      },
      "document_extraction": {
        "enabled": true,
        "handled_types": [
          "html",
          "pdf",
          "text",
          "office_document",
          "spreadsheet",
          "presentation",
          "image",
          "xml"
        ],
        "pdf": {
          "extract_text": true,
          "extract_metadata": true,
          "extract_links": true,
          "extract_images_default": false,
          "page_batching": true,
          "scanned_pdf_without_ocr_quality_flag": "image_only_pdf"
        }
      },
      "head_preview": {
        "enabled": true,
        "max_candidates": 16,
        "timeout_ms": 5000,
        "fields": [
          "title",
          "description",
          "canonical",
          "lang",
          "jsonld",
          "open_graph",
          "jsonld_schema_types",
          "head_fingerprint",
          "status"
        ]
      },
      "candidate_selection": {
        "strategy": "score_then_fetch_best_available",
        "score_axes": [
          "query_relevance",
          "link_text_signal",
          "head_metadata_signal",
          "source_diversity",
          "freshness_when_relevant",
          "content_density",
          "low_junk_signal"
        ],
        "record_rejection_reasons": true,
        "score_report": {
          "record_threshold": true,
          "record_min_max_avg": true,
          "record_top_matched_terms": true,
          "normalize_scores": true,
          "deterministic_for_same_cached_inputs": true,
          "empty_query_returns_unscored_discovery": true
        }
      },
      "search_result_followup": {
        "enabled": true,
        "source_pattern": "exa_search_then_fetch",
        "provider_binding": "none_source_pattern_is_attribution_only",
        "fetch_when": [
          "highlights_are_thin_but_source_is_promising",
          "snippet_mentions_requested_value_without_value",
          "soft_filter_requires_body_context",
          "requested_fields_are_missing_from_snippet",
          "source_quality_or_claim_validation_is_needed"
        ],
        "do_not_fetch_when": [
          "snippet_is_sufficient_for_narrow_lookup",
          "result_is_off_topic",
          "source_is_duplicate",
          "source_access_policy_blocks_fetch"
        ],
        "batching": {
          "preferred_url_batch_min": 3,
          "preferred_url_batch_max": 8,
          "respect_max_total_fetches": true
        },
        "record_fields": [
          "followup_reason",
          "source_url",
          "snippet_signal",
          "missing_field",
          "fetch_status",
          "per_url_error"
        ]
      },
      "reader_page_conversion": {
        "enabled": true,
        "source_pattern": "jina_reader_search_plus_read",
        "provider_binding": "none_source_pattern_is_attribution_only",
        "authority": "cd_policy_declares_reader_artifacts_adapter_executes",
        "purpose": "turn promising search rows into processible page or document artifacts before synthesis when snippets are not enough",
        "convert_when": [
          "search_result_followup.fetch_when_matches",
          "broad_research_needs_body_evidence",
          "source_quality_or_claim_validation_requires_page_context",
          "search_rows_are_relevant_but_low_detail",
          "the_user_supplied_url_or_site_needs_content_not_just_structure"
        ],
        "skip_when": [
          "narrow_lookup_is_directly_supported_by_result_metadata",
          "candidate_is_duplicate_or_off_topic",
          "source_access_policy_or_budget_blocks_fetch"
        ],
        "representation_variants": [
          "content",
          "markdown",
          "text",
          "html_excerpt",
          "screenshot_ref",
          "page_image_ref",
          "links_summary",
          "images_summary",
          "heading_chunks"
        ],
        "readiness_controls": [
          "html_ready",
          "visible_content_ready",
          "mutation_idle",
          "resource_idle",
          "media_idle",
          "network_idle"
        ],
        "selector_controls": [
          "target_selector",
          "wait_for_selector",
          "remove_selector"
        ],
        "cache_admission": {
          "allow_cache_for_public_repeatable_reads": true,
          "disable_cache_when": [
            "cookies_or_private_state_present",
            "script_injection_or_viewport_override_present",
            "instructional_or_schema_transform_present",
            "explicit_no_cache_or_zero_tolerance",
            "intermediate_snapshot_without_final_readiness",
            "captcha_or_low_content_block_signal"
          ],
          "record_fields": [
            "cache_status",
            "cache_freshness_status",
            "cache_tolerance_ms",
            "cache_rejection_reason"
          ]
        },
        "link_and_image_retention": {
          "retain_links_modes": [
            "none",
            "text",
            "safe_refs",
            "all_metadata"
          ],
          "retain_images_modes": [
            "none",
            "alt_text",
            "safe_refs",
            "generated_alt_when_capability_available"
          ],
          "normalize_urls": true,
          "reject_non_fetchable_schemes": true
        },
        "chunking": {
          "heading_aware": true,
          "include_parent_headings_when_contextual": true,
          "respect_token_budget": true,
          "record_chunk_separator": true
        },
        "non_goals": [
          "do_not_route_to_a_specific_reader_provider",
          "do_not_make_browser_rendering_default_for_all_pages",
          "do_not_force_user_visible_answer_format",
          "do_not_hardcode_topic_or_domain_defaults"
        ]
      },
      "retrieval_profile_selection": {
        "enabled": true,
        "authority": "content_and_evidence_state_not_domain_routes",
        "match_axes": [
          "content_type",
          "document_type",
          "quality_flags",
          "evidence_gap",
          "explicit_user_constraints"
        ],
        "fallback_profile": "default_markdown_fetch",
        "first_match_wins": true,
        "record_selected_profile": true,
        "disallow_match_axes": [
          "hardcoded_domain_name",
          "golden_case_id",
          "example_prompt_phrase"
        ]
      },
      "dynamic_escalation": {
        "enabled": true,
        "default": "off",
        "allowed_when_quality_flags_include": [
          "needs_js",
          "needs_dynamic",
          "blocked_but_retryable"
        ],
        "requires_capability": "web_fetch.dynamic_page_allowed"
      },
      "session_reuse": {
        "default": "stateless",
        "allowed_when": [
          "sequential_dynamic_steps_required",
          "explicit_session_handle_supplied",
          "capability_policy_admits_session_state"
        ],
        "parallel_session_reuse_allowed": false,
        "close_or_expire_on_completion": true,
        "record_session_state": "handle_only"
      }
    },
    "structured_results": {
      "enabled": true,
      "max_rows_per_stage": 16,
      "deterministic_extraction_first": true,
      "strategy_ladder": [
        "schema_selector_when_repeating_structure_detected",
        "regex_entity_extraction_for_known_low-risk_patterns",
        "semantic_extraction_when_structure_is_inconsistent"
      ],
      "record_fields": [
        "strategy",
        "base_selector",
        "element_count",
        "schema_confidence",
        "field_count",
        "extracted_row_count",
        "fallback_reason"
      ],
      "schema_safety": {
        "sample_before_full_extract": true,
        "validate_parent_selector_not_singleton_when_list_expected": true,
        "retain_base_attributes": true,
        "support_nested_and_list_fields": true,
        "raw_schema_chat_visible": false
      }
    },
    "provider_result_envelope": {
      "enabled": true,
      "source_pattern": "exa_safe_provider_fields",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "raw_payload_chat_visible": false,
      "sensitive_keys_removed": [
        "requestTags",
        "authorization",
        "cookie",
        "set-cookie"
      ],
      "search_metadata_fields": [
        "request_id",
        "resolved_search_type",
        "auto_prompt",
        "auto_date",
        "query",
        "provider_answer_candidate",
        "follow_up_questions",
        "image_results",
        "image_descriptions",
        "search_time_ms",
        "cost_summary",
        "provider_statuses"
      ],
      "result_metadata_fields": [
        "provider_score",
        "provider_rank",
        "title",
        "url",
        "published_date",
        "author",
        "summary",
        "raw_content_available",
        "raw_content_excerpt",
        "favicon",
        "highlights",
        "highlight_scores",
        "entities",
        "links",
        "image_links",
        "subpages"
      ],
      "status_fields": [
        "id",
        "status",
        "source",
        "error_tag",
        "http_status_code"
      ],
      "grounding_fields": [
        "field",
        "confidence",
        "citation_url",
        "citation_title"
      ],
      "consumed_by": [
        "research_plane_policy.evidence_extraction.provider_result_envelope",
        "web_retrieval_v0.tool_cd.diagnostic_projection_contract.progressive_retrieval_contract.provider_result_envelope"
      ],
      "retention_policy": "metadata_and_evidence_excerpts_only_until_synthesized"
    },
    "advanced_search_controls": {
      "enabled": true,
      "source_pattern": "exa_advanced_search_surface",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "authority": "adapter_owned_optional_request_fields",
      "controls": [
        "source_class_or_category_hint",
        "search_depth_profile",
        "include_domains",
        "exclude_domains",
        "country_boost",
        "time_range",
        "start_published_date",
        "end_published_date",
        "start_crawl_date",
        "end_crawl_date",
        "exact_match",
        "include_images",
        "include_image_descriptions",
        "include_favicon",
        "include_raw_content",
        "extract_depth_profile",
        "extract_query_rerank",
        "output_content_format",
        "include_text",
        "exclude_text",
        "user_location",
        "moderation",
        "additional_queries",
        "text_max_characters",
        "context_max_characters",
        "summary_query",
        "highlights_query",
        "highlights_max_characters",
        "freshness_max_age",
        "live_fetch_preference",
        "live_fetch_timeout_ms",
        "subpage_limit",
        "subpage_target_terms"
      ],
      "use_when": [
        "user_explicitly_requests_source_scope",
        "time_window_or_freshness_is_part_of_task",
        "evidence_state_requires_more_body_context",
        "known_promising_result_needs_subpage_expansion",
        "retrieval_quality_needs_source_class_balance"
      ],
      "non_goals": [
        "do_not_make_provider_specific_category_syntax_required",
        "do_not_add_domain_specific_defaults",
        "do_not_hide_filters_from_query_contract"
      ]
    },
    "site_mapping_and_crawl_controls": {
      "enabled": true,
      "source_pattern": "tavily_map_crawl_capability_split",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "authority": "adapter_owned_optional_request_fields",
      "purpose": "support cheap site-structure discovery before selected content crawl or extraction",
      "controls": [
        "root_url",
        "max_depth",
        "max_breadth",
        "limit",
        "instructions",
        "select_paths",
        "select_domains",
        "allow_external",
        "extract_depth_profile",
        "output_content_format"
      ],
      "use_when": [
        "user_supplies_a_site_or_url_and_asks_for_coverage",
        "search_results_identify_a_promising_source_site_but_not_the_right_page",
        "evidence_state_needs_more_urls_from_the_same_source_before_fetch",
        "documentation_or_site_structure_is_the_retrieval_target"
      ],
      "artifact_fields": [
        "mapped_url_count",
        "crawled_page_count",
        "base_url",
        "selected_path_patterns",
        "selected_domain_patterns",
        "external_link_policy",
        "crawl_depth",
        "crawl_breadth",
        "crawl_limit",
        "crawl_instructions_ref"
      ],
      "non_goals": [
        "do_not_make_site_crawl_the_default_for_all_research",
        "do_not_select_by_hardcoded_domain",
        "do_not_hide_path_or_domain_filters_from_tool_metadata"
      ]
    },
    "provider_request_lifecycle": {
      "enabled": true,
      "source_pattern": "exa_mcp_auth_rate_error_lifecycle",
      "provider_binding": "none_source_pattern_is_attribution_only",
      "purpose": "classify provider and transport states before synthesis so retrieval failures do not look like empty successful evidence",
      "status_values": [
        "usable",
        "low_signal",
        "irrelevant",
        "empty_success",
        "partial_success",
        "bad_request_shape",
        "auth_required",
        "rate_limited",
        "transient_provider_failure",
        "permanent_provider_failure"
      ],
      "retry_policy": {
        "retry_transient_statuses": [
          500,
          502,
          503,
          504
        ],
        "do_not_retry_without_request_change": [
          "bad_request_shape",
          "auth_required",
          "permanent_provider_failure"
        ],
        "rate_limit_handling": "record_retry_after_and_budget_status_without_turning_it_into_final_chat"
      },
      "record_fields": [
        "request_status",
        "auth_state",
        "rate_limit_state",
        "retry_after",
        "provider_error_code",
        "provider_error_message_ref",
        "provider_docs_ref",
        "bad_request_shape_hint",
        "request_sanitized",
        "empty_value_fields_pruned",
        "default_parameters_applied",
        "partial_success_count",
        "partial_error_count"
      ],
      "feeds": [
        "tool_result_quality.status",
        "research_plane_policy.evidence_extraction.retrieval_status_classification",
        "web_retrieval_v0.tool_cd.diagnostic_projection_contract.progressive_retrieval_contract.provider_error_contract"
      ],
      "research_status_normalization": {
        "usable": "usable_evidence",
        "low_signal": "low_signal_evidence",
        "irrelevant": "irrelevant_evidence",
        "empty_success": "empty_success",
        "partial_success": "partial_success",
        "bad_request_shape": "bad_request_shape",
        "auth_required": "auth_or_permission_blocked",
        "rate_limited": "rate_limited",
        "transient_provider_failure": "transient_provider_failure",
        "permanent_provider_failure": "permanent_provider_failure"
      },
      "non_goals": [
        "do_not_expose_credentials_or_raw_provider_errors_to_chat",
        "do_not_treat_protocol_success_as_evidence_usefulness",
        "do_not_require_provider_specific_routes"
      ]
    },
    "adaptive_sufficiency": {
      "enabled": true,
      "authority": "policy_owned_retrieval_primitive",
      "min_evidence_items": 4,
      "min_source_domains": 3,
      "candidate_gain_threshold": 0.08,
      "stop_when": [
        "evidence_threshold_met",
        "source_diversity_threshold_met",
        "candidate_gain_below_threshold",
        "query_budget_exhausted",
        "tool_budget_exhausted"
      ],
      "diagnostics": [
        "candidate_count",
        "evidence_count",
        "source_domain_count",
        "quality_flags",
        "partial_failures",
        "query_plan_source",
        "candidate_rejection_reasons",
        "cache_status",
        "cache_freshness_status",
        "structured_artifact_counts",
        "chunk_relevance_scores",
        "coverage_bucket_count",
        "covered_bucket_count",
        "missing_coverage_buckets",
        "bucket_evidence_counts",
        "result_envelope_quality",
        "confidence_components",
        "previous_confidence",
        "confidence_delta",
        "score_distribution",
        "score_threshold",
        "query_diversity_axes",
        "provider_result_statuses",
        "highlight_coverage",
        "provider_answer_present",
        "follow_up_questions_count",
        "image_result_count",
        "map_candidate_count",
        "crawl_page_count",
        "exact_match_applied",
        "domain_filter_applied",
        "time_filter_applied",
        "subpage_candidate_count",
