{
  "version": "v1",
  "batch_query": {
    "enabled_sources": [
      "web"
    ],
    "allow_large": false,
    "max_parallel_subqueries": 3,
    "query_timeout_ms": 20000,
    "cache": {
      "mode": "enabled",
      "ttl_success_seconds": 1800,
      "ttl_no_results_seconds": 120,
      "max_entries": 240,
      "lifecycle": {
        "cleanup_bound": "state_cleanup_policy:local/state/batch_query",
        "validation_metadata": [
          "etag",
          "last_modified",
          "head_fingerprint",
          "source_timestamp"
        ],
        "freshness_check": "conditional_headers_or_head_fingerprint_when_available"
      }
    },
    "page_extraction": {
      "enabled": true,
      "extract_mode": "markdown",
      "max_links_per_stage": 3,
      "max_total_fetches": 8,
      "min_link_score": 0.0,
      "trigger": "low_or_empty_candidates",
      "prefetch": {
        "enabled": true,
        "goal": "discover_and_rank_links_before_full_fetch",
        "mode": "fast_link_and_head_discovery_before_selected_full_fetch",
        "skip_heavy_processing_during_discovery": true,
        "max_prefetch_links": 24,
        "include_link_text": true,
        "include_parent_context": true
      },
      "head_preview": {
        "enabled": true,
        "max_candidates": 16,
        "timeout_ms": 5000,
        "fields": [
          "title",
          "description",
          "canonical",
          "lang",
          "jsonld",
          "status"
        ]
      },
      "candidate_selection": {
        "strategy": "score_then_fetch_best_available",
        "score_axes": [
          "query_relevance",
          "link_text_signal",
          "head_metadata_signal",
          "source_diversity",
          "freshness_when_relevant",
          "content_density",
          "low_junk_signal"
        ],
        "record_rejection_reasons": true
      },
      "dynamic_escalation": {
        "enabled": true,
        "default": "off",
        "allowed_when_quality_flags_include": [
          "needs_js",
          "needs_dynamic",
          "blocked_but_retryable"
        ],
        "requires_capability": "web_fetch.dynamic_page_allowed"
      }
    },
    "structured_results": {
      "enabled": true,
      "max_rows_per_stage": 16
    },
    "adaptive_sufficiency": {
      "enabled": true,
      "authority": "policy_owned_retrieval_primitive",
      "min_evidence_items": 4,
      "min_source_domains": 3,
      "candidate_gain_threshold": 0.08,
      "stop_when": [
        "evidence_threshold_met",
        "source_diversity_threshold_met",
        "candidate_gain_below_threshold",
        "query_budget_exhausted",
        "tool_budget_exhausted"
      ],
      "diagnostics": [
        "candidate_count",
        "evidence_count",
        "source_domain_count",
        "quality_flags",
        "partial_failures",
        "query_plan_source",
        "candidate_rejection_reasons",
        "cache_status",
        "cache_freshness_status",
        "structured_artifact_counts",
        "chunk_relevance_scores",
        "result_envelope_quality"
      ]
    },
    "evidence_pack": {
      "enabled": true,
      "max_items": 6,
      "max_snippet_words": 72,
      "result_envelope": {
        "include_source_url": true,
        "include_final_url": true,
        "include_status_code": true,
        "include_redirect_status": true,
        "include_fetch_mode": true,
        "include_cache_status": true,
        "include_cache_freshness_status": true,
        "include_head_fingerprint": true,
        "include_quality_flags": true,
        "include_error_summary": true
      },
      "content_variants": [
        "source_excerpt",
        "fit_markdown",
        "markdown_with_citations",
        "references_markdown",
        "cleaned_content_excerpt"
      ],
      "chunking": {
        "enabled": true,
        "selection": "rank_query_relevant_chunks_with_adjacent_context",
        "metadata_fields": [
          "chunk_id",
          "source_url",
          "parent_artifact",
          "heading_path",
          "relevance_score",
          "token_estimate",
          "rejection_reason"
        ]
      },
      "structured_artifacts": {
        "enabled": true,
        "artifact_kinds": [
          "table_summary",
          "link_summary",
          "media_summary",
          "page_metadata_summary"
        ],
        "summaries_only": true,
        "raw_payload_chat_visible": false
      }
    },
    "quality_gate": {
      "enabled": true,
      "provider_recovery": {
        "enabled": true,
        "max_providers": 2,
        "providers": [
          "gdelt_doc"
        ],
        "current_intent_providers": [
          "gdelt_doc"
        ]
      }
    },
    "query_recovery": {
      "broad_current_research": {
        "enabled": true,
        "max_queries": 10,
        "intent_markers": [
          "breakthrough",
          "breakthroughs",
          "changes",
          "current state",
          "developments",
          "landscape",
          "milestone",
          "milestones",
          "news",
          "overview",
          "state of",
          "trend",
          "trends"
        ],
        "templates": [
          "{query}",
          "{query} primary evidence",
          "{query} primary sources",
          "{query} official sources",
          "{query} recent publications",
          "{query} institution announcements",
          "{query} research publications",
          "{query} official announcements",
          "{query} technical reports",
          "{query} datasets",
          "{query} methodology evidence",
          "{query} peer reviewed evidence",
          "{query} source list"
        ]
      },
      "general_research": {
        "enabled": true,
        "max_queries": 10,
        "intent_markers": [
          "assess",
          "avoid",
          "benchmark",
          "best ",
          "choose",
          "compare",
          "comparison",
          "current state",
          "ecosystem",
          "evaluate",
          "evaluation",
          "fit ",
          "landscape",
          "limitation",
          "limitations",
          "mature",
          "maturity",
          "production",
          "recommend",
          "recommendation",
          "reliability",
          "risk",
          "risks",
          "security",
          "strength",
          "strengths",
          "versus",
          " vs ",
          "weakness",
          "weaknesses",
          "which "
        ],
        "templates": [
          "{query}",
          "{query} primary source evidence",
          "{query} official documentation project sources",
          "{query} independent analysis comparison evidence",
          "{query} risks limitations security reliability evidence",
          "{query} production usage examples case studies",
          "{query} methodology evidence",
          "{query} technical report",
          "{query} source diversity evidence",
          "{query} changelog release notes",
          "{query} repository issues adoption evidence",
          "{query} benchmark methodology evidence",
          "{query} security advisory evidence"
        ]
      }
    }
  }
}
