{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://protheuslabs.github.io/schemas/finding-v1.json",
  "title": "FindingV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "item_id",
    "severity",
    "status",
    "location",
    "evidence",
    "timestamp"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "confirmed",
        "resolved",
        "dismissed",
        "needs-review"
      ]
    },
    "location": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string"
          }
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
