#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

resolve_ops_binary() {
  if [[ -n "${INFRING_NPM_BINARY:-}" && -f "${INFRING_NPM_BINARY}" ]]; then
    printf '%s\n' "${INFRING_NPM_BINARY}"
    return 0
  fi

  local vendor="$ROOT/client/cli/npm/vendor/infring-ops"
  local debug_bin="$ROOT/target/debug/infring-ops"
  local release_bin="$ROOT/target/release/infring-ops"

  if [[ -f "$vendor" ]]; then
    printf '%s\n' "$vendor"
    return 0
  fi
  if [[ -f "$debug_bin" ]]; then
    printf '%s\n' "$debug_bin"
    return 0
  fi
  if [[ -f "$release_bin" ]]; then
    printf '%s\n' "$release_bin"
    return 0
  fi
  return 1
}

if BIN="$(resolve_ops_binary)"; then
  exec "$BIN" infringctl "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$ROOT/core/layer0/ops/Cargo.toml" --bin infring-ops -- infringctl "$@"
fi

echo "infring launcher failed: missing core ops binary and cargo." >&2
echo "Install Rust/Cargo or set INFRING_NPM_BINARY." >&2
exit 1
