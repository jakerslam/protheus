#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

if [[ -x "$ROOT/target/release/infringd" ]]; then
  exec "$ROOT/target/release/infringd" "$@"
fi

if [[ -x "$ROOT/target/debug/infringd" ]]; then
  exec "$ROOT/target/debug/infringd" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$ROOT/core/layer0/ops/Cargo.toml" --bin infringd -- "$@"
fi

echo "infringd launcher failed: missing daemon binary and cargo." >&2
echo "Build with cargo or install Rust/Cargo." >&2
exit 1
