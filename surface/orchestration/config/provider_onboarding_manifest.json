      "model_id": "openai/gpt-5.2",
      "provider_key": "openai",
      "tiers": [2, 3],
      "roles": ["planning", "logic", "coding", "general"],
      "class": "cloud_specialist",
      "spawn_allowed": true,
      "budget": {
        "daily_token_cap": 24000,
        "request_token_cap": 3200
