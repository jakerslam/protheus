      "guard": {
        "max_risk": "high",
        "require_second_opinion_for_high_risk": true
      },
      "secret": {
        "secret_id": "openai_api_key",
        "env_var": "OPENAI_API_KEY"
      },
      "trainability": {
        "allow": false,
        "note": "Third-party terms review required."
      }
    },
    "frontier_provider_claude_cloud": {
      "enabled": false,
      "model_id": "frontier_provider/claude-3.7-sonnet",
      "provider_key": "frontier_provider",
      "tiers": [2, 3],
      "roles": ["planning", "logic", "general"],
      "class": "cloud_specialist",
      "spawn_allowed": true,
      "budget": {
        "daily_token_cap": 22000,
        "request_token_cap": 2800
      },
      "guard": {
        "max_risk": "high",
        "require_second_opinion_for_high_risk": true
      },
      "secret": {
        "secret_id": "frontier_provider_api_key",
        "env_var": "FRONTIER_PROVIDER_API_KEY"
      },
      "trainability": {
        "allow": false,
        "note": "Third-party terms review required."
