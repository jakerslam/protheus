{
  "type": "assurance_governance_registry",
  "schema_version": 1,
  "owner": "validation/governance",
  "status": "physical_domain_owner",
  "updated_at": "2026-04-30",
  "policy_refs": [
    "docs/workspace/assurance_plane_policy.md",
    "docs/workspace/assurance_evidence_envelope_contract.md",
    "validation/conformance/contracts/assurance_validation_registry.json",
    "observability/source_coverage/assurance_observability_registry.json",
    "validation/release_gates/config/release_gates.yaml",
    "validation/evals/config/eval_quality_thresholds.json"
  ],
  "governance_policy": {
    "allowed_verdicts": [
      "allow",
      "block",
      "warn",
      "needs_more_evidence",
      "issue_candidate_ready",
      "retirement_candidate_ready"
    ],
    "allowed_input_domains": [
      "validation",
      "observability",
      "governance"
    ],
    "scorecards_are_derived": true,
    "scorecards_must_reference_evidence": true,
    "no_direct_mutation": true,
    "promotion_requires": [
      "recurrence",
      "corroboration",
      "explicit_policy_rule"
    ],
    "issue_candidates_require": [
      "stable_fingerprint",
      "evidence_refs",
      "dedupe_key",
      "safe_to_auto_apply_patch_false",
      "human_review_required_true"
    ]
  },
  "verdict_inputs": [
    {
      "id": "input.validation_release_gates",
      "domain": "validation",
      "source_refs": [
        "validation/conformance/contracts/assurance_validation_registry.json",
        "validation/release_gates/config/release_gates.yaml",
        "ops:release:proof-pack",
        "ops:release:verdict"
      ],
      "accepted_signal_classes": [
        "hard_gate",
        "advisory",
        "diagnostic"
      ],
      "required_evidence_refs": true
    },
    {
      "id": "input.observability_required_sources",
      "domain": "observability",
      "source_refs": [
        "observability/source_coverage/assurance_observability_registry.json",
        "local/state/kernel_sentinel/evidence/*.jsonl"
      ],
      "accepted_signal_classes": [
        "hard_gate",
        "advisory",
        "diagnostic"
      ],
      "required_evidence_refs": true
    },
    {
      "id": "input.sentinel_self_study_outputs",
      "domain": "observability",
      "source_refs": [
        "local/state/kernel_sentinel/feedback_inbox.jsonl",
        "local/state/kernel_sentinel/top_system_holes_current.json",
        "local/state/kernel_sentinel/rsi_readiness_summary_current.json"
      ],
      "accepted_signal_classes": [
        "advisory",
        "diagnostic"
      ],
      "required_evidence_refs": true,
      "notes": "Self-study outputs inform issue candidates and readiness; they do not recursively become primary evidence."
    },
    {
      "id": "input.eval_quality_thresholds",
      "domain": "validation",
      "source_refs": [
        "validation/evals/config/eval_quality_thresholds.json",
        "ops:eval:quality:gate:v1",
        "ops:eval:regression:guard"
      ],
      "accepted_signal_classes": [
        "hard_gate",
        "advisory"
      ],
      "required_evidence_refs": true
    }
  ],
  "verdict_outputs": [
    {
      "id": "output.release_verdict",
      "output_kind": "release_gate",
      "artifact_paths": [
        "core/local/artifacts/release_verdict_current.json",
        "core/local/artifacts/kernel_sentinel_auto_run_current.json"
      ],
      "allowed_verdicts": [
        "allow",
        "block",
        "warn",
        "needs_more_evidence"
      ],
      "must_reference_evidence": true,
      "may_block_release": true,
      "may_apply_patch": false
    },
    {
      "id": "output.release_scorecard",
      "output_kind": "scorecard",
      "artifact_paths": [
        "client/runtime/local/state/release/scorecard/release_scorecard.json"
      ],
      "allowed_verdicts": [
        "allow",
        "block",
        "warn",
        "needs_more_evidence"
      ],
      "must_reference_evidence": true,
      "may_block_release": false,
      "may_apply_patch": false
    },
    {
      "id": "output.issue_candidate",
      "output_kind": "issue_candidate",
      "artifact_paths": [
        "local/state/kernel_sentinel/issues.jsonl",
        "local/state/kernel_sentinel/top_system_holes_current.json"
      ],
      "allowed_verdicts": [
        "issue_candidate_ready",
        "needs_more_evidence"
      ],
      "must_reference_evidence": true,
      "may_block_release": false,
      "may_apply_patch": false
    },
    {
      "id": "output.retirement_candidate",
      "output_kind": "retirement_candidate",
      "artifact_paths": [
        "local/state/kernel_sentinel/suggestions.jsonl",
        "core/local/artifacts/test_maturity_registry_guard_current.json"
      ],
      "allowed_verdicts": [
        "retirement_candidate_ready",
        "needs_more_evidence"
      ],
      "must_reference_evidence": true,
      "may_block_release": false,
      "may_apply_patch": false
    }
  ],
  "scorecard_derivation_rules": [
    {
      "id": "scorecard.rows_reference_evidence",
      "description": "Every scorecard row must reference at least one source evidence artifact or Assurance envelope projection.",
      "required": true
    },
    {
      "id": "scorecard.no_manual_truth",
      "description": "Scorecards summarize evidence and may not introduce manually curated pass/fail truth absent source artifacts.",
      "required": true
    },
    {
      "id": "scorecard.domain_breakdown_required",
      "description": "Scorecards should group or tag inputs by Validation, Observability, and Governance source domain.",
      "required": true
    },
    {
      "id": "scorecard.stale_or_missing_evidence_visible",
      "description": "Scorecards must surface stale, missing, malformed, or partial evidence as diagnostic rows instead of hiding them.",
      "required": true
    }
  ],
  "promotion_rules": [
    {
      "id": "promotion.deterministic_failure_to_hard_gate",
      "from_signal_class": "advisory",
      "to_signal_class": "hard_gate",
      "allowed_when": [
        "corroborated_by_deterministic_kernel_authority",
        "explicit_release_policy_rule"
      ],
      "minimum_occurrences": 1,
      "notes": "A deterministic authority failure can block immediately when policy says it is release-critical."
    },
    {
      "id": "promotion.advisory_eval_recurrence",
      "from_signal_class": "advisory",
      "to_signal_class": "hard_gate",
      "allowed_when": [
        "same_fingerprint_recurs",
        "eval_regression_threshold_crossed",
        "human_review_or_policy_marks_release_relevant"
      ],
      "minimum_occurrences": 3,
      "minimum_distinct_runs": 2,
      "notes": "Eval observations do not block by themselves; recurrence plus threshold/policy can promote through Governance."
    },
    {
      "id": "promotion.shell_context_corroborated",
      "from_signal_class": "advisory",
      "to_signal_class": "hard_gate",
      "allowed_when": [
        "presentation_telemetry_only_is_corroborated",
        "matching_deterministic_or_advisory_evidence_exists",
        "governance_policy_allows_promotion"
      ],
      "minimum_occurrences": 2,
      "notes": "Shell telemetry is symptom context only; it can strengthen a case but not create hard truth alone."
    },
    {
      "id": "promotion.diagnostic_to_advisory_or_hard_gate",
      "from_signal_class": "diagnostic",
      "to_signal_class": "advisory",
      "allowed_when": [
        "diagnostic_probe_produces_evidence",
        "evidence_is_not_malformed"
      ],
      "minimum_occurrences": 1,
      "notes": "Diagnostics gather evidence; follow-up classification depends on what the probe finds."
    }
  ],
  "issue_candidate_routing": {
    "minimum_occurrences": 2,
    "minimum_distinct_sources": 1,
    "dedupe_key_fields": [
      "fingerprint",
      "root_frame",
      "violated_invariants",
      "source_kind"
    ],
    "required_flags": {
      "safe_to_auto_file_issue": true,
      "safe_to_auto_apply_patch": false,
      "human_review_required": true,
      "autonomous_mitigation_allowed": false
    },
    "routes": [
      {
        "id": "route.deterministic_release_blocker",
        "input_signal_class": "hard_gate",
        "output": "issue_candidate_ready",
        "priority": 1
      },
      {
        "id": "route.repeated_architectural_incident",
        "input_signal_class": "advisory",
        "output": "issue_candidate_ready",
        "priority": 2,
        "requires": [
          "same_root_frame",
          "same_violated_invariants"
        ]
      },
      {
        "id": "route.more_data_needed",
        "input_signal_class": "diagnostic",
        "output": "needs_more_evidence",
        "priority": 3
      }
    ]
  }
}
