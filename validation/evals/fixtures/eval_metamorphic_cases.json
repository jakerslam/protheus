      "variants": [
        {
          "id": "frustrated-followup-short",
          "prompt_suffix": "Just talk to me.",
          "perturbation_family": "frustrated_followup",
          "predicted": {
            "route": "orchestration",
            "workflow": "recovery_followup",
            "tool_family": "orchestration",
            "final_answer_class": "recovery_explanation"
          }
        },
        {
          "id": "frustrated-followup-tool-order",
          "prompt_suffix": "The tool list order changed, but no new tool should be required.",
          "perturbation_family": "ordering",
          "predicted": {
            "route": "orchestration",
            "workflow": "recovery_followup",
            "tool_family": "orchestration",
