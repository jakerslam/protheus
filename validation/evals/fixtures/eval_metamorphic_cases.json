          }
        },
        {
          "id": "empty-result-missing-search-capability",
          "prompt_suffix": "workspace_search is unavailable but workspace_read exists.",
          "perturbation_family": "missing_capability",
          "predicted": {
            "route": "workspace",
            "workflow": "empty_result_recovery",
            "tool_family": "workspace",
            "final_answer_class": "empty_result_with_next_step",
            "missing_capability_unhandled": false
          }
        }
      ]
    },
    {
      "id": "frustrated-followup",
      "base_prompt": "You gave the wrong tool answer earlier; answer normally and explain what changed.",
      "expected": {
        "route": "orchestration",
        "workflow": "recovery_followup",
        "tool_family": "orchestration",
        "final_answer_class": "recovery_explanation"
