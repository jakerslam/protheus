  "gateway_only_invariant": {
    "shell_plug_to_gateway_only": true,
    "no_shell_plug_to_kernel_direct": true,
    "no_shell_plug_to_orchestration_direct": true,
    "no_shell_plug_to_assurance_direct": true,
    "no_stateful_shell_socket_runtime": true,
    "gateway_remains_external_ambiguity_firewall": true
  },
  "allowed_route_classes": [
    "request_ingress",
    "event_output_egress",
    "health_status",
    "detail_fetch",
    "bounded_search_query"
  ],
  "prohibited_route_shapes": [
    "full_state",
    "all_state",
    "mirror_state",
    "raw_runtime_state",
    "request_plus_full_result",
    "health_plus_state_dump",
    "search_plus_raw_payloads",
    "event_plus_trace_body"
  ],
  "forbidden_default_payload_fields_policy": {
    "inherits": "shell/socket/contract/shell_socket_contract.json#/forbidden_default_payload_fields",
    "enforced_on_every_default_route": true,
    "detail_routes_must_remain_bounded": true
  },
  "required_gateway_enforcement": [
    "authentication",
    "authorization",
    "payload_limits",
    "projection_shaping",
    "rate_limits",
    "capability_checks",
    "mutation_approval_checks",
    "audit_receipts",
    "route_policy",
    "shell_isolation",
    "lazy_detail_access",
    "issue_eval_submission_controls"
  ],
