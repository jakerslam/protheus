{
  "type": "gateway_adapter_invariants_policy",
  "schema_version": 1,
  "owner_domain": "validation.conformance",
  "scope": "adapters/runtime/**",
  "invariants": [
    "gateway_start_is_idempotent_when_already_running",
    "gateway_status_is_non_mutating",
    "gateway_default_payloads_are_bounded",
    "gateway_detail_fetches_are_ref_based",
    "gateway_shutdown_timers_are_bounded",
    "gateway_external_surface_does_not_mirror_raw_runtime_state"
  ],
  "max_shutdown_wait_ms": 120000,
  "policy": {
    "shell_independent": true,
    "no_shell_mutation_required": true
  }
}
