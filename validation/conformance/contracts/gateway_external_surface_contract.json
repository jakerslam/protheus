{
  "type": "gateway_external_surface_contract",
  "schema_version": 1,
  "owner": "assurance.validation",
  "status": "enforced",
  "updated_at": "2026-05-01",
  "policy_refs": [
    "docs/workspace/gateway_ingress_egress_policy.md",
    "docs/workspace/interface_payload_budget_policy.md",
    "docs/workspace/nexus_conduit_checkpoint_policy.md",
    "docs/workspace/conduit_scrambler_posture_policy.md",
    "docs/workspace/shell_ui_projection_policy.md",
    "docs/workspace/shell_ui_message_detail_contract.md"
  ],
  "policy_doc_required_tokens": [
    "The Gateway is the external ambiguity firewall.",
    "Issue-reporting and eval-submission routes are request ingress routes with additional controls.",
    "External surfaces have no first-party Shell exception"
  ],
  "required_route_classes": [
    "request_ingress",
    "event_output_egress",
    "health_status",
    "detail_fetch",
    "bounded_search_query"
  ],
  "global_rules": {
    "gateway_only_external_ingress": true,
    "no_first_party_shell_exception": true,
    "issue_eval_submission_gateway_only": true,
    "bounded_default_payloads": true,
    "nexus_checkpoint_required": true,
    "no_direct_kernel_or_orchestration_external_surface": true,
    "detail_payloads_lazy_by_ref": true
  },
  "required_forbidden_bypass_patterns": [
    "direct_kernel_or_core_authority_call",
    "direct_orchestration_internal_import",
    "first_party_shell_exception",
    "raw_runtime_state_upload",
    "full_state_mirror"
  ],
  "evidence_gates": [
    {
      "id": "ops:gateway:interface:guard",
      "required_package_script": true,
      "required_tooling_registry": false,
      "proves": [
        "route classes",
        "Gateway enforcement responsibilities",
        "forbidden full-state route shapes"
      ]
    },
    {
      "id": "ops:interface:payload-budget:guard",
      "required_package_script": true,
      "required_tooling_registry": false,
