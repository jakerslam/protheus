  "rules": [
    "tests/tooling/scripts may execute checks but must not own behavioral truth.",
    "tests/tooling/config/tooling_gate_registry.json and verify_profiles.json are harness plumbing only.",
    "Definition-shaped files under tests/tooling must either be moved to a canonical Assurance domain or declared as time-bounded transition debt.",
    "Expired or malformed transition debt fails closed."
  ]
}
