    },
    {
      "path": "tests/tooling/config/trusted_core_manifest.json",
      "target_domain": "governance",
      "target_prefix": "governance/contracts/",
      "owner": "assurance.governance",
      "expires": "2026-05-21",
      "reason": "Trusted Kernel/Core manifest is governance/security truth."
    }
