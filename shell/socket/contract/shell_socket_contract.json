{
  "type": "shell_socket_contract",
  "schema_version": 1,
  "version": "2026-05-02",
  "owner": "shell.presentation_contract",
  "status": "contracted",
  "policy_refs": [
    "docs/workspace/shell_ui_projection_policy.md",
    "docs/workspace/shell_independent_operation_policy.md",
    "docs/workspace/gateway_ingress_egress_policy.md",
    "docs/workspace/interface_payload_budget_policy.md",
    "docs/workspace/nexus_conduit_checkpoint_policy.md",
    "docs/workspace/conduit_scrambler_posture_policy.md",
    "docs/workspace/shell_socket_parallel_execution_plan.md"
  ],
  "gateway_mapping_contract": "validation/conformance/contracts/shell_socket_gateway_contract.json",
  "axioms": {
    "socket_is_contract_not_runtime": true,
    "socket_owns_no_authority": true,
    "socket_owns_no_canonical_state": true,
    "shell_plugs_call_gateway_only": true,
    "default_payloads_are_projections": true,
    "heavy_payloads_are_lazy_detail_refs": true,
    "legacy_dashboard_is_not_canonical_socket": true
  },
  "allowed_shell_plug_state": [
    "layout",
    "theme",
    "input_buffer",
    "focus_state",
    "hover_state",
    "selection_state",
    "expanded_ids",
    "scroll_position",
    "visible_window_rows",
    "cursors",
    "detail_refs",
    "small_preview_cache"
  ],
  "forbidden_shell_plug_state": [
    "canonical_truth",
    "workflow_truth",
    "planner_truth",
    "policy_truth",
    "authorization_truth",
    "gateway_policy",
    "kernel_state",
    "raw_tool_outputs",
    "raw_traces",
    "full_plan_graphs",
    "eval_payloads",
    "full_conversation_trees",
    "unbounded_runtime_mirrors"
  ],
  "forbidden_default_payload_fields": [
    "raw",
    "root",
    "full_state",
    "all_state",
    "mirror_state",
    "all_messages",
    "conversation_tree",
    "raw_payload",
    "raw_runtime_state",
    "tool_input",
    "tool_result",
    "tool_result_body",
    "raw_tool_result",
    "trace_body",
    "decision_trace",
    "plan_graph",
    "workflow_graph",
    "execution_observation",
    "runtime_quality",
    "eval_payload",
    "artifact_body",
    "file_output",
    "folder_tree",
    "policy_decision",
    "authorization_state"
  ],
  "default_payload_budget": {
    "inherits": "validation/conformance/contracts/interface_payload_budget_contract.json#/global_default_payload_budget",
    "max_response_bytes": 65536,
    "max_array_items": 100,
    "max_object_depth": 4,
    "max_string_chars": 12000,
    "max_nested_collection_items": 20,
    "max_top_level_fields": 32
  },
  "projection_types": [
    {
      "name": "RuntimeStatusProjection",
      "description": "Bounded readiness/status truth from the owning runtime surfaces.",
      "allowed_top_level_fields": [
        "state",
        "label",
        "source",
        "source_sequence",
        "age_seconds",
        "stale",
        "degraded_reason",
        "next_retry_hint",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": false
    },
    {
      "name": "AgentRosterProjection",
      "description": "Windowed agent roster for shell navigation.",
      "allowed_top_level_fields": [
        "agents",
        "agent_ids",
        "active_agent_id",
        "labels",
        "status_counts",
        "last_activity_preview",
        "next_cursor",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 32768,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "SessionListProjection",
      "description": "Windowed session list for a selected agent or operator scope.",
      "allowed_top_level_fields": [
        "sessions",
        "session_ids",
        "active_session_id",
        "last_message_previews",
        "message_counts",
        "next_cursor",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 32768,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "MessageWindowProjection",
      "description": "Bounded chat/message window; not a full conversation mirror.",
      "allowed_top_level_fields": [
        "ok",
        "agent_id",
        "session_id",
        "active_session_id",
        "message_window",
        "message_count",
        "total_count",
        "has_more",
        "before_cursor",
        "after_cursor",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 65536,
      "max_array_items": 80,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "MessageDetailProjection",
      "description": "Capability-scoped detail expansion for one referenced message, tool, trace, artifact, or workflow detail.",
      "allowed_top_level_fields": [
        "detail_id",
        "detail_kind",
        "requested_view",
        "detail_projection",
        "size_bound",
        "next_cursor",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 65536,
      "requires_cursor": false,
      "requires_detail_refs": false
    },
    {
      "name": "ShellEventProjection",
      "description": "Bounded event stream projection for display/update only.",
      "allowed_top_level_fields": [
        "event_id",
        "event_kind",
        "agent_id",
        "session_id",
        "display_projection",
        "status_label",
        "cursor_refs",
        "detail_refs",
        "receipt_refs",
        "correlation_id"
      ],
      "max_response_bytes": 32768,
      "max_array_items": 40,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "SubmitMessageResultProjection",
      "description": "Bounded assistant result projection for browser-style HTTP fallback rendering; raw execution state and full tool payloads remain outside shell plugs.",
      "allowed_top_level_fields": [
        "ok",
        "response",
        "content",
        "input_tokens",
        "output_tokens",
        "cost_usd",
        "iterations",
        "agent_id",
        "agent_name",
        "auto_route",
        "route",
        "context_tokens",
        "context_used_tokens",
        "context_total_tokens",
        "context_window",
        "context_window_tokens",
        "context_ratio",
        "context_pressure",
        "context_pool",
        "tools",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 65536,
      "max_array_items": 16,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "BoundedSearchResults",
      "description": "Bounded search hits over indexed projections, not raw payload mirrors.",
      "allowed_top_level_fields": [
        "query_id",
        "hits",
        "hit_ids",
        "snippets",
        "labels",
        "counts",
        "next_cursor",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 32768,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "ModelCatalogProjection",
      "description": "Bounded model catalog rows for shell display and selection; provider secrets and routing truth remain authority-owned.",
      "allowed_top_level_fields": [
        "ok",
        "models",
        "model_ids",
        "providers",
        "counts",
        "next_cursor",
        "detail_refs",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 65536,
      "max_array_items": 100,
      "requires_cursor": true,
      "requires_detail_refs": true
    },
    {
      "name": "ModelDiscoveryProjection",
      "description": "Bounded model discovery summary for shell display; secrets and raw provider responses are never returned.",
      "allowed_top_level_fields": [
        "ok",
        "provider",
        "input_kind",
        "provider_count",
        "probed",
        "model_count",
        "available_model_count",
        "models",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 32768,
      "max_array_items": 100,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "ModelDownloadProjection",
      "description": "Bounded model download acknowledgement for shell display; download authority and raw provider output remain outside the shell.",
      "allowed_top_level_fields": [
        "ok",
        "method",
        "download_path",
        "provider",
        "model",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "ProviderMutationProjection",
      "description": "Bounded provider configuration/test acknowledgement for shell display; secrets and raw provider probe bodies remain outside the shell.",
      "allowed_top_level_fields": [
        "ok",
        "status",
        "provider",
        "auth_status",
        "switched_default",
        "message",
        "reachable",
        "latency_ms",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "ProviderOAuthProjection",
      "description": "Bounded provider OAuth device-flow status for shell display; access tokens and raw provider responses remain outside the shell.",
      "allowed_top_level_fields": [
        "ok",
        "provider",
        "status",
        "poll_id",
        "user_code",
        "verification_uri",
        "interval",
        "expires_in",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "ConfigMutationProjection",
      "description": "Bounded configuration mutation acknowledgement for shell display; canonical settings truth remains outside shell plugs.",
      "allowed_top_level_fields": [
        "ok",
        "path",
        "value",
        "provider",
        "auth_status",
        "switched_default",
        "message",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "AgentMutationProjection",
      "description": "Bounded acknowledgement for agent config/mode/tool-filter mutations; canonical agent state remains outside shell plugs.",
      "allowed_top_level_fields": [
        "ok",
        "agent_id",
        "mode",
        "provider",
        "model",
        "runtime_model",
        "rename_notice",
        "tool_filters",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 16384,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "AgentLifecycleProjection",
      "description": "Bounded acknowledgement for agent lifecycle ingress; shell plugs receive ids/receipts, not full agent profiles or contracts.",
      "allowed_top_level_fields": [
        "ok",
        "id",
        "agent_id",
        "name",
        "role",
        "state",
        "type",
        "archived",
        "reason",
        "removed_history_entries",
        "deleted_archived_agents",
        "error",
        "receipt_ref",
        "correlation_id"
      ],
      "max_response_bytes": 16384,
      "requires_cursor": false,
      "requires_detail_refs": true
    },
    {
      "name": "IngressAck",
      "description": "Bounded acknowledgement or receipt for a shell-submitted request.",
      "allowed_top_level_fields": [
        "accepted",
        "rejected",
        "reason_code",
        "receipt_ref",
        "follow_up_ref",
        "correlation_id"
      ],
      "max_response_bytes": 8192,
      "requires_cursor": false,
      "requires_detail_refs": true
    }
  ],
  "capabilities": [
