{
  "type": "assurance_observability_registry",
  "schema_version": 1,
  "owner": "kernel/assurance/observability",
  "status": "initial_seed",
  "updated_at": "2026-04-30",
  "policy_refs": [
    "docs/workspace/assurance_plane_policy.md",
    "docs/workspace/assurance_evidence_envelope_contract.md",
    "docs/workspace/kernel_sentinel_evidence_source_map.md",
    "docs/workspace/kernel_sentinel_evidence_schema_contracts.md"
  ],
  "source_class_policy": {
    "allowed_source_classes": [
      "kernel_receipt_stream",
      "runtime_observation_stream",
      "state_mutation_stream",
      "scheduler_admission_stream",
      "recovery_stream",
      "boundedness_stream",
      "release_proof_stream",
      "gateway_boundary_stream",
      "queue_pressure_stream",
      "advisory_eval_stream",
      "presentation_telemetry_stream",
      "sentinel_self_study_output"
    ],
    "required_fields": [
      "id",
      "domain",
      "source_class",
      "authority_class",
      "default_signal_class",
      "owner_of_truth",
      "source_refs",
      "evidence_streams",
      "freshness_required",
      "coverage_required",
      "can_open_finding",
      "can_block_release"
    ],
    "shell_telemetry_rule": "presentation_telemetry_stream entries cannot open findings or block release unless corroborated by deterministic_kernel_authority or advisory_workflow_quality evidence through Governance policy.",
    "sentinel_role_rule": "Kernel Sentinel is a privileged Observability resident that normalizes, synthesizes, and reports evidence, but it is not the entire Validation system and must not recursively treat its own self-study outputs as primary evidence."
  },
  "freshness_policy": {
    "default_stale_after_seconds": 5400,
    "release_stale_after_seconds": 1800,
    "missing_freshness_signal_class": "diagnostic",
    "stale_required_source_signal_class": "hard_gate",
    "stale_optional_source_signal_class": "advisory"
  },
  "entries": [
