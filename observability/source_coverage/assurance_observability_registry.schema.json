{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infring.local/schemas/assurance_observability_registry.schema.json",
  "title": "Assurance Observability Registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "schema_version", "owner", "source_class_policy", "freshness_policy", "entries"],
  "properties": {
    "type": { "const": "assurance_observability_registry" },
    "schema_version": { "type": "integer", "const": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "source_class_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["allowed_source_classes", "required_fields", "shell_telemetry_rule", "sentinel_role_rule"]
    },
    "freshness_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["default_stale_after_seconds", "release_stale_after_seconds", "missing_freshness_signal_class"]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "domain",
          "source_class",
          "authority_class",
          "default_signal_class",
          "owner_of_truth",
          "source_refs",
          "evidence_streams",
          "freshness_required",
          "coverage_required",
          "can_open_finding",
          "can_block_release"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "domain": { "const": "observability" },
          "source_class": {
            "type": "string",
            "enum": [
              "kernel_receipt_stream",
              "runtime_observation_stream",
              "state_mutation_stream",
              "scheduler_admission_stream",
              "recovery_stream",
              "boundedness_stream",
              "release_proof_stream",
              "gateway_boundary_stream",
              "queue_pressure_stream",
              "advisory_eval_stream",
              "presentation_telemetry_stream",
              "sentinel_self_study_output"
            ]
          },
          "authority_class": {
            "type": "string",
            "enum": ["deterministic_kernel_authority", "advisory_workflow_quality", "presentation_telemetry_only"]
          },
          "default_signal_class": {
            "type": "string",
            "enum": ["hard_gate", "advisory", "diagnostic"]
          },
          "owner_of_truth": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_streams": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "freshness_required": { "type": "boolean" },
          "coverage_required": { "type": "boolean" },
          "can_open_finding": { "type": "boolean" },
          "can_block_release": { "type": "boolean" },
          "corroboration_required_for_finding": { "type": "boolean" },
          "recursive_primary_input_allowed": { "type": "boolean" }
        }
      }
    }
  }
}
