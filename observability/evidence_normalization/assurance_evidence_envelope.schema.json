{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infring.local/schemas/assurance_evidence_envelope.schema.json",
  "title": "Assurance Evidence Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "schema_version",
    "generated_at",
    "domain",
    "source",
    "source_kind",
    "authority_class",
    "signal_class",
    "subject",
    "status",
    "evidence",
    "freshness"
  ],
  "properties": {
    "type": { "const": "assurance_evidence" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "domain": {
      "type": "string",
      "enum": ["validation", "observability", "governance"]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "sentinel_stream",
        "eval_output",
        "proof_pack",
        "release_gate",
        "scorecard",
        "benchmark",
        "conformance_guard",
        "regression_suite",
        "telemetry",
        "health",
        "trace",
        "runtime_finding",
        "readiness_verdict"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "deterministic_kernel_authority",
        "controlled_validation",
        "advisory_workflow_quality",
        "presentation_telemetry_only",
        "governance_verdict",
        "harness_only"
      ]
    },
    "signal_class": {
      "type": "string",
      "enum": ["hard_gate", "advisory", "diagnostic"]
    },
    "subject": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "degraded",
        "observed",
        "missing",
        "malformed",
        "stale",
        "unknown",
        "not_applicable"
      ]
    },
    "ok": { "type": "boolean" },
    "verdict": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "category": { "type": "string" },
    "summary": { "type": "string" },
    "recommended_action": { "type": "string" },
    "fingerprint": { "type": "string" },
    "receipt_hash": { "type": "string" },
    "lifecycle_state": {
      "type": "string",
      "enum": ["experimental", "advisory", "release_gate", "retirement_candidate", "retired"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "artifact_path": { "type": "string" },
        "producer": { "type": "string" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["observed", "stale"],
      "properties": {
        "observed": { "type": "boolean" },
        "generated_at_epoch_seconds": { "type": "integer", "minimum": 0 },
        "age_seconds": { "type": "integer", "minimum": 0 },
        "stale": { "type": "boolean" },
        "stale_after_seconds": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      }
    },
    "details": { "type": "object" }
  }
}
